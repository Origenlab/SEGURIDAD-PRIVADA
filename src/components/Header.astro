---
/**
 * Header.astro — ORIGINS Private Security
 * Header profesional con mega-menú desktop y drawer móvil
 * Incluye TopBar como componente separado
 */
import TopBar from './TopBar.astro';
const currentPath = Astro.url.pathname;

// Helper para active state
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');
---

<TopBar />

<header class="header" role="banner">
  <div class="header__inner">

    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="ORIGINS Private Security — Inicio">
      <img
        src="/img/seguridad-privada.avif"
        alt="ORIGINS Private Security — Seguridad Privada para Condominios CDMX"
        width="200" height="54"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Nav Desktop -->
    <nav class="header__nav" aria-label="Navegación principal">
      <ul class="nav__list" role="list">

        <!-- Inicio -->
        <li class="nav__item">
          <a href="/" class:list={['nav__link', { 'nav__link--active': currentPath === '/' }]}>
            Inicio
          </a>
        </li>

        <!-- SERVICIOS → Mega-menú -->
        <li class="nav__item nav__item--mega">
          <a
            href="/servicios"
            class:list={['nav__link nav__link--has-dropdown', { 'nav__link--active': isActive('/servicios') }]}
            aria-haspopup="true"
            aria-expanded="false"
          >
            Servicios
            <svg class="nav__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </a>

          <!-- MEGA MENÚ -->
          <div class="mega" role="region" aria-label="Menú de servicios">
            <div class="mega__inner">

              <!-- Col 1: Seguridad Residencial (pillar) -->
              <div class="mega__col">
                <p class="mega__col-title">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  Seguridad Residencial
                </p>
                <ul class="mega__list">
                  <li>
                    <a href="/servicios/seguridad-condominios" class="mega__link mega__link--featured">
                      <span class="mega__link-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M15 3v18M3 9h18M3 15h18"/></svg>
                      </span>
                      <span>
                        <strong>Condominios</strong>
                        <small>Guardias para edificios y torres</small>
                      </span>
                    </a>
                  </li>
                  <li>
                    <a href="/servicios/seguridad-residenciales" class="mega__link mega__link--featured">
                      <span class="mega__link-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                      </span>
                      <span>
                        <strong>Residenciales</strong>
                        <small>Fraccionamientos y privadas</small>
                      </span>
                    </a>
                  </li>
                  <li>
                    <a href="/servicios/guardias-intramuros" class="mega__link mega__link--featured">
                      <span class="mega__link-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      </span>
                      <span>
                        <strong>Guardias Intramuros</strong>
                        <small>Vigilancia 24/7 certificada SSC</small>
                      </span>
                    </a>
                  </li>
                  <li><a href="/servicios/control-de-accesos" class="mega__link">Control de Accesos</a></li>
                  <li><a href="/servicios/patrullaje" class="mega__link">Patrullaje Vehicular</a></li>
                </ul>
              </div>

              <!-- Col 2: Vigilancia y Tecnología -->
              <div class="mega__col">
                <p class="mega__col-title">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 6l10.5 6L22 6M1 6v12l10.5 6L22 18V6"/></svg>
                  Tecnología y Monitoreo
                </p>
                <ul class="mega__list">
                  <li><a href="/servicios/tecnologia-monitoreo-seguridad" class="mega__link">Tecnología y Monitoreo</a></li>
                  <li><a href="/servicios/vigilancia-remota-cctv" class="mega__link">Vigilancia Remota CCTV</a></li>
                  <li><a href="/servicios/monitoreo-alarmas" class="mega__link">Monitoreo de Alarmas 24/7</a></li>
                  <li><a href="/servicios/seguridad-gps-satelital" class="mega__link">Rastreo GPS Satelital</a></li>
                  <li><a href="/servicios/prevencion-de-perdidas" class="mega__link">Prevención de Pérdidas</a></li>
                </ul>

                <p class="mega__col-title mega__col-title--mt">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                  Sectores Especializados
                </p>
                <ul class="mega__list">
                  <li><a href="/servicios/seguridad-construccion" class="mega__link">Construcción</a></li>
                  <li><a href="/servicios/seguridad-eventos" class="mega__link">Eventos Corporativos</a></li>
                  <li><a href="/servicios/seguridad-hospitalaria" class="mega__link">Hospitalaria</a></li>
                  <li><a href="/servicios/guardias-de-seguridad-y-vigilancia" class="mega__link">Guardias Corporativos</a></li>
                </ul>
              </div>

              <!-- Col 3: Protección y Consultoría -->
              <div class="mega__col">
                <p class="mega__col-title">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  Protección y Consultoría
                </p>
                <ul class="mega__list">
                  <li><a href="/servicios/proteccion-ejecutiva" class="mega__link">Protección Ejecutiva</a></li>
                  <li><a href="/servicios/custodia-de-mercancias" class="mega__link">Custodia de Valores</a></li>
                  <li><a href="/servicios/consultoria-seguridad" class="mega__link">Consultoría de Seguridad</a></li>
                  <li><a href="/servicios/consultoria-analisis-riesgos" class="mega__link">Análisis de Riesgos</a></li>
                  <li><a href="/servicios/investigaciones-confiabilidad" class="mega__link">Investigaciones</a></li>
                </ul>
              </div>

              <!-- Col 4: CTA lateral -->
              <div class="mega__col mega__col--cta">
                <div class="mega__cta-card">
                  <div class="mega__cta-badge">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                    Permiso SSC 0102-15
                  </div>
                  <h3>¿Necesitas seguridad para tu condominio?</h3>
                  <p>Diagnóstico gratuito y propuesta personalizada en menos de 24 horas.</p>
                  <a href="https://wa.me/525530255580?text=Hola%2C%20me%20interesa%20cotizar%20seguridad%20para%20mi%20condominio" class="mega__cta-btn" target="_blank" rel="noopener">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    Cotizar por WhatsApp
                  </a>
                  <a href="/contacto" class="mega__cta-link">O solicitar cotización →</a>
                </div>
                <a href="/servicios" class="mega__ver-todos">
                  Ver todos los servicios →
                </a>
              </div>

            </div>
          </div>
        </li>

        <!-- ZONAS -->
        <li class="nav__item nav__item--dropdown">
          <a
            href="/zonas"
            class:list={['nav__link nav__link--has-dropdown', { 'nav__link--active': isActive('/zonas') }]}
            aria-haspopup="true"
          >
            Zonas
            <svg class="nav__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </a>
          <div class="dropdown" role="menu">
            <div class="dropdown__section">
              <p class="dropdown__title">CDMX — Alcaldías</p>
              <ul>
                <li><a href="/zonas/miguel-hidalgo" class="dropdown__link">Miguel Hidalgo <small>Polanco · Lomas · Santa Fe</small></a></li>
                <li><a href="/zonas/cuauhtemoc" class="dropdown__link">Cuauhtémoc <small>Roma · Condesa · Juárez</small></a></li>
                <li><a href="/zonas/benito-juarez" class="dropdown__link">Benito Juárez <small>Del Valle · Narvarte · Nápoles</small></a></li>
                <li><a href="/zonas/alvaro-obregon" class="dropdown__link">Álvaro Obregón <small>Santa Fe · Plateros</small></a></li>
                <li><a href="/zonas/coyoacan" class="dropdown__link">Coyoacán <small>Pedregal · Copilco</small></a></li>
              </ul>
            </div>
            <div class="dropdown__section">
              <p class="dropdown__title">Estado de México</p>
              <ul>
                <li><a href="/zonas/naucalpan" class="dropdown__link">Naucalpan <small>Interlomas · Satélite</small></a></li>
                <li><a href="/zonas/tlalnepantla" class="dropdown__link">Tlalnepantla <small>Industrial · Residencial</small></a></li>
                <li><a href="/zonas/atizapan" class="dropdown__link">Atizapán <small>Bosques · Lomas</small></a></li>
              </ul>
            </div>
            <a href="/zonas" class="dropdown__footer">Ver todas las zonas →</a>
          </div>
        </li>

        <!-- NOSOTROS -->
        <li class="nav__item">
          <a href="/nosotros" class:list={['nav__link', { 'nav__link--active': isActive('/nosotros') }]}>
            Nosotros
          </a>
        </li>

        <!-- BLOG -->
        <li class="nav__item">
          <a href="/blog" class:list={['nav__link', { 'nav__link--active': isActive('/blog') }]}>
            Blog
          </a>
        </li>

      </ul>
    </nav>

    <!-- Header CTAs (desktop) -->
    <div class="header__actions">
      <a href="tel:+525530255580" class="header__tel" aria-label="Llamar al 55 3025 5580">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        55 3025 5580
      </a>
      <a
        href="https://wa.me/525530255580?text=Hola%2C%20me%20interesa%20cotizar%20seguridad%20para%20mi%20condominio"
        class="header__cta-wa"
        target="_blank"
        rel="noopener"
        aria-label="Cotizar por WhatsApp"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Cotizar
      </a>
      <a href="/contacto" class="header__cta-contact">Contacto</a>
    </div>

    <!-- Hamburger (mobile) -->
    <button
      class="header__hamburger"
      id="hamburger"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>
</header>

<!-- ============================================================
     MOBILE DRAWER
============================================================ -->
<div class="drawer" id="mobile-drawer" aria-hidden="true" role="dialog" aria-label="Menú de navegación móvil">
  <div class="drawer__backdrop" id="drawer-backdrop"></div>
  <nav class="drawer__panel" aria-label="Menú móvil">

    <!-- Drawer header -->
    <div class="drawer__header">
      <a href="/" class="drawer__logo">
        <img src="/img/seguridad-privada.avif" alt="ORIGINS Private Security" width="140" height="38" loading="lazy" />
      </a>
      <button class="drawer__close" id="drawer-close" aria-label="Cerrar menú">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Drawer nav -->
    <div class="drawer__body">
      <ul class="drawer__list" role="list">

        <li><a href="/" class="drawer__link">Inicio</a></li>

        <!-- Servicios accordion -->
