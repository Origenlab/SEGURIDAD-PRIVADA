<!-- Header -->
<header class="header">
  <div class="container">
    <div class="header__content">
      <div class="header__logo">
        <a href="/">
          <img src="/img/seguridad-privada.avif" alt="ORIGINS Private Security - Empresa de Seguridad Privada en CDMX" class="logo__image" width="372" height="100">
        </a>
      </div>

      <button class="menu-toggle" id="menuToggle" aria-label="Abrir menú de navegación" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav class="header__nav" id="headerNav" aria-label="Navegación principal">
        <ul class="nav__list">
          <li><a class="nav__link" href="/" aria-current={currentPath === '/' ? 'page' : undefined}>Inicio</a></li>

          <li class="nav__item--dropdown">
            <a class="nav__link" href="/servicios">Servicios</a>
            <div class="dropdown">
              <div class="dropdown__inner">
                <div class="dropdown__column">
                  <h4><a href="/servicios/guardias-de-seguridad-y-vigilancia">Vigilancia Corporativa</a></h4>
