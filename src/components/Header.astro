<header class="header">
  <div class="container">
    <div class="header__content">
      <div class="header__logo">
        <a href="/"><img src="/img/seguridad-privada.avif" alt="ORIGINS Private Security" class="logo__image" width="372" height="100"></a>
      </div>
      <button class="menu-toggle" id="menuToggle" aria-label="Menú"><span></span><span></span><span></span></button>
      <nav class="header__nav" id="headerNav">
        <ul class="nav__list">
          <li><a class="nav__link" href="/">Inicio</a></li>
          <li class="nav__item--dropdown">
            <a class="nav__link" href="/servicios">Servicios</a>
            <div class="dropdown">
              <div class="dropdown__inner">
                {services.map(col => (
                  <div class="dropdown__column">
                    <h4><a href={col.href}>{col.title}</a></h4>
                    <ul>
                      {col.items.map(item => (
                        <li><a href={item.href}>{item.name}</a></li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          </li>
          <li><a class="nav__link" href="/nosotros">Nosotros</a></li>
          <li><a class="nav__link" href="/blog/">Blog</a></li>
          <li><a class="nav__link" href="/bolsa-de-trabajo">Bolsa de Trabajo</a></li>
        </ul>
      </nav>
      <div class="header__contact">
        <a href="/contacto" class="contact__btn">Contacto</a>
      </div>
    </div>
  </div>
  <div class="menu-overlay" id="menuOverlay"></div>
</header>
