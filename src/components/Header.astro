          </button>
          <div class="drawer__accordion-panel">
            <a href="/servicios" class="drawer__link drawer__link--sub drawer__link--all">Ver todos los servicios →</a>
            <p class="drawer__sub-title">Seguridad Residencial</p>
            <a href="/servicios/seguridad-condominios" class="drawer__link drawer__link--sub">Condominios</a>
            <a href="/servicios/seguridad-residenciales" class="drawer__link drawer__link--sub">Residenciales</a>
