            <a href="/zonas" class="drawer__link drawer__link--sub drawer__link--all">Ver todas las zonas →</a>
            <p class="drawer__sub-title">CDMX</p>
            <a href="/zonas/miguel-hidalgo" class="drawer__link drawer__link--sub">Miguel Hidalgo</a>
            <a href="/zonas/cuauhtemoc" class="drawer__link drawer__link--sub">Cuauhtémoc</a>
            <a href="/zonas/benito-juarez" class="drawer__link drawer__link--sub">Benito Juárez</a>
            <a href="/zonas/alvaro-obregon" class="drawer__link drawer__link--sub">Álvaro Obregón</a>
            <a href="/zonas/coyoacan" class="drawer__link drawer__link--sub">Coyoacán</a>
            <p class="drawer__sub-title">Estado de México</p>
            <a href="/zonas/naucalpan" class="drawer__link drawer__link--sub">Naucalpan</a>
            <a href="/zonas/tlalnepantla" class="drawer__link drawer__link--sub">Tlalnepantla</a>
            <a href="/zonas/atizapan" class="drawer__link drawer__link--sub">Atizapán</a>
          </div>
        </li>

        <li><a href="/nosotros" class="drawer__link">Nosotros</a></li>
        <li><a href="/blog" class="drawer__link">Blog</a></li>
        <li><a href="/bolsa-de-trabajo" class="drawer__link">Bolsa de Trabajo</a></li>

      </ul>
    </div>

    <!-- Drawer footer CTAs -->
    <div class="drawer__footer">
