            <a href="/servicios/control-de-accesos" class="drawer__link drawer__link--sub">Control de Accesos</a>
            <a href="/servicios/patrullaje" class="drawer__link drawer__link--sub">Patrullaje</a>
            <p class="drawer__sub-title">Tecnología</p>
            <a href="/servicios/tecnologia-monitoreo-seguridad" class="drawer__link drawer__link--sub">Tecnología y Monitoreo</a>
            <a href="/servicios/vigilancia-remota-cctv" class="drawer__link drawer__link--sub">Vigilancia CCTV</a>
            <a href="/servicios/monitoreo-alarmas" class="drawer__link drawer__link--sub">Monitoreo Alarmas</a>
            <p class="drawer__sub-title">Protección y Consultoría</p>
            <a href="/servicios/proteccion-ejecutiva" class="drawer__link drawer__link--sub">Protección Ejecutiva</a>
            <a href="/servicios/consultoria-seguridad" class="drawer__link drawer__link--sub">Consultoría</a>
          </div>
        </li>

        <!-- Zonas accordion -->
        <li class="drawer__item--accordion">
          <button class="drawer__accordion-toggle" aria-expanded="false">
            Zonas
            <svg class="drawer__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
