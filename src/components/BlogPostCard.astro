---
/**
 * BlogPostCard.astro — ORIGINS Private Security
 * Card para listado de artículos del blog.
 * Sin fechas. Sin reading time. Contenido atemporal.
 */

interface Props {
  href: string;
  title: string;
  description: string;
  category: string;
  heroImage?: { src: string; alt: string };
}

const { href, title, description, category, heroImage } = Astro.props;

const categoryLabel = category.replace(/-/g, ' ');
---

<article class="blog-card">
  <a href={href} class="blog-card__link" aria-label={`Leer: ${title}`}>

    <div class="blog-card__image">
      {heroImage
        ? <img src={heroImage.src} alt={heroImage.alt} loading="lazy" width="800" height="450" />
        : (
          <div class="blog-card__placeholder" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
        )
      }
    </div>

    <div class="blog-card__body">
      <span class="blog-card__category">{categoryLabel}</span>
      <h3 class="blog-card__title">{title}</h3>
      <p class="blog-card__desc">{description}</p>
      <span class="blog-card__cta">
        Leer guía completa
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </span>
    </div>

  </a>
</article>

<style>
/* ============================================================
   BLOG CARD — atemporal, sin fechas
============================================================ */
.blog-card {
  border-radius: 14px;
  border: 1px solid rgba(10,15,30,0.08);
  background: #ffffff;
  overflow: hidden;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.blog-card:hover {
  border-color: rgba(10,15,30,0.18);
  box-shadow: 0 8px 32px rgba(10,15,30,0.06);
}

.blog-card__link {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  height: 100%;
}

/* Imagen */
.blog-card__image {
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: #0a0f1e;
}

.blog-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.blog-card:hover .blog-card__image img {
  transform: scale(1.03);
}

.blog-card__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.25);
  background: linear-gradient(160deg, #0d1520 0%, #0a0f1e 100%);
}

/* Body */
.blog-card__body {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}

/* Categoría pill */
.blog-card__category {
  display: inline-block;
  padding: 0.3rem 0.7rem;
  background: rgba(10,15,30,0.06);
  border: 1px solid rgba(10,15,30,0.08);
  color: rgba(10,15,30,0.6);
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  border-radius: 980px;
  margin-bottom: 0.85rem;
  width: fit-content;
}

/* Título */
.blog-card__title {
  font-size: 1.0625rem;
  font-weight: 700;
  color: #0a0f1e;
  line-height: 1.35;
  letter-spacing: -0.01em;
  margin: 0 0 0.625rem;
}

/* Descripción */
.blog-card__desc {
  font-size: 0.875rem;
  color: rgba(10,15,30,0.6);
  line-height: 1.6;
  margin: 0 0 1.25rem;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* CTA inline en lugar de fecha */
.blog-card__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: auto;
  padding-top: 0.5rem;
  font-size: 0.8125rem;
  font-weight: 600;
  color: #0a0f1e;
  border-top: 1px solid rgba(10,15,30,0.06);
}

.blog-card__cta svg {
  transition: transform 0.2s ease;
}

.blog-card:hover .blog-card__cta svg {
  transform: translateX(3px);
}

/* ============================================================
   Tablet 768px+
============================================================ */
@media (min-width: 768px) {
  .blog-card__body {
    padding: 1.5rem;
  }

  .blog-card__title {
    font-size: 1.125rem;
  }
}
</style>
