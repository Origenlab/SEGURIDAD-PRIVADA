<style>
  /* ==========================================================================
     FOOTER - Mobile First
     ========================================================================== */
  .footer {
    background-color: var(--color-primary);
    color: rgba(255, 255, 255, 0.8);
    padding: 3rem 0 0;
  }

  .footer-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .footer-section {
    min-width: 0;
  }

  .footer-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .footer-title a {
    color: inherit;
    text-decoration: none;
  }

  .footer-title a:hover {
    opacity: 0.8;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  .footer-links li {
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: #ffffff;
    opacity: 1;
  }

  .footer-contact {
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .contact-item {
    margin-bottom: 1rem;
  }

  .contact-item strong {
    color: #ffffff;
    font-weight: 600;
  }

  .contact-item a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
  }

  .contact-item a:hover {
    color: #ffffff;
    opacity: 1;
  }

  .footer-bottom {
    margin-top: 2rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-legal {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .footer-legal p {
    margin: 0;
  }

  .footer-legal-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-legal-links a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-legal-links a:hover {
    color: #ffffff;
    opacity: 1;
  }

  /* Tablet */
  @media (min-width: 640px) {
    .footer {
      padding: 4rem 0 0;
    }

    .footer-container {
      padding: 0 1.5rem;
    }

    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }

    .footer-legal {
      font-size: 0.8125rem;
    }
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .footer-bottom {
      margin-top: 3rem;
    }

    .footer-legal {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
