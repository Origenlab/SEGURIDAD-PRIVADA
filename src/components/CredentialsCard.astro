---
/**
 * CredentialsCard Component
 * Card for displaying company credentials with icon, title, and list
 * Used in dark background sections (glass morphism style)
 * Follows ORIGINS design system - NO animations on cards
 */
interface Props {
  title: string;
  items: string[];
  icon?: 'shield' | 'users' | 'document' | 'clock';
}

const { title, items, icon = 'shield' } = Astro.props;

const icons = {
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>`,
  users: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  document: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/>`,
  clock: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`
};
---

<div class="credentials-card">
  <div class="credentials-card__header">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <Fragment set:html={icons[icon]} />
    </svg>
    <h4>{title}</h4>
  </div>
  <ul class="credentials-card__list">
    {items.map(item => <li>{item}</li>)}
  </ul>
</div>

<style>
  /* ==========================================================================
     CREDENTIALS CARD - Mobile First
     Glass morphism style for dark backgrounds
     ========================================================================== */
  .credentials-card {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
  }

  .credentials-card__header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1rem;
  }

  .credentials-card__header svg {
    flex-shrink: 0;
    color: #D4AF37;
  }

  .credentials-card__header h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-white);
    margin: 0;
  }

  .credentials-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .credentials-card__list li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .credentials-card__list li:last-child {
    margin-bottom: 0;
  }

  .credentials-card__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 6px;
    height: 6px;
    background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
    border-radius: 50%;
  }
</style>
