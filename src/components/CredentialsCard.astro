---
/**
 * CredentialsCard.astro — ORIGINS Private Security
 * Card de credenciales para sección oscura About
 * Sin animaciones. Sin glassmorphism pesado.
 */
interface Props {
  title: string;
  items: string[];
  icon?: 'shield' | 'users' | 'document' | 'clock';
}

const { title, items, icon = 'shield' } = Astro.props;

const icons = {
  shield:   `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>`,
  users:    `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  document: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/>`,
  clock:    `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`
};
---

<div class="cred-card">
  <div class="cred-card__header">
    <span class="cred-card__icon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <Fragment set:html={icons[icon]} />
      </svg>
    </span>
    <h4 class="cred-card__title">{title}</h4>
  </div>
  <ul class="cred-card__list">
    {items.map(item => (
      <li>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        {item}
      </li>
    ))}
  </ul>
</div>

<style>
.cred-card {
  padding: 1.375rem 1.5rem;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 14px;
  color: rgba(255,255,255,0.72);
}

.cred-card__header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
  padding-bottom: 0.875rem;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}

.cred-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 9px;
  background: rgba(37,211,102,0.12);
  color: #25D366;
  flex-shrink: 0;
}

.cred-card__title {
  font-size: 0.9375rem;
  font-weight: 700;
  color: #ffffff !important;
  margin: 0;
  line-height: 1.3;
}

.cred-card__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.cred-card__list li {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.875rem;
  color: rgba(255,255,255,0.72) !important;
  line-height: 1.4;
}

.cred-card__list li svg {
  flex-shrink: 0;
  color: #25D366;
  opacity: 0.8;
}
</style>
