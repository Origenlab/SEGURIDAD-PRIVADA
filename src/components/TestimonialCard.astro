---
/**
 * TestimonialCard.astro — ORIGINS Private Security
 * Card de testimonio. Patrón: redeil.com / bombero.mx
 * Primera card puede tener companyUrl para link externo verificado.
 */
import StarRating from './icons/StarRating.astro';

interface Props {
  rating: number;
  quote: string;
  name: string;
  initials: string;
  role: string;
  company: string;
  companyUrl?: string;
  verified?: boolean;
}

const { rating, quote, name, initials, role, company, companyUrl, verified = false } = Astro.props;
---

<article class="t-card">
  <!-- Header: verificado + estrellas -->
  <div class="t-card__top">
    {verified && (
      <span class="t-card__verified">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Empresa verificada
      </span>
    )}
    <div class="t-card__stars">
      <StarRating rating={rating} size={16} />
    </div>
  </div>

  <!-- Quote -->
  <blockquote class="t-card__quote">
    &ldquo;{quote}&rdquo;
  </blockquote>

  <!-- Author -->
  <div class="t-card__author">
    <div class="t-card__avatar" aria-hidden="true">
      <span>{initials}</span>
    </div>
    <div class="t-card__info">
      <cite class="t-card__name">{name}</cite>
      <span class="t-card__role">{role}</span>
      {companyUrl ? (
        <a href={companyUrl} class="t-card__company t-card__company--link" target="_blank" rel="noopener noreferrer">
          {company}
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      ) : (
        <span class="t-card__company">{company}</span>
      )}
    </div>
  </div>
</article>

<style>
.t-card {
  background: #ffffff;
  border: 1px solid rgba(10,15,30,0.07);
  border-radius: 16px;
  padding: 1.625rem;
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* Top: verificado + estrellas */
.t-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
  min-height: 22px;
}

.t-card__verified {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.7rem;
  font-weight: 600;
  color: #25D366;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.t-card__stars {
  display: flex;
  gap: 0.15rem;
}

/* Quote */
.t-card__quote {
  font-size: 0.9rem;
  line-height: 1.75;
  color: rgba(10,15,30,0.68);
  margin: 0 0 1.375rem;
  font-style: normal;
  flex: 1;
}

/* Author */
.t-card__author {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  padding-top: 1.125rem;
  border-top: 1px solid rgba(10,15,30,0.07);
  margin-top: auto;
}

/* Avatar */
.t-card__avatar {
  width: 42px;
  height: 42px;
  background: var(--color-primary, #0a0f1e);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.t-card__avatar span {
  color: #ffffff;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.03em;
}

/* Info */
.t-card__info {
  display: flex;
  flex-direction: column;
  gap: 0.1rem;
  min-width: 0;
}

.t-card__name {
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-primary, #0a0f1e);
  font-style: normal;
  line-height: 1.3;
}

.t-card__role {
  font-size: 0.775rem;
  color: rgba(10,15,30,0.45);
  line-height: 1.3;
}

.t-card__company {
  font-size: 0.775rem;
  color: rgba(10,15,30,0.4);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.t-card__company--link {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  color: var(--color-primary, #0a0f1e);
  font-weight: 600;
  text-decoration: none;
  font-size: 0.8rem;
}

.t-card__company--link:hover {
  opacity: 0.7;
}

.t-card__company--link svg {
  flex-shrink: 0;
  opacity: 0.6;
}
</style>
