---
/**
 * CategoriaCard.astro — ORIGINS Private Security
 * Card de categoría principal con imagen, subtítulos de sección y subcards
 * Patrón: redeil.com categories — imagen grande + sub-links con imagen + CTA
 */

interface SubServicio {
  slug: string;
  titulo: string;
  descripcionCorta: string;
  imagen: string;
  imagenAlt: string;
}

interface Props {
  id: string;
  etiqueta: string;
  titulo: string;
  descripcion: string;
  imagenHero: string;
  imagenHeroAlt: string;
  href: string;
  ctaTexto: string;
  subServicios: SubServicio[];
  acento?: string; // color de acento del badge
}

const {
  id,
  etiqueta,
  titulo,
  descripcion,
  imagenHero,
  imagenHeroAlt,
  href,
  ctaTexto,
  subServicios,
  acento = 'default'
} = Astro.props;
---

<article class={`cat-card cat-card--${acento}`} id={id}>
  <!-- Imagen hero de la categoría -->
  <a href={href} class="cat-card__hero" aria-label={`Ver ${titulo}`}>
    <img src={imagenHero} alt={imagenHeroAlt} loading="lazy" width="800" height="450" />
    <div class="cat-card__hero-overlay">
      <span class="cat-card__etiqueta">{etiqueta}</span>
    </div>
  </a>

  <!-- Contenido -->
  <div class="cat-card__body">
    <h2 class="cat-card__titulo">
      <a href={href}>{titulo}</a>
    </h2>
    <p class="cat-card__desc">{descripcion}</p>

    <!-- Sub-servicios -->
    <ul class="cat-card__subs">
      {subServicios.map((sub) => (
        <li>
          <a href={`/servicios/${sub.slug}`} class="cat-sub">
            <img src={sub.imagen} alt={sub.imagenAlt} loading="lazy" width="80" height="80" />
            <div class="cat-sub__text">
              <strong>{sub.titulo}</strong>
              <span>{sub.descripcionCorta}</span>
            </div>
            <svg class="cat-sub__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a href={href} class="cat-card__cta">
      {ctaTexto}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</article>

<style>
/* ============================================================
   CARD BASE
============================================================ */
.cat-card {
  display: flex;
  flex-direction: column;
  background: #ffffff;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(0,0,0,0.07), 0 1px 6px rgba(0,0,0,0.04);
  border: 1px solid rgba(0,0,0,0.05);
}

.cat-card:hover {
  box-shadow: 0 12px 40px rgba(0,0,0,0.12), 0 4px 12px rgba(0,0,0,0.06);
}

/* ============================================================
   HERO IMAGE
============================================================ */
.cat-card__hero {
  display: block;
  position: relative;
  aspect-ratio: 16/9;
  overflow: hidden;
}

.cat-card__hero img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}


.cat-card__hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.65) 100%);
  display: flex;
  align-items: flex-end;
  padding: 1rem 1.25rem;
}

.cat-card__etiqueta {
  display: inline-flex;
  align-items: center;
  padding: 0.375rem 0.875rem;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  border-radius: 980px;
  color: #ffffff;
  background: rgba(255,255,255,0.18);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,0.25);
}

/* Acentos por categoría */
.cat-card--residencial .cat-card__etiqueta { background: rgba(10,15,30,0.7); }
.cat-card--tecnologia .cat-card__etiqueta  { background: rgba(30,80,140,0.7); }
.cat-card--proteccion .cat-card__etiqueta  { background: rgba(120,50,20,0.7); }

/* ============================================================
   BODY
============================================================ */
.cat-card__body {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding: 1.25rem;
  gap: 0;
}

.cat-card__titulo {
  font-size: 1.125rem;
  font-weight: 800;
  line-height: 1.2;
  margin: 0 0 0.5rem;
}

.cat-card__titulo a {
  color: var(--color-primary, #0a0f1e);
  text-decoration: none;
}
.cat-card__titulo a:hover { opacity: 0.75; }

.cat-card__desc {
  font-size: 0.85rem;
  line-height: 1.6;
  color: rgba(10,15,30,0.6);
  margin: 0 0 1rem;
}

/* Ocultar descripción en mobile para ahorrar espacio */
@media (max-width: 767px) {
  .cat-card__desc {
    display: none;
  }
}

/* ============================================================
   SUB-SERVICIOS
============================================================ */
.cat-card__subs {
  list-style: none;
  margin: 0 0 1.5rem;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid rgba(0,0,0,0.07);
  border-radius: 12px;
  overflow: hidden;
}

.cat-sub {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.625rem 0.875rem;
  text-decoration: none;
  color: inherit;
  background: #ffffff;
  border-bottom: 1px solid rgba(0,0,0,0.06);
}

.cat-card__subs li:last-child .cat-sub {
  border-bottom: none;
}

.cat-sub:hover {
  background: rgba(10,15,30,0.03);
}

.cat-sub img {
  width: 40px;
  height: 40px;
  object-fit: cover;
  border-radius: 7px;
  flex-shrink: 0;
  filter: grayscale(20%);
}

.cat-sub__text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
  min-width: 0;
}

.cat-sub__text strong {
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-primary, #0a0f1e);
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cat-sub__text span {
  font-size: 0.775rem;
  color: rgba(10,15,30,0.5);
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cat-sub__arrow {
  flex-shrink: 0;
  color: rgba(10,15,30,0.25);
}

.cat-sub:hover .cat-sub__arrow {
  color: var(--color-primary, #0a0f1e);
}

/* ============================================================
   CTA
============================================================ */
.cat-card__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.75rem 1.25rem;
  font-size: 0.875rem;
  font-weight: 700;
  color: #ffffff;
  text-decoration: none;
  border-radius: 10px;
  margin-top: auto;
  background: var(--color-primary, #0a0f1e);
}

.cat-card__cta:hover {
  background: #131b2e;
}

.cat-card--residencial .cat-card__cta { background: #0a0f1e; }
.cat-card--tecnologia  .cat-card__cta { background: #0f2a44; }
.cat-card--proteccion  .cat-card__cta { background: #1a0f06; }

.cat-card--residencial .cat-card__cta:hover { background: #131b2e; }
.cat-card--tecnologia  .cat-card__cta:hover { background: #1a3d5c; }
.cat-card--proteccion  .cat-card__cta:hover { background: #2a1a0a; }

/* ============================================================
   Responsive
============================================================ */
@media (min-width: 768px) {
  .cat-card__titulo { font-size: 1.4375rem; }
  .cat-sub img { width: 52px; height: 52px; }
}

@media (min-width: 1024px) {
  .cat-card__hero { aspect-ratio: 4/3; }
  .cat-card__body { padding: 1.625rem; }
  .cat-card__titulo { font-size: 1.25rem; }
}

@media (min-width: 1280px) {
  .cat-card__hero { aspect-ratio: 16/9; }
  .cat-card__titulo { font-size: 1.375rem; }
}
</style>
