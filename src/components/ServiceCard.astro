---
/**
 * ServiceCard Component
 * Card component for displaying services with image, badge, and features
 * Follows ORIGINS design system - NO animations on cards (only CTA button)
 */
interface Props {
  href: string;
  image: string;
  imageAlt: string;
  badge: string;
  title: string;
  description: string;
  features: string[];
  ctaText: string;
  loading?: 'eager' | 'lazy';
}

const {
  href,
  image,
  imageAlt,
  badge,
  title,
  description,
  features,
  ctaText,
  loading = 'lazy'
} = Astro.props;
---

<a href={href} class="service-card">
  <div class="service-card__image">
    <img src={image} alt={imageAlt} loading={loading} width="600" height="400">
    <div class="service-card__overlay">
      <span class="service-card__badge">{badge}</span>
    </div>
  </div>
  <div class="service-card__body">
    <h3 class="service-card__title">{title}</h3>
    <p class="service-card__desc">{description}</p>
    <ul class="service-card__list">
      {features.map(feature => <li>{feature}</li>)}
    </ul>
    <span class="service-card__cta">
      {ctaText}
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </span>
  </div>
</a>

<style>
  /* ==========================================================================
     SERVICE CARD - Mobile First
     ========================================================================== */
  .service-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.03);
  }

  .service-card:hover {
    opacity: 1;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12), 0 4px 12px rgba(0, 0, 0, 0.06);
  }

  .service-card__image {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .service-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .service-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 30%, rgba(0,0,0,0.7) 100%);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
  }

  .service-card__badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
    color: var(--color-white);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 50px;
    box-shadow: 0 2px 8px rgba(212, 175, 55, 0.4);
  }

  .service-card__body {
    padding: 1.5rem;
    padding-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .service-card__title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .service-card__desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-light);
    margin: 0 0 1.25rem 0;
  }

  .service-card__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem 0;
  }

  .service-card__list li {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    background: linear-gradient(135deg, #fef9e7 0%, #fdf3d0 100%);
    color: #92600a;
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 50px;
    border: 1px solid #f5d77a;
  }

  .service-card__list li::before {
    content: '';
    width: 6px;
    height: 6px;
    background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .service-card__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    width: calc(100% + 3rem);
    margin-left: -1.5rem;
    margin-right: -1.5rem;
    margin-top: auto;
    margin-bottom: -1.25rem;
    padding: 1.125rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-white);
    background: linear-gradient(135deg, var(--color-primary) 0%, #0f2a44 100%);
    border-radius: 0 0 20px 20px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: all 0.3s ease;
  }

  .service-card__cta svg {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .service-card:hover .service-card__cta {
    background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
    box-shadow: 0 4px 15px rgba(212, 175, 55, 0.4);
  }

  .service-card:hover .service-card__cta svg {
    transform: translateX(4px);
  }

  /* ==========================================================================
     Tablet - 640px+
     ========================================================================== */
  @media (min-width: 640px) {
    .service-card__body {
      padding: 1.25rem;
      padding-bottom: 1rem;
    }

    .service-card__title {
      font-size: 1.125rem;
      margin-bottom: 0.875rem;
    }

    .service-card__desc {
      margin-bottom: 1rem;
    }

    .service-card__list {
      margin-bottom: 1rem;
    }

    .service-card__cta {
      width: calc(100% + 2.5rem);
      margin-left: -1.25rem;
      margin-right: -1.25rem;
      margin-bottom: -1rem;
    }
  }

  /* ==========================================================================
     Desktop - 1024px+
     ========================================================================== */
  @media (min-width: 1024px) {
    .service-card {
      border-radius: 16px;
    }

    .service-card__image {
      aspect-ratio: 1/1;
    }

    .service-card__overlay {
      padding: 0.75rem;
    }

    .service-card__badge {
      font-size: 0.5625rem;
      padding: 0.375rem 0.625rem;
    }

    .service-card__body {
      padding: 1rem;
      padding-bottom: 0.875rem;
    }

    .service-card__title {
      font-size: 0.9375rem;
      margin-bottom: 0.625rem;
    }

    .service-card__desc {
      font-size: 0.75rem;
      line-height: 1.5;
      margin-bottom: 0.75rem;
      display: -webkit-box;
      -webkit-line-clamp: 4;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .service-card__list {
      gap: 0.25rem;
      margin-bottom: 0.75rem;
    }

    .service-card__list li {
      font-size: 0.625rem;
      padding: 0.25rem 0.5rem;
    }

    .service-card__list li::before {
      width: 4px;
      height: 4px;
    }

    .service-card__cta {
      width: calc(100% + 2rem);
      margin-left: -1rem;
      margin-right: -1rem;
      margin-bottom: -0.875rem;
      font-size: 0.6875rem;
      padding: 0.875rem 1rem;
      border-radius: 0 0 16px 16px;
      gap: 0.375rem;
    }

    .service-card__cta svg {
      width: 14px;
      height: 14px;
    }
  }

  /* ==========================================================================
     Large Desktop - 1280px+
     ========================================================================== */
  @media (min-width: 1280px) {
    .service-card {
      border-radius: 20px;
    }

    .service-card__body {
      padding: 1.25rem;
      padding-bottom: 1rem;
    }

    .service-card__title {
      font-size: 1rem;
      margin-bottom: 0.75rem;
    }

    .service-card__desc {
      font-size: 0.8125rem;
      margin-bottom: 0.875rem;
      -webkit-line-clamp: 5;
    }

    .service-card__list {
      margin-bottom: 0.875rem;
    }

    .service-card__list li {
      font-size: 0.6875rem;
      padding: 0.3rem 0.625rem;
    }

    .service-card__cta {
      width: calc(100% + 2.5rem);
      margin-left: -1.25rem;
      margin-right: -1.25rem;
      margin-bottom: -1rem;
      font-size: 0.75rem;
      padding: 1rem 1.25rem;
      border-radius: 0 0 20px 20px;
    }

    .service-card__cta svg {
      width: 16px;
      height: 16px;
    }
  }
</style>
