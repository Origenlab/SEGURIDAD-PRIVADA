---
/**
 * PageCTA.astro — ORIGINS Private Security
 * CTA de cierre reutilizable para páginas internas.
 * Fondo oscuro, texto blanco, sin animaciones.
 */

interface Props {
  titulo: string;
  descripcion: string;
  ctaPrimario?: { texto: string; href: string };
  ctaWhatsapp?: boolean;
}

const { titulo, descripcion, ctaPrimario, ctaWhatsapp = false } = Astro.props;
---

<section class="page-cta" aria-labelledby="page-cta-title">
  <div class="container">
    <div class="page-cta__inner">

      <span class="page-cta__badge" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <path d="m9 12 2 2 4-4"/>
        </svg>
      </span>

      <h2 id="page-cta-title" class="page-cta__titulo">{titulo}</h2>
      <p class="page-cta__desc">{descripcion}</p>

      {(ctaPrimario || ctaWhatsapp) && (
        <div class="page-cta__btns">
          {ctaWhatsapp && (
            <a
              href="https://wa.me/525530255580?text=Hola%2C%20me%20interesa%20cotizar%20seguridad%20para%20mi%20condominio"
              class="page-cta__btn page-cta__btn--wa"
              target="_blank"
              rel="noopener"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp Directo
            </a>
          )}
          {ctaPrimario && (
            <a href={ctaPrimario.href} class="page-cta__btn page-cta__btn--outline">
              {ctaPrimario.texto}
            </a>
          )}
        </div>
      )}

    </div>
  </div>
</section>

<style>
/* ============================================================
   PAGE CTA — Cierre de páginas internas
============================================================ */
.page-cta {
  padding: 4rem 0;
  background: #0a0f1e;
  text-align: center;
}

.page-cta__inner {
  max-width: 640px;
  margin: 0 auto;
}

.page-cta__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.12);
  margin-bottom: 1.25rem;
  color: #25D366;
}

.page-cta__titulo {
  font-size: 1.75rem;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.2;
  letter-spacing: -0.02em;
  margin: 0 0 0.875rem;
}

.page-cta__desc {
  font-size: 1rem;
  color: rgba(255,255,255,0.65);
  line-height: 1.65;
  margin: 0 0 2rem;
}

.page-cta__btns {
  display: flex;
  flex-wrap: wrap;
  gap: 0.875rem;
  justify-content: center;
}

.page-cta__btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.875rem 1.75rem;
  border-radius: 8px;
  font-size: 0.9375rem;
  font-weight: 700;
  text-decoration: none;
}

.page-cta__btn--wa {
  background: #25D366;
  color: #ffffff;
}

.page-cta__btn--wa:hover {
  background: #1ebe5d;
}

.page-cta__btn--outline {
  background: transparent;
  color: rgba(255,255,255,0.9);
  border: 1.5px solid rgba(255,255,255,0.25);
}

.page-cta__btn--outline:hover {
  background: rgba(255,255,255,0.06);
  border-color: rgba(255,255,255,0.4);
}

/* ============================================================
   Tablet 768px+
============================================================ */
@media (min-width: 768px) {
  .page-cta {
    padding: 5rem 0;
  }

  .page-cta__titulo {
    font-size: 2.25rem;
  }

  .page-cta__desc {
    font-size: 1.0625rem;
  }
}
</style>
