---
/**
 * HeroPagina.astro — ORIGINS Private Security
 * Hero reutilizable para páginas internas.
 * Breadcrumb automático + schema BreadcrumbList + badge + H1 + desc + CTAs
 */

interface Breadcrumb {
  label: string;
  href: string;
}

interface Props {
  badge: string;
  titulo: string;
  descripcion: string;
  breadcrumb?: Breadcrumb[];
  ctaPrimario?: { texto: string; href: string };
  ctaWhatsapp?: boolean;
}

const {
  badge,
  titulo,
  descripcion,
  breadcrumb = [],
  ctaPrimario,
  ctaWhatsapp = false,
} = Astro.props;

const siteUrl = 'https://seguridad-privada.com.mx';

// Always prepend "Inicio" as first breadcrumb
const fullBreadcrumb = [{ label: 'Inicio', href: '/' }, ...breadcrumb];

// Build BreadcrumbList schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": fullBreadcrumb.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.label,
    "item": `${siteUrl}${item.href}`
  }))
};
---

{fullBreadcrumb.length > 1 && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}

<section class="hero-page" aria-labelledby="hero-page-title">
  <div class="container">

    {fullBreadcrumb.length > 1 && (
      <nav class="hero-page__breadcrumb" aria-label="Breadcrumb">
        {fullBreadcrumb.map((item, index) => {
          const isLast = index === fullBreadcrumb.length - 1;
          return (
            <>
              {index > 0 && <span class="hero-page__bc-sep" aria-hidden="true">/</span>}
              {isLast
                ? <span aria-current="page">{item.label}</span>
                : <a href={item.href}>{item.label}</a>
              }
            </>
          );
        })}
      </nav>
    )}

    <div class="hero-page__badge">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <path d="m9 12 2 2 4-4"/>
      </svg>
      <span>{badge}</span>
    </div>

    <h1 id="hero-page-title" class="hero-page__titulo">{titulo}</h1>
    <p class="hero-page__desc">{descripcion}</p>

    {(ctaPrimario || ctaWhatsapp) && (
      <div class="hero-page__cta">
        {ctaPrimario && (
          <a href={ctaPrimario.href} class="btn btn-hero-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {ctaPrimario.texto}
          </a>
        )}
        {ctaWhatsapp && (
          <a
            href="https://wa.me/525530255580?text=Hola%2C%20me%20interesa%20cotizar%20seguridad%20para%20mi%20condominio"
            class="btn btn-hero-whatsapp"
            target="_blank"
            rel="noopener"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Directo
          </a>
        )}
      </div>
    )}

  </div>
</section>

<style>
/* ============================================================
   HERO PAGE — Reutilizable para páginas internas
============================================================ */
.hero-page {
  padding: 4rem 0 5rem;
  background: linear-gradient(160deg, #0d1520 0%, #0a0f1e 100%);
  position: relative;
  overflow: hidden;
}

/* Breadcrumb */
.hero-page__breadcrumb {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.375rem;
  margin-bottom: 1.5rem;
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.5);
}

.hero-page__breadcrumb a {
  color: rgba(255,255,255,0.5);
  text-decoration: none;
}

.hero-page__breadcrumb a:hover {
  color: rgba(255,255,255,0.8);
}

.hero-page__breadcrumb span[aria-current="page"] {
  color: rgba(255,255,255,0.75);
}

.hero-page__bc-sep {
  color: rgba(255,255,255,0.25);
  margin: 0 0.125rem;
}

/* Badge */
.hero-page__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.375rem 0.875rem;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 980px;
  margin-bottom: 1.25rem;
  color: rgba(255,255,255,0.8);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
}

.hero-page__badge svg {
  color: #25D366;
  flex-shrink: 0;
}

/* Título H1 */
.hero-page__titulo {
  font-size: 2rem;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.18;
  letter-spacing: -0.02em;
  margin: 0 0 1rem;
  max-width: 760px;
}

/* Descripción */
.hero-page__desc {
  font-size: 1rem;
  color: rgba(255,255,255,0.78);
  line-height: 1.7;
  margin: 0 0 2rem;
  max-width: 680px;
}

/* CTAs */
.hero-page__cta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.875rem;
}

.btn-hero-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.875rem 1.75rem;
  background: #ffffff;
  color: #0a0f1e;
  font-size: 0.9375rem;
  font-weight: 700;
  border-radius: 8px;
  text-decoration: none;
}

.btn-hero-primary:hover {
  background: #f0f0f0;
}

.btn-hero-whatsapp {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.875rem 1.75rem;
  background: #25D366;
  color: #ffffff;
  font-size: 0.9375rem;
  font-weight: 700;
  border-radius: 8px;
  text-decoration: none;
}

.btn-hero-whatsapp:hover {
  background: #1ebe5d;
}

/* ============================================================
   Tablet 768px+
============================================================ */
@media (min-width: 768px) {
  .hero-page {
    padding: 5rem 0 6rem;
  }

  .hero-page__titulo {
    font-size: 2.5rem;
  }

  .hero-page__desc {
    font-size: 1.125rem;
  }
}

/* ============================================================
   Desktop 1024px+
============================================================ */
@media (min-width: 1024px) {
  .hero-page__titulo {
    font-size: 3rem;
  }
}
</style>
