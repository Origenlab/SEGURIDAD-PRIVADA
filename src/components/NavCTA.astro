---
/**
 * NavCTA.astro — ORIGINS Private Security
 * Barra de 4 cards de acceso rápido post-hero.
 * Diseño idéntico al nav-cta del index.
 * Uso: colocar inmediatamente después de <HeroPagina /> en cada página interna.
 *
 * Props por card: label, sublabel, href, icon (SVG path), external?, accent?
 * La 4ta card generalmente es accent (WhatsApp / CTA primario).
 */

interface NavCard {
  label: string;
  sublabel: string;
  href: string;
  external?: boolean;
  accent?: boolean;   // fondo oscuro tipo primario
  whatsapp?: boolean; // usa el ícono de WhatsApp automáticamente
  icon?: 'shield' | 'map' | 'blog' | 'people' | 'phone' | 'monitor' | 'star' | 'briefcase' | 'home' | 'consult';
}

interface Props {
  cards: [NavCard, NavCard, NavCard, NavCard];
  ariaLabel?: string;
  footer?: boolean; /* true = variante pre-footer con borde superior */
}

const { cards, ariaLabel = 'Accesos rápidos', footer = false } = Astro.props;

const icons: Record<string, string> = {
  shield:    `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  map:       `<circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.35 11.76a1 1 0 0 0 1.3 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/>`,
  blog:      `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>`,
  people:    `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  phone:     `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>`,
  monitor:   `<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>`,
  star:      `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`,
  briefcase: `<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
  home:      `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  consult:   `<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
};

const waIcon = `<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>`;
---

<section class:list={['nav-cta', { 'nav-cta--footer': footer }]} aria-label={ariaLabel}>
  <div class="container">
    <div class="nav-cta__grid">

      {cards.map((card, i) => (
        <a
          href={card.href}
          class:list={[
            'nav-cta__card',
            `nav-cta__card--${i + 1}`,
            { 'nav-cta__card--accent': card.accent || card.whatsapp }
          ]}
          target={card.external ? '_blank' : undefined}
          rel={card.external ? 'noopener' : undefined}
        >
          <div class="nav-cta__card-inner">
            <span class="nav-cta__icon">
              <svg
                width="28" height="28"
                viewBox="0 0 24 24"
                fill={card.whatsapp ? 'currentColor' : 'none'}
                stroke={card.whatsapp ? 'none' : 'currentColor'}
                stroke-width="1.75"
                aria-hidden="true"
              >
                <Fragment set:html={card.whatsapp ? waIcon : (icons[card.icon ?? 'shield'] ?? icons.shield)} />
              </svg>
            </span>
            <div class="nav-cta__text">
              <strong>{card.label}</strong>
              <span>{card.sublabel}</span>
            </div>
            <svg class="nav-cta__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </div>
        </a>
      ))}

    </div>
  </div>
</section>

<style is:global>
/* ==========================================================================
   NAV-CTA — Componente post-hero reutilizable (estilos globales)
   ========================================================================== */
.nav-cta {
  background: #ffffff;
  border-bottom: 1px solid rgba(0,0,0,0.07);
  position: relative;
  z-index: 2;
  box-shadow: 0 4px 24px rgba(0,0,0,0.06);
}

.nav-cta--footer {
  box-shadow: none;
  border-top: 1px solid rgba(0,0,0,0.07);
  border-bottom: none;
}

.nav-cta__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
}

.nav-cta__card {
  display: block;
  text-decoration: none;
  border-bottom: 1px solid rgba(0,0,0,0.07);
  border-right: 1px solid rgba(0,0,0,0.07);
  position: relative;
  overflow: hidden;
}

.nav-cta__card:nth-child(2n) { border-right: none; }
.nav-cta__card:nth-child(3),
.nav-cta__card:nth-child(4)  { border-bottom: none; }

.nav-cta__card-inner {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
}

.nav-cta__card--1:hover { background: rgba(10,15,30,0.03); }
.nav-cta__card--2       { background: #fafafa; }
.nav-cta__card--2:hover { background: rgba(10,15,30,0.04); }
.nav-cta__card--3:hover { background: rgba(10,15,30,0.03); }

.nav-cta__card--accent               { background: var(--color-primary, #0a0f1e); }
.nav-cta__card--accent:hover         { background: #131b2e; }
.nav-cta__card--accent .nav-cta__icon          { background: rgba(255,255,255,0.12); color: #ffffff; }
.nav-cta__card--accent .nav-cta__text strong   { color: #ffffff; }
.nav-cta__card--accent .nav-cta__text span     { color: rgba(255,255,255,0.7); }
.nav-cta__card--accent .nav-cta__arrow         { color: rgba(255,255,255,0.6); }
.nav-cta__card--accent:hover .nav-cta__arrow   { color: #25D366; }

.nav-cta__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: rgba(10,15,30,0.05);
  color: var(--color-primary, #0a0f1e);
  flex-shrink: 0;
}

.nav-cta__icon svg { width: 20px; height: 20px; }

.nav-cta__text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.nav-cta__text strong {
  font-size: 0.8125rem;
  font-weight: 700;
  color: var(--color-primary, #0a0f1e);
  line-height: 1.3;
}

.nav-cta__text span {
  font-size: 0.725rem;
  color: rgba(10,15,30,0.5);
  line-height: 1.4;
}

.nav-cta__arrow {
  color: rgba(10,15,30,0.25);
  flex-shrink: 0;
  width: 16px;
  height: 16px;
}

@media (min-width: 480px) {
  .nav-cta__icon        { width: 46px; height: 46px; border-radius: 12px; }
  .nav-cta__text strong { font-size: 0.875rem; }
  .nav-cta__text span   { font-size: 0.775rem; }
  .nav-cta__card-inner  { padding: 1.125rem 1.25rem; gap: 0.875rem; }
}

@media (min-width: 640px) {
  .nav-cta__icon { width: 48px; height: 48px; }
}

@media (min-width: 1024px) {
  .nav-cta__grid { grid-template-columns: repeat(4, 1fr); }

  .nav-cta__card        { border-bottom: none; border-right: 1px solid rgba(0,0,0,0.07); }
  .nav-cta__card:nth-child(2n) { border-right: 1px solid rgba(0,0,0,0.07); }
  .nav-cta__card:last-child    { border-right: none; }
  .nav-cta__card:nth-child(3),
  .nav-cta__card:nth-child(4)  { border-bottom: none; }
  .nav-cta__card:nth-child(1),
  .nav-cta__card:nth-child(2)  { border-bottom: none; }

  .nav-cta__card-inner  { padding: 1.625rem 1.75rem; gap: 1.25rem; }
  .nav-cta__icon        { width: 56px; height: 56px; border-radius: 16px; }
  .nav-cta__icon svg    { width: 28px; height: 28px; }
  .nav-cta__text strong { font-size: 1rem; }
  .nav-cta__text span   { font-size: 0.875rem; }
  .nav-cta__arrow       { width: 20px; height: 20px; }
}

@media (min-width: 1280px) {
  .nav-cta__card-inner { padding: 1.75rem 2rem; }
}
</style>
