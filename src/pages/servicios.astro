---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';

const title = 'Servicios de Seguridad Privada CDMX | ORIGINS Private Security';
const description = 'Servicios de seguridad privada en CDMX: guardias certificados SSC, control de accesos, monitoreo 24/7, protección ejecutiva. +15 años de experiencia. ☎ 55 3025 5580';
---
<BaseLayout title={title} description={description}>
  <Hero
    title="Servicios de Seguridad Privada"
    subtitle="Guardias Intramuros para Condominios y Empresas en CDMX"
    description='ORIGINS Private Security: Guardias <strong>certificados SSC</strong>, control de accesos 24/7, monitoreo GPS y protección ejecutiva. <strong>+15 años</strong> protegiendo lo que más valoras.'
    card1Title="Seguridad que SÍ funciona"
    card1Text="¿Contrataste seguridad que solo calienta la silla? No estás solo. Nuestros guardias certificados SSC verdaderamente vigilan, con tecnología GPS que no miente sobre rondines y supervisión real 24/7."
    card2Title="Protección integral con garantía"
    card2Text="Desde guardias para condominios donde tus hijos juegan sin miedo, hasta protección ejecutiva y custodia de mercancías. Cada servicio incluye reportes con evidencia fotográfica GPS y garantía de satisfacción."
  />

  <section class="services-section">
    <div class="container">
      <h2 class="section-title">Todos Nuestros Servicios</h2>
      <p class="section-subtitle">Soluciones integrales de seguridad para cada necesidad</p>

      <h3 style="margin-bottom:20px">Vigilancia Corporativa</h3>
      <div class="service-items-grid" style="margin-bottom:48px">
        <ServiceCard href="/servicios/guardias-de-seguridad-y-vigilancia" imgSrc="/img/img-index/guardias-de-seguridad.avif" imgAlt="Guardias de Seguridad" title="Guardias de Seguridad" />
        <ServiceCard href="/servicios/guardias-intramuros" imgSrc="/img/img-index/guardias-intramuros.avif" imgAlt="Guardias Intramuros" title="Guardias Intramuros" />
        <ServiceCard href="/servicios/control-de-accesos" imgSrc="/img/img-index/control-de-accesos.avif" imgAlt="Control de Accesos" title="Control de Accesos" />
        <ServiceCard href="/servicios/patrullaje" imgSrc="/img/img-index/patrullaje.avif" imgAlt="Patrullaje" title="Patrullaje" />
        <ServiceCard href="/servicios/prevencion-de-perdidas" imgSrc="/img/img-index/prevencion-de-perdidas.avif" imgAlt="Prevención de Pérdidas" title="Prevención de Pérdidas" />
      </div>

      <h3 style="margin-bottom:20px">Seguridad Especializada</h3>
      <div class="service-items-grid" style="margin-bottom:48px">
        <ServiceCard href="/servicios/seguridad-especializada" imgSrc="/img/img-index/seguridad-especializada.avif" imgAlt="Seguridad Especializada" title="Seguridad Especializada" />
        <ServiceCard href="/servicios/seguridad-condominios" imgSrc="/img/img-index/seguridad-para-condominios.avif" imgAlt="Condominios" title="Seguridad para Condominios" />
        <ServiceCard href="/servicios/seguridad-construccion" imgSrc="/img/img-index/seguridad-para-construccion.avif" imgAlt="Construcción" title="Seguridad para Construcción" />
        <ServiceCard href="/servicios/seguridad-eventos" imgSrc="/img/img-index/seguridad-para-eventos.avif" imgAlt="Eventos" title="Seguridad para Eventos" />
        <ServiceCard href="/servicios/seguridad-hospitalaria" imgSrc="/img/img-index/seguridad-hospitalaria.avif" imgAlt="Hospitalaria" title="Seguridad Hospitalaria" />
      </div>

      <h3 style="margin-bottom:20px">Tecnología y Monitoreo</h3>
      <div class="service-items-grid" style="margin-bottom:48px">
        <ServiceCard href="/servicios/tecnologia-monitoreo-seguridad" imgSrc="/img/img-index/monitoreo-camaras.avif" imgAlt="Tecnología y Monitoreo" title="Tecnología y Monitoreo" />
        <ServiceCard href="/servicios/vigilancia-remota-cctv" imgSrc="/img/img-index/vigilancia-remota-y-cctv.avif" imgAlt="Vigilancia Remota CCTV" title="Vigilancia Remota CCTV" />
        <ServiceCard href="/servicios/monitoreo-alarmas" imgSrc="/img/img-index/monitoreo-de-alarmas-24-7.avif" imgAlt="Monitoreo de Alarmas" title="Monitoreo de Alarmas 24/7" />
        <ServiceCard href="/servicios/seguridad-gps-satelital" imgSrc="/img/img-index/seguridad-satelital-gps.avif" imgAlt="Seguridad GPS" title="Seguridad Satelital (GPS)" />
      </div>

      <h3 style="margin-bottom:20px">Protección Ejecutiva y Consultoría</h3>
      <div class="service-items-grid" style="margin-bottom:48px">
        <ServiceCard href="/servicios/proteccion-ejecutiva-y-consultoria" imgSrc="/img/img-index/proteccion-ejecutiva-consultoria.avif" imgAlt="Protección y Consultoría" title="Protección y Consultoría" />
        <ServiceCard href="/servicios/custodia-de-mercancias" imgSrc="/img/img-index/custodia-de-mercancias.avif" imgAlt="Custodia de Mercancías" title="Custodia de Mercancías" />
        <ServiceCard href="/servicios/proteccion-ejecutiva" imgSrc="/img/img-index/proteccion-ejecutiva.avif" imgAlt="Protección Ejecutiva" title="Protección Ejecutiva" />
        <ServiceCard href="/servicios/consultoria-seguridad" imgSrc="/img/img-index/consultoria-de-seguridad.avif" imgAlt="Consultoría" title="Consultoría de Seguridad" />
        <ServiceCard href="/servicios/consultoria-analisis-riesgos" imgSrc="/img/img-index/analisis-de-riesgos.avif" imgAlt="Análisis de Riesgos" title="Análisis de Riesgos" />
        <ServiceCard href="/servicios/investigaciones-confiabilidad" imgSrc="/img/img-index/investigaciones-de-confiabilidad.avif" imgAlt="Investigaciones" title="Investigaciones de Confiabilidad" />
      </div>
    </div>
  </section>

  <section class="cta-business">
    <div class="cta-business__content">
      <h2 class="cta-business__title">¿No Sabes Qué Servicio Necesitas?</h2>
      <p class="cta-business__description">Contáctanos y te asesoramos sin costo para encontrar la solución perfecta para tu situación</p>
      <div class="cta-business__actions">
        <a href="https://wa.me/525530255580" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/cotizar" class="cta-business__btn cta-business__btn--secondary">Cotizar en Línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
