        const formData = new FormData(form);
        const nombre = formData.get('nombre');
        const email = formData.get('email');
        const telefono = formData.get('telefono');
        const empresa = formData.get('empresa') || 'No especificado';
        const ubicacion = formData.get('ubicacion');
        const tipoServicio = formData.get('tipoServicio');
        const duracion = formData.get('duracion');
        const mensaje = formData.get('mensaje') || 'Sin mensaje adicional';
        const serviciosAdicionales = formData.getAll('servicios').join(', ') || 'Ninguno';

        const whatsappMessage = `*Nueva Solicitud de Cotización*

*Datos de Contacto:*
- Nombre: ${nombre}
- Email: ${email}
- Teléfono: ${telefono}
- Empresa/Condominio: ${empresa}

*Servicio Solicitado:*
- Ubicación: ${ubicacion}
- Tipo de Servicio: ${tipoServicio}
- Duración: ${duracion}
- Servicios Adicionales: ${serviciosAdicionales}

*Mensaje:*
${mensaje}

---
Enviado desde seguridad-privada.com.mx`;

        // 1) Enviar email de respaldo vía formsubmit.co (sin redirigir la página)
        fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' }
        }).catch(() => {
          // Silencioso — el canal principal es WhatsApp
        });

        // 2) Abrir WhatsApp con todos los datos del formulario
        window.open(`https://wa.me/525530255580?text=${encodeURIComponent(whatsappMessage)}`, '_blank');
      });
    }
  });
</script>
