---
/**
 * Homepage - ORIGINS Private Security
 * Optimized Astro page with modular components and data
 */
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FAQItem from '../components/FAQItem.astro';
import CredentialsCard from '../components/CredentialsCard.astro';
import StarRating from '../components/icons/StarRating.astro';

// Import data
import { featuredServices } from '../data/featured-services';
import { homepageTestimonials, trustMetrics } from '../data/homepage-testimonials';
import { homepageFaqs } from '../data/homepage-faqs';
import { homepageCredentials, companyStats } from '../data/homepage-credentials';

// Import section styles
import '../styles/sections/index.css';

const siteUrl = 'https://seguridad-privada.com.mx';

// Schema.org for homepage
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#business`,
      "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
      "legalName": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
      "alternateName": ["ORIGINS Private Security", "Seguridad Privada para Condominios CDMX"],
      "image": `${siteUrl}/img/logo.avif`,
      "description": "Empresa especializada en seguridad privada para condominios y residenciales en CDMX. Guardias intramuros certificados SSC para condominios verticales y horizontales, control de accesos 24/7, monitoreo CCTV. +15 años protegiendo comunidades residenciales. Permiso SSC 0102-15.",
      "url": siteUrl,
      "telephone": "+52-55-3025-5580",
      "email": "contacto@seguridad-privada.com.mx",
      "knowsAbout": [
        "Seguridad privada para condominios",
        "Guardias intramuros para condominios",
        "Seguridad para residenciales y fraccionamientos",
        "Control de accesos en condominios",
        "Vigilancia para condominios verticales y horizontales"
      ],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Basiliso Romo Anguiano No 22 int 3",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "postalCode": "07800",
        "addressCountry": "MX"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "19.4326",
        "longitude": "-99.1332"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
        "opens": "00:00",
        "closes": "23:59"
      },
      "sameAs": [
        "https://www.facebook.com/originsprivatesecurity",
        "https://www.instagram.com/originsprivatesecurity"
      ],
      "areaServed": [
        { "@type": "City", "name": "Ciudad de México" },
        { "@type": "City", "name": "Naucalpan" },
        { "@type": "City", "name": "Tlalnepantla" },
        { "@type": "City", "name": "Atizapán" },
        { "@type": "City", "name": "Huixquilucan" },
        { "@type": "City", "name": "Cuautitlán Izcalli" }
      ]
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
      "url": siteUrl,
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/img/logo.avif`,
        "width": 372,
        "height": 100
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+52-55-3025-5580",
        "contactType": "customer service",
        "areaServed": "MX",
        "availableLanguage": "Spanish"
      }
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "ORIGINS Private Security — Seguridad Privada para Condominios",
      "alternateName": "Seguridad Privada para Condominios CDMX",
      "publisher": { "@id": `${siteUrl}/#organization` }
    },
    {
      "@type": "FAQPage",
      "mainEntity": homepageFaqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer.replace(/<[^>]*>/g, '')
        }
      }))
    }
  ]
};
---

<Base
  title="Seguridad Privada para Condominios en CDMX | Guardias Intramuros SSC"
  description="Seguridad privada para condominios en CDMX. Guardias intramuros certificados SSC para condominios y residenciales: control de accesos 24/7, rondines, monitoreo CCTV. +15 años. Cotización gratis."
  canonical={siteUrl}
  schema={schema}
>
  <!-- HERO SECTION -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero__background"></div>
    <div class="container">
      <div class="hero__grid">
        <div class="hero__main">
          <div class="hero__badge">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
            <span>Permiso SSC 0102-15</span>
          </div>
          <h1 id="hero-title" class="hero__title">Seguridad Privada para Condominios en CDMX — Guardias Intramuros Certificados 24/7</h1>
          <p class="hero__subtitle">Especialistas en <strong>seguridad privada para condominios</strong> y residenciales: guardias intramuros, control de accesos y monitoreo permanente en la Zona Metropolitana</p>
          <div class="hero__cta">
            <a href="#cotizacion" class="btn btn-primary btn-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Solicitar Cotización Gratis
            </a>
            <a href="https://wa.me/525530255580" class="btn btn-whatsapp btn-lg" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp Directo
            </a>
          </div>
        </div>
        <div class="hero__seo">
          <p class="hero__seo-text">
            ¿Buscas <strong>seguridad privada para tu condominio</strong>? En <strong>ORIGINS Private Security</strong> nos especializamos exclusivamente en proteger <a href="/servicios/seguridad-condominios"><strong>condominios verticales y horizontales</strong></a> en CDMX. Nuestros <a href="/servicios/guardias-intramuros"><strong>guardias intramuros para condominios</strong></a> conocen a cada residente, gestionan accesos con registro digital y realizan rondines programados con bitácora electrónica. Más de 15 años de experiencia respaldan cada operación.
          </p>
          <p class="hero__seo-text">
            A diferencia de empresas generalistas, entendemos la operación diaria de un condominio: el trato discreto con residentes, la gestión de visitantes y proveedores, el <a href="/servicios/control-de-accesos">monitoreo de estacionamientos</a> y la coordinación con la administración. Cada elemento pasa por exámenes psicométricos, verificación de antecedentes y capacitación específica para <strong>seguridad residencial</strong>.
          </p>
          <p class="hero__seo-text">
            También protegemos <a href="/servicios/seguridad-residenciales"><strong>fraccionamientos privados</strong> y <strong>residenciales de lujo</strong></a> con casetas de vigilancia, patrullaje interno y seguridad perimetral. Operamos con <strong>póliza de responsabilidad civil</strong>, cumplimiento IMSS-INFONAVIT y <strong>permiso SSC 0102-15</strong>. Solicita tu cotización y descubre por qué más de 50 comunidades residenciales confían en ORIGINS.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS PRINCIPALES -->
  <section class="services-section services-section--featured" id="servicios" aria-labelledby="services-title">
    <div class="container">
      <div class="section-header">
        <div class="section-header__main">
          <h2 id="services-title" class="section-title">Especialistas en Seguridad para Condominios y Residenciales</h2>
          <p class="section-subtitle">Soluciones de <strong>seguridad intramuros</strong> diseñadas específicamente para comunidades residenciales en CDMX</p>
        </div>
        <div class="section-header__seo">
          <p>Somos la <strong>empresa de seguridad privada</strong> especializada en proteger <strong>condominios</strong>, <strong>fraccionamientos</strong> y <strong>residenciales privados</strong> en la Zona Metropolitana. Nuestros <strong>guardias intramuros</strong> conocen las necesidades únicas de la vida en comunidad: control de accesos discreto, trato profesional con residentes y respuesta inmediata ante emergencias.</p>
          <p>A diferencia de empresas generalistas, nos enfocamos exclusivamente en <strong>seguridad residencial</strong>. Esto significa guardias con capacitación específica para condominios, protocolos adaptados a cada comunidad y supervisión constante. Más de 50 desarrollos residenciales confían en ORIGINS para proteger a sus familias las 24 horas del día.</p>
        </div>
      </div>

      <div class="featured-services-grid">
        {featuredServices.map((service) => (
          <ServiceCard
            href={service.href}
            image={service.image}
            imageAlt={service.imageAlt}
            badge={service.badge}
            title={service.title}
            description={service.description}
            features={service.features}
            ctaText={service.ctaText}
            loading={service.loading}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT ORIGINS -->
  <section class="about-origins" aria-labelledby="about-title">
    <div class="container">
      <div class="about-origins__grid">
        <div class="about-origins__content">
          <span class="about-origins__badge">Empresa de Seguridad Privada en CDMX</span>
          <h2 id="about-title" class="about-origins__title">Empresa de Seguridad Privada para Condominios en CDMX — Desde 2008</h2>
          <p class="about-origins__tagline">Especialistas en <strong>seguridad privada para condominios</strong> y comunidades residenciales en Ciudad de México y Zona Metropolitana</p>

          <div class="about-origins__text">
            <p><strong>ORIGINS PRIVATE SECURITY S.A. DE C.V.</strong> es una empresa mexicana dedicada exclusivamente a la <strong>seguridad privada para condominios, residenciales y fraccionamientos</strong>. Nuestra especialización nos permite ofrecer un servicio que entiende las necesidades reales de las comunidades residenciales: guardias que conocen a cada residente, protocolos diseñados para la convivencia y coordinación directa con administradores y comités de vigilancia.</p>
            <p>Operamos bajo el <strong>Permiso SSC 0102-15</strong> de la Secretaría de Seguridad Ciudadana, con pleno cumplimiento de la <strong>Ley Federal de Seguridad Privada</strong>. Cada uno de nuestros elementos cuenta con verificación de antecedentes, exámenes psicométricos, capacitación continua y alta ante IMSS-INFONAVIT. Respaldamos nuestro servicio con <strong>póliza de responsabilidad civil</strong> y supervisión semanal documentada.</p>
          </div>

          <div class="about-origins__stats">
            {companyStats.map((stat) => (
              <div class="about-origins__stat">
                <span class="about-origins__stat-number">{stat.number}</span>
                <span class="about-origins__stat-label">{stat.label}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="about-origins__credentials">
          {homepageCredentials.map((credential) => (
            <CredentialsCard
              title={credential.title}
              icon={credential.icon}
              items={credential.items}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials-section" aria-labelledby="testimonials-title">
    <div class="container">
      <div class="testimonials-header">
        <span class="testimonials-badge">Testimonios</span>
        <h2 id="testimonials-title">Lo Que Dicen Nuestros Clientes</h2>
        <p>Administradores y comités de vigilancia comparten su experiencia con ORIGINS</p>
      </div>

      <div class="testimonials-grid">
        {homepageTestimonials.map((testimonial) => (
          <TestimonialCard
            rating={testimonial.rating}
            quote={testimonial.quote}
            name={testimonial.name}
            initials={testimonial.initials}
            role={testimonial.role}
            company={testimonial.company}
          />
        ))}
      </div>

      <div class="testimonials-trust">
        <div class="testimonials-trust__item">
          <span class="testimonials-trust__number">{trustMetrics.rating}</span>
          <div class="testimonials-trust__stars">
            <StarRating rating={5} size={16} />
          </div>
          <span class="testimonials-trust__label">Calificación promedio</span>
        </div>
        <div class="testimonials-trust__divider"></div>
        <div class="testimonials-trust__item">
          <span class="testimonials-trust__number">{trustMetrics.condominios}</span>
          <span class="testimonials-trust__label">Condominios satisfechos</span>
        </div>
        <div class="testimonials-trust__divider"></div>
        <div class="testimonials-trust__item">
          <span class="testimonials-trust__number">{trustMetrics.renovationRate}</span>
          <span class="testimonials-trust__label">Tasa de renovación</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner" aria-labelledby="cta-title">
    <div class="container">
      <div class="cta-banner__content">
        <div class="cta-banner__text">
          <h2 id="cta-title">¿Listo para Proteger tu Condominio?</h2>
          <p>Diagnóstico de seguridad gratuito + propuesta personalizada en 24 horas</p>
        </div>
        <div class="cta-banner__actions">
          <a href="#cotizacion" class="btn btn-primary btn-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Solicitar Cotización Gratis
          </a>
          <a href="https://wa.me/525530255580" class="btn btn-whatsapp btn-lg" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Directo
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FORMULARIO DE COTIZACIÓN -->
  <section class="cotizacion-section" id="cotizacion" aria-labelledby="cotizacion-title">
    <div class="container">
      <div class="section-header">
        <div class="section-header__main">
          <h2 id="cotizacion-title" class="section-title">Cotización de Seguridad Privada para tu Condominio</h2>
          <p class="section-subtitle">Recibe una <strong>propuesta personalizada para tu condominio</strong> en menos de 24 horas</p>
        </div>
        <div class="section-header__seo">
          <p>Cada condominio es diferente: número de accesos, cantidad de residentes, tipo de desarrollo y nivel de seguridad requerido. En <strong>ORIGINS</strong> analizamos las características específicas de tu comunidad para diseñar una propuesta que incluya el número óptimo de guardias, turnos, tecnología complementaria y protocolos adaptados.</p>
          <p>Nuestro equipo comercial visitará tu condominio para realizar un <strong>diagnóstico de seguridad gratuito</strong>: evaluar accesos, identificar vulnerabilidades y presentar una solución integral con la mejor relación costo-beneficio para tu administración.</p>
        </div>
      </div>

      <div class="cotizacion-form-wrapper">
        <form id="securityForm" action="https://formsubmit.co/josecruz@originsecurity.mx" method="POST">
              <input type="text" name="_honey" style="display:none">
              <input type="hidden" name="_captcha" value="false">
              <input type="hidden" name="_next" value="https://seguridad-privada.com.mx/gracias.html">
          <div class="cotizacion-form-row">
            <div class="cotizacion-form-col">
              <div class="cotizacion-field">
                <label for="nombre">Nombre Completo *</label>
                <input type="text" id="nombre" name="nombre" required placeholder="Ingresa tu nombre completo">
              </div>
              <div class="cotizacion-field">
                <label for="email">Correo Electrónico *</label>
                <input type="email" id="email" name="email" required placeholder="correo@empresa.com">
              </div>
              <div class="cotizacion-field">
                <label for="telefono">Teléfono de Contacto *</label>
                <input type="tel" id="telefono" name="telefono" required placeholder="55 1234 5678">
              </div>
              <div class="cotizacion-field">
                <label for="empresa">Nombre del Condominio / Residencial *</label>
                <input type="text" id="empresa" name="empresa" placeholder="Ej: Residencial Las Lomas, Torre Polanco 200">
              </div>
              <div class="cotizacion-field">
                <label for="ubicacion">Ubicación del Servicio *</label>
                <select id="ubicacion" name="ubicacion" required>
                  <option value="">Selecciona una opción</option>
                  <option value="cdmx-cuauhtemoc">CDMX - Cuauhtémoc</option>
                  <option value="cdmx-miguel-hidalgo">CDMX - Miguel Hidalgo</option>
                  <option value="cdmx-benito-juarez">CDMX - Benito Juárez</option>
                  <option value="cdmx-coyoacan">CDMX - Coyoacán</option>
                  <option value="cdmx-alvaro-obregon">CDMX - Álvaro Obregón</option>
                  <option value="cdmx-tlalpan">CDMX - Tlalpan</option>
                  <option value="cdmx-otras">CDMX - Otras Alcaldías</option>
                  <option value="edomex-naucalpan">Estado de México - Naucalpan</option>
                  <option value="edomex-tlalnepantla">Estado de México - Tlalnepantla</option>
                  <option value="edomex-atizapan">Estado de México - Atizapán</option>
                  <option value="edomex-interlomas">Estado de México - Interlomas</option>
                  <option value="edomex-cuautitlan">Estado de México - Cuautitlán Izcalli</option>
                  <option value="edomex-otros">Estado de México - Otros Municipios</option>
                </select>
              </div>
            </div>

            <div class="cotizacion-form-col">
              <div class="cotizacion-field">
                <label for="tipoServicio">Tipo de Servicio Requerido *</label>
                <select id="tipoServicio" name="tipoServicio" required>
                  <option value="">Selecciona un servicio</option>
                  <option value="seguridad-condominios">Seguridad para Condominios</option>
                  <option value="guardias-intramuros">Guardias Intramuros para Condominio</option>
                  <option value="seguridad-residenciales">Seguridad para Residenciales / Fraccionamientos</option>
                  <option value="control-accesos-condominios">Control de Accesos para Condominio</option>
                  <option value="guardias-seguridad">Guardias de Seguridad Corporativa</option>
                  <option value="vigilancia-remota">Vigilancia Remota y CCTV</option>
                  <option value="monitoreo-alarmas">Monitoreo de Alarmas 24/7</option>
                  <option value="patrullaje-residencial">Patrullaje Residencial</option>
                  <option value="consultoria">Consultoría de Seguridad para Condominios</option>
                  <option value="otro">Otro Servicio</option>
                </select>
              </div>
              <div class="cotizacion-field">
                <label for="duracion">Duración del Servicio *</label>
                <select id="duracion" name="duracion" required>
                  <option value="">Selecciona duración</option>
                  <option value="evento-puntual">Evento Puntual (1-3 días)</option>
                  <option value="semanal">1 Semana</option>
