---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';

const title = 'Seguridad Privada CDMX | Guardias Intramuros 24/7';
const description = 'Seguridad privada intramuros en CDMX. Guardias certificados SSC 24/7, control de accesos y monitoreo. +15 años de experiencia. ☎ 55 3025 5580';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://seguridad-privada.com.mx/#business",
      "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
      "legalName": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
      "alternateName": "ORIGINS Private Security",
      "image": "https://seguridad-privada.com.mx/img/logo.avif",
      "description": "ORIGINS PRIVATE SECURITY - Empresa líder en seguridad privada intramuros para condominios, residenciales y empresas en CDMX. Guardias certificados SSC, control de accesos 24/7, monitoreo GPS. +15 años de experiencia. Permiso SSC 0102-15.",
      "url": "https://seguridad-privada.com.mx/",
      "telephone": "+52-55-3025-5580",
      "email": "josecruz@originsecurity.mx",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Basiliso Romo Anguiano No 22 int 3",
        "addressLocality": "Ciudad de México",
        "addressRegion": "CDMX",
        "postalCode": "07800",
        "addressCountry": "MX"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": "19.4326", "longitude": "-99.1332" },
      "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"], "opens": "00:00", "closes": "23:59" }],
      "areaServed": [{ "@type": "City", "name": "Ciudad de México" }, { "@type": "State", "name": "Estado de México" }]
    },
    {
      "@type": "Organization",
      "@id": "https://seguridad-privada.com.mx/#organization",
      "name": "Seguridad Privada CDMX",
      "url": "https://seguridad-privada.com.mx/",
      "logo": { "@type": "ImageObject", "url": "https://seguridad-privada.com.mx/img/logo.avif", "width": 600, "height": 60 },
      "contactPoint": { "@type": "ContactPoint", "telephone": "+52-55-3025-5580", "contactType": "customer service", "areaServed": ["MX"], "availableLanguage": ["Spanish"] }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "¿Qué servicios de seguridad privada ofrecen en CDMX y Estado de México?", "acceptedAnswer": { "@type": "Answer", "text": "Ofrecemos servicios integrales de seguridad privada que incluyen: guardias de seguridad intramuros certificados, control de accesos vehicular y peatonal, patrullaje preventivo 24/7, monitoreo de alarmas con central de respuesta inmediata, vigilancia remota CCTV en tiempo real, rastreo GPS satelital para vehículos y mercancías, protección ejecutiva con escoltas profesionales, custodia de mercancías en tránsito, consultoría en análisis de riesgos corporativos e investigaciones de confiabilidad para personal clave." } },
        { "@type": "Question", "name": "¿Los guardias de seguridad cuentan con certificación SSC vigente?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, todos nuestros guardias de seguridad privada tienen certificación vigente emitida por la Secretaría de Seguridad Ciudadana (SSC) de la Ciudad de México y cumplen con todos los requisitos establecidos por la Ley Federal de Seguridad Privada." } },
        { "@type": "Question", "name": "¿Cómo solicitar una cotización de servicios de seguridad privada en CDMX?", "acceptedAnswer": { "@type": "Answer", "text": "Contáctanos por WhatsApp al 55 3025 5580 para recibir una propuesta adaptada a tu situación particular. Ofrecemos cotizaciones personalizadas sin compromiso tras evaluar tus necesidades específicas." } },
        { "@type": "Question", "name": "¿Qué zonas de CDMX y Estado de México cubren sus servicios?", "acceptedAnswer": { "@type": "Answer", "text": "Brindamos servicios de seguridad privada en toda la Zona Metropolitana incluyendo las 16 alcaldías de la Ciudad de México y municipios clave del Estado de México como Naucalpan, Tlalnepantla, Atizapán de Zaragoza, Huixquilucan (Interlomas), Cuautitlán Izcalli, Ecatepec, Nezahualcóyotl, Texcoco y Toluca." } },
        { "@type": "Question", "name": "¿Cuentan con seguro de responsabilidad civil?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, contamos con póliza de responsabilidad civil vigente emitida por aseguradora reconocida que cubre daños a terceros, responsabilidad patronal de nuestro personal y eventualidades durante la prestación de servicios de seguridad privada." } }
      ]
    }
  ]
});

const faqs = [
  { q: '¿Qué servicios de seguridad privada ofrecen en CDMX y Estado de México?', a: 'Ofrecemos servicios integrales de seguridad privada que incluyen: <strong>guardias de seguridad intramuros certificados</strong>, control de accesos vehicular y peatonal, patrullaje preventivo 24/7, monitoreo de alarmas con central de respuesta inmediata, vigilancia remota CCTV en tiempo real, rastreo GPS satelital para vehículos y mercancías, protección ejecutiva con escoltas profesionales, custodia de mercancías en tránsito, consultoría en análisis de riesgos corporativos e investigaciones de confiabilidad para personal clave. Todos nuestros servicios están disponibles en toda la Zona Metropolitana de la Ciudad de México y municipios del Estado de México como Naucalpan, Tlalnepantla, Atizapán e Interlomas.' },
  { q: '¿Los guardias de seguridad cuentan con certificación SSC vigente?', a: 'Sí, todos nuestros <strong>guardias de seguridad privada tienen certificación vigente</strong> emitida por la Secretaría de Seguridad Ciudadana (SSC) de la Ciudad de México y cumplen con todos los requisitos establecidos por la Ley Federal de Seguridad Privada. Cada elemento pasa por verificación exhaustiva de antecedentes penales, exámenes psicométricos, estudios socioeconómicos, capacitación en protocolos de seguridad preventiva y evaluaciones médicas toxicológicas.' },
  { q: '¿Cómo solicito una cotización de servicios de seguridad privada?', a: '<strong>La pregunta no es cuánto cuesta, sino cuánto te puede costar NO tener seguridad profesional.</strong> Cada situación es única. El costo de <strong>guardias certificados SSC</strong> depende de: número de elementos requeridos, turnos (12 horas diurno/nocturno o 24/7), ubicación del servicio, nivel de riesgo de la zona, servicios adicionales incluidos y duración del contrato. <strong>WhatsApp 55 3025 5580</strong> - respuesta en menos de 2 horas con propuesta personalizada.' },
  { q: '¿Qué zonas de CDMX y Estado de México cubren sus servicios?', a: 'Brindamos <strong>servicios de seguridad privada en toda la Zona Metropolitana</strong> incluyendo las 16 alcaldías de la Ciudad de México (con especial presencia en Miguel Hidalgo, Cuauhtémoc, Benito Juárez, Álvaro Obregón, Coyoacán y Tlalpan) y municipios clave del Estado de México como Naucalpan, Tlalnepantla, Atizapán de Zaragoza, Huixquilucan (Interlomas), Cuautitlán Izcalli, Ecatepec, Nezahualcóyotl, Texcoco y Toluca.' },
  { q: '¿Cómo es el proceso para contratar servicios de seguridad privada?', a: 'El proceso de contratación es rápido y profesional: <strong>1) Contacto inicial</strong> por WhatsApp (55 3025 5580), teléfono o formulario web. <strong>2) Diagnóstico de seguridad</strong> con visita sin costo. <strong>3) Propuesta personalizada</strong> con cotización detallada. <strong>4) Firma de contrato</strong> con póliza de responsabilidad civil. <strong>5) Implementación inmediata</strong> en 24 a 48 horas.' },
  { q: '¿Qué incluye el servicio de guardias intramuros?', a: 'Nuestro servicio de <strong>guardias intramuros certificados</strong> incluye: vigilancia física permanente, control de accesos con registro de entradas/salidas, rondines perimetrales e interiores con bitácora digital, monitoreo de cámaras CCTV y sistemas de alarma, uniformes corporativos profesionales, equipo de comunicación y supervisión semanal de calidad.' },
  { q: '¿Ofrecen servicios de seguridad para condominios residenciales?', a: 'Sí, somos especialistas en <strong>seguridad para condominios residenciales en CDMX y Estado de México</strong>. Ofrecemos paquetes diseñados específicamente para desarrollos habitacionales que incluyen: guardias de caseta con control de accesos, rondines perimetrales nocturnos, monitoreo de áreas comunes, bitácoras digitales compartidas y protocolos de emergencia. Trabajamos con condominios desde 50 hasta 500+ departamentos.' },
  { q: '¿Cuentan con seguro de responsabilidad civil?', a: 'Sí, contamos con <strong>póliza de responsabilidad civil vigente</strong> emitida por aseguradora reconocida que cubre daños a terceros, responsabilidad patronal de nuestro personal y eventualidades durante la prestación de servicios de seguridad privada. Cumplimos con todas las obligaciones laborales ante el IMSS, INFONAVIT y SAT.' },
  { q: '¿Qué diferencia existe entre guardias armados y no armados?', a: 'Los <strong>guardias de seguridad no armados</strong> se enfocan en disuasión, detección de irregularidades, control de accesos y reporte de incidencias. Los <strong>guardias armados certificados</strong> portan arma de fuego con permiso federal de la SEDENA y se utilizan para custodia de valores, protección ejecutiva de alto nivel o zonas de riesgo elevado.' },
  { q: '¿Qué tecnología utilizan para el monitoreo de seguridad?', a: 'Nuestra <strong>central de monitoreo 24/7</strong> utiliza: sistemas de CCTV IP de alta resolución (1080p a 4K) con grabación en la nube, plataformas de video-analítica, paneles de alarma perimetral, rastreo GPS satelital en tiempo real, radios de comunicación encriptada Motorola, software de gestión de guardias con código QR o NFC, y aplicaciones móviles para clientes.' },
];

const testimonials = [
  { name: 'Lic. Fernando Vega Torres', position: 'Director General', company: 'Seguridad Privada MX', companyUrl: 'https://seguridadprivadamx.com/', location: 'Ciudad de México', img: '/img/img-index/roberto-castillo.avif', text: '"Como empresa del sector de seguridad privada en México, reconocemos la excelencia operativa de ORIGINS Private Security. Su metodología de trabajo, certificaciones SSC vigentes y compromiso con los más altos estándares de la industria los posicionan como referentes en servicios de vigilancia corporativa y protección patrimonial en CDMX."' },
  { name: 'Ing. Carolina Mendoza Ruiz', position: 'Directora de Operaciones', company: 'Seguridad Eventos', companyUrl: 'https://seguridadeventos.com/', location: 'Ciudad de México', img: '/img/img-index/maria-guadalupe-hernandez.avif', text: '"Hemos colaborado con ORIGINS Private Security en múltiples proyectos de seguridad para eventos masivos. Su capacidad de respuesta, personal altamente capacitado en control de multitudes y coordinación con autoridades locales es impecable."' },
  { name: 'Arq. Ricardo Sánchez Morales', position: 'Director Comercial', company: 'Seguridad Privada Condominios', companyUrl: 'https://seguridadprivadacondominios.com/', location: 'Estado de México', img: '/img/img-index/jorge-martinez.avif', text: '"En el sector de seguridad residencial, ORIGINS Private Security destaca por su especialización en condominios y fraccionamientos de alto nivel. Su servicio de guardias intramuros, control de accesos biométrico y monitoreo CCTV 24/7 ofrece la tranquilidad que los residentes de zonas premium merecen."' },
  { name: 'Lic. Patricia Hernández Luna', position: 'Gerente de Recursos Humanos', company: 'Guardias Privados', companyUrl: 'https://guardias-privados.com/', location: 'Ciudad de México', img: '/img/img-index/andrea-sanchez.avif', text: '"La profesionalización del personal de seguridad es fundamental en nuestra industria. ORIGINS Private Security mantiene estándares excepcionales en capacitación continua, certificaciones STPS y cumplimiento normativo SSC."' },
  { name: 'Ing. Alejandro Ramírez Fuentes', position: 'Director de Proyectos', company: 'GAMA de México', companyUrl: 'https://gamademexico.com/', location: 'Ciudad de México', img: '/img/img-index/luis-enrique-ramirez.avif', text: '"Nuestra alianza estratégica con ORIGINS Private Security nos ha permitido ofrecer soluciones integrales de seguridad patrimonial. Su tecnología de monitoreo GPS satelital, central de alarmas 24/7 y servicio de custodia de mercancías cumple con los más rigurosos estándares."' },
  { name: 'Lic. Gabriela Torres Olvera', position: 'Directora Administrativa', company: 'MESECI', companyUrl: 'https://meseci.com.mx/', location: 'Ciudad de México', img: '/img/img-index/patricia-mendoza.avif', text: '"En MESECI valoramos trabajar con empresas de seguridad privada que comparten nuestro compromiso con la excelencia. ORIGINS Private Security demuestra día a día por qué es líder en servicios de protección ejecutiva, consultoría de seguridad y análisis de riesgos en CDMX."' },
];
---
<BaseLayout title={title} description={description} schema={schema}>

  <Hero
    title="Seguridad Privada en CDMX"
    subtitle="Guardias Intramuros para Condominios, Residenciales y Empresas"
    description='ORIGINS Private Security: Empresa líder en seguridad privada intramuros con <strong>+15 años de experiencia</strong>. Guardias certificados SSC, control de accesos 24/7 y monitoreo GPS en tiempo real.'
    card1Title="Protección que nace de la experiencia real"
    card1Text='Cuando fundamos <strong>ORIGINS Private Security</strong> hace más de 15 años, lo hicimos con una convicción: la <strong>seguridad privada en CDMX</strong> necesitaba un enfoque diferente. No queríamos ser otra empresa que simplemente coloca guardias en una caseta. Queríamos construir un sistema donde cada elemento —desde la selección rigurosa del personal hasta la supervisión tecnológica en tiempo real— trabajara en conjunto para <strong>prevenir incidentes antes de que ocurran</strong>. Hoy, esa visión se traduce en condominios y residenciales donde los vecinos duermen tranquilos, sabiendo que cada acceso está controlado y cada rondín se cumple al minuto.'
    card2Title="El respaldo que tu patrimonio merece"
    card2Text='Nuestros <strong>guardias de seguridad intramuros</strong> no solo portan un uniforme: cargan con la responsabilidad de proteger lo que más valoras. Por eso cada elemento pasa por <strong>verificación exhaustiva de antecedentes</strong>, evaluaciones psicométricas y capacitación continua certificada por la SSC. Operamos con <strong>póliza de responsabilidad civil vigente</strong> y nuestra central de monitoreo propia supervisa cada turno mediante GPS, garantizando respuesta inmediata ante cualquier eventualidad.'
  />

  <!-- Certifications -->
  <section class="certifications-section">
    <div class="container">
      <div class="certifications-grid">
        <div class="certification-item">
          <div class="certification-icon"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>
          <h3 class="certification-title">Certificación SSC</h3>
          <p class="certification-text">Personal registrado y certificado ante la Secretaría de Seguridad Ciudadana</p>
        </div>
        <div class="certification-item">
          <div class="certification-icon"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <h3 class="certification-title">+15 Años de Experiencia</h3>
          <p class="certification-text">Más de una década protegiendo familias y empresas en CDMX</p>
        </div>
        <div class="certification-item">
          <div class="certification-icon"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg></div>
          <h3 class="certification-title">Póliza de Responsabilidad Civil</h3>
          <p class="certification-text">Cobertura amplia que protege tu patrimonio ante cualquier eventualidad</p>
        </div>
        <div class="certification-item">
          <div class="certification-icon"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
          <h3 class="certification-title">Cumplimiento STPS</h3>
          <p class="certification-text">Personal dado de alta ante IMSS y cumplimiento normativo laboral</p>
        </div>
        <div class="certification-item">
          <div class="certification-icon"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg></div>
          <h3 class="certification-title">Central de Monitoreo 24/7</h3>
          <p class="certification-text">Supervisión en tiempo real con tecnología GPS para cada guardia</p>
        </div>
        <div class="certification-item">
          <div class="certification-icon"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg></div>
          <h3 class="certification-title">Personal Verificado</h3>
          <p class="certification-text">Exámenes psicométricos, antidoping y verificación exhaustiva de antecedentes</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="services-section" id="servicios">
    <div class="container">
      <h2 class="section-title">Nuestros Servicios</h2>
      <p class="section-subtitle">Personal profesional de primera calidad para proteger lo que más valoras</p>

      <div class="service-category">
        <div class="service-category__inner">
          <h3 class="category-title">Guardias de Seguridad y Vigilancia Profesional</h3>
          <p class="category-description">Duerme tranquilo sabiendo que profesionales certificados vigilan tu hogar o empresa las 24 horas. Protegemos lo que más valoras mientras tú te enfocas en lo importante: tu familia y tu negocio.</p>
          <div class="service-items-grid">
            <ServiceCard href="/servicios/guardias-de-seguridad-y-vigilancia" imgSrc="/img/img-index/guardias-de-seguridad.avif" imgAlt="Tres guardias de seguridad privada permanecen alerta en el exterior de un edificio por la noche" title="Guardias de Seguridad" />
            <ServiceCard href="/servicios/guardias-intramuros" imgSrc="/img/img-index/guardias-intramuros.avif" imgAlt="Tres guardias de seguridad privada de uniforme en un mostrador de recepción" title="Guardias Intramuros" />
            <ServiceCard href="/servicios/control-de-accesos" imgSrc="/img/img-index/control-de-accesos.avif" imgAlt="Agentes de seguridad privada junto a un coche de policía por la noche" title="Control de Accesos" />
            <ServiceCard href="/servicios/patrullaje" imgSrc="/img/img-index/patrullaje.avif" imgAlt="Dos guardias de seguridad privada en un centro comercial" title="Patrullaje" />
            <ServiceCard href="/servicios/prevencion-de-perdidas" imgSrc="/img/img-index/prevencion-de-perdidas.avif" imgAlt="Prevención de Pérdidas - Guardias de seguridad privada en establecimiento comercial" title="Prevención de Pérdidas" />
          </div>
          <div class="category-footer">
            <h4 class="category-footer__title">La Tranquilidad de Saber que Estás en Manos Expertas</h4>
            <div class="category-footer__grid">
              <p class="category-footer__text">¿Te preocupa dejar tu negocio por la noche? ¿Quieres que tu familia se sienta segura en casa? Nuestros <strong>guardias certificados SSC</strong> no solo vigilan: son profesionales confiables que pasan por <strong>exámenes psicométricos, verificación de antecedentes</strong> y evaluaciones de integridad para que solo personas honestas y capacitadas cuiden tu patrimonio.</p>
              <p class="category-footer__text">Con <strong>vigilancia 24/7</strong>, nunca estarás solo ante una emergencia. Ya sea protegiendo tu hogar mientras estás de vacaciones, cuidando tu negocio durante la madrugada o controlando accesos en tu condominio, nuestro equipo está ahí para prevenir riesgos antes de que se conviertan en problemas. <strong>Más de 15 años protegiendo familias y empresas</strong> nos respaldan.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="service-category">
        <div class="service-category__inner">
          <h3 class="category-title">Seguridad Especializada por Sector Industrial</h3>
          <p class="category-description">Cada industria tiene riesgos únicos que te quitan el sueño. Entendemos tus preocupaciones específicas y diseñamos soluciones que te permiten concentrarte en hacer crecer tu negocio sin la ansiedad constante por la seguridad.</p>
          <div class="service-items-grid">
            <ServiceCard href="/servicios/seguridad-especializada" imgSrc="/img/img-index/seguridad-especializada.avif" imgAlt="Seguridad Especializada por Sector - Soluciones personalizadas CDMX" title="Seguridad Especializada" />
            <ServiceCard href="/servicios/seguridad-condominios" imgSrc="/img/img-index/seguridad-para-condominios.avif" imgAlt="Seguridad para Condominios - Protección residencial CDMX" title="Seguridad para Condominios" />
            <ServiceCard href="/servicios/seguridad-construccion" imgSrc="/img/img-index/seguridad-para-construccion.avif" imgAlt="Seguridad para Construcción - Vigilancia obras Estado de México" title="Seguridad para Construcción" />
            <ServiceCard href="/servicios/seguridad-eventos" imgSrc="/img/img-index/seguridad-para-eventos.avif" imgAlt="Seguridad para Eventos - Protección eventos CDMX" title="Seguridad para Eventos" />
            <ServiceCard href="/servicios/seguridad-hospitalaria" imgSrc="/img/img-index/seguridad-hospitalaria.avif" imgAlt="Seguridad Hospitalaria - Protección centros médicos" title="Seguridad Hospitalaria" />
          </div>
          <div class="category-footer">
            <h4 class="category-footer__title">Protección que Entiende Tu Industria y Tus Preocupaciones</h4>
            <div class="category-footer__grid">
              <p class="category-footer__text">¿Vives en un condominio y te preocupa la seguridad de tus hijos? Nuestra <strong>seguridad para condominios</strong> crea ese ambiente de tranquilidad donde tus vecinos se saludan sin miedo y los niños juegan protegidos. ¿Tienes una obra en construcción y despertaste preocupado por el robo de materiales? Nuestros <strong>guardias especializados en construcción</strong> protegen tu inversión día y noche.</p>
              <p class="category-footer__text">¿Organizas un evento y temes que un incidente arruine años de reputación? Con nuestra <strong>seguridad para eventos</strong>, tus invitados disfrutan mientras nosotros nos preocupamos por su seguridad. ¿Administras un hospital donde cada segundo cuenta? Nuestra <strong>seguridad hospitalaria</strong> maneja situaciones delicadas con empatía, protegiendo a pacientes vulnerables y personal médico.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="service-category">
        <div class="service-category__inner">
          <h3 class="category-title">Tecnología y Monitoreo de Seguridad 24/7</h3>
          <p class="category-description">Nunca te sientas solo ante una emergencia. Estamos contigo 24/7 monitoreando cada rincón de tu propiedad, listos para actuar en segundos cuando algo anormal ocurre.</p>
          <div class="service-items-grid">
            <ServiceCard href="/servicios/tecnologia-monitoreo-seguridad" imgSrc="/img/img-index/monitoreo-camaras.avif" imgAlt="Tecnología y Monitoreo - Soluciones 24/7 CDMX" title="Tecnología y Monitoreo" />
            <ServiceCard href="/servicios/vigilancia-remota-cctv" imgSrc="/img/img-index/vigilancia-remota-y-cctv.avif" imgAlt="Vigilancia Remota y CCTV - Monitoreo 24/7 CDMX" title="Vigilancia Remota y CCTV" />
