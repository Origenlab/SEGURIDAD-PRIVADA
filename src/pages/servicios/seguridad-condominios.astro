---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import GallerySection from '../../components/GallerySection.astro';

const title = 'Seguridad para Condominios CDMX | Guardias 24/7';
const description = 'Seguridad privada para condominios en CDMX. Guardias intramuros certificados SSC, control de accesos 24/7. ☎ 55 3025 5580';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Seguridad para Condominios",
  "description": "Seguridad privada para condominios en CDMX. Guardias intramuros certificados SSC, control de accesos 24/7. ☎ 55 3025 5580",
  "provider": {
    "@type": "Organization",
    "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "url": "https://seguridad-privada.com.mx/"
  },
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "telephone": "+52-55-3025-5580"
});

const gallery = [
  { src: '/img/img-condominios/guardia-certificado-ssc-condominio-premium.avif', alt: 'Guardia certificado SSC para condominios de lujo y alto valor', captionTitle: 'Personal Certificado SSC Premium', captionText: 'Guardias de élite especializados en protección de condominios de alto valor' },
  { src: '/img/img-condominios/control-accesos-biometrico-residencial-lujo.avif', alt: 'Control de accesos biométrico para condominios premium CDMX', captionTitle: 'Control de Accesos Biométrico', captionText: 'Tecnología de reconocimiento facial y huella dactilar para máxima seguridad' },
  { src: '/img/img-condominios/vigilancia-cctv-inteligente-condominios.avif', alt: 'Sistema CCTV inteligente para vigilancia de condominios de lujo', captionTitle: 'Vigilancia CCTV con IA', captionText: 'Cámaras 4K con analítica de video y reconocimiento automático de amenazas' },
  { src: '/img/img-condominios/patrullaje-seguridad-condominios-alto-valor.avif', alt: 'Patrullaje de seguridad en condominios residenciales premium', captionTitle: 'Patrullaje Perimetral 24/7', captionText: 'Rondines estratégicos con registro GPS y supervisión constante' },
  { src: '/img/img-condominios/monitoreo-alarmas-residencial-premium-cdmx.avif', alt: 'Centro de monitoreo de alarmas para condominios de alto valor', captionTitle: 'Monitoreo de Alarmas Premium', captionText: 'Centro de control certificado con respuesta inmediata ante emergencias' },
  { src: '/img/img-condominios/proteccion-ejecutiva-residentes-vip.avif', alt: 'Protección ejecutiva para residentes de condominios de lujo', captionTitle: 'Protección Ejecutiva Discreta', captionText: 'Escoltas profesionales para residentes de alto perfil y familias VIP' },
  { src: '/img/img-condominios/guardias-intramuros-elite-condominios.avif', alt: 'Guardias intramuros especializados en condominios premium', captionTitle: 'Guardias Intramuros de Élite', captionText: 'Personal con protocolo de atención premium para residenciales de lujo' },
  { src: '/img/img-condominios/reconocimiento-facial-control-accesos.avif', alt: 'Sistema de reconocimiento facial para control de accesos residencial', captionTitle: 'Reconocimiento Facial Avanzado', captionText: 'Identificación automática de residentes y alertas de personas no autorizadas' },
  { src: '/img/img-condominios/tecnologia-seguridad-integral-condominios.avif', alt: 'Tecnología de seguridad integral para condominios de alto valor', captionTitle: 'Tecnología de Seguridad Integral', captionText: 'Sistemas integrados de última generación para protección total del complejo' },
];
---
<BaseLayout title={title} description={description} schema={schema}>
  <Hero
    title="Seguridad para Condominios en CDMX"
    subtitle="Guardias Profesionales Certificados SSC que Conocen a Cada Residente — Tranquilidad Familiar Garantizada"
    description='Seguridad privada especializada para condominios y residenciales. +15 años creando ambientes seguros donde las familias viven en paz.'
    card1Title="Protección real para tu comunidad residencial"
    card1Text='En condominios y fraccionamientos residenciales de CDMX, la diferencia entre vivir con tranquilidad o paranoia está en tener guardias que realmente protejan tu comunidad. ¿Te preocupa que extraños merodeen sin verificar mientras tus hijos juegan en las áreas comunes? Nuestros elementos conocen a cada residente por nombre y aplican protocolos de verificación rigurosos pero corteses.'
    card2Title="Seguridad que refleja un condominio premium"
    card2Text='En ORIGINS PRIVATE SECURITY, con más de 15 años creando ambientes seguros donde las familias viven en paz, nuestra filosofía es Seguridad, Prevención, Confianza. Ofrecemos control de visitantes riguroso, guardias certificados SSC y el profesionalismo que refleja un condominio premium. Porque tu inversión en mantenimientos merece seguridad de verdad.'
  />

  {gallery.length > 0 && <GallerySection items={gallery} />}

  <section class="attention-box" style="max-width:1200px;margin:40px auto;padding:48px">
    <h2 class="attention-box__title">Por Qué la Seguridad de Tu Condominio Determina Tu Tranquilidad Familiar</h2>
    <p class="attention-box__text">En condominios residenciales, la diferencia entre vivir tranquilo o con paranoia constante está en tener guardias profesionales que realmente protejan a tu comunidad. No basta con tener alguien en la caseta: necesitas personal certificado SSC que conozca a cada familia, verifique visitantes rigurosamente y cree el ambiente donde tus hijos pueden jugar sin miedo.</p>
    <p class="attention-box__text">En ORIGINS, entendemos que la seguridad de tu familia no es negociable. Por eso cada guardia pasa por verificación exhaustiva de antecedentes, exámenes psicométricos y capacitación en atención residencial. Más de 15 años protegiendo condominios en Bosques de las Lomas, Lomas de Chapultepec, Santa Fe e Interlomas nos respaldan.</p>
  </section>

  <section class="cta-business">
    <div class="cta-business__content">
      <h2 class="cta-business__title">¿Necesita Proteger su Empresa o Condominio?</h2>
      <p class="cta-business__description">Únase a las empresas líderes y condominios de prestigio que confían en nuestra experiencia</p>
      <div class="cta-business__actions">
        <a href="https://wa.me/525530255580?text=Hola,%20necesito%20información%20sobre%20servicios%20de%20seguridad%20privada" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/cotizar" class="cta-business__btn cta-business__btn--secondary">Cotizar en Línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
