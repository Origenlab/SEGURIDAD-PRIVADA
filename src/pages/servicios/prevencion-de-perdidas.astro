---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import GallerySection from '../../components/GallerySection.astro';

const title = 'Prevención de Pérdidas para Empresas CDMX | Seguridad Privada Retail';
const description = 'Prevención de pérdidas para retail y empresas en CDMX. Personal certificado SSC, control de mermas. Reduce pérdidas 70%. ☎ 55 3025 5580';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Prevención de Pérdidas",
  "description": "Prevención de pérdidas para retail y empresas en CDMX. Personal certificado SSC, control de mermas. Reduce pérdidas 70%. ☎ 55 3025 5580",
  "provider": {
    "@type": "Organization",
    "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "url": "https://seguridad-privada.com.mx/"
  },
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "telephone": "+52-55-3025-5580"
});

const gallery = [
  { src: '/img/prevencion-de-perdidas/arcos-de-seguridad.avif', alt: 'Personal civil encubierto detectando robo hormiga en tienda retail CDMX', captionTitle: 'Personal Civil Encubierto', captionText: 'Detección discreta de robo interno' },
  { src: '/img/prevencion-de-perdidas/auditoria-de-seguridad.avif', alt: 'Supervisión de cajas registradoras para prevenir fraudes en retail', captionTitle: 'Supervisión de Cajas', captionText: 'Control de fraudes en puntos de venta' },
  { src: '/img/prevencion-de-perdidas/control-de-accesos.avif', alt: 'Control de inventarios y prevención de mermas en almacén', captionTitle: 'Control de Inventarios', captionText: 'Verificación de faltantes y mermas' },
  { src: '/img/prevencion-de-perdidas/control-de-inventarios.avif', alt: 'Monitoreo de probadores en tiendas departamentales', captionTitle: 'Áreas de Alto Riesgo', captionText: 'Vigilancia de probadores y zonas críticas' },
  { src: '/img/prevencion-de-perdidas/control-de-salidas.avif', alt: 'Verificación de entregas de proveedores para prevenir faltantes', captionTitle: 'Control de Proveedores', captionText: 'Verificación de entregas y facturación' },
  { src: '/img/prevencion-de-perdidas/custodia-de-mercancia.avif', alt: 'Personal de prevención en tienda boutique detectando robo', captionTitle: 'Tiendas Boutique', captionText: 'Protección discreta de mercancía premium' },
  { src: '/img/prevencion-de-perdidas/deteccion-de-fraudes.avif', alt: 'Análisis de reportes de pérdidas en centro comercial', captionTitle: 'Reportes de Análisis', captionText: 'Documentación detallada de incidentes' },
  { src: '/img/prevencion-de-perdidas/guardias-de-seguridad.avif', alt: 'Personal encubierto en supermercado detectando robo externo', captionTitle: 'Supermercados', captionText: 'Control de robo externo y hormiga' },
  { src: '/img/prevencion-de-perdidas/investigacion-de-perdidas.avif', alt: 'Farmacia con personal de prevención certificado SSC', captionTitle: 'Farmacias', captionText: 'Protección de medicamentos controlados' },
];
---
<BaseLayout title={title} description={description} schema={schema}>
  <Hero
    title="Prevención de Pérdidas en CDMX"
    subtitle="Control de Mermas, Robo Hormiga y Pérdidas Operativas — Reduce Tus Pérdidas Hasta 70%"
    description='Personal civil encubierto certificado SSC para retail. Detecta robo interno, externo y fraudes antes de que destruyan tus márgenes.'
    card1Title="Identifica exactamente dónde pierdes dinero"
    card1Text='La diferencia entre una tienda rentable y una que pierde dinero silenciosamente está en el control de mermas. Cada producto que desaparece sin registro, cada empleado que toma mercancía sin pagarla, cada proveedor que entrega menos de lo facturado destruye tus márgenes. La prevención de pérdidas no es vigilancia: es investigación profesional que identifica exactamente dónde pierdes y quién te está robando.'
    card2Title="El robo hormiga representa el 70% de pérdidas"
    card2Text='En ORIGINS, entendemos que el robo hormiga por empleados representa el 70% de las pérdidas en retail. Nuestro servicio de prevención de pérdidas con personal civil encubierto certificado SSC está diseñado para detectar robo interno, robo externo, fraudes en cajas, faltantes de inventario y colusiones con proveedores. Protegemos tu utilidad.'
  />

  {gallery.length > 0 && <GallerySection items={gallery} />}

  <section class="attention-box" style="max-width:1200px;margin:40px auto;padding:48px">
    <h2 class="attention-box__title">Por Qué la Prevención de Pérdidas de ORIGINS Reduce Mermas Hasta 70%</h2>
    <p class="attention-box__text">La diferencia entre una tienda rentable y una que pierde dinero silenciosamente está en detectar exactamente dónde desaparecen tus productos. Las mermas no son accidentales: son empleados tomando mercancía sin pagar, clientes robando sin que nadie los detenga, proveedores facturando más de lo entregado y cajas registrando menos de lo vendido. La prevención de pérdidas no es vigilancia: es investigación profesional que identifica culpables con evidencia legal.</p>
    <p class="attention-box__text">En ORIGINS, entendemos que cada producto robado destruye tus márgenes y cada empleado ladrón contamina a otros. Nuestro servicio de prevención de pérdidas con personal civil encubierto certificado SSC está diseñado para detectar robo hormiga, fraudes en cajas, faltantes de inventario y coluisiones con proveedores antes de que destruyan tu rentabilidad.</p>
  </section>

  <section class="cta-business">
    <div class="cta-business__content">
      <h2 class="cta-business__title">¿Necesita Proteger su Empresa o Condominio?</h2>
      <p class="cta-business__description">Únase a las empresas líderes y condominios de prestigio que confían en nuestra experiencia</p>
      <div class="cta-business__actions">
        <a href="https://wa.me/525530255580?text=Hola,%20necesito%20información%20sobre%20servicios%20de%20seguridad%20privada" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/cotizar" class="cta-business__btn cta-business__btn--secondary">Cotizar en Línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
