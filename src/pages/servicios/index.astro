---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import HeroPagina from '../../components/HeroPagina.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import CategoriaCard from '../../components/CategoriaCard.astro';
import NavCTA from '../../components/NavCTA.astro';
import ServicioCatalogCard from '../../components/ServicioCatalogCard.astro';
import FAQItem from '../../components/FAQItem.astro';
import { serviciosFaqs } from '../../data/servicios-faqs';
import '../../styles/sections/servicios-cats.css';
import '../../styles/sections/nav-cta.css';
import '../../styles/sections/faq-cotizacion.css';
import '../../styles/pages/servicios.css';

const servicios = await getCollection('servicios', ({ data }) => !data.draft);
const siteUrl = 'https://seguridad-privada.com.mx';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ItemList",
      "name": "Servicios de Seguridad Privada — ORIGINS Private Security",
      "description": "Guardias intramuros, seguridad para condominios, control de accesos, monitoreo CCTV y consultoría. Permiso SSC 0102-15.",
      "url": `${siteUrl}/servicios`,
      "numberOfItems": servicios.length,
      "itemListElement": servicios.map((s, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": s.data.title.split('|')[0].trim(),
        "url": `${siteUrl}/servicios/${s.id}`
      }))
    },
    {
      "@type": "FAQPage",
      "mainEntity": serviciosFaqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer.replace(/<[^>]*>/g, '')
        }
      }))
    }
  ]
};
---

<Base
  title="Servicios de Seguridad Privada CDMX · Permiso SSC | ORIGINS"
  description="Guardias intramuros, seguridad para condominios, residenciales y tecnología de monitoreo en CDMX. Permiso SSC 0102-15. Cotización gratis."
  canonical={`${siteUrl}/servicios`}
  schema={schema}
>

  <HeroPagina
    badge="Servicios de Seguridad"
    titulo="Servicios de Seguridad Privada para Condominios en CDMX"
    descripcion="Guardias intramuros certificados SSC, control de accesos, monitoreo CCTV, patrullaje y consultoría de seguridad para condominios, residenciales y empresas en la Zona Metropolitana."
    breadcrumb={[{ label: 'Servicios', href: '/servicios' }]}
    ctaPrimario={{ texto: 'Solicitar Cotización', href: '/contacto' }}
    ctaWhatsapp={true}
    seoParrafo1='En <strong>ORIGINS Private Security</strong> nos especializamos exclusivamente en comunidades residenciales. Nuestros <a href="/servicios/guardias-intramuros">guardias intramuros</a> conocen a cada residente, gestionan accesos con registro digital y coordinan directamente con la administración del <a href="/servicios/seguridad-condominios">condominio</a>. Más de 15 años protegiendo desarrollos residenciales en CDMX con Permiso SSC 0102-15 vigente.'
    seoParrafo2='Desde <a href="/servicios/vigilancia-remota-cctv">vigilancia remota CCTV</a> hasta <a href="/servicios/consultoria-seguridad">consultoría de seguridad</a>, cada servicio está diseñado para la convivencia en comunidad. Supervisión semanal documentada, guardias con certificación vigente y proceso transparente desde el primer día. Más de 50 desarrollos en CDMX y <a href="/zonas">Zona Metropolitana</a> confían en ORIGINS.'
  />

  <!-- NAV CTA — Misma estructura y diseño que el index -->
  <section class="nav-cta" aria-label="Accesos rápidos a servicios">
    <div class="container">
      <div class="nav-cta__grid">

        <a href="#seguridad-residencial" class="nav-cta__card nav-cta__card--1">
          <div class="nav-cta__card-inner">
            <span class="nav-cta__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </span>
            <div class="nav-cta__text">
              <strong>Seguridad Residencial</strong>
              <span>Guardias, accesos y patrullaje</span>
            </div>
            <svg class="nav-cta__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
        </a>

        <a href="#tecnologia-monitoreo" class="nav-cta__card nav-cta__card--2">
          <div class="nav-cta__card-inner">
            <span class="nav-cta__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </span>
            <div class="nav-cta__text">
              <strong>Tecnología y Monitoreo</strong>
              <span>CCTV, alarmas y GPS satelital</span>
            </div>
            <svg class="nav-cta__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
        </a>

        <a href="#proteccion-consultoria" class="nav-cta__card nav-cta__card--3">
          <div class="nav-cta__card-inner">
            <span class="nav-cta__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4l2 2"/></svg>
            </span>
            <div class="nav-cta__text">
              <strong>Protección y Consultoría</strong>
              <span>Ejecutivos, valores y análisis</span>
            </div>
            <svg class="nav-cta__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
        </a>

        <a href="https://wa.me/525530255580?text=Hola%2C%20me%20interesa%20cotizar%20seguridad%20para%20mi%20condominio" class="nav-cta__card nav-cta__card--4 nav-cta__card--accent" target="_blank" rel="noopener">
          <div class="nav-cta__card-inner">
            <span class="nav-cta__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </span>
            <div class="nav-cta__text">
              <strong>Cotización Gratuita</strong>
              <span>Respuesta en menos de 2 horas</span>
            </div>
            <svg class="nav-cta__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- 3 categorías principales -->
  <section class="servicios-cats" id="servicios" aria-labelledby="servicios-cats-title">
    <div class="container">

      <SectionHeader
        badge="Nuestros Servicios"
        titulo="Especialistas en Seguridad para Condominios"
        subtitulo="Soluciones de seguridad intramuros diseñadas específicamente para comunidades residenciales en CDMX"
        parrafo1='En <a href="/nosotros"><strong>ORIGINS Private Security</strong></a> nos especializamos exclusivamente en comunidades residenciales. Nuestros guardias conocen a cada residente, gestionan accesos con registro digital y coordinan directamente con la administración del condominio.'
        parrafo2='Más de 50 desarrollos en CDMX y <a href="/zonas">Zona Metropolitana</a> confían en nosotros porque ofrecemos lo que las empresas generalistas no pueden: protocolos diseñados para la convivencia en comunidad, supervisión semanal documentada y guardias intramuros con certificación SSC vigente.'
        align="left"
      />

      <div class="servicios-cats__grid">

        <!-- CATEGORÍA 1: Seguridad Residencial -->
        <CategoriaCard
          id="seguridad-residencial"
          acento="residencial"
          etiqueta="Seguridad Residencial"
          titulo="Guardias y Control de Accesos"
          descripcion="Protección permanente para condominios, fraccionamientos y residenciales. Guardias intramuros certificados SSC que conocen a cada residente y coordinan directamente con la administración."
          imagenHero="/img/img-index/guardias-intramuros.avif"
          imagenHeroAlt="Guardias intramuros para condominios en CDMX"
          href="/servicios/seguridad-condominios"
          ctaTexto="Ver Seguridad Residencial"
          subServicios={[
            {
              slug: 'guardias-intramuros',
              titulo: 'Guardias Intramuros',
              descripcionCorta: 'Vigilancia 24/7 certificada SSC',
              imagen: '/img/img-index/guardia-lobby.avif',
              imagenAlt: 'Guardia intramuros en lobby de condominio'
            },
            {
              slug: 'seguridad-condominios',
              titulo: 'Seguridad Condominios',
              descripcionCorta: 'Lobby, áreas comunes y CCTV',
              imagen: '/img/img-index/seguridad-para-condominios.avif',
              imagenAlt: 'Seguridad para condominios verticales CDMX'
            },
            {
              slug: 'seguridad-residenciales',
              titulo: 'Seguridad Residenciales',
              descripcionCorta: 'Casetas, patrullaje y control vehicular',
              imagen: '/img/img-index/patrullaje.avif',
              imagenAlt: 'Seguridad para fraccionamientos privados'
            },
            {
              slug: 'control-de-accesos',
              titulo: 'Control de Accesos',
              descripcionCorta: 'Registro digital peatonal y vehicular',
              imagen: '/img/img-index/control-de-accesos.avif',
              imagenAlt: 'Control de accesos para condominios CDMX'
            }
          ]}
        />

        <!-- CATEGORÍA 2: Tecnología y Monitoreo -->
        <CategoriaCard
          id="tecnologia-monitoreo"
          acento="tecnologia"
          etiqueta="Tecnología y Monitoreo"
          titulo="Vigilancia y Monitoreo 24/7"
          descripcion="Soluciones tecnológicas para reforzar la seguridad de tu propiedad: monitoreo CCTV en tiempo real, alarmas certificadas, rastreo GPS y vigilancia remota desde nuestra central de monitoreo."
          imagenHero="/img/img-index/monitoreo-camaras.avif"
          imagenHeroAlt="Central de monitoreo de seguridad CCTV CDMX"
          href="/servicios/tecnologia-monitoreo-seguridad"
          ctaTexto="Ver Tecnología y Monitoreo"
          subServicios={[
            {
              slug: 'tecnologia-monitoreo-seguridad',
              titulo: 'Tecnología de Seguridad',
              descripcionCorta: 'CCTV, alarmas y sistemas integrados',
              imagen: '/img/img-index/tecnologia-monitoreo.avif',
              imagenAlt: 'Tecnología de monitoreo de seguridad'
            },
            {
              slug: 'vigilancia-remota-cctv',
              titulo: 'Vigilancia Remota CCTV',
              descripcionCorta: 'Monitoreo en tiempo real 24/7',
              imagen: '/img/img-index/vigilancia-remota-y-cctv.avif',
              imagenAlt: 'Vigilancia remota CCTV para condominios'
            },
            {
              slug: 'monitoreo-alarmas',
              titulo: 'Monitoreo de Alarmas',
              descripcionCorta: 'Central certificada UL operativa 24/7',
              imagen: '/img/img-index/monitoreo-de-alarmas.avif',
              imagenAlt: 'Monitoreo de alarmas 24/7 CDMX'
            },
            {
              slug: 'seguridad-gps-satelital',
              titulo: 'Rastreo GPS Satelital',
              descripcionCorta: 'Telemetría vehicular en tiempo real',
              imagen: '/img/img-index/seguridad-satelital-gps.avif',
              imagenAlt: 'Rastreo GPS satelital para flotas CDMX'
            }
          ]}
        />

        <!-- CATEGORÍA 3: Protección y Consultoría -->
        <CategoriaCard
          id="proteccion-consultoria"
          acento="proteccion"
          etiqueta="Protección y Consultoría"
          titulo="Seguridad Especializada"
          descripcion="Servicios de alto valor para empresas y ejecutivos: protección personal, custodia de valores, consultoría estratégica y análisis de vulnerabilidades con metodología internacional."
          imagenHero="/img/img-index/proteccion-ejecutiva.avif"
          imagenHeroAlt="Protección ejecutiva y consultoría de seguridad CDMX"
          href="/servicios/servicios-de-proteccion-ejecutiva-y-consultoria"
          ctaTexto="Ver Protección y Consultoría"
          subServicios={[
            {
              slug: 'proteccion-ejecutiva',
              titulo: 'Protección Ejecutiva',
              descripcionCorta: 'Escoltas certificados SSC',
              imagen: '/img/img-index/proteccion-ejecutiva-consultoria.avif',
              imagenAlt: 'Protección ejecutiva en CDMX'
            },
            {
              slug: 'custodia-de-mercancias',
              titulo: 'Custodia de Valores',
              descripcionCorta: 'Traslado blindado con póliza',
              imagen: '/img/img-index/custodia-de-mercancias.avif',
              imagenAlt: 'Custodia de efectivo y mercancías CDMX'
            },
            {
              slug: 'consultoria-seguridad',
              titulo: 'Consultoría de Seguridad',
              descripcionCorta: 'Auditorías y diseño de protocolos',
              imagen: '/img/img-index/consultoria-de-seguridad.avif',
              imagenAlt: 'Consultoría de seguridad privada CDMX'
            },
            {
              slug: 'consultoria-analisis-riesgos',
              titulo: 'Análisis de Riesgos',
              descripcionCorta: 'Metodología ISO 31000',
              imagen: '/img/img-index/analisis-de-riesgos.avif',
              imagenAlt: 'Análisis de riesgos de seguridad CDMX'
            }
          ]}
        />

      </div>

    </div>
  </section>

  <!-- Catálogo completo de servicios — módulos 2 columnas -->
  <section class="todos-servicios" aria-labelledby="todos-servicios-title">
    <div class="container">

      <SectionHeader
        badge="Catálogo Completo"
        titulo="Todos Nuestros Servicios de Seguridad Privada en CDMX"
        subtitulo="Guardias intramuros, control de accesos, monitoreo CCTV, patrullaje, protección ejecutiva y consultoría. Permiso SSC 0102-15 vigente."
        parrafo1='Desde <a href="/servicios/guardias-intramuros"><strong>guardias intramuros certificados SSC</strong></a> hasta <a href="/servicios/consultoria-analisis-riesgos">análisis de riesgos con metodología ISO 31000</a>, ORIGINS cuenta con el catálogo más completo de seguridad privada para condominios y empresas en la Zona Metropolitana. Cada servicio está diseñado para operar de forma autónoma o integrada — el mismo proveedor, la misma supervisión, una sola factura.'
        parrafo2='Más de 15 años protegiendo más de 50 desarrollos residenciales y corporativos en CDMX nos dan la experiencia que las empresas generalistas no tienen. Sin subcontrataciones, sin rotación arbitraria de guardias, con supervisión semanal presencial documentada. Selecciona el servicio que necesitas o solicita un <a href="#cotizacion"><strong>diagnóstico de seguridad gratuito</strong></a> — respondemos en menos de 24 horas.'
        align="left"
      />

      <div class="todos-servicios__lista">

        <ServicioCatalogCard
          slug="guardias-intramuros"
          etiqueta="Seguridad Residencial"
          titulo="Guardias Intramuros CDMX — Vigilancia 24/7 Certificada SSC"
          descripcion="Nuestros guardias intramuros son la primera línea de defensa de tu condominio: presentes en lobby, áreas comunes y accesos vehiculares las 24 horas del día, los 365 días del año. Cada elemento pasa por verificación de antecedentes penales, exámenes psicométricos y capacitación específica para entornos residenciales antes de ser asignado. No son guardias genéricos — conocen a cada residente, aprenden los protocolos del edificio y coordinan directamente con la administración."
          parrafo2="Con más de 15 años especializados exclusivamente en comunidades residenciales, nuestros guardias intramuros reducen incidentes hasta en un 85% en los primeros tres meses. Entregamos bitácoras digitales diarias, reportes fotográficos semanales y supervisión presencial documentada. Operamos con Permiso SSC 0102-15 vigente, póliza de responsabilidad civil y cumplimiento total de obligaciones laborales. Cotización personalizada en menos de 24 horas."
          imagen="/img/img-guardias-intramuros/elementos-de-seguridad-intramuros.avif"
          imagenAlt="Guardias intramuros certificados SSC en condominio CDMX"
          badges={["Certificación SSC vigente", "Disponibilidad 24/7", "Bitácoras digitales", "Supervisión semanal"]}
          reverse={false}
        />

        <ServicioCatalogCard
          slug="seguridad-condominios"
          etiqueta="Seguridad Residencial"
          titulo="Seguridad para Condominios CDMX — Protección Integral Residencial"
          descripcion="La seguridad de un condominio va más allá de colocar un guardia en la puerta. En ORIGINS diseñamos un esquema de protección integral que abarca control de accesos peatonal y vehicular, monitoreo de áreas comunes, protocolos de respuesta ante emergencias y coordinación con la administración del edificio. Nuestros elementos conocen el edificio, a los residentes y los horarios de operación — eso hace la diferencia real."
          parrafo2="Más de 50 condominios verticales y horizontales en CDMX confían en ORIGINS porque ofrecemos lo que las empresas generalistas no pueden: protocolos diseñados para la convivencia en comunidad. El guardia de tu condominio debe ser discreto, profesional y confiable. Alta al IMSS desde el primer día, uniformes estándar y reportes mensuales entregados a la administración. Diagnóstico gratuito de seguridad sin compromiso."
          imagen="/img/img-condominios/control-accesos-biometrico-residencial-lujo.avif"
          imagenAlt="Seguridad integral para condominios verticales en CDMX"
          badges={["Protocolos residenciales", "+50 condominios", "Coordinación con administración", "Póliza RC incluida"]}
          reverse={false}
        />

        <ServicioCatalogCard
          slug="control-de-accesos"
          etiqueta="Seguridad Residencial"
          titulo="Control de Accesos para Condominios y Empresas CDMX"
          descripcion="Un sistema de control de accesos bien implementado es el activo de seguridad más rentable de cualquier propiedad. Nuestros guardias certificados gestionan el registro digital de visitantes, proveedores, empleados y vehículos con bitácoras en tiempo real accesibles desde cualquier dispositivo. Identificamos a cada persona que entra y sale, verificamos identidades y alertamos ante accesos no autorizados de manera inmediata."
          parrafo2="Implementamos sistemas de control de accesos adaptados a cada tipo de propiedad: desde intercomunicadores y lectores de tarjeta hasta reconocimiento facial y control vehicular con plumas automáticas. Todo integrado con nuestra central de monitoreo para respuesta coordinada 24/7. El control de accesos de ORIGINS no es solo hardware — es el guardia capacitado que sabe cómo operar cada tecnología y qué hacer cuando algo falla."
          imagen="/img/control-de-accesos/control-vehicular-para-condominios.avif"
          imagenAlt="Control de accesos vehicular y peatonal para condominios CDMX"
          badges={["Registro digital en tiempo real", "Control vehicular", "Integración CCTV", "Acceso remoto al historial"]}
          reverse={false}
        />

        <ServicioCatalogCard
          slug="seguridad-residenciales"
          etiqueta="Seguridad Residencial"
          titulo="Seguridad para Residenciales Privados y Fraccionamientos CDMX"
          descripcion="Los fraccionamientos y residenciales privados requieren un esquema de seguridad perimetral mucho más complejo que un condominio vertical: accesos vehiculares múltiples, casetas de vigilancia, patrullaje interno, iluminación estratégica y coordinación con la vialidad interna. En ORIGINS diseñamos el plan de seguridad para tu fraccionamiento desde cero, considerando la topografía, los puntos ciegos y los patrones de tráfico de tu comunidad."
          parrafo2="Nuestro servicio para residenciales privados incluye guardias intramuros en casetas, patrullaje vehicular interno programado, control de accesos con registro de placas, monitoreo CCTV en perímetro y protocolos de respuesta ante intrusiones. Supervisión semanal presencial documentada y reportes a la mesa directiva del fraccionamiento. Más de 15 años atendiendo desarrollos residenciales de todos los tamaños en CDMX y Zona Metropolitana."
          imagen="/img/img-condominios/seguridad-perimetral-condominios-premium.avif"
          imagenAlt="Seguridad perimetral para fraccionamientos y residenciales privados CDMX"
          badges={["Casetas de vigilancia", "Patrullaje interno", "Control de placas", "Monitoreo perimetral"]}
          reverse={false}
        />

        <ServicioCatalogCard
          slug="patrullaje"
          etiqueta="Seguridad Residencial"
          titulo="Patrullaje para Condominios y Fraccionamientos CDMX"
          descripcion="El patrullaje preventivo es la herramienta más efectiva para disuadir incidentes antes de que ocurran. Nuestras unidades de patrullaje realizan rondines programados y aleatorios con GPS de rastreo en tiempo real, cubriendo perímetros, estacionamientos, áreas comunes y zonas de baja visibilidad. Cada rondín queda registrado digitalmente con geolocalización, hora exacta y reporte fotográfico de puntos críticos."
          parrafo2="El patrullaje de ORIGINS no es una ronda con linterna — es un servicio profesional con unidades identificadas, guardias certificados SSC y protocolo de reporte inmediato ante cualquier anomalía. Disponible en modalidad motorizada, vehicular y a pie según las necesidades de tu desarrollo. Ideal para fraccionamientos grandes, residenciales con múltiples accesos o condominios con áreas exteriores extensas. Cotización sin compromiso."
          imagen="/img/patrullaje/patrullaje-de-seguridad-privada.avif"
          imagenAlt="Patrullaje preventivo para condominios y fraccionamientos CDMX"
          badges={["GPS en tiempo real", "Rondines documentados", "Modalidad motorizada o a pie", "Reportes fotográficos"]}
          reverse={false}
        />

        <ServicioCatalogCard
          slug="vigilancia-remota-cctv"
          etiqueta="Tecnología y Monitoreo"
          titulo="Vigilancia Remota CCTV — Monitoreo 24/7 en Tiempo Real"
