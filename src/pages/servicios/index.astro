---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const servicios = await getCollection('servicios', ({ data }) => !data.draft);
const pillarServices = servicios.filter(s => s.data.category === 'pillar');
const otherServices = servicios.filter(s => s.data.category !== 'pillar');

const siteUrl = 'https://seguridad-privada.com.mx';

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Servicios de Seguridad Privada",
  "description": "Servicios profesionales de seguridad privada para condominios, residenciales y empresas en CDMX",
  "itemListElement": servicios.map((servicio, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Service",
      "name": servicio.data.title.split('|')[0].trim(),
      "description": servicio.data.description,
      "url": `${siteUrl}/servicios/${servicio.id}`
    }
  }))
};
---

<Base
  title="Servicios de Seguridad Privada | ORIGINS Security CDMX"
  description="Servicios profesionales de seguridad privada: guardias intramuros, seguridad para condominios, residenciales y empresas. Cotización gratis en CDMX."
  canonical={`${siteUrl}/servicios`}
  schema={schema}
>
  <!-- Hero -->
  <section class="services-hero">
    <div class="container">
      <h1>Servicios de Seguridad Privada</h1>
      <p>Soluciones profesionales de vigilancia y protección para condominios, residenciales y empresas en CDMX</p>
    </div>
  </section>

  <!-- Pillar Services -->
  <section class="pillar-services">
    <div class="container">
      <h2>Servicios Principales</h2>
      <p class="section-subtitle">Nuestra especialización en seguridad residencial</p>

      <div class="pillar-grid">
        {pillarServices.map((servicio) => (
          <a href={`/servicios/${servicio.id}`} class="pillar-card">
            {servicio.data.heroImage && (
              <div class="pillar-card__image">
                <img src={servicio.data.heroImage.src} alt={servicio.data.heroImage.alt} loading="eager" />
              </div>
            )}
            <div class="pillar-card__content">
              <span class="pillar-card__badge">Servicio Principal</span>
              <h3>{servicio.data.title.split('|')[0].trim()}</h3>
              <p>{servicio.data.description}</p>
                            <span class="pillar-card__cta">Ver servicio →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="services-cta">
    <div class="container">
      <h2>¿No Sabes Qué Servicio Necesitas?</h2>
      <p>Nuestros expertos te asesorarán para encontrar la solución perfecta para tu propiedad</p>
      <div class="cta-buttons">
        <a href="/contacto" class="btn btn-primary">Solicitar Asesoría</a>
        <a href="https://wa.me/525530255580" class="btn btn-whatsapp">WhatsApp Directo</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .services-hero {
    padding: 3rem 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, #1a1a1a 100%);
    color: var(--color-white);
    text-align: center;
  }

  .services-hero h1 {
    color: var(--color-white);
    margin-bottom: 0.75rem;
  }

  .services-hero p {
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  .pillar-services {
    padding: 3rem 0;
  }

  .pillar-services h2 {
    text-align: center;
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .pillar-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    text-decoration: none;
    box-shadow: var(--shadow-md);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .pillar-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    opacity: 1;
  }

  .pillar-card__image {
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .pillar-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .pillar-card:hover .pillar-card__image img {
    transform: scale(1.03);
  }

  .pillar-card__content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pillar-card__badge {
    display: inline-block;
    width: fit-content;
    padding: 0.25rem 0.75rem;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 50px;
  }

  .pillar-card h3 {
    font-size: 1.25rem;
    color: var(--color-primary);
    margin: 0;
  }

  .pillar-card p {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin: 0;
  }

  .pillar-card__price {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-success);
  }

  .pillar-card__cta {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: auto;
  }

  .services-cta {
    padding: 4rem 0;
    background: var(--color-accent);
    text-align: center;
  }

  .services-cta h2 {
    margin-bottom: 0.75rem;
  }

  .services-cta p {
    color: var(--color-text-light);
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 640px) {
    .cta-buttons {
      flex-direction: row;
    }
  }

  @media (min-width: 768px) {
    .services-hero {
      padding: 4rem 0;
    }

    .pillar-services {
      padding: 4rem 0;
    }

    .pillar-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
