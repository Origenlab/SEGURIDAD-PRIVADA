---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import GallerySection from '../../components/GallerySection.astro';

const title = 'Tecnología de Seguridad Privada y Monitoreo 24/7 CDMX | CCTV y Alarmas';
const description = 'Tecnología de seguridad privada: monitoreo CCTV 24/7, alarmas y GPS satelital en CDMX. Central de monitoreo profesional para condominios y empresas. ☎ 55 3025 5580';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Tecnología y Monitoreo 24/7",
  "description": "Tecnología de seguridad privada: monitoreo CCTV 24/7, alarmas y GPS satelital en CDMX. Central de monitoreo profesional para condominios y empresas. ☎ 55 3025 5580",
  "provider": {
    "@type": "Organization",
    "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "url": "https://seguridad-privada.com.mx/"
  },
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "telephone": "+52-55-3025-5580"
});

const gallery: any[] = [];
---
<BaseLayout title={title} description={description} schema={schema}>
  <Hero
    title="Tecnología y Monitoreo 24/7"
    subtitle="Nunca Estás Solo — Ojos Expertos Cuidando tu Casa o Negocio Desde Cualquier Lugar"
    description='Central de monitoreo propia en CDMX. Alertas reales con foto o video, operadores certificados 24/7/365.'
    card1Title="Paz mental desde cualquier lugar del mundo"
    card1Text='¿Sales de vacaciones y no dejas de pensar si tu casa está bien? Nuestra central de monitoreo 24/7 te da algo invaluable: paz mental desde cualquier lugar. Operadores humanos certificados vigilan tus instalaciones en tiempo real, discriminan falsas alarmas y te contactan únicamente cuando realmente importa, con evidencia fotográfica clara.'
    card2Title="Ojos donde no puedes estar, sin complicaciones"
    card2Text='Desde tu celular recibes alertas reales con foto o video. Nuestro sistema combina cámaras de alta resolución, sensores inteligentes y GPS satelital, con personas capacitadas interpretando cada evento 24/7/365. Si detectan movimiento real, recibes notificación con imagen. Si es tu jardinero o mascota, no te molestan.'
  />

  {gallery.length > 0 && <GallerySection items={gallery} />}

  <section class="attention-box" style="max-width:1200px;margin:40px auto;padding:48px">
    <h2 class="attention-box__title">Tecnología de Seguridad Integrada para Empresas y Condominios</h2>
    <p class="attention-box__text">La tecnología de seguridad moderna va más allá de las cámaras y alarmas: es un ecosistema integrado de monitoreo CCTV, sistemas de alarma certificados UL y rastreo GPS satelital que trabajan en conjunto para proteger su patrimonio las 24 horas del día.</p>
    <p class="attention-box__text">En ORIGINS, operamos nuestra propia central de monitoreo en CDMX con operadores certificados que vigilan sus instalaciones en tiempo real. Alertas verificadas con evidencia fotográfica, discriminación inteligente de falsas alarmas y respuesta coordinada ante emergencias reales.</p>
  </section>

  <section class="cta-business">
    <div class="cta-business__content">
      <h2 class="cta-business__title">¿Necesita Proteger su Empresa o Condominio?</h2>
      <p class="cta-business__description">Únase a las empresas líderes y condominios de prestigio que confían en nuestra experiencia</p>
      <div class="cta-business__actions">
        <a href="https://wa.me/525530255580?text=Hola,%20necesito%20información%20sobre%20servicios%20de%20seguridad%20privada" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/cotizar" class="cta-business__btn cta-business__btn--secondary">Cotizar en Línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
