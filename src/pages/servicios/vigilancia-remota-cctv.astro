---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import GallerySection from '../../components/GallerySection.astro';

const title = 'Vigilancia Remota CCTV | Seguridad 24/7 CDMX';
const description = 'Vigilancia CCTV y seguridad privada para condominios, residenciales y empresas en CDMX. Monitoreo remoto 24/7, analítica inteligente. ☎ 55 3025 5580';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Vigilancia Remota CCTV",
  "description": "Vigilancia CCTV y seguridad privada para condominios, residenciales y empresas en CDMX. Monitoreo remoto 24/7, analítica inteligente. ☎ 55 3025 5580",
  "provider": {
    "@type": "Organization",
    "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "url": "https://seguridad-privada.com.mx/"
  },
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "telephone": "+52-55-3025-5580"
});

const gallery = [
  { src: '/img/img-vigilancia-remota/central-monitoreo-cctv-24-7.avif', alt: 'Central de monitoreo CCTV 24/7 con operadores certificados CDMX', captionTitle: 'Central de Monitoreo 24/7', captionText: 'Operadores certificados supervisando múltiples feeds en tiempo real' },
  { src: '/img/img-vigilancia-remota/camaras-ip-alta-resolucion-vigilancia.avif', alt: 'Cámaras IP alta resolución para vigilancia empresarial', captionTitle: 'Cámaras IP Alta Resolución', captionText: 'Imágenes ultra nítidas 4MP-8MP con visión nocturna avanzada' },
  { src: '/img/img-vigilancia-remota/videovigilancia-remota-tiempo-real.avif', alt: 'Videovigilancia remota en tiempo real desde cualquier dispositivo', captionTitle: 'Acceso Remoto en Vivo', captionText: 'Visualización en tiempo real desde celular, tablet o computadora' },
  { src: '/img/img-vigilancia-remota/analisis-video-inteligencia-artificial.avif', alt: 'Análisis de video con inteligencia artificial para detección de amenazas', captionTitle: 'Analítica de Video AI', captionText: 'Detección inteligente de intrusión y reconocimiento de patrones' },
  { src: '/img/img-vigilancia-remota/grabacion-evidencia-respaldo.avif', alt: 'Sistema de grabación y respaldo de evidencia para seguridad', captionTitle: 'Grabación con Respaldo', captionText: 'Almacenamiento seguro con retención 30-365 días según necesidad' },
  { src: '/img/img-vigilancia-remota/camaras-ptz-control-remoto.avif', alt: 'Cámaras PTZ con control remoto y zoom óptico profesional', captionTitle: 'Cámaras PTZ Profesionales', captionText: 'Control remoto con zoom óptico 30x y seguimiento automático' },
  { src: '/img/img-vigilancia-remota/dashboard-monitoreo-multiusuario.avif', alt: 'Dashboard ejecutivo de monitoreo con métricas y reportes', captionTitle: 'Dashboard Ejecutivo', captionText: 'Métricas en tiempo real y reportes analíticos personalizados' },
  { src: '/img/img-vigilancia-remota/notificaciones-push-alertas-tiempo-real.avif', alt: 'Notificaciones push de alertas en tiempo real a dispositivos móviles', captionTitle: 'Alertas Inteligentes', captionText: 'Notificaciones push instantáneas con evidencia fotográfica' },
  { src: '/img/img-vigilancia-remota/integracion-sistemas-alarma-cctv.avif', alt: 'Integración de sistemas de alarmas con CCTV y control de accesos', captionTitle: 'Integración de Sistemas', captionText: 'Interoperabilidad con alarmas, control de accesos y BMS' },
];
---
<BaseLayout title={title} description={description} schema={schema}>
  <Hero
    title="Vigilancia Remota CCTV en CDMX"
    subtitle="Videovigilancia CCTV de Nivel Corporativo — Analítica Inteligente y ROI Cuantificable"
    description='Video Management System empresarial con monitoreo 24/7. Cámaras IP de alta resolución, analítica de video y central de monitoreo certificada.'
    card1Title="Inteligencia operativa, no solo vigilancia"
    card1Text='Las empresas líderes en CDMX implementan sistemas de videovigilancia CCTV como herramienta estratégica de inteligencia operativa. Nuestro VMS empresarial integra cámaras IP de alta resolución (4MP-8MP), NVR con redundancia RAID, analítica de video con detección inteligente y central de monitoreo certificada 24/7/365.'
    card2Title="Resultados cuantificables que impactan tu ROI"
    card2Text='La diferencia radica en resultados: reducción de 73% en pérdidas por robo interno, disminución de 58% en incidentes mediante intervención preventiva, evidencia digital con cadena de custodia certificada y capacidad de auditoría operativa. +15 años implementando soluciones CCTV para corporativos multinacionales en CDMX.'
  />

  {gallery.length > 0 && <GallerySection items={gallery} />}

  <section class="attention-box" style="max-width:1200px;margin:40px auto;padding:48px">
    <h2 class="attention-box__title">Cumplimiento Normativo y Protección de Datos en Videovigilancia Corporativa</h2>
    <p class="attention-box__text">Las empresas que operan sistemas de videovigilancia CCTV en México deben cumplir con normativa específica sobre protección de datos personales (LFPDPPP), retención de evidencia digital, y derechos de privacidad de empleados y visitantes. Nuestro sistema empresarial está diseñado con arquitectura de compliance integrado: encriptación end-to-end de streams de video (AES-256), políticas de retención configurables según normativa sectorial, controles de acceso basados en roles (RBAC), logs de auditoría inmutables que documentan quién accedió a qué video y cuándo, y capacidad de anonimización de rostros para cumplimiento con GDPR en operaciones internacionales.</p>
    <p class="attention-box__text">Más allá del compliance básico, proporcionamos documentación legal certificada para uso de evidencia en procesos judiciales: cadena de custodia digital con timestamps certificados, exportación de video con marca de agua forense que previene manipulación, declaratorias técnicas de operadores certificados, y compatibilidad con sistemas de gestión de incidentes corporativos (SIEM). Empresas auditadas por corporativos internacionales, certificaciones ISO 27001, o regulaciones sectoriales específicas (financiero, farmacéutico, gobierno) requieren este nivel de rigor técnico y legal.</p>
  </section>

  <section class="cta-business">
    <div class="cta-business__content">
      <h2 class="cta-business__title">¿Necesita Proteger su Empresa o Condominio?</h2>
      <p class="cta-business__description">Únase a las empresas líderes y condominios de prestigio que confían en nuestra experiencia</p>
      <div class="cta-business__actions">
        <a href="https://wa.me/525530255580?text=Hola,%20necesito%20información%20sobre%20servicios%20de%20seguridad%20privada" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/cotizar" class="cta-business__btn cta-business__btn--secondary">Cotizar en Línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
