---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import GallerySection from '../../components/GallerySection.astro';

const title = 'Monitoreo de Alarmas 24/7 CDMX | Central UL';
const description = 'Monitoreo de alarmas y seguridad privada para condominios, residenciales y empresas en CDMX. Central certificada UL 24/7. ☎ 55 3025 5580';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Monitoreo de Alarmas 24/7",
  "description": "Monitoreo de alarmas y seguridad privada para condominios, residenciales y empresas en CDMX. Central certificada UL 24/7. ☎ 55 3025 5580",
  "provider": {
    "@type": "Organization",
    "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "url": "https://seguridad-privada.com.mx/"
  },
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "telephone": "+52-55-3025-5580"
});

const gallery = [
  { src: '/img/img-monitoreo-de-alarmas/central-monitoreo-alarmas-24-7-cdmx.avif', alt: 'Central de monitoreo de alarmas 24/7 certificada UL en CDMX', captionTitle: 'Central de Monitoreo Certificada UL', captionText: 'Operación 24/7/365 con operadores capacitados y protocolos estándar' },
  { src: '/img/img-monitoreo-de-alarmas/operadores-certificados-monitoreo-alarmas.avif', alt: 'Operadores certificados monitoreando alarmas en tiempo real', captionTitle: 'Operadores Certificados', captionText: 'Personal capacitado con verificación multi-etapa de eventos' },
  { src: '/img/img-monitoreo-de-alarmas/deteccion-incendio-humo-alarmas.avif', alt: 'Sistema de detección de incendio y humo integrado con alarmas', captionTitle: 'Detección de Incendio y Humo', captionText: 'Cumplimiento normativo NOM-002-STPS con respuesta inmediata' },
  { src: '/img/img-monitoreo-de-alarmas/panel-control-alarma-certificado.avif', alt: 'Panel de control de alarma certificado para empresas', captionTitle: 'Panel de Control Empresarial', captionText: 'Sistemas de última generación con redundancia garantizada' },
  { src: '/img/img-monitoreo-de-alarmas/verificacion-video-alarma-real-time.avif', alt: 'Verificación de alarmas por video en tiempo real', captionTitle: 'Verificación por Video', captionText: 'Integración CCTV para validación visual de eventos en vivo' },
  { src: '/img/img-monitoreo-de-alarmas/botones-panico-emergencia.avif', alt: 'Botones de pánico para emergencias conectados a central', captionTitle: 'Botones de Pánico', captionText: 'Respuesta inmediata ante situaciones de emergencia crítica' },
  { src: '/img/img-monitoreo-de-alarmas/app-control-alarma-smartphone.avif', alt: 'App móvil para control de alarmas desde smartphone', captionTitle: 'Control desde Smartphone', captionText: 'App ejecutiva con notificaciones push y control remoto total' },
  { src: '/img/img-monitoreo-de-alarmas/respuesta-rapida-emergencias-alarma.avif', alt: 'Protocolo de respuesta rápida a emergencias de alarmas', captionTitle: 'Respuesta Rápida a Emergencias', captionText: 'Coordinación directa con C5, bomberos y protección civil' },
  { src: '/img/img-monitoreo-de-alarmas/certificacion-ul-central-monitoreo.avif', alt: 'Certificación UL 827 de central de monitoreo profesional', captionTitle: 'Certificación UL 827', captionText: 'Auditorías trimestrales y cumplimiento de estándares internacionales' },
];
---
<BaseLayout title={title} description={description} schema={schema}>
  <Hero
    title="Monitoreo de Alarmas 24/7 en CDMX"
    subtitle="Central Certificada UL con Verificación Multi-Etapa — Reducción del 87% en Falsas Alarmas"
    description='Plataforma empresarial de detección de intrusión, incendio y emergencias. Protocolos Contact ID y SIA DC-09 con comunicación encriptada AES-256.'
    card1Title="Certificación UL 827 con estándares rigurosos"
    card1Text='Las centrales de monitoreo corporativas operan bajo certificación UL 827 que establece estándares rigurosos de redundancia, personal capacitado y protocolos de verificación. Nuestra central procesa señales desde sistemas de detección de intrusión, incendio y emergencias, discriminando eventos mediante verificación secuencial multi-sensor, audio bidireccional y video en tiempo real.'
    card2Title="Comunicación dual a prueba de sabotaje"
    card2Text='La arquitectura de comunicación dual (GPRS/celular primario + IP/Ethernet secundario) con protocolo encriptado AES-256 end-to-end garantiza que señales críticas lleguen a la central incluso ante sabotaje. Cada evento genera timestamp inmutable, grabación de audio y registro de acciones para auditoría y cumplimiento normativo.'
  />

  {gallery.length > 0 && <GallerySection items={gallery} />}

  <section class="attention-box" style="max-width:1200px;margin:40px auto;padding:48px">
    <h2 class="attention-box__title">Por Qué la Central de Monitoreo Certificada UL Es la Decisión Correcta para Su Empresa</h2>
    <p class="attention-box__text">En el sector corporativo y empresarial, la diferencia entre una central de monitoreo que genera valor y una que solo genera costos está en la verificación profesional. Las centrales certificadas UL 827 no son solo vigilancia remota: son una inversión estratégica en reducción de riesgos operativos y cumplimiento normativo.</p>
    <p class="attention-box__text">Nuestra central de monitoreo certificada UL está diseñada para eliminar falsas alarmas que generan costos innecesarios mientras garantiza respuesta inmediata ante emergencias reales. Con protocolos Contact ID y SIA DC-09, operadores certificados 24/7 y arquitectura redundante, protegemos sus instalaciones con los más altos estándares de la industria.</p>
  </section>

  <section class="cta-business">
    <div class="cta-business__content">
      <h2 class="cta-business__title">¿Necesita Proteger su Empresa o Condominio?</h2>
      <p class="cta-business__description">Únase a las empresas líderes y condominios de prestigio que confían en nuestra experiencia</p>
      <div class="cta-business__actions">
        <a href="https://wa.me/525530255580?text=Hola,%20necesito%20información%20sobre%20servicios%20de%20seguridad%20privada" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/cotizar" class="cta-business__btn cta-business__btn--secondary">Cotizar en Línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
