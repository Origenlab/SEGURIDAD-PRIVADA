  @media (max-width: 480px) {
    :global(.deliverables-grid) { grid-template-columns: 1fr; }
  }

  /* === Invisible Work — trabajo previo en línea de tiempo === */
  :global(.invisible-work) {
    margin: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    background: #fff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 16px;
