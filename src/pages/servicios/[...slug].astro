  }

  :global(.patrol-coverage__block--day       .patrol-coverage__fill) { background: #f59e0b; }
  :global(.patrol-coverage__block--afternoon .patrol-coverage__fill) { background: #ea580c; }
  :global(.patrol-coverage__block--night     .patrol-coverage__fill) { background: #7c3aed; }
  :global(.patrol-coverage__block--dawn      .patrol-coverage__fill) { background: #1d4ed8; }

  :global(.patrol-coverage__desc) {
