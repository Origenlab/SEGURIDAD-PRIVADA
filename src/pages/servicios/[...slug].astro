  /* === Threat Levels — niveles de amenaza con indicadores visuales === */
  :global(.threat-levels) {
    margin: 1.5rem 0;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(10,15,30,0.08);
    background: #fff;
