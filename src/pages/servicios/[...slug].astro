  :global(.patrol-coverage__block--afternoon) { border-top: 3px solid #ea580c; }
  :global(.patrol-coverage__block--night)     { border-top: 3px solid #7c3aed; }
  :global(.patrol-coverage__block--dawn)      { border-top: 3px solid #1d4ed8; }

