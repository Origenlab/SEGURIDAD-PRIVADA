---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import HeroPagina from '../../components/HeroPagina.astro';
import NavCTA from '../../components/NavCTA.astro';
import FAQItem from '../../components/FAQItem.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import '../../styles/sections/faq-cotizacion.css';

// Mapa de datos enriquecidos por servicio (para ServiceCard en sección complementaria)
const serviceCardData: Record<string, { image: string; imageAlt: string; badge: string; features: string[]; ctaText: string }> = {
  'vigilancia-remota-cctv': {
    image: '/img/img-vigilancia-remota/central-monitoreo-cctv-24-7.avif',
    imageAlt: 'Central de monitoreo CCTV 24/7 CDMX',
    badge: 'Vigilancia',
    features: ['CCTV 24/7', 'Visión nocturna', 'Acceso remoto', 'IA analítica'],
    ctaText: 'Ver Vigilancia CCTV',
  },
  'monitoreo-alarmas': {
    image: '/img/img-monitoreo-de-alarmas/central-monitoreo-alarmas-24-7-cdmx.avif',
    imageAlt: 'Central de monitoreo de alarmas certificada UL CDMX',
    badge: 'Monitoreo',
    features: ['Central UL certificada', '< 90 seg respuesta', 'Respaldo 4G', 'Verificación humana'],
    ctaText: 'Ver Monitoreo de Alarmas',
  },
  'seguridad-gps-satelital': {
    image: '/img/img-rastreo-gps/central-monitoreo-gps-24-7.avif',
    imageAlt: 'Rastreo GPS satelital para flotillas en CDMX',
    badge: 'GPS Satelital',
    features: ['Tiempo real 30 seg', 'Geocercas', 'Historial 90 días', 'Botón de pánico'],
    ctaText: 'Ver Rastreo GPS',
  },
  'guardias-intramuros': {
    image: '/img/img-guardias-intramuros/elementos-de-seguridad-intramuros.avif',
    imageAlt: 'Guardias intramuros certificados SSC en CDMX',
    badge: 'Guardias',
    features: ['Certificación SSC', 'Vigilancia 24/7', 'Control de accesos', 'Rondines programados'],
    ctaText: 'Ver Guardias Intramuros',
  },
  'control-de-accesos': {
    image: '/img/control-de-accesos/control-de-accesos-en-corporativos.avif',
    imageAlt: 'Control de accesos para condominios y empresas CDMX',
    badge: 'Accesos',
    features: ['Registro digital 24/7', 'Control biométrico', 'Visitas programadas', 'Integración CCTV'],
    ctaText: 'Ver Control de Accesos',
  },
  'patrullaje': {
    image: '/img/img-guardias-de-seguridad/guardias-de-seguridad-cdmx.avif',
    imageAlt: 'Patrullaje vehicular de seguridad privada CDMX',
    badge: 'Patrullaje',
    features: ['Rondines vehiculares', 'GPS en tiempo real', 'Disuasión activa', 'Respuesta rápida'],
    ctaText: 'Ver Patrullaje',
  },
  'proteccion-ejecutiva': {
    image: '/img/img-proteccion-ejecutiva/proteccion-ejecutiva-cdmx.avif',
    imageAlt: 'Protección ejecutiva y escoltas en CDMX',
    badge: 'Protección',
    features: ['Escoltas certificados', 'Análisis de rutas', 'Vehículos blindados', 'Discreción total'],
    ctaText: 'Ver Protección Ejecutiva',
  },
  'consultoria-seguridad': {
    image: '/img/consultoria-de-seguridad/consultoria-seguridad-empresarial.avif',
    imageAlt: 'Consultoría de seguridad para empresas CDMX',
    badge: 'Consultoría',
    features: ['Análisis de riesgos', 'Protocolos a medida', 'Auditoría de accesos', 'Plan de respuesta'],
    ctaText: 'Ver Consultoría',
  },
};

// Mapa de emojis por tipo de servicio
const serviceIcons: Record<string, string> = {
  'guardias-intramuros': '🛡️',
  'seguridad-condominios': '🏢',
  'seguridad-residenciales': '🏘️',
  'control-de-accesos': '🚪',
  'guardias-de-seguridad-y-vigilancia': '👮',
  'monitoreo-alarmas': '📡',
  'patrullaje': '🚔',
  'tecnologia-monitoreo-seguridad': '📹',
  'proteccion-ejecutiva': '🤵',
  'seguridad-eventos': '🎪',
  'seguridad-construccion': '🏗️',
  'seguridad-hospitalaria': '🏥',
  'custodia-de-mercancias': '📦',
  'consultoria-seguridad': '💼',
  'consultoria-analisis-riesgos': '📊',
  'investigaciones-confiabilidad': '🔍',
  'prevencion-de-perdidas': '🔒',
  'seguridad-gps-satelital': '🛰️',
  'seguridad-especializada': '⭐',
};

export async function getStaticPaths() {
  const servicios = await getCollection('servicios', ({ data }) => !data.draft);
  return servicios.map((servicio) => ({
    params: { slug: servicio.id },
    props: { servicio },
  }));
}

const { servicio } = Astro.props;
const { Content } = await render(servicio);

// Obtener datos de servicios relacionados para el cross-linking
const todosLosServicios = await getCollection('servicios', ({ data }) => !data.draft);
const serviciosRelacionados = servicio.data.relatedServices
  ? todosLosServicios
      .filter(s => servicio.data.relatedServices.includes(s.id))
      .map(s => ({
        id: s.id,
        titulo: s.data.title.split('|')[0].trim(),
        descripcion: s.data.description,
        icon: serviceIcons[s.id] || '🛡️',
        cardData: serviceCardData[s.id] || null,
      }))
  : [];

const siteUrl = 'https://seguridad-privada.com.mx';

// Build Schema.org structured data
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": `${siteUrl}/servicios/${servicio.id}#service`,
      "name": servicio.data.title.split('|')[0].trim(),
      "description": servicio.data.description,
      "provider": {
        "@id": `${siteUrl}/#business`
      },
      "areaServed": servicio.data.targetLocations?.map(loc => ({
        "@type": "City",
        "name": loc
      })) || [{ "@type": "City", "name": "Ciudad de México" }],
      "serviceType": servicio.data.pillarType || "Security Service"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Servicios",
          "item": `${siteUrl}/servicios`
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": servicio.data.title.split('|')[0].trim(),
          "item": `${siteUrl}/servicios/${servicio.id}`
        }
      ]
    }
  ]
};

// Add FAQPage schema if FAQs exist
if (servicio.data.faqs && servicio.data.faqs.length > 0) {
  schema["@graph"].push({
    "@type": "FAQPage",
    "mainEntity": servicio.data.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  });
}

// NavCTA dinámico: primer servicio relacionado como card principal, resto fijo
const navCard1 = serviciosRelacionados.length > 0
  ? { label: serviciosRelacionados[0].titulo, sublabel: serviciosRelacionados[0].descripcion.substring(0, 48) + '…', href: `/servicios/${todosLosServicios.find(s => s.data.title.split('|')[0].trim() === serviciosRelacionados[0].titulo)?.id ?? ''}`, icon: 'shield' as const }
  : { label: 'Todos los Servicios', sublabel: 'Guardias, accesos y monitoreo', href: '/servicios', icon: 'shield' as const };
const waServicio = 'https://wa.me/525530255580?text=' + encodeURIComponent('Hola, me interesa cotizar ' + servicio.data.title.split('|')[0].trim() + ' para mi condominio');
---

<Base
  title={servicio.data.title}
  description={servicio.data.description}
  canonical={`${siteUrl}/servicios/${servicio.id}`}
  schema={schema}
>
  <HeroPagina
    badge={servicio.data.category === 'pillar' ? 'Servicio Principal' : 'Servicio de Seguridad'}
    titulo={servicio.data.title.split('|')[0].trim()}
    descripcion={servicio.data.description}
    breadcrumb={[
      { label: 'Servicios', href: '/servicios' },
      { label: servicio.data.title.split('|')[0].trim(), href: `/servicios/${servicio.id}` }
    ]}
    ctaPrimario={{ texto: servicio.data.ctaText, href: servicio.data.ctaLink }}
    ctaWhatsapp={true}
    seoParrafo1={`<strong>ORIGINS Private Security</strong> ofrece ${servicio.data.title.split('|')[0].trim().toLowerCase()} con <strong>Permiso SSC 0102-15</strong> vigente. Nuestros elementos están certificados, verificados en antecedentes y capacitados específicamente para entornos residenciales en CDMX y <a href="/zonas">Zona Metropolitana</a>.`}
    seoParrafo2={`Más de 15 años de experiencia exclusiva en comunidades residenciales. <a href="/servicios">Ver todos los servicios</a> o contáctanos para un diagnóstico gratuito — respondemos en menos de 2 horas y entregamos propuesta formal en menos de 24 horas.`}
  />

  <NavCTA
    ariaLabel={`Servicios relacionados con ${servicio.data.title.split('|')[0].trim()}`}
    cards={[
      navCard1,
      { label: 'Zonas de Cobertura',   sublabel: 'CDMX y Zona Metropolitana',           href: '/zonas',     icon: 'map'    },
      { label: 'Quiénes Somos',        sublabel: 'Permiso SSC 0102-15 · Desde 2008',     href: '/nosotros',  icon: 'people' },
      { label: 'Cotizar este Servicio', sublabel: 'Diagnóstico gratuito en 24 horas',    href: waServicio, whatsapp: true, accent: true, external: true },
    ]}
  />

  <!-- Main Content + Features dentro del mismo grid con sidebar -->
  <section class="service-content">
    <div class="container">
      <div class="service-content__grid">
        <div class="service-content__main prose">

          <!-- Features integradas al inicio del main content -->
          {servicio.data.serviceFeatures && servicio.data.serviceFeatures.length > 0 && (
            <div class="service-features-inline">
              <div class="prose-section-header">
                <span class="prose-section-badge">Cobertura Completa</span>
                <h2>¿Qué Incluye el Servicio?</h2>
                <p class="prose-section-sub">Todo lo que necesitas para proteger tu propiedad, integrado en un solo servicio.</p>
              </div>
              <div class="sfi__grid">
                {servicio.data.serviceFeatures.map((feature) => (
                  <div class="sfi__card">
                    <span class="sfi__check">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                    <div>
                      <strong>{feature.title}</strong>
                      <p>{feature.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          <Content />
        </div>

        <!-- Sidebar -->
        <aside class="service-content__sidebar">

          <!-- WIDGET 1: CTA principal — conversión inmediata -->
          <div class="sw sw--cta">
            <span class="sw__badge">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              Permiso SSC 0102-15
            </span>
            <h3 class="sw__title">¿Necesitas cotización para tu condominio?</h3>
            <p class="sw__desc">Diagnóstico gratuito · Respuesta en menos de 24 horas · Sin compromiso.</p>
            <a
              href={`https://wa.me/525530255580?text=${encodeURIComponent('Hola, me interesa cotizar ' + servicio.data.title.split('|')[0].trim() + ' para mi propiedad')}`}
              class="sw__cta-wa"
              target="_blank"
              rel="noopener"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Cotizar por WhatsApp
            </a>
            <a href="/contacto" class="sw__cta-outline">
              Ver formulario de contacto
            </a>
            <div class="sw__tel">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              <a href="tel:+525530255580">55 3025 5580</a>
            </div>
          </div>

          <!-- WIDGET 2: Servicios relacionados (datos del frontmatter + fallback manual) -->
          <div class="sw sw--list">
            <h4 class="sw__heading">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Servicios Relacionados
            </h4>
            <ul class="sw__link-list">
              {serviciosRelacionados.length > 0
                ? serviciosRelacionados.map((rel) => (
                  <li>
                    <a href={`/servicios/${rel.id}`} class="sw__link-item">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                      <span>{rel.titulo}</span>
                    </a>
                  </li>
                ))
                : [
                    { id: 'guardias-intramuros',     label: 'Guardias Intramuros'       },
                    { id: 'control-de-accesos',       label: 'Control de Accesos'        },
                    { id: 'vigilancia-remota-cctv',   label: 'Vigilancia Remota CCTV'    },
                    { id: 'monitoreo-alarmas',         label: 'Monitoreo de Alarmas'      },
                    { id: 'seguridad-condominios',     label: 'Seguridad Condominios'     },
                  ].map((item) => (
                    <li>
                      <a href={`/servicios/${item.id}`} class="sw__link-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                        <span>{item.label}</span>
                      </a>
                    </li>
                  ))
              }
              <li>
                <a href="/servicios" class="sw__link-ver-todos">
                  Ver todos los servicios
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </li>
            </ul>
          </div>

          <!-- WIDGET 3: Zonas de cobertura -->
          <div class="sw sw--list">
            <h4 class="sw__heading">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.35 11.76a1 1 0 0 0 1.3 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
              Zonas de Cobertura
            </h4>
            <ul class="sw__link-list">
              {[
                { slug: 'miguel-hidalgo',  label: 'Miguel Hidalgo · Polanco'         },
                { slug: 'cuauhtemoc',      label: 'Cuauhtémoc · Roma · Condesa'      },
                { slug: 'benito-juarez',   label: 'Benito Juárez · Del Valle'        },
                { slug: 'alvaro-obregon',  label: 'Álvaro Obregón · Santa Fe'        },
                { slug: 'naucalpan',       label: 'Naucalpan · Interlomas'            },
                { slug: 'atizapan',        label: 'Atizapán · Bosques'               },
              ].map((z) => (
                <li>
                  <a href={`/zonas/${z.slug}`} class="sw__link-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                    <span>{z.label}</span>
                  </a>
                </li>
              ))}
              <li>
                <a href="/zonas" class="sw__link-ver-todos">
                  Ver todas las zonas
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </li>
            </ul>
          </div>

          <!-- WIDGET 4: Credenciales de confianza -->
          <div class="sw sw--trust">
            <h4 class="sw__heading">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              Por qué confiar en ORIGINS
            </h4>
            <ul class="sw__trust-list">
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong>Permiso SSC 0102-15</strong> vigente</span>
              </li>
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Póliza de responsabilidad civil</span>
              </li>
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Alta IMSS e INFONAVIT desde día 1</span>
              </li>
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong>+15 años</strong> en CDMX</span>
              </li>
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong>+50 condominios</strong> protegidos</span>
              </li>
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Supervisión semanal documentada</span>
              </li>
            </ul>
            <a href="/nosotros" class="sw__link-ver-todos" style="margin-top: 0.75rem;">
              Conocer más sobre ORIGINS
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <!-- WIDGET 5: Categorías del catálogo — navegación rápida -->
          <div class="sw sw--list">
            <h4 class="sw__heading">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
              Categorías de Servicios
            </h4>
            <ul class="sw__cat-list">
              <li>
                <a href="/servicios#seguridad-residencial" class="sw__cat-item">
                  <span class="sw__cat-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  </span>
                  <div>
                    <strong>Seguridad Residencial</strong>
                    <span>Guardias, accesos y patrullaje</span>
                  </div>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              </li>
              <li>
                <a href="/servicios#tecnologia-monitoreo" class="sw__cat-item">
                  <span class="sw__cat-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                  </span>
                  <div>
                    <strong>Tecnología y Monitoreo</strong>
                    <span>CCTV, alarmas y GPS</span>
                  </div>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              </li>
              <li>
                <a href="/servicios#proteccion-consultoria" class="sw__cat-item">
                  <span class="sw__cat-icon">
