    :global(.patrol-coverage__block) { border-right: none !important; border-top: 3px solid transparent; border-bottom: 1px solid rgba(10,15,30,0.07); }
    :global(.patrol-coverage__block--day)       { border-top-color: #f59e0b !important; }
    :global(.patrol-coverage__block--afternoon) { border-top-color: #ea580c !important; }
    :global(.patrol-coverage__block--night)     { border-top-color: #7c3aed !important; }
    :global(.patrol-coverage__block--dawn)      { border-top-color: #1d4ed8 !important; border-bottom: none; }
  }

  /* === Cost vs Loss — comparativa de costo GPS vs pérdida por robo === */
  :global(.cost-vs-loss) {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0;
    margin: 1.5rem 0;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(10,15,30,0.08);
  }

  :global(.cost-vs-loss__side) {
    padding: 1.75rem 1.5rem;
  }

  :global(.cost-vs-loss__side--loss) {
    background: rgba(239,68,68,0.04);
    border-right: 1px solid rgba(10,15,30,0.07);
  }

  :global(.cost-vs-loss__side--cost) {
    background: rgba(22,163,74,0.04);
  }

  :global(.cost-vs-loss__label) {
    font-size: 0.72rem !important;
    font-weight: 700 !important;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: 0.5rem;
  }

  :global(.cost-vs-loss__side--loss .cost-vs-loss__label) { color: #b91c1c !important; }
  :global(.cost-vs-loss__side--cost .cost-vs-loss__label) { color: #15803d !important; }

  :global(.cost-vs-loss__amount) {
    font-size: 2.75rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  :global(.cost-vs-loss__side--loss .cost-vs-loss__amount) { color: #dc2626; }
  :global(.cost-vs-loss__side--cost .cost-vs-loss__amount) { color: #16a34a; }

  :global(.cost-vs-loss__unit) {
    font-size: 0.8rem !important;
    color: rgba(10,15,30,0.5) !important;
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  :global(.cost-vs-loss__list) {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  :global(.cost-vs-loss__list li) {
    font-size: 0.8rem !important;
    line-height: 1.4 !important;
    padding-left: 1rem !important;
    position: relative;
  }

  :global(.cost-vs-loss__side--loss .cost-vs-loss__list li) { color: rgba(10,15,30,0.6) !important; }
  :global(.cost-vs-loss__side--loss .cost-vs-loss__list li::before) { content: '−'; position: absolute; left: 0; color: #dc2626; font-weight: 700; }
  :global(.cost-vs-loss__side--cost .cost-vs-loss__list li) { color: #166534 !important; font-weight: 500 !important; }
  :global(.cost-vs-loss__side--cost .cost-vs-loss__list li::before) { content: '✓'; position: absolute; left: 0; color: #16a34a; font-weight: 700; font-size: 0.75rem; }

  :global(.cost-vs-loss__divider) {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: #0a0f1e;
    color: #fff;
    font-size: 1rem;
    font-weight: 900;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    height: 100%;
    min-width: 40px;
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    :global(.cost-vs-loss) { grid-template-columns: 1fr; }
    :global(.cost-vs-loss__divider) { writing-mode: horizontal-tb; height: auto; min-width: unset; padding: 0.5rem; font-size: 1.25rem; }
    :global(.cost-vs-loss__side--loss) { border-right: none; border-bottom: 1px solid rgba(10,15,30,0.07); }
  }

  /* === GPS Preview — simulación visual de pantalla de monitoreo === */
  :global(.gps-preview) {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 1rem;
    margin: 1.5rem 0;
    align-items: start;
  }

  :global(.gps-preview__screen) {
    background: #0a0f1e;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
  }

  :global(.gps-preview__map) {
    height: 200px;
    background: linear-gradient(135deg, #0d1b2a 0%, #112240 50%, #0d1b2a 100%);
    position: relative;
    overflow: hidden;
  }

  /* Grid de mapa estilo satélite */
  :global(.gps-preview__map::before) {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(0deg, rgba(255,255,255,0.03) 0px, transparent 1px, transparent 30px, rgba(255,255,255,0.03) 31px), repeating-linear-gradient(90deg, rgba(255,255,255,0.03) 0px, transparent 1px, transparent 40px, rgba(255,255,255,0.03) 41px);
  }

  /* Ruta animada */
  :global(.gps-preview__route) {
    position: absolute;
    top: 50%;
    left: 10%;
    width: 80%;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(74,222,128,0.3), rgba(74,222,128,0.7), rgba(74,222,128,0.3));
    transform: translateY(-50%) rotate(-8deg);
  }

  :global(.gps-preview__route::before) {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    right: 60%;
    height: 4px;
    background: #4ade80;
    border-radius: 2px;
  }

  /* Punto en movimiento */
  :global(.gps-preview__dot) {
    position: absolute;
    top: calc(50% - 20px);
    left: 42%;
    width: 16px;
    height: 16px;
  }

  :global(.gps-preview__dot span) {
    display: block;
    width: 10px;
    height: 10px;
    background: #4ade80;
    border-radius: 50%;
    position: absolute;
    top: 3px;
    left: 3px;
    box-shadow: 0 0 0 3px rgba(74,222,128,0.3);
    animation: gps-pulse 2s infinite;
  }

  :global(.gps-preview__dot::before) {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: rgba(74,222,128,0.15);
    animation: gps-ping 2s infinite;
  }

  @keyframes gps-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(74,222,128,0.3); }
    50% { box-shadow: 0 0 0 6px rgba(74,222,128,0.1); }
  }

  @keyframes gps-ping {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(3); opacity: 0; }
  }

  /* Pin de origen */
  :global(.gps-preview__pin--origin) {
    position: absolute;
    top: calc(50% - 40px);
    left: 12%;
    width: 8px;
    height: 8px;
    background: rgba(255,255,255,0.4);
    border-radius: 50%;
  }

  :global(.gps-preview__panel) {
    padding: 1rem 1.25rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  :global(.gps-preview__vehicle) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem !important;
    font-weight: 600 !important;
    color: rgba(255,255,255,0.85) !important;
    margin-bottom: 0.875rem;
  }

  :global(.gps-preview__vehicle svg) { opacity: 0.6; }

  :global(.gps-preview__stats) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  :global(.gps-preview__stat) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  :global(.gps-preview__stat-val) {
    font-size: 0.8rem !important;
    font-weight: 700 !important;
    color: rgba(255,255,255,0.9) !important;
    line-height: 1.2;
  }

  :global(.gps-preview__stat-val--live) { color: #4ade80 !important; }
  :global(.gps-preview__stat-val--ok) { color: #86efac !important; }

  :global(.gps-preview__stat-key) {
    font-size: 0.65rem !important;
    color: rgba(255,255,255,0.35) !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  :global(.gps-preview__alert) {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    font-size: 0.72rem !important;
    font-weight: 500 !important;
  }

  :global(.gps-preview__alert--ok) {
    background: rgba(74,222,128,0.1);
    color: #86efac !important;
    border: 1px solid rgba(74,222,128,0.2);
  }

  :global(.gps-preview__features) {
    background: #fff;
    border-radius: 14px;
    border: 1px solid rgba(10,15,30,0.08);
    padding: 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  :global(.gps-preview__feature) {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.825rem !important;
    color: rgba(10,15,30,0.7) !important;
    line-height: 1.4;
  }

  :global(.gps-preview__feature svg) {
    color: #0a0f1e;
    opacity: 0.5;
    flex-shrink: 0;
    margin-top: 0.1em;
  }

  @media (max-width: 768px) {
    :global(.gps-preview) { grid-template-columns: 1fr; }
  }

  /* === Access Flow — diagrama visual de flujo de acceso === */
  :global(.access-flow) {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin: 1.5rem 0;
    background: #fff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 16px;
    overflow: hidden;
  }

  :global(.access-flow__step) {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.625rem;
    padding: 1.5rem 1rem;
    border-right: 1px solid rgba(10,15,30,0.07);
    position: relative;
  }

  :global(.access-flow__step:last-child) {
    border-right: none;
  }

  :global(.access-flow__step--1 .access-flow__icon) { background: rgba(10,15,30,0.05); color: #0a0f1e; }
  :global(.access-flow__step--2 .access-flow__icon) { background: rgba(234,88,12,0.08); color: #c2410c; }
  :global(.access-flow__step--3 .access-flow__icon) { background: rgba(22,163,74,0.08); color: #15803d; }
  :global(.access-flow__step--4 .access-flow__icon) { background: rgba(37,99,235,0.08); color: #1d4ed8; }

  :global(.access-flow__icon) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    flex-shrink: 0;
    margin-bottom: 0.25rem;
  }

  :global(.access-flow__step strong) {
    font-size: 0.825rem !important;
    font-weight: 700 !important;
    color: #0a0f1e !important;
    line-height: 1.2;
    display: block;
  }

  :global(.access-flow__step p) {
    font-size: 0.775rem !important;
    color: rgba(10,15,30,0.5) !important;
    line-height: 1.5 !important;
    margin: 0 !important;
  }

  :global(.access-flow__arrow) {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.2rem;
    color: rgba(10,15,30,0.2);
    flex-shrink: 0;
    align-self: center;
  }

  @media (max-width: 640px) {
    :global(.access-flow) { flex-direction: column; }
    :global(.access-flow__step) {
      flex-direction: row;
      text-align: left;
      border-right: none;
      border-bottom: 1px solid rgba(10,15,30,0.07);
      gap: 0.875rem;
      padding: 1rem 1.25rem;
    }
    :global(.access-flow__step:last-child) { border-bottom: none; }
    :global(.access-flow__arrow) { display: none; }
    :global(.access-flow__icon) { margin-bottom: 0; flex-shrink: 0; }
  }

  /* === Methods Compare — comparativa de 3 métodos === */
  :global(.methods-compare) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin: 1.5rem 0;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 16px;
    overflow: hidden;
  }

  :global(.methods-compare__col) {
    padding: 0;
    border-right: 1px solid rgba(10,15,30,0.07);
  }

  :global(.methods-compare__col:last-child) {
    border-right: none;
  }

  :global(.methods-compare__header) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.125rem;
    font-size: 0.8rem !important;
    font-weight: 700 !important;
    border-bottom: 1px solid rgba(10,15,30,0.07);
  }

  :global(.methods-compare__col--bad   .methods-compare__header) { background: rgba(10,15,30,0.04); color: rgba(10,15,30,0.5) !important; }
  :global(.methods-compare__col--warn  .methods-compare__header) { background: rgba(234,88,12,0.06); color: #c2410c !important; }
  :global(.methods-compare__col--good  .methods-compare__header) { background: rgba(22,163,74,0.07); color: #15803d !important; }

  :global(.methods-compare__col ul) {
    list-style: none !important;
    padding: 0.875rem 1.125rem !important;
    margin: 0 !important;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.methods-compare__col ul li) {
    font-size: 0.8rem !important;
    line-height: 1.45 !important;
    padding-left: 1rem !important;
    position: relative;
  }

  :global(.methods-compare__col--bad  ul li) { color: rgba(10,15,30,0.45) !important; }
  :global(.methods-compare__col--warn ul li) { color: rgba(10,15,30,0.55) !important; }
  :global(.methods-compare__col--good ul li) { color: #166534 !important; font-weight: 500 !important; }

  :global(.methods-compare__col--bad  ul li::before) { content: '✕'; position: absolute; left: 0; color: #ef4444; font-size: 0.65rem; top: 0.1em; font-weight: 700; }
  :global(.methods-compare__col--warn ul li::before) { content: '⚠'; position: absolute; left: 0; color: #f59e0b; font-size: 0.65rem; top: 0.05em; }
  :global(.methods-compare__col--good ul li::before) { content: '✓'; position: absolute; left: 0; color: #16a34a; font-size: 0.7rem; top: 0.05em; font-weight: 800; }

  @media (max-width: 640px) {
    :global(.methods-compare) { grid-template-columns: 1fr; }
    :global(.methods-compare__col) { border-right: none; border-bottom: 1px solid rgba(10,15,30,0.07); }
    :global(.methods-compare__col:last-child) { border-bottom: none; }
  }

  /* === Scenarios Grid — casos reales problema/solución === */
  :global(.scenarios-grid) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin: 1.5rem 0;
  }

  :global(.scenario-card) {
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(10,15,30,0.08);
    background: #fff;
  }

  :global(.scenario-card__situation),
  :global(.scenario-card__solution) {
    padding: 1rem 1.125rem;
  }

  :global(.scenario-card__situation) {
    background: rgba(10,15,30,0.03);
    border-bottom: 1px solid rgba(10,15,30,0.07);
  }

  :global(.scenario-card__solution) {
    background: rgba(22,163,74,0.04);
  }

  :global(.scenario-card__situation p) {
    font-size: 0.8125rem !important;
    color: rgba(10,15,30,0.7) !important;
    line-height: 1.5 !important;
    margin: 0.375rem 0 0 !important;
    font-style: italic;
  }

  :global(.scenario-card__solution p) {
    font-size: 0.8125rem !important;
    color: #166534 !important;
    line-height: 1.5 !important;
    margin: 0.375rem 0 0 !important;
  }

  :global(.scenario-card__badge) {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.625rem;
    border-radius: 980px;
    font-size: 0.68rem !important;
    font-weight: 700 !important;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  :global(.scenario-card__badge--problem)  { background: rgba(239,68,68,0.1); color: #b91c1c !important; }
  :global(.scenario-card__badge--solution) { background: rgba(22,163,74,0.12); color: #15803d !important; }

  @media (max-width: 640px) {
    :global(.scenarios-grid) { grid-template-columns: 1fr; }
  }

  /* === Trust Bar — barra de credenciales horizontales === */
  :global(.trust-bar) {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    background: #fff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 16px;
    overflow: hidden;
    margin: 1.5rem 0;
  }

  :global(.trust-bar__item) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 180px;
    padding: 1.125rem 1.25rem;
    border-right: 1px solid rgba(10,15,30,0.07);
  }

  :global(.trust-bar__item:last-child) {
    border-right: none;
  }

  :global(.trust-bar__item svg) {
    color: #0a0f1e;
    flex-shrink: 0;
    opacity: 0.7;
  }

  :global(.trust-bar__item strong) {
    display: block;
    font-size: 0.825rem !important;
    font-weight: 700 !important;
    color: #0a0f1e !important;
    line-height: 1.2;
    margin-bottom: 0.15rem;
  }

  :global(.trust-bar__item span) {
    display: block;
    font-size: 0.72rem !important;
    color: rgba(10,15,30,0.5) !important;
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    :global(.trust-bar) { flex-direction: column; }
    :global(.trust-bar__item) {
      border-right: none;
      border-bottom: 1px solid rgba(10,15,30,0.07);
      min-width: unset;
    }
    :global(.trust-bar__item:last-child) { border-bottom: none; }
  }

  /* === Contract Includes — 3 columnas de qué incluye === */
  :global(.contract-includes) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 1.5rem 0;
  }

  :global(.contract-includes__col) {
    background: #fff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 14px;
    padding: 1.25rem;
    transition: box-shadow 0.15s;
  }

  :global(.contract-includes__col:hover) {
    box-shadow: 0 4px 16px rgba(10,15,30,0.06);
  }

  :global(.contract-includes__title) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem !important;
    font-weight: 700 !important;
    color: #0a0f1e !important;
    margin: 0 0 0.875rem !important;
    padding-bottom: 0.75rem !important;
    border-bottom: 1px solid rgba(10,15,30,0.07) !important;
  }

  :global(.contract-includes__title svg) {
    flex-shrink: 0;
    opacity: 0.6;
  }

  :global(.contract-includes__col ul) {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.contract-includes__col ul li) {
    font-size: 0.8125rem !important;
    color: rgba(10,15,30,0.65) !important;
    line-height: 1.45 !important;
    padding-left: 1.125rem !important;
    position: relative;
  }

  :global(.contract-includes__col ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #0a0f1e;
    opacity: 0.25;
  }

  @media (max-width: 768px) {
    :global(.contract-includes) { grid-template-columns: 1fr; }
  }

  /* === Zones Grid === */
  :global(.zones-grid) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.875rem;
    margin: 1.5rem 0;
  }

  :global(.zones-card) {
    background: #fff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 14px;
    overflow: hidden;
  }

  :global(.zones-card h4) {
    font-size: 0.78rem !important;
    font-weight: 700 !important;
    color: #fff !important;
    background: #0a0f1e;
    padding: 0.625rem 1rem !important;
    margin: 0 !important;
    letter-spacing: 0.02em;
    border-bottom: none !important;
  }

  :global(.zones-card--accent h4) {
    background: linear-gradient(135deg, #0a0f1e 0%, #1a2744 100%);
  }

  :global(.zones-card ul) {
    list-style: none !important;
    padding: 0.875rem 1rem !important;
    margin: 0 !important;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  :global(.zones-card ul li) {
    font-size: 0.8rem !important;
    color: rgba(10,15,30,0.65) !important;
    line-height: 1.4 !important;
    padding-left: 0.875rem !important;
    position: relative;
  }

  :global(.zones-card ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(10,15,30,0.3);
  }

  @media (max-width: 900px) {
    :global(.zones-grid) { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 500px) {
    :global(.zones-grid) { grid-template-columns: 1fr; }
  }

  /* === Alarm Stats — métricas de impacto === */
  :global(.alarm-stats) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin: 1.5rem 0;
  }

  :global(.alarm-stat) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 1.5rem 1.375rem;
    background: #fff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 16px;
    position: relative;
    overflow: hidden;
  }

  :global(.alarm-stat--accent) {
    background: #0a0f1e;
    border-color: transparent;
  }

  :global(.alarm-stat__num) {
    font-size: 3.25rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #0a0f1e;
  }

  :global(.alarm-stat--accent .alarm-stat__num) {
    color: #fff;
  }

  :global(.alarm-stat__unit) {
    font-size: 1rem;
    font-weight: 700;
    color: rgba(10,15,30,0.4);
    margin-top: 0.1rem;
    margin-bottom: 0.625rem;
  }

  :global(.alarm-stat--accent .alarm-stat__unit) {
    color: rgba(255,255,255,0.5);
  }

  :global(.alarm-stat__label) {
    font-size: 0.8125rem !important;
    color: rgba(10,15,30,0.55) !important;
    line-height: 1.5 !important;
    margin: 0 !important;
  }

  :global(.alarm-stat--accent .alarm-stat__label) {
    color: rgba(255,255,255,0.6) !important;
  }

  @media (min-width: 640px) {
    :global(.alarm-stats) { grid-template-columns: repeat(4, 1fr); }
  }

  /* === Sensor Grid === */
  :global(.sensor-grid) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin: 1.5rem 0;
  }

  :global(.sensor-card) {
    border-radius: 14px;
    border: 1px solid rgba(10,15,30,0.08);
    overflow: hidden;
    background: #fff;
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  :global(.sensor-card:hover) {
    box-shadow: 0 4px 20px rgba(10,15,30,0.07);
    border-color: rgba(10,15,30,0.14);
  }

  :global(.sensor-card__header) {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.125rem;
    font-size: 0.82rem !important;
    font-weight: 700 !important;
  }

  :global(.sensor-card--intrusion .sensor-card__header) { background: rgba(10,15,30,0.05); color: #0a0f1e !important; }
  :global(.sensor-card--fire      .sensor-card__header) { background: rgba(220,38,38,0.07); color: #b91c1c !important; }
  :global(.sensor-card--panic     .sensor-card__header) { background: rgba(234,88,12,0.07); color: #c2410c !important; }
  :global(.sensor-card--flood     .sensor-card__header) { background: rgba(37,99,235,0.07); color: #1d4ed8 !important; }

  :global(.sensor-card ul) {
    list-style: none !important;
    padding: 0.875rem 1.125rem !important;
    margin: 0 !important;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.sensor-card ul li) {
    font-size: 0.8125rem !important;
    color: rgba(10,15,30,0.65) !important;
    line-height: 1.4 !important;
    padding-left: 1rem !important;
    position: relative;
  }

  :global(.sensor-card ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(10,15,30,0.25);
  }

  :global(.sensor-card--fire  ul li::before) { background: rgba(220,38,38,0.5); }
  :global(.sensor-card--panic ul li::before) { background: rgba(234,88,12,0.5); }
  :global(.sensor-card--flood ul li::before) { background: rgba(37,99,235,0.5); }

  @media (max-width: 580px) {
    :global(.sensor-grid) { grid-template-columns: 1fr; }
    :global(.alarm-stats) { grid-template-columns: repeat(2, 1fr); }
  }

  /* === CCTV Process Flow === */
  :global(.cctv-process) {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin: 1.5rem 0;
    background: #fff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 16px;
    overflow: hidden;
  }

  :global(.cctv-process__step) {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.375rem 1.25rem;
    position: relative;
  }

  :global(.cctv-process__step:not(:last-child)) {
    border-right: 1px solid rgba(10,15,30,0.07);
  }

  :global(.cctv-process__num) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: #0a0f1e;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  :global(.cctv-process__content strong) {
    display: block;
    font-size: 0.875rem !important;
    font-weight: 700 !important;
    color: #0a0f1e !important;
    margin-bottom: 0.375rem;
    line-height: 1.3;
  }

  :global(.cctv-process__content p) {
    font-size: 0.8rem !important;
    color: rgba(10,15,30,0.55) !important;
    line-height: 1.55 !important;
    margin: 0 !important;
  }

  :global(.cctv-process__arrow) {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.25rem;
    color: rgba(10,15,30,0.2);
    flex-shrink: 0;
    align-self: center;
  }

  @media (max-width: 640px) {
    :global(.cctv-process) {
      flex-direction: column;
    }
    :global(.cctv-process__step:not(:last-child)) {
      border-right: none;
      border-bottom: 1px solid rgba(10,15,30,0.07);
    }
    :global(.cctv-process__arrow) {
      display: none;
    }
  }

  /* === Coverage Grid === */
  :global(.coverage-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.875rem;
    margin: 1.5rem 0;
  }

  :global(.coverage-item) {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1.125rem;
    background: #fff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 14px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  :global(.coverage-item:hover) {
    border-color: rgba(10,15,30,0.16);
    box-shadow: 0 4px 16px rgba(10,15,30,0.05);
  }

  :global(.coverage-item__icon) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: rgba(10,15,30,0.05);
    color: #0a0f1e;
    flex-shrink: 0;
  }

  :global(.coverage-item__body strong) {
    display: block;
    font-size: 0.875rem !important;
    font-weight: 700 !important;
    color: #0a0f1e !important;
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }

  :global(.coverage-item__body p) {
    font-size: 0.8rem !important;
    color: rgba(10,15,30,0.55) !important;
    line-height: 1.5 !important;
    margin: 0 !important;
  }

  @media (max-width: 580px) {
    :global(.coverage-grid) {
      grid-template-columns: 1fr;
    }
  }

  /* === Profile Grid === */
  :global(.profile-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.875rem;
    margin: 1.5rem 0;
  }

  :global(.profile-card) {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.125rem 1.25rem;
    border-radius: 14px;
    border: 1px solid rgba(10,15,30,0.08);
    background: #fff;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  :global(.profile-card:hover) {
    border-color: rgba(10,15,30,0.16);
    box-shadow: 0 4px 16px rgba(10,15,30,0.06);
  }

  :global(.profile-card--highlight) {
    border-color: rgba(10,15,30,0.15);
    background: linear-gradient(135deg, #f8f9ff 0%, #fff 100%);
    grid-column: 1 / -1;
    flex-direction: row;
  }

  :global(.profile-card__icon) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(10,15,30,0.05);
    color: #0a0f1e;
    flex-shrink: 0;
  }

  :global(.profile-card--highlight .profile-card__icon) {
    background: rgba(10,15,30,0.08);
  }

  :global(.profile-card__body) {
    flex: 1;
    min-width: 0;
  }

  :global(.profile-card__name) {
    display: block;
    font-size: 0.9rem !important;
    font-weight: 700 !important;
    color: #0a0f1e !important;
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  :global(.profile-card__need) {
    font-size: 0.8rem !important;
    color: rgba(10,15,30,0.5) !important;
    margin: 0 0 0.625rem !important;
    line-height: 1.4;
  }

  :global(.profile-card__solution) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  :global(.profile-tag) {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.6rem;
    border-radius: 980px;
    font-size: 0.72rem !important;
    font-weight: 600 !important;
    color: #0a0f1e !important;
    background: rgba(10,15,30,0.06);
    border: 1px solid rgba(10,15,30,0.08);
    white-space: nowrap;
  }

  :global(.profile-card--highlight .profile-tag) {
    background: rgba(10,15,30,0.08);
    border-color: rgba(10,15,30,0.12);
  }

  @media (max-width: 580px) {
    :global(.profile-grid) {
      grid-template-columns: 1fr;
    }
    :global(.profile-card--highlight) {
      grid-column: 1;
    }
  }

  /* === Numeración de pasos ol === */
  .service-content__main.prose ol {
    counter-reset: step-counter;
    list-style: none;
    padding: 0;
  }

  .service-content__main.prose ol li {
    counter-increment: step-counter;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(10,15,30,0.06);
  }

  .service-content__main.prose ol li::before {
    content: counter(step-counter);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: #0a0f1e;
    color: #ffffff;
    font-size: 0.75rem;
    font-weight: 800;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* ==========================================================
     SIDEBAR WIDGETS — sistema sw
  ========================================================== */
  .service-content__sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Base widget */
  .sw {
    background: #ffffff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 16px;
    overflow: hidden;
  }

  /* Widget heading compartido */
  .sw__heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: rgba(10,15,30,0.55);
    margin: 0 0 1rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid rgba(10,15,30,0.07);
  }

  .sw__heading svg { flex-shrink: 0; opacity: 0.6; }

  /* -------------------------------------------------------
     WIDGET 1: CTA
  ------------------------------------------------------- */
  .sw--cta {
    background: linear-gradient(160deg, #0a0f1e 0%, #1a2634 100%);
    padding: 1.375rem 1.25rem;
  }

  .sw__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.75rem;
    background: rgba(37,211,102,0.15);
    border: 1px solid rgba(37,211,102,0.3);
    border-radius: 980px;
    font-size: 0.68rem;
    font-weight: 700;
    color: #25D366;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.875rem;
  }

  .sw__badge svg { color: #25D366; }

  .sw__title {
    font-size: 1rem;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }

  .sw__desc {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.55;
    margin: 0 0 1.125rem;
  }

  .sw__cta-wa {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    width: 100%;
    padding: 0.75rem 1rem;
    background: #25D366;
    color: #ffffff;
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: 10px;
    text-decoration: none;
    margin-bottom: 0.5rem;
  }
  .sw__cta-wa:hover { background: #1ebe5d; }

  .sw__cta-outline {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.65rem 1rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.18);
    color: rgba(255,255,255,0.85);
    font-size: 0.8rem;
    font-weight: 600;
    border-radius: 10px;
    text-decoration: none;
    margin-bottom: 0.875rem;
  }
  .sw__cta-outline:hover { background: rgba(255,255,255,0.1); }

  .sw__tel {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.55);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 0.75rem;
  }

  .sw__tel a {
    color: rgba(255,255,255,0.9);
    font-weight: 600;
    text-decoration: none;
  }
  .sw__tel a:hover { color: #ffffff; }

  /* -------------------------------------------------------
     WIDGET 2 + 3: Listas de links
  ------------------------------------------------------- */
  .sw--list {
    padding: 1.25rem;
  }

  .sw__link-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sw__link-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(10,15,30,0.05);
    font-size: 0.8375rem;
    color: rgba(10,15,30,0.7);
    text-decoration: none;
    font-weight: 500;
  }

  .sw__link-list li:last-child .sw__link-item { border-bottom: none; }

  .sw__link-item svg { flex-shrink: 0; color: rgba(10,15,30,0.3); }

  .sw__link-item:hover {
    color: #0a0f1e;
  }
  .sw__link-item:hover svg { color: #0a0f1e; }

  .sw__link-ver-todos {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 0.625rem;
    font-size: 0.775rem;
    font-weight: 700;
    color: #0a0f1e;
    text-decoration: none;
  }
  .sw__link-ver-todos:hover { opacity: 0.7; }

  /* -------------------------------------------------------
     WIDGET 4: Trust
  ------------------------------------------------------- */
  .sw--trust {
    padding: 1.25rem;
    background: #f8f9fa;
  }

  .sw__trust-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sw__trust-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: rgba(10,15,30,0.7);
    line-height: 1.4;
  }

  .sw__trust-list li svg { flex-shrink: 0; margin-top: 0.1rem; }
  .sw__trust-list li strong { color: #0a0f1e; font-weight: 700; }

  /* -------------------------------------------------------
     WIDGET 5: Categorías
  ------------------------------------------------------- */
  .sw__cat-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sw__cat-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0;
    border-bottom: 1px solid rgba(10,15,30,0.05);
    text-decoration: none;
    color: inherit;
  }

  .sw__cat-list li:last-child .sw__cat-item { border-bottom: none; }

  .sw__cat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: rgba(10,15,30,0.05);
    color: #0a0f1e;
    flex-shrink: 0;
  }

  .sw__cat-item:hover .sw__cat-icon { background: #0a0f1e; color: #ffffff; }

  .sw__cat-item > div {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .sw__cat-item strong {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #0a0f1e;
    line-height: 1.3;
  }

  .sw__cat-item span {
    font-size: 0.725rem;
    color: rgba(10,15,30,0.45);
  }

  .sw__cat-item > svg:last-child {
    color: rgba(10,15,30,0.25);
    flex-shrink: 0;
  }

  /* -------------------------------------------------------
     WIDGET 6: Contacto
  ------------------------------------------------------- */
  .sw--contact {
    padding: 1.25rem;
  }

  .sw__contact-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sw__contact-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0;
    border-bottom: 1px solid rgba(10,15,30,0.06);
    text-decoration: none;
    color: inherit;
  }

  .sw__contact-item:last-of-type { border-bottom: none; }

  .sw__contact-item svg {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    background: rgba(10,15,30,0.05);
    border-radius: 8px;
    padding: 7px;
    color: #0a0f1e;
    box-sizing: content-box;
  }

  .sw__contact-item--wa svg {
    background: rgba(37,211,102,0.1);
    color: #25D366;
  }

  .sw__contact-item > div {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .sw__contact-item strong {
    font-size: 0.775rem;
    font-weight: 700;
    color: #0a0f1e;
    line-height: 1.2;
  }

  .sw__contact-item span {
    font-size: 0.725rem;
    color: rgba(10,15,30,0.5);
    line-height: 1.3;
  }

  .sw__contact-item:hover strong { color: #25D366; }
  .sw__contact-item--wa:hover strong { color: #1ebe5d; }

  .sw__horario {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0 0;
    font-size: 0.725rem;
    color: rgba(10,15,30,0.45);
    border-top: 1px solid rgba(10,15,30,0.05);
    margin-top: 0.25rem;
  }

  .sw__horario svg { opacity: 0.5; }

  @media (min-width: 1024px) {
    .service-content__grid {
      grid-template-columns: 1fr 340px;
      gap: 2.5rem;
    }

    /* Sidebar no sticky — el contenido es más largo que el viewport */
    .service-content__sidebar {
      align-self: start;
    }
  }

  @media (min-width: 1280px) {
    .service-content__grid {
      grid-template-columns: 1fr 360px;
      gap: 3rem;
    }
  }

  /* Service FAQs */
  /* === FAQ + Cotización 2 columnas === */
  .sfaq-cot {
    padding: 4rem 0 5rem;
    background: var(--color-accent, #f8f9fa);
  }

  .sfaq-cot__header {
    margin-bottom: 3rem;
  }

  .sfaq-cot__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* Col header badge + título + sub */
  .sfaq-cot__col-title {
    font-size: 1.375rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
  }

  .sfaq-cot__col-sub {
    font-size: 0.9rem;
    color: rgba(10,15,30,0.55);
    line-height: 1.6;
    margin: 0 0 1.75rem;
  }

  .sfaq-cot__col-sub a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .sfaq-cot__col-header {
    margin-bottom: 1.5rem;
  }

  /* Items FAQ */
  .sfaq-cot__items {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Formulario */
  .sfaq-cot__form-card {
    background: #ffffff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 20px;
    padding: 1.75rem;
    box-shadow: 0 4px 24px rgba(10,15,30,0.06);
  }

  .sfaq-cot__form-header {
    margin-bottom: 1.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(10,15,30,0.07);
  }

  .sfaq-cot__form-header .sfaq-cot__col-sub {
    margin-bottom: 0;
  }

  @media (min-width: 768px) {
    .sfaq-cot { padding: 5rem 0 6rem; }
    .sfaq-cot__col-title { font-size: 1.5rem; }
    .sfaq-cot__form-card { padding: 2rem; }
  }

  @media (min-width: 1024px) {
    .sfaq-cot__grid {
      grid-template-columns: 1fr 480px;
      gap: 3.5rem;
    }
    .sfaq-cot__form-col {
      position: sticky;
      top: 6rem;
    }
  }

  @media (min-width: 1280px) {
    .sfaq-cot__grid {
      grid-template-columns: 1fr 520px;
      gap: 4.5rem;
    }
    .sfaq-cot__form-card { padding: 2.5rem; }
  }

  /* Servicios Complementarios */
  /* === Servicios Complementarios — ServiceCard grid === */
  .sc-section {
    padding: 4rem 0 5rem;
    background: var(--color-accent, #f8f9fa);
  }

  .sc-section__grid {
    display: grid;
    grid-template-columns: 1fr;
