    line-height: 1.6 !important;
    margin: 0 !important;
    max-width: 640px;
  }

  @media (min-width: 768px) {
    :global(.prose-section-header) { margin-bottom: 2.5rem; }
    :global(.prose-section-header) h2 { font-size: 2.125rem !important; }
    :global(.prose-section-sub) { font-size: 1.0625rem !important; }
  }

  @media (min-width: 1024px) {
    :global(.prose-section-header) h2 { font-size: 2.5rem !important; }
  }

  @media (min-width: 1280px) {
    :global(.prose-section-header) h2 { font-size: 2.75rem !important; }
  }

  /* === Numbered section block === */
  :global(.prose-section-block) {
    margin: 0 0 2rem 0;
    background: #ffffff;
    border: 1px solid rgba(10,15,30,0.07);
    border-radius: 16px;
    overflow: hidden;
  }

  :global(.prose-section-block__header) {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: #f8f9fa;
    border-bottom: 1px solid rgba(10,15,30,0.07);
  }

  :global(.prose-section-block__num) {
    font-size: 1.5rem;
    font-weight: 900;
    color: rgba(10,15,30,0.12);
    line-height: 1;
    flex-shrink: 0;
    letter-spacing: -0.04em;
  }

  :global(.prose-section-block__label) {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #25D366;
    margin-bottom: 0.25rem;
  }

  :global(.prose-section-block__title) {
    font-size: 1rem !important;
    font-weight: 800 !important;
    color: #0a0f1e !important;
    line-height: 1.25 !important;
    margin: 0 !important;
  }

  :global(.prose-section-block__title)::before { display: none !important; }

  /* === Dos columnas: texto + imágenes === */
  :global(.prose-two-col) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding: 1.5rem;
  }

  :global(.prose-two-col__text) p {
    font-size: 0.9rem;
    line-height: 1.75;
    color: rgba(10,15,30,0.7);
    margin-bottom: 1rem;
  }

  :global(.prose-two-col__text) ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  :global(.prose-two-col__text) li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid rgba(10,15,30,0.05);
    font-size: 0.875rem;
    color: rgba(10,15,30,0.7);
    line-height: 1.5;
  }

  :global(.prose-two-col__text) li:last-child { border-bottom: none; }

  :global(.prose-two-col__text) li::before {
    content: '';
    width: 6px;
    height: 6px;
    background: #25D366;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.45em;
  }

  :global(.prose-two-col__img) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  :global(.prose-two-col__img) img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 10px;
    display: block;
  }

  /* En el contexto del main (con sidebar a la derecha, ~824px disponibles)
     el two-col tiene 2 columnas de ~373px c/u.
     Las imágenes en la columna derecha deben apilarse para verse grandes. */
  @media (min-width: 768px) {
    :global(.prose-two-col) {
      grid-template-columns: 1fr 0.9fr;
      gap: 1.75rem;
      align-items: start;
    }

    /* Imágenes en 1 columna para que sean más grandes */
    :global(.prose-two-col__img) {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }

  /* === Steps === */
  :global(.prose-steps) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border: 1px solid rgba(10,15,30,0.07);
    border-radius: 16px;
    overflow: hidden;
    margin: 1.25rem 0;
  }

  :global(.prose-step) {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.125rem 1.25rem;
    border-bottom: 1px solid rgba(10,15,30,0.07);
    background: #ffffff;
  }

  :global(.prose-step):last-child { border-bottom: none; }

  :global(.prose-step):nth-child(even) { background: #fafafa; }

  :global(.prose-step__num) {
    font-size: 1.25rem;
    font-weight: 900;
    color: #0a0f1e;
    background: rgba(10,15,30,0.06);
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 0.775rem;
    letter-spacing: 0.02em;
  }

  :global(.prose-step__content) {
    flex: 1;
  }

  :global(.prose-step__content) strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    color: #0a0f1e;
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  :global(.prose-step__content) p {
    font-size: 0.825rem;
    color: rgba(10,15,30,0.55);
    line-height: 1.55;
    margin: 0;
  }

  @media (min-width: 640px) {
    :global(.prose-steps) { grid-template-columns: 1fr 1fr; }
    :global(.prose-step):nth-child(1),
    :global(.prose-step):nth-child(2) { border-bottom: 1px solid rgba(10,15,30,0.07); }
    :global(.prose-step):nth-child(3),
    :global(.prose-step):nth-child(4) { border-bottom: none; }
  }

  /* === Highlight box === */
  :global(.prose-highlight) {
    background: rgba(37,211,102,0.07);
    border-left: 3px solid #25D366;
    border-radius: 0 10px 10px 0;
    padding: 0.875rem 1.125rem;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: rgba(10,15,30,0.8);
    margin: 1.25rem 0;
  }

  /* === Galería 3 columnas === */
  :global(.prose-gallery) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  :global(.prose-gallery) figure {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(10,15,30,0.07);
    background: #f8f9fa;
  }

  :global(.prose-gallery) img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  :global(.prose-gallery) figcaption {
    padding: 0.625rem 0.875rem;
    font-size: 0.75rem;
    color: rgba(10,15,30,0.5);
    line-height: 1.4;
    font-style: normal;
  }

  @media (min-width: 640px) {
    :global(.prose-gallery) { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    :global(.prose-gallery) { grid-template-columns: repeat(3, 1fr); }
  }

  /* === Response Matrix === */
  :global(.response-matrix) {
    margin: 1.5rem 0;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(10,15,30,0.09);
    background: #fff;
  }

  :global(.response-matrix__header) {
    display: grid;
    grid-template-columns: 1fr 140px 1fr;
    gap: 0;
    background: #0a0f1e;
    padding: 0.625rem 1.25rem;
  }

  :global(.response-matrix__header) span {
    font-size: 0.72rem !important;
    font-weight: 700 !important;
    color: rgba(255,255,255,0.7) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.07em !important;
  }

  :global(.response-matrix__row) {
    display: grid;
    grid-template-columns: 1fr 140px 1fr;
    align-items: center;
    gap: 0;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid rgba(10,15,30,0.06);
    transition: background 0.15s;
  }

  :global(.response-matrix__row:last-child) {
    border-bottom: none;
  }

  :global(.response-matrix__row--red)   { border-left: 3px solid #dc2626; }
  :global(.response-matrix__row--orange) { border-left: 3px solid #ea580c; }
  :global(.response-matrix__row--blue)  { border-left: 3px solid #2563eb; }
  :global(.response-matrix__row--amber) { border-left: 3px solid #d97706; }

  :global(.response-matrix__event) {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #0a0f1e;
  }

  :global(.rm-icon) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: rgba(10,15,30,0.05);
    flex-shrink: 0;
  }

  :global(.response-matrix__row--red   .rm-icon) { background: rgba(220,38,38,0.08); color: #dc2626; }
  :global(.response-matrix__row--orange .rm-icon) { background: rgba(234,88,12,0.08); color: #ea580c; }
  :global(.response-matrix__row--blue  .rm-icon) { background: rgba(37,99,235,0.08); color: #2563eb; }
  :global(.response-matrix__row--amber .rm-icon) { background: rgba(217,119,6,0.08); color: #d97706; }

  :global(.response-matrix__time) {
    display: flex;
    justify-content: center;
  }

  :global(.rm-badge) {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    border-radius: 980px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  :global(.rm-badge--red)   { background: rgba(220,38,38,0.1);  color: #b91c1c; }
  :global(.rm-badge--orange) { background: rgba(234,88,12,0.1);  color: #c2410c; }
  :global(.rm-badge--blue)  { background: rgba(37,99,235,0.1);  color: #1d4ed8; }
  :global(.rm-badge--amber) { background: rgba(217,119,6,0.1);  color: #b45309; }

  :global(.response-matrix__action) {
    font-size: 0.8375rem;
    color: rgba(10,15,30,0.6);
    line-height: 1.5;
    padding-left: 0.5rem;
  }

  @media (max-width: 640px) {
    :global(.response-matrix__header) {
      display: none;
    }
    :global(.response-matrix__row) {
      grid-template-columns: 1fr;
      gap: 0.5rem;
      padding: 1rem 1rem 1rem 1.25rem;
    }
    :global(.response-matrix__time) {
      justify-content: flex-start;
    }
    :global(.response-matrix__action) {
      padding-left: 0;
      font-size: 0.8125rem;
    }
  }

  /* === Compare Table (vs. competencia) === */
  :global(.compare-table) {
    margin: 1.5rem 0;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(10,15,30,0.09);
    background: #fff;
  }

  /* Header */
  :global(.compare-table__head) {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    background: #0a0f1e;
  }

  :global(.compare-table__head-feature) {
    padding: 0.875rem 1.25rem;
    font-size: 0.72rem !important;
    font-weight: 700 !important;
    color: rgba(255,255,255,0.45) !important;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  :global(.compare-table__head-col) {
    padding: 0.875rem 1.25rem;
    font-size: 0.82rem !important;
    font-weight: 700 !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  :global(.compare-table__head-col--bad) {
    color: rgba(255,255,255,0.4) !important;
    border-top: 3px solid rgba(255,255,255,0.12);
  }

  :global(.compare-table__head-col--good) {
    color: #4ade80 !important;
    border-top: 3px solid #4ade80;
    background: rgba(74,222,128,0.06);
  }

  :global(.compare-table__head-col svg) {
    flex-shrink: 0;
    opacity: 0.9;
  }

  /* Rows */
  :global(.compare-table__row) {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    border-bottom: 1px solid rgba(10,15,30,0.06);
    transition: background 0.12s;
  }

  :global(.compare-table__row:last-child) {
    border-bottom: none;
  }

  :global(.compare-table__row:hover) {
    background: rgba(10,15,30,0.02);
  }

  :global(.compare-table__feature) {
    padding: 0.875rem 1.25rem;
    font-size: 0.85rem !important;
    font-weight: 600 !important;
    color: #0a0f1e !important;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-right: 1px solid rgba(10,15,30,0.06);
  }

  :global(.compare-table__feature svg) {
    color: rgba(10,15,30,0.3);
    flex-shrink: 0;
  }

  :global(.compare-table__cell) {
    padding: 0.875rem 1.25rem;
    font-size: 0.84rem !important;
    display: flex;
    align-items: center;
    line-height: 1.4;
  }

  :global(.compare-table__cell--bad) {
    color: rgba(10,15,30,0.4) !important;
    background: rgba(239,68,68,0.03);
    border-right: 1px solid rgba(10,15,30,0.06);
  }

  :global(.compare-table__cell--bad::before) {
    content: "✕";
    margin-right: 0.5rem;
    color: #ef4444;
    font-weight: 700;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  :global(.compare-table__cell--warn) {
    color: rgba(10,15,30,0.5) !important;
    background: rgba(245,158,11,0.04);
    border-right: 1px solid rgba(10,15,30,0.06);
  }

  :global(.compare-table__cell--warn::before) {
    content: "⚠";
    margin-right: 0.5rem;
    color: #f59e0b;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  :global(.compare-table__cell--good) {
    color: #166534 !important;
    font-weight: 600 !important;
    background: rgba(74,222,128,0.06);
  }

  :global(.compare-table__cell--good::before) {
    content: "✓";
    margin-right: 0.5rem;
    color: #16a34a;
    font-weight: 800;
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    :global(.compare-table__head) {
      grid-template-columns: 1fr 1fr;
    }
    :global(.compare-table__head-feature) { display: none; }
    :global(.compare-table__row) {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }
    :global(.compare-table__feature) {
      grid-column: 1 / -1;
      border-right: none;
      border-bottom: 1px solid rgba(10,15,30,0.06);
      padding-bottom: 0.5rem;
      background: rgba(10,15,30,0.02);
      font-size: 0.8rem !important;
    }
    :global(.compare-table__cell) {
      font-size: 0.78rem !important;
      padding: 0.625rem 1rem;
    }
  }

  /* === Loss Calculator — calculadora visual de merma por nivel === */
  :global(.loss-calculator) {
    margin: 1.5rem 0;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
  }

  :global(.loss-calculator__header) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: #0a0f1e;
    font-size: 0.75rem !important;
    font-weight: 700 !important;
    color: rgba(255,255,255,0.7) !important;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  :global(.loss-calculator__header svg) { opacity: 0.7; }

  :global(.loss-calculator__grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  :global(.loss-calculator__scenario) {
    padding: 1.25rem;
    border-right: 1px solid rgba(10,15,30,0.07);
  }

  :global(.loss-calculator__scenario:last-child) { border-right: none; }

  :global(.loss-calculator__scenario--accent) {
    background: rgba(10,15,30,0.03);
  }

  :global(.loss-calculator__label) {
    font-size: 0.72rem !important;
    font-weight: 700 !important;
    color: rgba(10,15,30,0.35) !important;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.15rem;
  }

  :global(.loss-calculator__sales) {
    font-size: 0.85rem !important;
    font-weight: 700 !important;
    color: #0a0f1e !important;
    margin-bottom: 0.875rem;
    line-height: 1.3;
  }

  :global(.loss-calculator__rates) {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  :global(.loss-calculator__rate) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  :global(.loss-calculator__pct) {
    font-size: 0.7rem !important;
    font-weight: 600 !important;
    color: rgba(10,15,30,0.4) !important;
  }

  :global(.loss-calculator__amount) {
    font-size: 1.375rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  :global(.loss-calculator__amount--yellow) { color: #b45309; }
  :global(.loss-calculator__amount--red) { color: #dc2626; }

  :global(.loss-calculator__year) {
    font-size: 0.72rem !important;
    color: rgba(10,15,30,0.45) !important;
  }

  :global(.loss-calculator__footer) {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.875rem 1.25rem;
    border-top: 1px solid rgba(10,15,30,0.07);
    background: rgba(10,15,30,0.02);
    font-size: 0.78rem !important;
    color: rgba(10,15,30,0.55) !important;
    line-height: 1.5;
  }

  :global(.loss-calculator__footer svg) { flex-shrink: 0; opacity: 0.5; margin-top: 0.1em; }

  @media (max-width: 640px) {
    :global(.loss-calculator__grid) { grid-template-columns: 1fr; }
    :global(.loss-calculator__scenario) { border-right: none; border-bottom: 1px solid rgba(10,15,30,0.07); }
    :global(.loss-calculator__scenario:last-child) { border-bottom: none; }
  }

  /* === Theft Methods — métodos de robo con señales de alerta === */
  :global(.theft-methods) {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 1.5rem 0;
    background: #fff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 16px;
    overflow: hidden;
  }

  :global(.theft-method) {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.125rem 1.25rem;
    border-bottom: 1px solid rgba(10,15,30,0.06);
    border-left: 3px solid rgba(220,38,38,0.4);
    transition: background 0.12s;
  }

  :global(.theft-method:last-child) { border-bottom: none; }
  :global(.theft-method:hover) { background: rgba(10,15,30,0.015); }

  :global(.theft-method__num) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: rgba(220,38,38,0.08);
    color: #dc2626 !important;
    font-size: 0.75rem !important;
    font-weight: 800 !important;
    flex-shrink: 0;
    margin-top: 0.1em;
  }

  :global(.theft-method__content) {
    flex: 1;
  }

  :global(.theft-method__content strong) {
    display: block;
    font-size: 0.875rem !important;
    font-weight: 700 !important;
    color: #0a0f1e !important;
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }

  :global(.theft-method__content p) {
    font-size: 0.8125rem !important;
    color: rgba(10,15,30,0.6) !important;
    line-height: 1.55 !important;
    margin: 0 0 0.5rem !important;
  }

  :global(.theft-method__signal) {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.3rem;
    font-size: 0.72rem !important;
    font-weight: 600 !important;
    color: #b45309 !important;
    background: rgba(245,158,11,0.08);
    padding: 0.25rem 0.5rem !important;
    border-radius: 6px;
    line-height: 1.4;
  }

  :global(.theft-method__signal::before) {
    content: '⚠';
    flex-shrink: 0;
    font-size: 0.65rem;
  }

  @media (max-width: 580px) {
    :global(.theft-method) { flex-direction: column; gap: 0.5rem; }
  }

  /* === Pillars Grid — 4 pilares del sistema de seguridad === */
  :global(.pillars-grid) {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin: 1.5rem 0;
  }

  :global(.pillar-card) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.375rem 1.25rem;
    border-radius: 16px;
    border: 1px solid rgba(10,15,30,0.08);
    background: #fff;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  :global(.pillar-card:hover) {
    box-shadow: 0 6px 24px rgba(10,15,30,0.08);
    border-color: rgba(10,15,30,0.15);
  }

  :global(.pillar-card--1) { border-top: 3px solid #0a0f1e; }
  :global(.pillar-card--2) { border-top: 3px solid #1d4ed8; }
  :global(.pillar-card--3) { border-top: 3px solid #7c3aed; }
  :global(.pillar-card--4) { border-top: 3px solid #dc2626; }

  :global(.pillar-card__num) {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: rgba(10,15,30,0.06);
    position: absolute;
    top: 0.75rem;
    right: 1rem;
  }

  :global(.pillar-card__icon) {
