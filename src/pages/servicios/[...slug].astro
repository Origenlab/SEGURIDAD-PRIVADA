---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

// Mapa de emojis por tipo de servicio
const serviceIcons: Record<string, string> = {
  'guardias-intramuros': '🛡️',
  'seguridad-condominios': '🏢',
  'seguridad-residenciales': '🏘️',
  'control-de-accesos': '🚪',
  'guardias-de-seguridad-y-vigilancia': '👮',
  'monitoreo-alarmas': '📡',
  'patrullaje': '🚔',
  'tecnologia-monitoreo-seguridad': '📹',
  'proteccion-ejecutiva': '🤵',
  'seguridad-eventos': '🎪',
  'seguridad-construccion': '🏗️',
  'seguridad-hospitalaria': '🏥',
  'custodia-de-mercancias': '📦',
  'consultoria-seguridad': '💼',
  'consultoria-analisis-riesgos': '📊',
  'investigaciones-confiabilidad': '🔍',
  'prevencion-de-perdidas': '🔒',
  'seguridad-gps-satelital': '🛰️',
  'seguridad-especializada': '⭐',
  'servicios-de-proteccion-ejecutiva-y-consultoria': '🤵',
};

export async function getStaticPaths() {
  const servicios = await getCollection('servicios');
  return servicios.map((servicio) => ({
    params: { slug: servicio.id },
    props: { servicio },
  }));
}

const { servicio } = Astro.props;
const { Content } = await render(servicio);

// Obtener datos de servicios relacionados para el cross-linking
const todosLosServicios = await getCollection('servicios', ({ data }) => !data.draft);
const serviciosRelacionados = servicio.data.relatedServices
  ? todosLosServicios
      .filter(s => servicio.data.relatedServices.includes(s.id))
      .map(s => ({
        id: s.id,
        titulo: s.data.title.split('|')[0].trim(),
        descripcion: s.data.description,
        icon: serviceIcons[s.id] || '🛡️',
      }))
  : [];

const siteUrl = 'https://seguridad-privada.com.mx';

// Build Schema.org structured data
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": `${siteUrl}/servicios/${servicio.id}#service`,
      "name": servicio.data.title.split('|')[0].trim(),
      "description": servicio.data.description,
      "provider": {
        "@id": `${siteUrl}/#business`
      },
      "areaServed": servicio.data.targetLocations?.map(loc => ({
        "@type": "City",
        "name": loc
      })) || [{ "@type": "City", "name": "Ciudad de México" }],
      "serviceType": servicio.data.pillarType || "Security Service"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Servicios",
          "item": `${siteUrl}/servicios`
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": servicio.data.title.split('|')[0].trim(),
          "item": `${siteUrl}/servicios/${servicio.id}`
        }
      ]
    }
  ]
};

// Add FAQPage schema if FAQs exist
if (servicio.data.faqs && servicio.data.faqs.length > 0) {
  schema["@graph"].push({
    "@type": "FAQPage",
    "mainEntity": servicio.data.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  });
}
---

<Base
  title={servicio.data.title}
  description={servicio.data.description}
  canonical={`${siteUrl}/servicios/${servicio.id}`}
  schema={schema}
>
  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumbs__list">
        <li><a href="/">Inicio</a></li>
        <li><a href="/servicios">Servicios</a></li>
        <li aria-current="page">{servicio.data.title.split('|')[0].trim()}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="service-hero">
    <div class="container">
      <div class="service-hero__grid">
        <div class="service-hero__content">
          {servicio.data.category === 'pillar' && (
            <span class="service-hero__badge">Servicio Principal</span>
          )}
          <h1>{servicio.data.title.split('|')[0].trim()}</h1>
          <p class="service-hero__description">{servicio.data.description}</p>

          
          <div class="service-hero__cta">
            <a href={servicio.data.ctaLink} class="btn btn-primary">{servicio.data.ctaText}</a>
            <a href="https://wa.me/525530255580" class="btn btn-whatsapp">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp
            </a>
          </div>
        </div>

        {servicio.data.heroImage && (
          <div class="service-hero__image">
            <img src={servicio.data.heroImage.src} alt={servicio.data.heroImage.alt} loading="eager" />
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Service Features -->
  {servicio.data.serviceFeatures && servicio.data.serviceFeatures.length > 0 && (
    <section class="service-features">
      <div class="container">
        <h2>¿Qué Incluye el Servicio?</h2>
        <div class="features-grid">
          {servicio.data.serviceFeatures.map((feature) => (
            <div class="feature-card">
              <h3>{feature.title}</h3>
              <p>{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Main Content -->
  <section class="service-content">
    <div class="container">
      <div class="service-content__grid">
        <div class="service-content__main prose">
          <Content />
        </div>

        <!-- Sidebar -->
        <aside class="service-content__sidebar">
          <!-- CTA Card -->
          <div class="sidebar-card sidebar-card--cta">
            <h3>¿Listo para Proteger tu Propiedad?</h3>
            <p>Solicita una evaluación de seguridad sin costo.</p>
            <a href={servicio.data.ctaLink} class="btn btn-primary btn-block">{servicio.data.ctaText}</a>
            <p class="sidebar-card__phone">
              <strong>Llámanos:</strong> <a href="tel:+525530255580">55 3025 5580</a>
            </p>
          </div>

          <!-- Related Services -->
          {servicio.data.relatedServices && servicio.data.relatedServices.length > 0 && (
            <div class="sidebar-card">
              <h4>Servicios Relacionados</h4>
              <ul class="related-list">
                {servicio.data.relatedServices.map((related) => (
                  <li><a href={`/servicios/${related}`}>{related.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}</a></li>
                ))}
              </ul>
            </div>
          )}

          <!-- Target Locations -->
          {servicio.data.targetLocations && servicio.data.targetLocations.length > 0 && (
            <div class="sidebar-card">
              <h4>Zonas de Servicio</h4>
              <ul class="locations-list">
                {servicio.data.targetLocations.map((location) => (
                  <li>{location}</li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  {servicio.data.faqs && servicio.data.faqs.length > 0 && (
    <section class="service-faqs">
      <div class="container">
        <h2>Preguntas Frecuentes</h2>
        <div class="faq-container">
          {servicio.data.faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-question">
                <span class="faq-question-text">{faq.question}</span>
                <span class="faq-icon" aria-hidden="true"></span>
              </summary>
              <div class="faq-answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Servicios Complementarios -->
  {serviciosRelacionados.length > 0 && (
    <section class="servicios-complementarios">
      <div class="container">
        <div class="servicios-complementarios__header">
          <h2>Servicios Complementarios</h2>
          <p>Soluciones de seguridad que potencian la protección de tu condominio o empresa</p>
        </div>
        <div class="servicios-complementarios__grid">
          {serviciosRelacionados.map((rel) => (
            <a href={`/servicios/${rel.id}`} class="servicios-comp__card">
              <span class="servicios-comp__icon">{rel.icon}</span>
              <div class="servicios-comp__content">
                <h3>{rel.titulo}</h3>
                <p>{rel.descripcion}</p>
              </div>
              <span class="servicios-comp__arrow">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="service-cta">
    <div class="container">
      <div class="service-cta__content">
        <h2>Protege tu Propiedad con Profesionales</h2>
        <p>Más de 15 años de experiencia en seguridad privada. Permiso SSC vigente. Guardias certificados.</p>
        <div class="service-cta__buttons">
          <a href="/contacto" class="btn btn-primary">Solicitar Cotización</a>
          <a href="https://wa.me/525530255580" class="btn btn-whatsapp">WhatsApp Directo</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Breadcrumbs */
  .breadcrumbs {
    padding: 1rem 0;
    background: var(--color-accent);
    font-size: 0.875rem;
  }

  .breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .breadcrumbs__list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumbs__list li:not(:last-child)::after {
    content: '/';
    color: var(--color-text-muted);
  }

  .breadcrumbs__list a {
    color: var(--color-text-light);
  }

  .breadcrumbs__list li[aria-current="page"] {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Service Hero */
  .service-hero {
    padding: 2rem 0 3rem;
  }

  .service-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .service-hero__badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 50px;
    margin-bottom: 1rem;
  }

  .service-hero h1 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .service-hero__description {
    font-size: 1.0625rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .service-hero__pricing {
    margin-bottom: 1.5rem;
  }

  .service-hero__price {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .service-hero__unit {
    font-size: 1rem;
    color: var(--color-text-light);
  }

  .service-hero__cta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-hero__image {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
  }

  .service-hero__image img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .service-hero {
      padding: 3rem 0 4rem;
    }

    .service-hero__grid {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }

    .service-hero h1 {
      font-size: 2.25rem;
    }

    .service-hero__cta {
      flex-direction: row;
    }
  }

  /* Service Features */
  .service-features {
    padding: 3rem 0;
    background: var(--color-accent);
  }

  .service-features h2 {
    text-align: center;
    margin-bottom: 2rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .feature-card {
    background: var(--color-white);
    padding: 1.5rem;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-sm);
  }

  .feature-card h3 {
    font-size: 1.0625rem;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    margin: 0;
    line-height: 1.6;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Service Content */
  .service-content {
    padding: 3rem 0;
  }

  .service-content__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .service-content__main.prose {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .service-content__main.prose h2 {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .service-content__main.prose h3 {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .service-content__main.prose p {
    margin-bottom: 1.25rem;
  }

  .service-content__main.prose ul,
  .service-content__main.prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .service-content__main.prose li {
    margin-bottom: 0.5rem;
  }

  /* Sidebar */
  .service-content__sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-card {
    background: var(--color-accent);
    padding: 1.5rem;
    border-radius: var(--border-radius);
  }

  .sidebar-card--cta {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .sidebar-card--cta h3 {
    color: var(--color-white);
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .sidebar-card--cta p {
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  .sidebar-card--cta .btn-primary {
    background: var(--color-white);
    color: var(--color-primary);
  }

  .sidebar-card__phone {
    margin-top: 1rem;
    margin-bottom: 0;
    font-size: 0.9375rem;
  }

  .sidebar-card__phone a {
    color: var(--color-white);
  }

  .sidebar-card h4 {
    font-size: 1rem;
    margin-bottom: 1rem;
  }

  .related-list,
  .locations-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .related-list li,
  .locations-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.9375rem;
  }

  .related-list li:last-child,
  .locations-list li:last-child {
    border-bottom: none;
  }

  .btn-block {
    display: block;
    width: 100%;
    text-align: center;
  }

  @media (min-width: 1024px) {
    .service-content__grid {
      grid-template-columns: 1fr 320px;
      gap: 3rem;
    }

    .service-content__sidebar {
      position: sticky;
      top: 2rem;
      align-self: start;
    }
  }

  /* Service FAQs */
  .service-faqs {
    padding: 3rem 0;
    background: var(--color-accent);
  }

  .service-faqs h2 {
    text-align: center;
    margin-bottom: 2rem;
  }

  .service-faqs .faq-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-white);
  }

  .faq-item:first-child {
    border-radius: var(--border-radius) var(--border-radius) 0 0;
  }

  .faq-item:last-child {
    border-radius: 0 0 var(--border-radius) var(--border-radius);
    border-bottom: none;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 1.25rem;
    cursor: pointer;
    list-style: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question-text {
    font-weight: 600;
    color: var(--color-primary);
    padding-right: 1rem;
  }

  .faq-icon {
    width: 24px;
    height: 24px;
    position: relative;
    flex-shrink: 0;
  }

  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background: var(--color-primary);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.3s ease;
  }

  .faq-icon::before {
    width: 12px;
    height: 2px;
  }

  .faq-icon::after {
    width: 2px;
    height: 12px;
  }

  .faq-item[open] .faq-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .faq-answer {
    padding: 0 1.25rem 1.25rem;
  }

  .faq-answer p {
    color: var(--color-text-light);
    line-height: 1.7;
    margin: 0;
  }

  /* Servicios Complementarios */
  .servicios-complementarios {
    padding: 3rem 0;
    background: var(--color-accent);
  }

  .servicios-complementarios__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .servicios-complementarios__header h2 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .servicios-complementarios__header p {
    color: var(--color-text-light);
    font-size: 1rem;
  }

  .servicios-complementarios__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .servicios-comp__card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .servicios-comp__card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    transform: translateY(-2px);
    opacity: 1;
  }

  .servicios-comp__icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 0.1rem;
  }

  .servicios-comp__content {
    flex: 1;
  }

  .servicios-comp__content h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.3rem;
  }

  .servicios-comp__content p {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .servicios-comp__arrow {
    font-size: 1.25rem;
    color: var(--color-primary);
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.2s ease, transform 0.2s ease;
    align-self: center;
  }

  .servicios-comp__card:hover .servicios-comp__arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  @media (min-width: 640px) {
    .servicios-complementarios__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .servicios-complementarios__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Service CTA */
  .service-cta {
    padding: 4rem 0;
    background: var(--color-primary);
    color: var(--color-white);
    text-align: center;
  }

  .service-cta h2 {
    color: var(--color-white);
    margin-bottom: 1rem;
  }

  .service-cta p {
    opacity: 0.9;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .service-cta__buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  .service-cta .btn-primary {
    background: var(--color-white);
    color: var(--color-primary);
  }

