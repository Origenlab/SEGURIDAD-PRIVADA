  /* === Methodology Flow — flujo de metodología en 4 pasos === */
  :global(.methodology-flow) {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin: 1.5rem 0;
    background: #fff;
    border: 1px solid rgba(10,15,30,0.08);
