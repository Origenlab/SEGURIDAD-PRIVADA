  /* === Patrol Coverage — cobertura por turno con barras de intensidad === */
  :global(.patrol-coverage) {
    margin: 1.5rem 0;
    background: #fff;
    border: 1px solid rgba(10,15,30,0.08);
    border-radius: 16px;
    overflow: hidden;
