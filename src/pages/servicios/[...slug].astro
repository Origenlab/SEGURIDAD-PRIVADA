  :global(.threat-level:last-child) { border-bottom: none; }
  :global(.threat-level:hover) { background: rgba(10,15,30,0.015); }

  :global(.threat-level--green)  { border-left: 3px solid #16a34a; }
  :global(.threat-level--yellow) { border-left: 3px solid #ca8a04; }
  :global(.threat-level--orange) { border-left: 3px solid #ea580c; }
  :global(.threat-level--red)    { border-left: 3px solid #dc2626; }

  :global(.threat-level__profile p) {
    font-size: 0.78rem !important;
