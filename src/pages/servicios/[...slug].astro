  :global(.threat-level__badge--green)  { background: rgba(22,163,74,0.1);  color: #15803d !important; }
  :global(.threat-level__badge--yellow) { background: rgba(202,138,4,0.1);  color: #a16207 !important; }
  :global(.threat-level__badge--orange) { background: rgba(234,88,12,0.1);  color: #c2410c !important; }
  :global(.threat-level__badge--red)    { background: rgba(220,38,38,0.1);  color: #b91c1c !important; }

  :global(.threat-level__coverage) {
