  /* === Deliverables Grid — entregables del servicio === */
  :global(.deliverables-grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 1.5rem 0;
  }

  :global(.deliverable-card) {
    display: flex;
