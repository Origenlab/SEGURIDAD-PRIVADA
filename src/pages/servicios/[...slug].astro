  :global(.threat-level--yellow .threat-level__indicator span:not(.inactive)) { background: #ca8a04; }
  :global(.threat-level--orange .threat-level__indicator span:not(.inactive)) { background: #ea580c; }
  :global(.threat-level--red    .threat-level__indicator span:not(.inactive)) { background: #dc2626; }
  :global(.threat-level__indicator span.inactive) { background: rgba(10,15,30,0.1); }

