---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import GallerySection from '../../components/GallerySection.astro';

const title = 'Seguridad Privada Hospitalaria CDMX | Guardias para Hospitales y Clínicas';
const description = 'Seguridad privada para hospitales y clínicas en CDMX. Guardias intramuros certificados SSC especializados en entornos médicos. +15 años. ☎ 55 3025 5580';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Seguridad Hospitalaria",
  "description": "Seguridad privada para hospitales y clínicas en CDMX. Guardias intramuros certificados SSC especializados en entornos médicos. +15 años. ☎ 55 3025 5580",
  "provider": {
    "@type": "Organization",
    "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "url": "https://seguridad-privada.com.mx/"
  },
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "telephone": "+52-55-3025-5580"
});

const gallery = [
  { src: '/img/img-hospitalaria/control-accesos-hospitales-cdmx.avif', alt: 'Control de accesos en recepción de hospitales privados CDMX', captionTitle: 'Control de Accesos', captionText: 'Gestión de accesos en recepción con atención empática a familias' },
  { src: '/img/img-hospitalaria/seguridad-areas-restringidas-hospitales.avif', alt: 'Protección de áreas críticas y restringidas en hospitales', captionTitle: 'Áreas Críticas', captionText: 'Protección rigurosa de quirófanos, terapia intensiva y áreas restringidas' },
  { src: '/img/img-hospitalaria/prevencion-secuestro-recien-nacidos.avif', alt: 'Prevención de secuestro de recién nacidos en maternidad', captionTitle: 'Seguridad en Maternidad', captionText: 'Prevención de secuestro y verificación rigurosa que tranquiliza padres' },
  { src: '/img/img-hospitalaria/vigilancia-farmacia-hospitalaria.avif', alt: 'Custodia y vigilancia de farmacia hospitalaria interna', captionTitle: 'Farmacia Interna', captionText: 'Custodia especializada de medicamentos controlados de alto valor' },
  { src: '/img/img-hospitalaria/personal-certificado-hospitales-privados.avif', alt: 'Personal certificado SSC y RCP para hospitales privados', captionTitle: 'Personal Certificado', captionText: 'Guardias con certificación SSC, RCP y capacitación en empatía hospitalaria' },
  { src: '/img/img-hospitalaria/gestion-conflictos-urgencias-medicas.avif', alt: 'Gestión de conflictos y situaciones emocionales en urgencias', captionTitle: 'Manejo de Crisis', captionText: 'Des-escalación profesional de situaciones emocionales en urgencias' },
  { src: '/img/img-hospitalaria/proteccion-personal-medico-enfermeria.avif', alt: 'Protección de personal médico y enfermería en hospitales', captionTitle: 'Protección al Personal Médico', captionText: 'Respaldo inmediato a médicos y enfermería ante situaciones conflictivas' },
  { src: '/img/img-hospitalaria/proteccion-equipos-medicos-alto-valor.avif', alt: 'Custodia de equipos médicos de alto valor en hospitales', captionTitle: 'Equipos Médicos', captionText: 'Custodia de equipos médicos de alto valor y tecnología especializada' },
  { src: '/img/img-hospitalaria/patrullaje-instalaciones-hospitalarias.avif', alt: 'Patrullaje y rondines en instalaciones hospitalarias 24/7', captionTitle: 'Rondines Nocturnos', captionText: 'Vigilancia 24/7 con patrullaje sistemático en todas las instalaciones' },
];
---
<BaseLayout title={title} description={description} schema={schema}>
  <Hero
    title="Seguridad Hospitalaria en CDMX"
    subtitle="Protegemos Pacientes Vulnerables Sin Añadir Trauma a Familias en Crisis"
    description='Balance perfecto entre protocolos médicos y humanidad. Guardias certificados SSC especializados en sensibilidad hospitalaria.'
    card1Title="Cuando empatía y firmeza deben coexistir"
    card1Text='Son las 2 AM. Una familia desesperada exige entrar a terapia intensiva fuera de horario. Su ser querido está en estado crítico. La respuesta correcta determinará si protegiste al paciente vulnerable... o si generaste una queja que costará la reputación de tu hospital premium por noche.'
    card2Title="Firmeza absoluta con empatía genuina"
    card2Text='En ORIGINS, entendemos que la seguridad hospitalaria enfrenta el balance más delicado: aplicar protocolos médicos estrictos mientras manejas el dolor humano más profundo. Nuestros guardias certificados SSC especializados dominan firmeza en áreas críticas (quirófanos, maternidad, farmacia) con empatía hacia familias que atraviesan momentos de vida o muerte.'
  />

  {gallery.length > 0 && <GallerySection items={gallery} />}

  <section class="attention-box" style="max-width:1200px;margin:40px auto;padding:48px">
    <h2 class="attention-box__title">El Equilibrio Imposible Que Dominamos: Empatía + Firmeza Sin Compromiso</h2>
    <p class="attention-box__text">Una familia rompe en llanto exigiendo ver a su ser querido en terapia intensiva a las 3 AM, fuera de horario de visitas que protegen a todos los pacientes críticos. Un padre desesperado amenaza con demandas porque no puede entrar con celular a la sala donde su hijo recién nacido está en observación. Cada situación requiere firmeza absoluta en protocolos médicos + empatía genuina que previene quejas devastadoras.</p>
    <p class="attention-box__text">Nuestros guardias certificados SSC con capacitación intensiva en manejo de crisis emocionales dominan técnicas de des-escalación que protegen sin traumatizar. Entendemos que proteger pacientes vulnerables no puede generar quejas de pacientes que pagan tarifas premium por tratamiento.</p>
  </section>

  <section class="cta-business">
    <div class="cta-business__content">
      <h2 class="cta-business__title">¿Necesita Proteger su Empresa o Condominio?</h2>
      <p class="cta-business__description">Únase a las empresas líderes y condominios de prestigio que confían en nuestra experiencia</p>
      <div class="cta-business__actions">
        <a href="https://wa.me/525530255580?text=Hola,%20necesito%20información%20sobre%20servicios%20de%20seguridad%20privada" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/cotizar" class="cta-business__btn cta-business__btn--secondary">Cotizar en Línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
