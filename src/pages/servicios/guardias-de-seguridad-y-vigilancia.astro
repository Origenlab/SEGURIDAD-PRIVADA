---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import GallerySection from '../../components/GallerySection.astro';

const title = 'Guardias de Seguridad Intramuros CDMX | Vigilancia para Condominios 24/7';
const description = 'Guardias de seguridad intramuros certificados SSC para condominios y empresas en CDMX. Vigilancia 24/7 y control de accesos. ☎ 55 3025 5580';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Guardias de Seguridad y Vigilancia",
  "description": "Guardias de seguridad intramuros certificados SSC para condominios y empresas en CDMX. Vigilancia 24/7 y control de accesos. ☎ 55 3025 5580",
  "provider": {
    "@type": "Organization",
    "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "url": "https://seguridad-privada.com.mx/"
  },
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "telephone": "+52-55-3025-5580"
});

const gallery = [];
---
<BaseLayout title={title} description={description} schema={schema}>
  <Hero
    title="Guardias de Seguridad Intramuros en CDMX"
    subtitle="La Única Diferencia Entre Dormir Preocupado y Dormir Tranquilo Son Guardias Certificados SSC que Sí Funcionan"
    description='Vigilancia profesional para condominios, residenciales y empresas. +15 años de experiencia, supervisión GPS en tiempo real y respuesta en menos de 3 minutos.'
    card1Title="Guardias que realmente vigilan, no que calientan silla"
    card1Text='¿Alguna vez contrataste guardias y te decepcionó encontrar personal que solo "calienta la silla"? Con más de 15 años protegiendo empresas y condominios en CDMX, hemos aprendido que la seguridad no es solo poner un uniforme en la puerta: es confiar en personas verificadas, honestas y capacitadas que previenen problemas antes de que ocurran. Cada guardia pasa por exámenes psicométricos, verificación exhaustiva de antecedentes y evaluaciones de confiabilidad.'
    card2Title="Supervisión en tiempo real que garantiza resultados"
    card2Text='La diferencia con nosotros es simple: supervisión GPS en tiempo real de cada guardia, bitácoras digitales que puedes ver desde tu celular y respuesta en menos de 3 minutos ante emergencias. Todos nuestros elementos tienen certificación SSC vigente, uniformes impecables, equipos de comunicación profesionales y respaldo de pólizas de responsabilidad civil. Profesionales certificados cuidando tu patrimonio.'
  />

  {gallery.length > 0 && <GallerySection items={gallery} />}

  <section class="attention-box" style="max-width:1200px;margin:40px auto;padding:48px">
    <h2 class="attention-box__title">La Diferencia Entre Dormir Preocupado y Dormir Tranquilo</h2>
    <p class="attention-box__text">En más de 15 años protegiendo empresas y condominios en CDMX, hemos aprendido que la seguridad no es solo poner un uniforme en la puerta: es confiar en personas verificadas, honestas y capacitadas que previenen problemas antes de que ocurran.</p>
    <p class="attention-box__text">Cada guardia de ORIGINS pasa por exámenes psicométricos, verificación exhaustiva de antecedentes y evaluaciones de confiabilidad. Supervisión GPS en tiempo real, bitácoras digitales y respuesta en menos de 3 minutos ante emergencias.</p>
  </section>

  <section class="cta-business">
    <div class="cta-business__content">
      <h2 class="cta-business__title">¿Necesita Proteger su Empresa o Condominio?</h2>
      <p class="cta-business__description">Únase a las empresas líderes y condominios de prestigio que confían en nuestra experiencia</p>
      <div class="cta-business__actions">
        <a href="https://wa.me/525530255580?text=Hola,%20necesito%20información%20sobre%20servicios%20de%20seguridad%20privada" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/cotizar" class="cta-business__btn cta-business__btn--secondary">Cotizar en Línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
