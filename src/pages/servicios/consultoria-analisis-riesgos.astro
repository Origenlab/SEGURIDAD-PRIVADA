---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import GallerySection from '../../components/GallerySection.astro';

const title = 'Análisis de Riesgos de Seguridad Privada CDMX | Consultoría ISO 31000';
const description = 'Análisis de riesgos de seguridad privada para empresas y condominios en CDMX. Metodología ISO 31000, matrices ejecutivas. ☎ 55 3025 5580';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Análisis de Riesgos Corporativos",
  "description": "Análisis de riesgos de seguridad privada para empresas y condominios en CDMX. Metodología ISO 31000, matrices ejecutivas. ☎ 55 3025 5580",
  "provider": {
    "@type": "Organization",
    "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "url": "https://seguridad-privada.com.mx/"
  },
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "telephone": "+52-55-3025-5580"
});

const gallery = [
  { src: '/img/analisis-de-riesgos/identificacion-puntos-criticos-seguridad.avif', alt: 'Identificación de activos críticos', captionTitle: 'Identificación de Activos Críticos', captionText: 'Inventario sistemático de activos empresariales prioritarios' },
  { src: '/img/analisis-de-riesgos/evaluacion-amenazas-seguridad-empresarial-cdmx.avif', alt: 'Evaluación de amenazas', captionTitle: 'Evaluación de Amenazas Externas e Internas', captionText: 'Análisis de vectores de ataque y probabilidades' },
  { src: '/img/analisis-de-riesgos/recomendaciones-mitigacion-riesgos-seguridad.avif', alt: 'Cuantificación de pérdidas', captionTitle: 'Cuantificación de Pérdidas Potenciales', captionText: 'Cálculo de impacto financiero por escenario de riesgo' },
  { src: '/img/analisis-de-riesgos/matriz-riesgos-seguridad-corporativa.avif', alt: 'Matriz Heat Map', captionTitle: 'Matriz Heat Map de Riesgos', captionText: 'Visualización ejecutiva de probabilidad vs impacto' },
  { src: '/img/analisis-de-riesgos/mapeo-vulnerabilidades-instalaciones-corporativas.avif', alt: 'Análisis de vulnerabilidades', captionTitle: 'Análisis de Vulnerabilidades Operativas', captionText: 'Identificación de brechas de seguridad existentes' },
  { src: '/img/analisis-de-riesgos/plan-implementacion-mejoras-seguridad.avif', alt: 'Priorización de inversiones', captionTitle: 'Priorización de Inversiones', captionText: 'Roadmap de mitigación ordenado por ROI' },
  { src: '/img/analisis-de-riesgos/diagnostico-sistemas-seguridad-existentes.avif', alt: 'Evaluación de controles', captionTitle: 'Evaluación de Controles Existentes', captionText: 'Análisis de efectividad de medidas actuales' },
  { src: '/img/analisis-de-riesgos/estudios-seguridad-fisica-perimetral.avif', alt: 'Escenarios de crisis', captionTitle: 'Modelado de Escenarios de Crisis', captionText: 'Simulación de impactos por materialización de riesgos' },
  { src: '/img/analisis-de-riesgos/analisis-riesgos-metodologia-iso-31000.avif', alt: 'Compliance ISO 31000', captionTitle: 'Compliance ISO 31000', captionText: 'Documentación certificable para auditorías' },
];
---
<BaseLayout title={title} description={description} schema={schema}>
  <Hero
    title="Análisis de Riesgos Corporativos"
    subtitle="Metodología ISO 31000 con Matrices Heat Map en CDMX"
    description='ORIGINS Private Security: Evaluación de amenazas, cuantificación de pérdidas potenciales y priorización de inversiones. Identifica vulnerabilidades críticas antes de desperdiciar presupuesto. +15 años aplicando ISO 31000 en empresas Fortune 500.'
    card1Title="Priorización estratégica, no intuición"
    card1Text='La mayoría de empresas invierten en sistemas costosos para riesgos de bajo impacto mientras ignoran vulnerabilidades críticas. Un análisis profesional le permite tomar decisiones basadas en datos cuantificables, no en percepciones o miedos infundados.'
    card2Title="Heat Map ejecutivo en una página"
    card2Text='Matriz visual que muestra qué amenazas pueden quebrar su empresa vs. cuáles son ruido. Identificamos activos críticos, cuantificamos pérdida potencial por amenaza y priorizamos inversiones por ROI de protección. Decisiones claras, inversión inteligente.'
  />

  {gallery.length > 0 && <GallerySection items={gallery} />}

  <section class="attention-box" style="max-width:1200px;margin:40px auto;padding:48px">
    <h2 class="attention-box__title">Por Qué Invertir en Seguridad Sin Análisis de Riesgos Es Gastar a Ciegas</h2>
    <p class="attention-box__text">La mayoría de empresas gastan presupuesto de seguridad sin priorización estratégica: invierten en sistemas costosos para riesgos de bajo impacto mientras ignoran vulnerabilidades críticas. El análisis de riesgos cuantifica pérdida potencial esperada por cada amenaza y prioriza inversiones por ROI de protección real.</p>
    <p class="attention-box__text">Evite desperdiciar presupuesto en riesgos irrelevantes mientras deja expuestos activos críticos. Nuestro análisis ISO 31000 le proporciona datos cuantificables para decisiones informadas, matrices Heat Map ejecutivas que visualizan prioridades en una página y roadmaps de mitigación que maximizan retorno de cada peso invertido en seguridad.</p>
  </section>

  <section class="cta-business">
    <div class="cta-business__content">
      <h2 class="cta-business__title">¿Necesita Proteger su Empresa o Condominio?</h2>
      <p class="cta-business__description">Únase a las empresas líderes y condominios de prestigio que confían en nuestra experiencia</p>
      <div class="cta-business__actions">
        <a href="https://wa.me/525530255580?text=Hola,%20necesito%20información%20sobre%20servicios%20de%20seguridad%20privada" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/cotizar" class="cta-business__btn cta-business__btn--secondary">Cotizar en Línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
