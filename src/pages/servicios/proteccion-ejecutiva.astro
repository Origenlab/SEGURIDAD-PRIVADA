---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import GallerySection from '../../components/GallerySection.astro';

const title = 'Protección Ejecutiva y Seguridad Privada CDMX | Escoltas Certificados SSC';
const description = 'Protección ejecutiva y seguridad privada en CDMX. Escoltas certificados SSC, análisis de amenazas y transporte blindado para ejecutivos. ☎ 55 3025 5580';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Protección Ejecutiva Discreta",
  "description": "Protección ejecutiva y seguridad privada en CDMX. Escoltas certificados SSC, análisis de amenazas y transporte blindado para ejecutivos. ☎ 55 3025 5580",
  "provider": {
    "@type": "Organization",
    "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "url": "https://seguridad-privada.com.mx/"
  },
  "areaServed": { "@type": "City", "name": "Ciudad de México" },
  "telephone": "+52-55-3025-5580"
});

const gallery = [
  { src: '/img/img-proteccion-ejecutiva/escoltas-profesionales-ejecutivos-cdmx.avif', alt: 'Escolta ejecutivo certificado SSC para CEO en CDMX', captionTitle: 'Escoltas Certificados SSC', captionText: 'Personal con formación en fuerzas especiales y certificación vigente' },
  { src: '/img/img-proteccion-ejecutiva/vehiculos-blindados-proteccion-ejecutiva.avif', alt: 'Vehículo blindado para protección ejecutiva empresarial', captionTitle: 'Transporte Blindado Ejecutivo', captionText: 'Vehículos nivel III-A con sistemas de seguridad avanzados' },
  { src: '/img/img-proteccion-ejecutiva/analisis-amenazas-seguridad-ejecutiva.avif', alt: 'Análisis de amenazas para directores generales CDMX', captionTitle: 'Análisis de Amenazas OSINT', captionText: 'Inteligencia preventiva y evaluación de riesgo ejecutivo' },
  { src: '/img/img-proteccion-ejecutiva/proteccion-personal-directores-generales.avif', alt: 'Protección ejecutiva en eventos corporativos empresariales', captionTitle: 'Seguridad en Eventos Corporativos', captionText: 'Protección discreta durante conferencias y presentaciones' },
  { src: '/img/img-proteccion-ejecutiva/coordinacion-autoridades-proteccion-vip.avif', alt: 'Coordinación 24/7 para protección de ejecutivos C-level', captionTitle: 'Coordinación 24/7', captionText: 'Centro de control con monitoreo continuo y respuesta inmediata' },
  { src: '/img/img-proteccion-ejecutiva/guardaespaldas-certificados-alto-perfil.avif', alt: 'Protección familiar para ejecutivos de alto perfil', captionTitle: 'Protección Familiar Extendida', captionText: 'Seguridad para familiares directos de ejecutivos VIP' },
  { src: '/img/img-proteccion-ejecutiva/seguridad-ejecutiva-discreta-cdmx.avif', alt: 'Entrenamiento táctico para escoltas ejecutivos', captionTitle: 'Entrenamiento Táctico Continuo', captionText: 'Certificaciones internacionales y simulacros mensuales' },
  { src: '/img/img-proteccion-ejecutiva/protocolos-emergencia-seguridad-ejecutiva.avif', alt: 'Comunicación encriptada TETRA para protección ejecutiva', captionTitle: 'Comunicación Encriptada TETRA', captionText: 'Radios digitales con encriptación AES-256 gubernamental' },
  { src: '/img/img-proteccion-ejecutiva/rutas-seguras-traslado-ejecutivos.avif', alt: 'Planificación de rutas seguras para directivos empresariales', captionTitle: 'Planificación de Rutas Seguras', captionText: 'Análisis previo con rutas alternas y puntos de escape' },
];
---
<BaseLayout title={title} description={description} schema={schema}>
  <Hero
    title="Protección Ejecutiva Discreta"
    subtitle="Escoltas Ex-Fuerzas Especiales para CEOs y C-Level en CDMX"
    description='ORIGINS Private Security: Close protection con escoltas certificados SSC, formación en fuerzas especiales, transporte blindado nivel III-A y análisis de amenazas OSINT/HUMINT. 100% tasa de éxito en 18+ años protegiendo ejecutivos de alto perfil.'
    card1Title="Due diligence corporativa, no vanidad"
    card1Text='Para CEOs, directores generales y ejecutivos C-level con exposición mediática, toma de decisiones estratégicas y responsabilidad fiduciaria. La seguridad personal documentable ante auditorías de cumplimiento es responsabilidad corporativa obligatoria, no lujo.'
    card2Title="ROI claro: protección vs. secuestro"
    card2Text='Costo de un secuestro ejecutivo: $2-5M USD más trauma organizacional irrecuperable. Nuestros agentes operan con perfil bajo sin comprometer la cobertura. Protección discreta coordinada 24/7 con C4 y servicios médicos. Inversión mensual = 0.01% del riesgo total.'
  />

  {gallery.length > 0 && <GallerySection items={gallery} />}

  <section class="attention-box" style="max-width:1200px;margin:40px auto;padding:48px">
    <h2 class="attention-box__title">Por Qué la Protección Ejecutiva Inadecuada Es Responsabilidad Fiduciaria Evitable</h2>
    <p class="attention-box__text">Cuando un director general, CFO o miembro del consejo sufre secuestro, extorsión o ataque violento, la responsabilidad legal y reputacional recae sobre la junta directiva que no implementó medidas razonables de protección. Jurisprudencia corporativa establece que consejeros tienen deber fiduciario de proteger activos críticos de la organización, incluyendo capital humano ejecutivo que toma decisiones estratégicas. Auditorías de gestión de riesgo empresarial (ERM) evalúan protocolos de protección ejecutiva como indicador de gobernanza corporativa responsable.</p>
    <p class="attention-box__text">Más allá del cumplimiento normativo, el costo económico de perder a un CEO por secuestro incluye: rescate promedio $2-5M USD, caída bursátil inmediata del 8-15% en empresas públicas, interrupción operacional de 3-6 meses, pérdida de confianza de stakeholders, y trauma organizacional con rotación ejecutiva posterior del 40%. En contraste, protección ejecutiva profesional mensual representa 0.01% de ese riesgo financiero total. Para comités de auditoría y gestión de riesgos, NO invertir en protección ejecutiva certificada es negligencia cuantificable ante shareholders.</p>
  </section>

  <section class="cta-business">
    <div class="cta-business__content">
      <h2 class="cta-business__title">¿Necesita Proteger su Empresa o Condominio?</h2>
      <p class="cta-business__description">Únase a las empresas líderes y condominios de prestigio que confían en nuestra experiencia</p>
      <div class="cta-business__actions">
        <a href="https://wa.me/525530255580?text=Hola,%20necesito%20información%20sobre%20servicios%20de%20seguridad%20privada" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/cotizar" class="cta-business__btn cta-business__btn--secondary">Cotizar en Línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
