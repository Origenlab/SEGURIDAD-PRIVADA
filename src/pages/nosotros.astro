---
import Base from '../layouts/Base.astro';
import HeroPagina from '../components/HeroPagina.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CredentialsCard from '../components/CredentialsCard.astro';
import PageCTA from '../components/PageCTA.astro';
import { homepageCredentials } from '../data/homepage-credentials';
import '../styles/pages/nosotros.css';

const siteUrl = 'https://seguridad-privada.com.mx';

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": `${siteUrl}/nosotros`,
  "name": "Nosotros — ORIGINS Private Security | Empresa de Seguridad Privada en CDMX",
  "description": "Más de 15 años protegiendo condominios, residenciales y empresas en CDMX. Guardias intramuros certificados SSC, monitoreo 24/7 y tecnología de vanguardia.",
  "url": `${siteUrl}/nosotros`,
  "mainEntity": {
    "@type": ["Organization", "LocalBusiness"],
    "@id": `${siteUrl}/#organization`,
    "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "legalName": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "alternateName": ["ORIGINS Private Security", "Origins Security CDMX"],
    "url": siteUrl,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/img/logo.avif`,
      "width": 372,
      "height": 100
    },
    "image": `${siteUrl}/img/logo.avif`,
    "foundingDate": "2008",
    "description": "Empresa especializada en seguridad privada para condominios y residenciales en CDMX. Guardias intramuros certificados SSC, control de accesos 24/7, monitoreo CCTV y protocolos específicos para comunidades residenciales. Permiso SSC 0102-15.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Basiliso Romo Anguiano No 22 int 3",
      "addressLocality": "Ciudad de México",
      "addressRegion": "CDMX",
      "postalCode": "07800",
      "addressCountry": "MX"
    },
    "telephone": "+52-55-3025-5580",
    "email": "contacto@seguridad-privada.com.mx",
    "hasCredential": {
      "@type": "EducationalOccupationalCredential",
      "name": "Permiso SSC 0102-15",
      "credentialCategory": "Permiso de Seguridad Privada",
      "recognizedBy": {
        "@type": "Organization",
        "name": "Secretaría de Seguridad Ciudadana de la Ciudad de México"
      }
    },
    "areaServed": [
      { "@type": "City", "name": "Ciudad de México" },
      { "@type": "City", "name": "Naucalpan" },
      { "@type": "City", "name": "Tlalnepantla" },
      { "@type": "City", "name": "Atizapán" }
    ]
  }
};

const timelineEvents = [
  { year: '2008', titulo: 'Fundación de ORIGINS', descripcion: 'Nacemos como empresa especializada en seguridad intramuros para condominios en la Zona Metropolitana de la Ciudad de México.' },
  { year: '2012', titulo: 'Certificación SSC', descripcion: 'Obtenemos el Permiso SSC 0102-15 ante la Secretaría de Seguridad Ciudadana, consolidando nuestro cumplimiento legal y operativo.' },
  { year: '2015', titulo: 'Expansión Zona Metropolitana', descripcion: 'Ampliamos operaciones a Naucalpan, Tlalnepantla, Atizapán e Interlomas. Superamos los 20 condominios protegidos.' },
  { year: '2018', titulo: 'Tecnología de Monitoreo', descripcion: 'Incorporamos plataforma de monitoreo CCTV y bitácoras digitales. Iniciamos el servicio de reportes mensuales a administraciones.' },
  { year: '2021', titulo: '+40 Condominios', descripcion: 'Superamos los 40 desarrollos residenciales activos. Implementamos supervisión semanal documentada en todas las unidades.' },
  { year: '2024', titulo: '+50 Comunidades Protegidas', descripcion: 'Más de 50 condominios y fraccionamientos confían en ORIGINS. Reforzamos el programa de capacitación continua y exámenes de confiabilidad.' }
];

const diferenciadores = [
  {
    titulo: 'Especialización Exclusiva',
    descripcion: 'Solo trabajamos con condominios y residenciales. Cada protocolo está diseñado para la convivencia en comunidad, no para entornos corporativos o industriales.',
    svg: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>'
  },
  {
    titulo: 'Guardias que Conocen a los Residentes',
    descripcion: 'Nuestros elementos permanecen en el mismo desarrollo por meses o años, generando confianza real con cada familia y conociendo patrones de acceso normales.',
    svg: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>'
  },
  {
    titulo: 'Cumplimiento Legal Total',
    descripcion: 'Permiso SSC 0102-15 vigente, alta IMSS-INFONAVIT desde el primer día, póliza de responsabilidad civil y facturación fiscal completa.',
    svg: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>'
  },
  {
    titulo: 'Supervisión Documentada',
    descripcion: 'Visitas de supervisión cada semana, reportes mensuales a la administración y bitácora digital de incidencias accesible en tiempo real.',
    svg: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>'
  },
  {
    titulo: 'Sin Rotación Constante',
    descripcion: 'Ofrecemos estabilidad laboral real a nuestros guardias, lo que se traduce en menor rotación y mayor compromiso con el desarrollo al que están asignados.',
    svg: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>'
  },
  {
    titulo: 'Respuesta en Horas',
    descripcion: 'Cualquier incidencia o solicitud de cambio tiene respuesta en menos de 2 horas. Contamos con supervisores en campo disponibles las 24 horas.',
    svg: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>'
  }
];
---

<Base
  title="Nosotros | ORIGINS Private Security CDMX — Desde 2008"
  description="Empresa de seguridad privada en CDMX con +15 años especializados en condominios y residenciales. Guardias certificados SSC, póliza de responsabilidad civil y supervisión semanal documentada."
  canonical={`${siteUrl}/nosotros`}
  schema={schema}
>

  <HeroPagina
    badge="Empresa de Seguridad Privada"
    titulo="Empresa de Seguridad Privada para Condominios en CDMX — Desde 2008"
    descripcion="Más de 15 años especializados exclusivamente en comunidades residenciales. Guardias certificados SSC, póliza de responsabilidad civil y supervisión semanal documentada."
    breadcrumb={[{ label: 'Nosotros', href: '/nosotros' }]}
    ctaPrimario={{ texto: 'Ver Nuestros Servicios', href: '/servicios' }}
    ctaWhatsapp={true}
    seoParrafo1='<strong>ORIGINS PRIVATE SECURITY S.A. DE C.V.</strong> nació en 2008 con un objetivo claro: especializarse en la seguridad de comunidades residenciales, no en todo a la vez. Hoy somos la empresa de referencia en CDMX para condominios verticales, fraccionamientos privados y desarrollos corporativos. Cada <a href="/servicios/guardias-intramuros">guardia intramuros</a> que colocamos pasa por verificación de antecedentes, exámenes psicométricos y capacitación específica para entornos residenciales.'
    seoParrafo2='Operamos con <strong>Permiso SSC 0102-15</strong>, póliza de responsabilidad civil vigente y cumplimiento total de obligaciones laborales. Más de 50 comunidades en CDMX y <a href="/zonas">Zona Metropolitana</a> confían en ORIGINS porque entregamos supervisión semanal documentada, bitácoras digitales y un proceso transparente desde la primera visita hasta el cierre del contrato.'
  />

  <!-- Stats -->
  <section class="nos-stats" aria-label="Métricas de la empresa">
    <div class="container">
      <div class="nos-stats__grid">
        <div class="nos-stat-item">
          <span class="nos-stat-item__number">+15</span>
          <span class="nos-stat-item__label">Años de experiencia</span>
        </div>
        <div class="nos-stat-item">
          <span class="nos-stat-item__number">+50</span>
          <span class="nos-stat-item__label">Condominios protegidos</span>
        </div>
        <div class="nos-stat-item">
          <span class="nos-stat-item__number">200+</span>
          <span class="nos-stat-item__label">Guardias certificados</span>
        </div>
        <div class="nos-stat-item">
          <span class="nos-stat-item__number">24/7</span>
          <span class="nos-stat-item__label">Operación continua</span>
        </div>
      </div>
    </div>
  </section>

  <!-- About oscuro con credenciales -->
  <section class="nos-about" aria-labelledby="nos-about-title">
    <div class="container">
      <div class="nos-about__grid">

        <!-- Columna izquierda -->
        <div class="nos-about__content">
          <span class="nos-about__badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            Permiso SSC 0102-15 Vigente
          </span>

          <h2 id="nos-about-title" class="nos-about__titulo">¿Por qué ORIGINS?</h2>

          <div class="nos-about__texto">
            <p><strong>ORIGINS PRIVATE SECURITY S.A. DE C.V.</strong> trabaja exclusivamente con condominios, fraccionamientos y residenciales privados en la Zona Metropolitana. No somos una empresa generalista: cada protocolo, cada guardia y cada proceso están diseñados para la convivencia en comunidad.</p>
            <p>Operamos con <strong>Permiso SSC 0102-15</strong> vigente, póliza de responsabilidad civil y cumplimiento total de obligaciones laborales. Supervisión semanal documentada, bitácoras digitales y reportes mensuales a la administración de cada desarrollo garantizan transparencia total en nuestra operación.</p>
          </div>

          <div class="nos-about__actions">
            <a href="/contacto" class="nos-about__btn nos-about__btn--outline">
              Solicitar Cotización
            </a>
            <a
              href="https://wa.me/525530255580?text=Hola%2C%20me%20interesa%20cotizar%20seguridad%20para%20mi%20condominio"
              class="nos-about__btn nos-about__btn--wa"
              target="_blank"
              rel="noopener"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              55 3025 5580
            </a>
          </div>
        </div>

        <!-- Columna derecha: credenciales -->
        <div class="nos-about__credentials">
          {homepageCredentials.map((credential) => (
            <CredentialsCard
              title={credential.title}
              icon={credential.icon}
              items={credential.items}
            />
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- Misión Visión Valores -->
  <section class="nos-mvv" aria-labelledby="nos-mvv-title">
    <div class="container">
      <SectionHeader
        badge="Filosofía"
        titulo="Misión, Visión y Valores"
        subtitulo="Los principios que guían cada decisión en ORIGINS Private Security."
        align="center"
      />
      <div class="nos-mvv__grid">

        <div class="nos-mvv-card">
          <div class="nos-mvv-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="nos-mvv-card__titulo">Misión</h3>
          <p class="nos-mvv-card__texto">Proporcionar servicios de seguridad privada especializada para comunidades residenciales con los más altos estándares de profesionalismo, cumplimiento legal y atención al residente, generando tranquilidad real y duradera en cada condominio que protegemos.</p>
        </div>

        <div class="nos-mvv-card">
          <div class="nos-mvv-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3 class="nos-mvv-card__titulo">Visión</h3>
          <p class="nos-mvv-card__texto">Ser la empresa de seguridad privada más confiable y especializada en condominios y residenciales de la Zona Metropolitana de la Ciudad de México, reconocida por su transparencia, profesionalismo y resultados medibles.</p>
        </div>

        <div class="nos-mvv-card">
          <div class="nos-mvv-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          </div>
          <h3 class="nos-mvv-card__titulo">Valores</h3>
          <p class="nos-mvv-card__texto">Integridad en cada acto, transparencia total con la administración, respeto a los residentes, profesionalismo del personal, cumplimiento legal irrenunciable y mejora continua en protocolos y capacitación.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Historia / Timeline -->
  <section class="nos-historia" aria-labelledby="nos-historia-title">
    <div class="container">
      <SectionHeader
        badge="Historia"
        titulo="Nuestra Trayectoria desde 2008"
        subtitulo="Más de 15 años creciendo junto a las comunidades residenciales de la Ciudad de México."
        align="center"
      />
      <div class="nos-timeline" role="list">
        {timelineEvents.map(ev => (
          <div class="nos-timeline-item" role="listitem">
            <span class="nos-timeline-item__year">{ev.year}</span>
            <div class="nos-timeline-item__content">
              <h4>{ev.titulo}</h4>
              <p>{ev.descripcion}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Diferenciadores -->
  <section class="nos-diferenciadores" aria-labelledby="nos-dif-title">
    <div class="container">
      <SectionHeader
        badge="Diferenciadores"
        titulo="¿Por Qué Somos Diferentes?"
        subtitulo="Lo que hace a ORIGINS única en el mercado de seguridad privada para condominios en CDMX."
        align="center"
      />
      <div class="nos-diferenciadores__grid">
        {diferenciadores.map(d => (
          <div class="nos-dif-card">
            <div class="nos-dif-card__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" set:html={d.svg} />
            </div>
            <h3 class="nos-dif-card__titulo">{d.titulo}</h3>
            <p class="nos-dif-card__texto">{d.descripcion}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Equipo -->
  <section class="nos-equipo" aria-labelledby="nos-equipo-title">
    <div class="container">
      <SectionHeader
        badge="Nuestro Equipo"
        titulo="Personal Certificado SSC"
        subtitulo="Cada guardia de ORIGINS pasa por un proceso de selección riguroso antes de ser asignado a cualquier desarrollo residencial."
        parrafo1="Verificación de antecedentes penales y policiales, exámenes psicométricos, pruebas de confiabilidad y análisis toxicológico. Nuestros guardias conocen las normas de operación de la Ley Federal de Seguridad Privada y reciben capacitación específica para entornos residenciales."
        parrafo2="La capacitación no termina al contratar: programas de actualización trimestral, simulacros de emergencia y evaluaciones periódicas garantizan que el personal mantiene los estándares operativos que exige cada comunidad."
        align="left"
      />
      <div class="nos-equipo__grid">
        <div class="nos-equipo-stat">
          <div class="nos-equipo-stat__num">100%</div>
          <div class="nos-equipo-stat__label">Verificación de antecedentes</div>
        </div>
        <div class="nos-equipo-stat">
          <div class="nos-equipo-stat__num">SSC</div>
          <div class="nos-equipo-stat__label">Certificación vigente</div>
        </div>
        <div class="nos-equipo-stat">
          <div class="nos-equipo-stat__num">24h</div>
          <div class="nos-equipo-stat__label">Capacitación inicial</div>
        </div>
        <div class="nos-equipo-stat">
          <div class="nos-equipo-stat__num">Trim.</div>
          <div class="nos-equipo-stat__label">Actualización periódica</div>
        </div>
      </div>
    </div>
  </section>

  <PageCTA
    titulo="¿Listo para Proteger tu Condominio?"
    descripcion="Solicita tu diagnóstico de seguridad gratuito. Diagnóstico en 24 horas, sin compromiso."
    ctaPrimario={{ texto: 'Solicitar Cotización', href: '/contacto' }}
    ctaWhatsapp={true}
  />

</Base>
