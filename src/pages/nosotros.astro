---
import Base from '../layouts/Base.astro';

const title = "Nosotros | Empresa de Seguridad Privada Intramuros CDMX | +15 Años";
const description = "Empresa de seguridad privada en CDMX con +15 años. Guardias intramuros certificados SSC para condominios, residenciales y empresas. ☎ 55 3025 5580";
const schema = {"@context":"https://schema.org","@type":"AboutPage","name":"Nosotros - Seguridad Privada CDMX","description":"Empresa líder en seguridad privada en México con más de 15 años de experiencia protegiendo empresas, condominios y familias en CDMX y Estado de México.","url":"https://seguridad-privada.com.mx/nosotros.html","mainEntity":{"@type":"Organization","name":"Seguridad Privada CDMX","url":"https://seguridad-privada.com.mx/","logo":"https://seguridad-privada.com.mx/img/logo.avif","foundingDate":"2008","description":"Empresa líder en servicios de seguridad privada en México, especializada en guardias certificados SSC, monitoreo 24/7, protección ejecutiva y tecnología de vanguardia.","address":{"@type":"PostalAddress","streetAddress":"Tu Dirección","addressLocality":"Ciudad de México","addressRegion":"CDMX","postalCode":"01000","addressCountry":"MX"},"telephone":"+52-55-3025-5580","areaServed":[{"@type":"City","name":"Ciudad de México"},{"@type":"State","name":"Estado de México"}]}};
---

<Base title={title} description={description} schema={schema} useLegacyCSS={true}>
  <!-- Hero Section -->
    <section class="hero-two-col">
      <div class="hero-two-col__container">
        <div class="hero-two-col__left">
          <div class="hero-two-col__badge">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            <span>Permiso SSC 0102-15</span>
          </div>
          <h1 class="hero-two-col__title">Más de 15 Años Protegiendo lo que Más Valoras</h1>
          <p class="hero-two-col__subtitle">Empresa Líder en Seguridad Privada en CDMX</p>
          <p class="hero-two-col__description">
            ORIGINS Private Security S.A. de C.V.: <strong>+15 años de experiencia</strong> protegiendo empresas, condominios y familias en CDMX y Estado de México. Nuestra filosofía: <strong>Seguridad, Prevención, Confianza</strong>. Guardias certificados SSC y monitoreo 24/7.
          </p>
          <div class="hero-two-col__cta">
            <a href="servicios" class="btn btn-primary">Conoce Nuestros Servicios</a>
            <a href="https://wa.me/525530255580" class="btn btn-whatsapp" target="_blank" rel="noopener" aria-label="WhatsApp">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
              WhatsApp
            </a>
          </div>
        </div>
        <div class="hero-two-col__right">
          <div class="hero-two-col__card">
            <h2 class="hero-two-col__card-title">Trayectoria comprobable en zonas de prestigio</h2>
            <p class="hero-two-col__card-text">Hemos protegido cientos de empresas corporativas, condominios de prestigio y propiedades de alto valor en Polanco, Santa Fe, Interlomas, Bosques de las Lomas, Naucalpan y Tlalnepantla. Nuestro compromiso: tranquilidad con el más alto profesionalismo.</p>
          </div>
          <div class="hero-two-col__card">
            <h2 class="hero-two-col__card-title">Personal certificado y tecnología avanzada</h2>
            <p class="hero-two-col__card-text">Todos nuestros guardias están certificados ante la Secretaría de Seguridad Ciudadana de CDMX. Equipamiento de última generación, tecnología de monitoreo avanzada y protocolos probados que garantizan la protección de su patrimonio.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Estadísticas -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-number">15+</div>
            <div class="stat-label">Años de Experiencia</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">500+</div>
            <div class="stat-label">Clientes Satisfechos</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">200+</div>
            <div class="stat-label">Guardias Certificados</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">24/7</div>
            <div class="stat-label">Monitoreo Continuo</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Misión, Visión, Valores -->
    <section class="mission-vision-values">
      <div class="container">
        <div class="mvv-grid">
          <div class="mvv-card">
            <h3 class="mvv-title">Misión</h3>
            <p class="mvv-description">
              Ser la empresa líder a nivel nacional en seguridad privada, ofreciendo servicios de calidad que excedan las expectativas de nuestros clientes mediante personal comprometido, tecnología de vanguardia y relaciones transparentes. Nuestra filosofía: <strong>Seguridad, Prevención, Confianza</strong>.
            </p>
          </div>

          <div class="mvv-card">
            <h3 class="mvv-title">Visión</h3>
            <p class="mvv-description">
              Ser la organización más cercana a nuestros clientes, anticipándonos a sus necesidades con soluciones innovadoras. Consolidarnos como empresa confiable y de confianza en seguridad privada, siendo reconocidos por nuestra excelencia, profesionalismo y compromiso con las comunidades donde operamos.
            </p>
          </div>

          <div class="mvv-card">
            <h3 class="mvv-title">Valores</h3>
            <p class="mvv-description">
              Nuestros valores corporativos guían cada decisión y acción que tomamos como organización, definiendo quiénes somos y cómo servimos a nuestros clientes con integridad, profesionalismo y compromiso inquebrantable.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Valores Corporativos -->
    <section class="corporate-values">
      <div class="container">
        <h2 class="section-title">Valores que nos Definen</h2>
        <p class="section-subtitle">Los principios fundamentales que rigen nuestra operación diaria y nuestro compromiso con la excelencia</p>

        <div class="values-grid">
          <div class="value-card">
            <div class="value-icon">
              <div class="value-icon-circle">1</div>
            </div>
            <h3 class="value-title">Integridad</h3>
            <p class="value-description">Actuamos con honestidad y transparencia en cada servicio que brindamos, manteniendo siempre los más altos estándares éticos en todas nuestras operaciones.</p>
          </div>

          <div class="value-card">
            <div class="value-icon">
              <div class="value-icon-circle">2</div>
            </div>
            <h3 class="value-title">Profesionalismo</h3>
            <p class="value-description">Personal certificado y capacitado constantemente que representa nuestra marca con excelencia, respeto y dedicación en cada interacción.</p>
          </div>

          <div class="value-card">
            <div class="value-icon">
              <div class="value-icon-circle">3</div>
            </div>
            <h3 class="value-title">Compromiso</h3>
            <p class="value-description">Dedicación total a la protección de nuestros clientes, superando expectativas y garantizando su tranquilidad en todo momento.</p>
          </div>

          <div class="value-card">
            <div class="value-icon">
              <div class="value-icon-circle">4</div>
            </div>
            <h3 class="value-title">Confiabilidad</h3>
            <p class="value-description">Cumplimos lo que prometemos, siempre. Nuestra palabra es nuestra garantía y nuestro historial habla por sí mismo.</p>
          </div>

          <div class="value-card">
            <div class="value-icon">
              <div class="value-icon-circle">5</div>
            </div>
            <h3 class="value-title">Innovación</h3>
            <p class="value-description">Tecnología de punta para mejor protección, constantemente actualizando nuestros sistemas y procesos para ofrecer las mejores soluciones.</p>
          </div>

          <div class="value-card">
            <div class="value-icon">
              <div class="value-icon-circle">6</div>
            </div>
            <h3 class="value-title">Respeto</h3>
            <p class="value-description">Valoramos a nuestro equipo y clientes por igual, creando un ambiente de trabajo positivo y relaciones duraderas basadas en el respeto mutuo.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Nuestra Historia -->
    <section class="our-history">
      <div class="container">
        <h2 class="section-title">Nuestra Historia</h2>
        <p class="section-subtitle">Más de una década de crecimiento, aprendizaje y compromiso con la seguridad en México</p>

        <div class="history-timeline">
          <div class="timeline-item">
            <div class="timeline-year">2008</div>
            <div class="timeline-content">
              <h3 class="timeline-title">Fundación</h3>
              <p class="timeline-description">Iniciamos operaciones en la Ciudad de México con un equipo de 10 guardias de seguridad certificados, enfocándonos en servicios de vigilancia para empresas corporativas y condominios residenciales en zonas premium.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2012</div>
            <div class="timeline-content">
              <h3 class="timeline-title">Expansión Tecnológica</h3>
              <p class="timeline-description">Implementamos nuestra primera central de monitoreo 24/7 con tecnología CCTV de alta resolución y sistemas de alarmas inteligentes, convirtiéndonos en pioneros en la integración de tecnología y seguridad física.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2015</div>
            <div class="timeline-content">
              <h3 class="timeline-title">Certificaciones y Reconocimientos</h3>
              <p class="timeline-description">Obtuvimos certificaciones clave y reconocimientos de la industria. Expandimos operaciones al Estado de México, cubriendo Naucalpan, Tlalnepantla, Atizapán e Interlomas con personal altamente calificado.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2018</div>
            <div class="timeline-content">
              <h3 class="timeline-title">Especialización en Sectores</h3>
              <p class="timeline-description">Desarrollamos servicios especializados para diferentes industrias: seguridad hospitalaria, protección para construcción, seguridad para eventos corporativos y servicios de protección ejecutiva con escoltas certificadas.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2021</div>
            <div class="timeline-content">
              <h3 class="timeline-title">Innovación y Crecimiento</h3>
              <p class="timeline-description">Alcanzamos más de 200 guardias de seguridad certificados y lanzamos nuestra plataforma digital de monitoreo que permite a clientes acceder en tiempo real a reportes, cámaras y bitácoras desde cualquier dispositivo.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-year">2024</div>
            <div class="timeline-content">
              <h3 class="timeline-title">Líderes en la Industria</h3>
              <p class="timeline-description">Consolidados como empresa líder en seguridad privada en México, con más de 500 clientes activos, tecnología de inteligencia artificial para análisis de video y reconocimiento como empleador de excelencia en el sector de seguridad.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Por Qué Elegirnos (Diferenciadores) -->
    <section class="why-choose-us-about">
      <div class="container">
        <h2 class="section-title">¿Por Qué Somos Diferentes?</h2>
        <p class="section-subtitle">Los factores que nos posicionan como líderes en seguridad privada en México</p>

        <div class="differentiators-grid">
          <div class="differentiator-card">
            <div class="differentiator-icon">
              <img src="/img/img-nosotros/certificacion.avif" alt="Certificación SSC - Guardias certificados" loading="lazy" width="640" height="960">
            </div>
            <h3 class="differentiator-title">100% Certificados SSC</h3>
            <p class="differentiator-description">Todos nuestros guardias cuentan con certificación vigente de la Secretaría de Seguridad Ciudadana. Cumplimos rigurosamente con la Ley Federal de Seguridad Privada y renovamos certificaciones periódicamente.</p>
          </div>

          <div class="differentiator-card">
            <div class="differentiator-icon">
              <img src="/img/img-nosotros/tecnologia.avif" alt="Tecnología de vanguardia - Monitoreo 24/7" loading="lazy" width="640" height="960">
            </div>
            <h3 class="differentiator-title">Tecnología de Vanguardia</h3>
            <p class="differentiator-description">Central de monitoreo 24/7 con sistemas CCTV 4K, video-analítica con inteligencia artificial, rastreo GPS satelital en tiempo real y plataformas digitales de gestión para transparencia total.</p>
          </div>

          <div class="differentiator-card">
            <div class="differentiator-icon">
              <img src="/img/img-nosotros/capacitacion.avif" alt="Capacitación continua - Personal profesional" loading="lazy" width="640" height="960">
            </div>
            <h3 class="differentiator-title">Capacitación Continua</h3>
            <p class="differentiator-description">Programas de entrenamiento constante en protocolos de seguridad, primeros auxilios, manejo de crisis, atención al cliente y uso de tecnología. Invertimos en el desarrollo profesional de nuestro equipo.</p>
          </div>

          <div class="differentiator-card">
            <div class="differentiator-icon">
              <img src="/img/img-nosotros/cobertura.avif" alt="Cobertura total CDMX y Estado de México" loading="lazy" width="640" height="960">
            </div>
            <h3 class="differentiator-title">Cobertura Total</h3>
            <p class="differentiator-description">Presencia en toda la Zona Metropolitana: CDMX (16 alcaldías) y Estado de México (principales municipios). Respuesta rápida en menos de 30 minutos ante emergencias con unidades de supervisión móviles.</p>
          </div>

          <div class="differentiator-card">
            <div class="differentiator-icon">
              <img src="/img/img-nosotros/transparencia.avif" alt="Transparencia total - Reportes digitales" loading="lazy" width="640" height="960">
            </div>
            <h3 class="differentiator-title">Transparencia Total</h3>
            <p class="differentiator-description">Bitácoras digitales en tiempo real, reportes fotográficos de rondines, grabaciones CCTV disponibles en la nube, acceso remoto para clientes y reportes ejecutivos mensuales de desempeño.</p>
          </div>

          <div class="differentiator-card">
            <div class="differentiator-icon">
              <img src="/img/img-nosotros/respaldo.avif" alt="Respaldo legal - Pólizas de responsabilidad civil" loading="lazy" width="640" height="960">
            </div>
            <h3 class="differentiator-title">Respaldo Legal Completo</h3>
            <p class="differentiator-description">Pólizas de responsabilidad civil vigentes, cumplimiento total de obligaciones laborales (IMSS, INFONAVIT, SAR), contratos formales y asesoría legal especializada para nuestros clientes.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Nuestro Equipo -->
    <section class="our-team">
      <div class="container">
        <h2 class="section-title">Nuestro Equipo</h2>
        <p class="section-subtitle">Profesionales comprometidos con tu seguridad y tranquilidad</p>

        <div class="team-description">
          <p class="team-text">
            Nuestro equipo está conformado por más de <strong>200 guardias de seguridad certificados</strong>, supervisores con experiencia militar y policial, coordinadores de operaciones, personal de monitoreo especializado y administradores con visión estratégica. Cada miembro de nuestro equipo comparte nuestra filosofía de servicio de excelencia.
          </p>
          <p class="team-text">
            Todos nuestros guardias pasan por un <strong>proceso de selección riguroso</strong> que incluye: verificación exhaustiva de antecedentes penales, exámenes psicométricos de honestidad e integridad, estudios socioeconómicos con visita domiciliaria, evaluaciones médicas toxicológicas, entrevistas personales profundas y validación de referencias laborales. Solo el 15% de los candidatos son aceptados.
          </p>
        </div>

        <div class="team-stats-grid">
          <div class="team-stat-card">
            <h3 class="team-stat-title">Selección Rigurosa</h3>
            <p class="team-stat-description">Solo 15% de candidatos son aceptados tras evaluaciones exhaustivas de antecedentes, psicométricas, médicas y de confiabilidad.</p>
          </div>

          <div class="team-stat-card">
            <h3 class="team-stat-title">Capacitación Inicial</h3>
            <p class="team-stat-description">120 horas de entrenamiento en protocolos de seguridad, primeros auxilios, manejo de crisis, atención al cliente y uso de tecnología.</p>
          </div>

          <div class="team-stat-card">
            <h3 class="team-stat-title">Desarrollo Continuo</h3>
            <p class="team-stat-description">Cursos mensuales de actualización, certificaciones especializadas y oportunidades reales de crecimiento a supervisor y coordinador.</p>
          </div>

          <div class="team-stat-card">
            <h3 class="team-stat-title">Supervisión Constante</h3>
            <p class="team-stat-description">Supervisores capacitados realizan visitas semanales, evaluaciones de desempeño trimestrales y auditorías de calidad constantes.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Certificaciones y Cumplimiento -->
    <section class="certifications">
      <div class="container">
        <h2 class="section-title">Certificaciones y Cumplimiento Normativo</h2>
        <p class="section-subtitle">Operamos con total apego a la ley y los más altos estándares de la industria</p>

        <div class="certifications-grid">
          <div class="certification-item">
            <h3 class="certification-name">Registro ante la SSC</h3>
            <p class="certification-description">Empresa registrada y autorizada ante la Secretaría de Seguridad Ciudadana con permiso vigente. ORIGINS PRIVATE SECURITY S.A. DE C.V. - RFC: OPS1308309M5. Todos los permisos vigentes para operar servicios de seguridad privada en CDMX.</p>
          </div>

          <div class="certification-item">
            <h3 class="certification-name">Ley Federal de Seguridad Privada</h3>
            <p class="certification-description">Cumplimiento total con la normativa federal mexicana que regula la prestación de servicios de seguridad privada, incluyendo requisitos de personal, equipamiento y operación.</p>
          </div>

          <div class="certification-item">
            <h3 class="certification-name">Certificación de Guardias SSC</h3>
            <p class="certification-description">El 100% de nuestros guardias cuentan con certificación individual vigente emitida por la SSC tras aprobar cursos, exámenes y verificación de antecedentes no penales.</p>
          </div>

          <div class="certification-item">
            <h3 class="certification-name">Pólizas de Responsabilidad Civil</h3>
            <p class="certification-description">Cobertura de responsabilidad civil vigente emitida por aseguradora reconocida que protege a nuestros clientes ante cualquier eventualidad durante la prestación del servicio.</p>
          </div>

          <div class="certification-item">
            <h3 class="certification-name">Cumplimiento Laboral</h3>
            <p class="certification-description">Alta al IMSS, INFONAVIT y SAR de todo nuestro personal. Cumplimiento total de obligaciones patronales y derechos laborales conforme a la Ley Federal del Trabajo.</p>
          </div>

          <div class="certification-item">
            <h3 class="certification-name">Certificaciones Especializadas</h3>
            <p class="certification-description">Personal certificado en primeros auxilios, manejo de extintores, protocolos de evacuación, uso de tecnología de monitoreo y protección ejecutiva avanzada.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Compromiso Social -->
    <section class="social-commitment">
      <div class="container">
        <h2 class="section-title">Compromiso Social y Responsabilidad</h2>
        <div class="commitment-content">
          <p class="commitment-text">
            Además de proteger empresas y familias, creemos en <strong>contribuir positivamente a las comunidades</strong> donde operamos. Ofrecemos oportunidades laborales formales con prestaciones superiores de ley, capacitación profesional gratuita y planes de carrera reales para personas que buscan estabilidad y desarrollo.
          </p>
          <p class="commitment-text">
            Somos un <strong>empleador responsable</strong> que respeta los derechos laborales, promueve la igualdad de género en el sector de seguridad privada, ofrece condiciones de trabajo dignas y contribuye a la economía formal del país mediante el pago de impuestos y seguridad social.
          </p>
          <p class="commitment-text">
            Nuestro compromiso va más allá de la seguridad: <strong>formamos profesionales</strong>, fortalecemos familias mediante empleos estables y contribuimos a comunidades más seguras en la Ciudad de México y Estado de México.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-business">
      <div class="cta-business__content">
        <h2 class="cta-business__title">¿Listo para Proteger lo que Más Valoras con una Empresa de Seguridad Confiable?</h2>
        <p class="cta-business__description">
          Más de 15 años protegiendo empresas y familias en CDMX y Estado de México. Únete a cientos de clientes que confían en nuestra experiencia, profesionalismo y compromiso con la seguridad.
        </p>

        <div class="cta-business__features">
          <div class="cta-business__feature">
            <h3 class="cta-business__feature-title">15+ Años de Experiencia</h3>
            <p class="cta-business__feature-text">Trayectoria comprobada protegiendo empresas y familias</p>
          </div>
          <div class="cta-business__feature">
            <h3 class="cta-business__feature-title">Personal Certificado SSC</h3>
            <p class="cta-business__feature-text">100% de guardias con certificación vigente</p>
          </div>
          <div class="cta-business__feature">
            <h3 class="cta-business__feature-title">Cumplimiento Total</h3>
            <p class="cta-business__feature-text">Registro SSC vigente y pólizas de responsabilidad civil</p>
          </div>
        </div>

        <div class="cta-business__actions">
          <a href="https://wa.me/525530255580?text=Hola,%20necesito%20información%20sobre%20servicios%20de%20seguridad" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener" aria-label="WhatsApp">
            <span>WhatsApp</span>
