---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const title = 'Nosotros | ORIGINS Private Security - Seguridad Privada CDMX';
const description = 'Conoce ORIGINS Private Security: +15 años de experiencia en seguridad privada en CDMX. Guardias certificados SSC, 500+ clientes satisfechos. ☎ 55 3025 5580';

const valores = [
  { name: 'Integridad', text: 'Actuamos con honestidad y transparencia en cada servicio que brindamos, manteniendo siempre los más altos estándares éticos en todas nuestras operaciones.' },
  { name: 'Profesionalismo', text: 'Personal certificado y capacitado constantemente que representa nuestra marca con excelencia, respeto y dedicación en cada interacción.' },
  { name: 'Compromiso', text: 'Dedicación total a la protección de nuestros clientes, superando expectativas y garantizando su tranquilidad en todo momento.' },
  { name: 'Confiabilidad', text: 'Cumplimos lo que prometemos, siempre. Nuestra palabra es nuestra garantía y nuestro historial habla por sí mismo.' },
  { name: 'Innovación', text: 'Tecnología de punta para mejor protección, constantemente actualizando nuestros sistemas y procesos para ofrecer las mejores soluciones.' },
  { name: 'Respeto', text: 'Valoramos a nuestro equipo y clientes por igual, creando un ambiente de trabajo positivo y relaciones duraderas basadas en el respeto mutuo.' },
];

const timeline = [
  { year: '2008', title: 'Fundación', text: 'Iniciamos operaciones en la Ciudad de México con un equipo de 10 guardias de seguridad certificados, enfocándonos en servicios de vigilancia para empresas corporativas y condominios residenciales en zonas premium.' },
  { year: '2012', title: 'Expansión Tecnológica', text: 'Implementamos nuestra primera central de monitoreo 24/7 con tecnología CCTV de alta resolución y sistemas de alarmas inteligentes, convirtiéndonos en pioneros en la integración de tecnología y seguridad física.' },
  { year: '2015', title: 'Certificaciones y Reconocimientos', text: 'Obtuvimos certificaciones clave y reconocimientos de la industria. Expandimos operaciones al Estado de México, cubriendo Naucalpan, Tlalnepantla, Atizapán e Interlomas.' },
  { year: '2018', title: 'Especialización en Sectores', text: 'Desarrollamos servicios especializados para diferentes industrias: seguridad hospitalaria, protección para construcción, seguridad para eventos corporativos y servicios de protección ejecutiva.' },
  { year: '2021', title: 'Innovación y Crecimiento', text: 'Alcanzamos más de 200 guardias de seguridad certificados y lanzamos nuestra plataforma digital de monitoreo que permite a clientes acceder en tiempo real a reportes, cámaras y bitácoras.' },
  { year: '2024', title: 'Líderes en la Industria', text: 'Consolidados como empresa líder en seguridad privada en México, con más de 500 clientes activos, tecnología de inteligencia artificial para análisis de video y reconocimiento como empleador de excelencia.' },
];

const diferenciadores = [
  { title: '100% Certificados SSC', text: 'Todos nuestros guardias cuentan con certificación vigente de la Secretaría de Seguridad Ciudadana. Cumplimos rigurosamente con la Ley Federal de Seguridad Privada.' },
  { title: 'Tecnología de Vanguardia', text: 'Central de monitoreo 24/7 con sistemas CCTV 4K, video-analítica con inteligencia artificial, rastreo GPS satelital en tiempo real.' },
  { title: 'Capacitación Continua', text: 'Programas de entrenamiento constante en protocolos de seguridad, primeros auxilios, manejo de crisis, atención al cliente y uso de tecnología.' },
  { title: 'Cobertura Total', text: 'Presencia en toda la Zona Metropolitana: CDMX (16 alcaldías) y Estado de México. Respuesta rápida en menos de 30 minutos ante emergencias.' },
  { title: 'Transparencia Total', text: 'Bitácoras digitales en tiempo real, reportes fotográficos de rondines, grabaciones CCTV disponibles en la nube y reportes ejecutivos mensuales.' },
  { title: 'Respaldo Legal Completo', text: 'Pólizas de responsabilidad civil vigentes, cumplimiento total de obligaciones laborales (IMSS, INFONAVIT, SAR), contratos formales.' },
];
---
<BaseLayout title={title} description={description}>
  <Hero
    title="Más de 15 Años Protegiendo lo que Más Valoras"
    subtitle="Empresa Líder en Seguridad Privada en CDMX"
    description='ORIGINS Private Security S.A. de C.V.: <strong>+15 años de experiencia</strong> protegiendo empresas, condominios y familias en CDMX y Estado de México. Nuestra filosofía: <strong>Seguridad, Prevención, Confianza</strong>. Guardias certificados SSC y monitoreo 24/7.'
    card1Title="Trayectoria comprobable en zonas de prestigio"
    card1Text="Hemos protegido cientos de empresas corporativas, condominios de prestigio y propiedades de alto valor en Polanco, Santa Fe, Interlomas, Bosques de las Lomas, Naucalpan y Tlalnepantla. Nuestro compromiso: tranquilidad con el más alto profesionalismo."
    card2Title="Personal certificado y tecnología avanzada"
    card2Text="Todos nuestros guardias están certificados ante la Secretaría de Seguridad Ciudadana de CDMX. Equipamiento de última generación, tecnología de monitoreo avanzada y protocolos probados que garantizan la protección de su patrimonio."
  />

  <!-- Stats -->
  <section class="certifications-section">
    <div class="container">
      <div class="certifications-grid" style="grid-template-columns:repeat(4,1fr)">
        <div class="certification-item"><h3 class="certification-title" style="font-size:2rem">15+</h3><p class="certification-text">Años de Experiencia</p></div>
        <div class="certification-item"><h3 class="certification-title" style="font-size:2rem">500+</h3><p class="certification-text">Clientes Satisfechos</p></div>
        <div class="certification-item"><h3 class="certification-title" style="font-size:2rem">200+</h3><p class="certification-text">Guardias Certificados</p></div>
        <div class="certification-item"><h3 class="certification-title" style="font-size:2rem">24/7</h3><p class="certification-text">Monitoreo Continuo</p></div>
      </div>
    </div>
  </section>

  <!-- Misión y Visión -->
  <section class="page-section">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px">
        <div>
          <h2>Misión</h2>
          <p style="margin-top:12px">Ser la empresa líder a nivel nacional en seguridad privada, ofreciendo servicios de calidad que excedan las expectativas de nuestros clientes mediante personal comprometido, tecnología de vanguardia y relaciones transparentes. Nuestra filosofía: <strong>Seguridad, Prevención, Confianza</strong>.</p>
        </div>
        <div>
          <h2>Visión</h2>
          <p style="margin-top:12px">Ser la organización más cercana a nuestros clientes, anticipándonos a sus necesidades con soluciones innovadoras. Consolidarnos como empresa confiable en seguridad privada, siendo reconocidos por nuestra excelencia, profesionalismo y compromiso con las comunidades donde operamos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Valores -->
  <section class="page-section page-section--alt">
    <div class="container">
      <h2 class="section-title">Valores que nos Definen</h2>
      <p class="section-subtitle">Los principios fundamentales que rigen nuestra operación diaria y nuestro compromiso con la excelencia</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px">
        {valores.map(v => (
          <div style="background:var(--white);border-radius:12px;padding:24px">
            <h3 style="margin-bottom:8px">{v.name}</h3>
            <p>{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="page-section">
    <div class="container">
      <h2 class="section-title">Nuestra Historia</h2>
      <div style="max-width:800px;margin:0 auto;display:flex;flex-direction:column;gap:24px;margin-top:32px">
        {timeline.map(t => (
          <div style="display:flex;gap:20px;align-items:flex-start">
            <div style="background:var(--blue-900);color:var(--white);padding:8px 16px;border-radius:8px;font-weight:700;font-size:1.1rem;flex-shrink:0">{t.year}</div>
            <div>
              <h3 style="margin-bottom:4px">{t.title}</h3>
              <p>{t.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Diferenciadores -->
  <section class="page-section page-section--alt">
    <div class="container">
      <h2 class="section-title">Por Qué Somos Diferentes</h2>
      <p class="section-subtitle">Los factores que nos posicionan como líderes en seguridad privada en México</p>
      <div class="content-grid">
        {diferenciadores.map(d => (
          <div class="content-card">
            <h3>{d.title}</h3>
            <p>{d.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Equipo -->
  <section class="page-section">
    <div class="container">
      <h2 class="section-title">Nuestro Equipo</h2>
      <p class="section-subtitle">Profesionales comprometidos con tu seguridad y tranquilidad</p>
      <div style="max-width:800px;margin:0 auto">
        <p style="margin-bottom:16px">Más de <strong>200 guardias de seguridad certificados</strong>, supervisores con experiencia militar y policial, coordinadores de operaciones, personal de monitoreo especializado y administradores con visión estratégica.</p>
        <p style="margin-bottom:24px"><strong>Proceso de selección riguroso</strong>: verificación exhaustiva de antecedentes penales, exámenes psicométricos de honestidad e integridad, estudios socioeconómicos con visita domiciliaria, evaluaciones médicas toxicológicas, entrevistas personales profundas y validación de referencias laborales. Solo el 15% de los candidatos son aceptados.</p>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px">
          <div style="background:var(--gray-100);border-radius:8px;padding:16px;text-align:center"><h3 style="font-size:1rem">Selección Rigurosa</h3><p style="font-size:.82rem">Solo 15% aceptados</p></div>
          <div style="background:var(--gray-100);border-radius:8px;padding:16px;text-align:center"><h3 style="font-size:1rem">Capacitación Inicial</h3><p style="font-size:.82rem">120 horas</p></div>
          <div style="background:var(--gray-100);border-radius:8px;padding:16px;text-align:center"><h3 style="font-size:1rem">Desarrollo Continuo</h3><p style="font-size:.82rem">Cursos mensuales</p></div>
          <div style="background:var(--gray-100);border-radius:8px;padding:16px;text-align:center"><h3 style="font-size:1rem">Supervisión Constante</h3><p style="font-size:.82rem">Visitas semanales</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-business">
    <div class="cta-business__content">
      <h2 class="cta-business__title">¿Listo para Proteger lo que Más Valoras?</h2>
      <p class="cta-business__description">Contacta con nuestro equipo y recibe una cotización personalizada sin compromiso</p>
      <div class="cta-business__actions">
        <a href="https://wa.me/525530255580" class="cta-business__btn cta-business__btn--primary" target="_blank" rel="noopener">WhatsApp</a>
        <a href="/cotizar" class="cta-business__btn cta-business__btn--secondary">Cotizar en Línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
