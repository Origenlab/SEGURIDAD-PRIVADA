---
import Base from '../layouts/Base.astro';
import HeroPagina from '../components/HeroPagina.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PageCTA from '../components/PageCTA.astro';
import '../styles/pages/bolsa.css';

const siteUrl = 'https://seguridad-privada.com.mx';

const schema = {
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "title": "Guardia de Seguridad Certificado",
  "description": "ORIGINS PRIVATE SECURITY busca guardias de seguridad certificados para CDMX y Estado de México. Ofrecemos prestaciones superiores a la ley, capacitación constante, desarrollo profesional y ambiente laboral profesional.",
  "identifier": {
    "@type": "PropertyValue",
    "name": "ORIGINS PRIVATE SECURITY",
    "value": "GUARD-OPS-2025"
  },
  "employmentType": ["FULL_TIME", "PART_TIME"],
  "hiringOrganization": {
    "@type": "Organization",
    "name": "ORIGINS PRIVATE SECURITY S.A. DE C.V.",
    "sameAs": siteUrl,
    "logo": `${siteUrl}/img/logo.avif`
  },
  "jobLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Basiliso Romo Anguiano No 22 int 3",
      "addressLocality": "Ciudad de México",
      "addressRegion": "CDMX",
      "postalCode": "07800",
      "addressCountry": "MX"
    }
  },
  "baseSalary": {
    "@type": "MonetaryAmount",
    "currency": "MXN",
    "value": {
      "@type": "QuantitativeValue",
      "minValue": 10000,
      "maxValue": 15000,
      "unitText": "MONTH"
    }
  },
  "directApply": true
};

const beneficios = [
  {
    titulo: 'IMSS desde el día 1',
    descripcion: 'Alta inmediata ante el IMSS e INFONAVIT. Sin periodos de prueba sin prestaciones ni promesas vacías.',
    svg: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>'
  },
  {
    titulo: 'Pagos puntuales quincenal',
    descripcion: 'Quincenas puntuales, aguinaldo completo de ley y vacaciones respetadas. Sin retrasos ni descuentos injustificados.',
    svg: '<rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>'
  },
  {
    titulo: 'Certificación SSC pagada',
    descripcion: 'Te certificamos ante la SSC sin costo. Nosotros cubrimos trámites, exámenes y capacitación inicial.',
    svg: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/>'
  },
  {
    titulo: 'Uniformes y equipo completo',
    descripcion: 'Uniformes tácticos de calidad, radio Motorola profesional, linterna y bastón. Todo el equipo necesario incluido.',
    svg: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>'
  },
  {
    titulo: 'Crecimiento real',
    descripcion: 'Guardias comprometidos crecen a supervisor en 2-3 años con mejor sueldo. No somos una empresa donde te quedas en el mismo lugar.',
    svg: '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>'
  },
  {
    titulo: 'Turnos que respetan tu familia',
    descripcion: 'Esquema 24x24, turnos diurnos y nocturnos. Asignaciones estables en condominios de primer nivel en Polanco, Santa Fe e Interlomas.',
    svg: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>'
  }
];

const requisitos = [
  'Educación mínima secundaria concluida',
  'Mayor de 18 años con identificación oficial vigente',
  'Sin antecedentes penales (verificación obligatoria)',
  'Disponibilidad de horario (turnos rotativos)',
  'Actitud de servicio y trato respetuoso',
  'Responsabilidad, puntualidad e integridad',
  'Disposición para capacitación y certificación SSC (la pagamos nosotros)',
  'Experiencia en seguridad deseable pero NO indispensable'
];
---

<Base
  title="Bolsa de Trabajo Seguridad Privada CDMX | ORIGINS"
  description="Vacantes de guardia de seguridad en CDMX. Empresa con +15 años, IMSS desde día 1, certificación SSC pagada, pagos puntuales y crecimiento real. Aplica ya."
  canonical={`${siteUrl}/bolsa-de-trabajo`}
  schema={schema}
>

  <HeroPagina
    badge="Únete al Equipo"
    titulo="Únete al Equipo de ORIGINS Private Security"
    descripcion="Estabilidad laboral real, prestaciones superiores de ley, certificación SSC pagada y un ambiente de trabajo profesional. Llevamos +15 años cumpliendo lo que prometemos."
    breadcrumb={[{ label: 'Bolsa de Trabajo', href: '/bolsa-de-trabajo' }]}
    ctaWhatsapp={true}
    ctaPrimario={{ texto: 'Postularme ahora', href: '#formulario-empleo' }}
  />

  <!-- Beneficios -->
  <section class="bolsa-beneficios" aria-labelledby="bolsa-ben-title">
    <div class="container">
      <SectionHeader
        badge="Beneficios Reales"
        titulo="¿Por Qué Trabajar con Nosotros?"
        subtitulo="No son promesas vacías. Esto es lo que recibirás desde el primer día en ORIGINS."
        align="center"
      />
      <div class="bolsa-beneficios__grid">
        {beneficios.map(b => (
          <div class="bolsa-beneficio-card">
            <div class="bolsa-beneficio-card__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" set:html={b.svg} />
            </div>
            <h3 class="bolsa-beneficio-card__titulo">{b.titulo}</h3>
            <p class="bolsa-beneficio-card__texto">{b.descripcion}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Requisitos -->
  <section class="bolsa-requisitos" aria-labelledby="bolsa-req-title">
    <div class="container">
      <SectionHeader
        badge="Perfil del Candidato"
        titulo="Lo Que Buscamos"
        subtitulo="No necesitas experiencia previa. Buscamos actitud, compromiso y responsabilidad. Lo demás te lo enseñamos."
        align="center"
      />
      <ul class="bolsa-requisitos__list">
        {requisitos.map(r => (
          <li class="bolsa-requisito-item">
            <svg class="bolsa-requisito-item__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
            <p class="bolsa-requisito-item__texto">{r}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Formulario -->
  <section class="bolsa-form-section" id="formulario-empleo" aria-labelledby="bolsa-form-title">
    <div class="container">
      <SectionHeader
        badge="Postúlate"
        titulo="Envía Tu Solicitud"
        subtitulo="Completa el formulario y un reclutador te contactará en menos de 48 horas."
        align="center"
      />

      <div class="bolsa-form-card">
        <form
          class="bolsa-form"
          action="https://formsubmit.co/josecruz@originsecurity.mx"
          method="POST"
          novalidate
        >
          <input type="text" name="_honey" style="display:none" aria-hidden="true">
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_subject" value="Nueva solicitud de empleo - ORIGINS">

          <div class="bolsa-form__field">
            <label for="nombre-emp">Nombre completo <span aria-hidden="true">*</span></label>
            <input type="text" id="nombre-emp" name="nombre" required placeholder="Tu nombre completo" autocomplete="name">
          </div>

          <div class="bolsa-form__field">
            <label for="telefono-emp">Teléfono de contacto <span aria-hidden="true">*</span></label>
            <input type="tel" id="telefono-emp" name="telefono" required placeholder="55 1234 5678" autocomplete="tel">
          </div>

          <div class="bolsa-form__field">
            <label for="email-emp">Correo electrónico <span aria-hidden="true">*</span></label>
            <input type="email" id="email-emp" name="email" required placeholder="correo@ejemplo.com" autocomplete="email">
          </div>

          <div class="bolsa-form__field">
            <label for="experiencia">Experiencia en seguridad <span aria-hidden="true">*</span></label>
            <select id="experiencia" name="experiencia" required>
              <option value="">Selecciona</option>
              <option value="sin-experiencia">Sin experiencia (te capacitamos)</option>
              <option value="menos-1-año">Menos de 1 año</option>
              <option value="1-3-años">1 a 3 años</option>
              <option value="mas-3-años">Más de 3 años</option>
            </select>
          </div>

          <div class="bolsa-form__field">
            <label for="mensaje-emp">Cuéntanos un poco sobre ti <span style="font-size:0.8rem; font-weight:400; color:rgba(10,15,30,0.45)">(opcional)</span></label>
            <textarea id="mensaje-emp" name="mensaje" rows="3" placeholder="¿Por qué quieres trabajar en seguridad privada? ¿Tienes certificación SSC? ¿Tienes disponibilidad de turno?"></textarea>
          </div>

          <button type="submit" class="bolsa-form__submit">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Enviar Solicitud por WhatsApp
          </button>
        </form>
      </div>

    </div>
  </section>

  <PageCTA
    titulo="¿Tienes dudas sobre las vacantes?"
    descripcion="Escríbenos por WhatsApp y un reclutador te responde en menos de 2 horas."
    ctaWhatsapp={true}
    ctaPrimario={{ texto: 'Ver Servicios', href: '/servicios' }}
  />

</Base>
