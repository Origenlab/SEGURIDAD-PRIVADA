---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Bolsa de Trabajo | Empleos Seguridad Privada CDMX - ORIGINS';
const description = 'Únete al equipo #1 en seguridad privada de México. Estabilidad laboral, IMSS desde día 1, certificación SSC pagada, crecimiento profesional. ☎ 55 3025 5580';

const benefits = [
  { title: 'Estabilidad Laboral', text: 'Contratos formales con todas las prestaciones de ley y seguridad social completa (IMSS, INFONAVIT, SAR). Pagos puntuales y aguinaldo garantizado.' },
  { title: 'Capacitación Profesional', text: 'Cursos de certificación SSC pagados por la empresa, capacitación continua en protocolos de seguridad, primeros auxilios y desarrollo profesional.' },
  { title: 'Crecimiento Real', text: 'Oportunidades de ascenso a supervisor, coordinador o jefe de operaciones. Evaluamos el desempeño y promovemos desde dentro de la organización.' },
  { title: 'Equipo Profesional', text: 'Uniformes tácticos de calidad sin costo, equipos de comunicación modernos (radios Motorola), lámparas, bastones y todo el equipamiento necesario.' },
  { title: 'Prestaciones Superiores', text: 'IMSS desde el primer día, aguinaldo superior al mínimo de ley, vacaciones, prima vacacional, días festivos pagados y seguro de vida.' },
  { title: 'Horarios Flexibles', text: 'Turnos diurnos, nocturnos y mixtos. Esquemas de 12 horas con descansos adecuados. Respetamos tus días de descanso y tiempo personal.' },
  { title: 'Ambiente Profesional', text: 'Equipos de trabajo unidos, supervisores capacitados, comunicación abierta y respeto mutuo. Valoramos a cada miembro de nuestro equipo.' },
  { title: 'Asignaciones de Calidad', text: 'Trabajamos con empresas, condominios y clientes corporativos de primer nivel en las mejores zonas de CDMX y Estado de México.' },
];

const pasos = [
  { num: '1', title: 'Aplicación en Línea', time: '5-10 minutos', text: 'Completa nuestro formulario de empleo con tus datos personales, experiencia y disponibilidad.' },
  { num: '2', title: 'Revisión de Solicitud', time: '24-48 horas', text: 'Nuestro equipo de Recursos Humanos revisa tu solicitud y verifica requisitos básicos. Te contactamos en menos de 48 horas.' },
  { num: '3', title: 'Entrevista Personal', time: '1 hora', text: 'Entrevista presencial en nuestras oficinas para conocerte mejor, evaluar tus habilidades y explicarte la posición y beneficios.' },
  { num: '4', title: 'Evaluaciones y Verificación', time: '3-5 días', text: 'Exámenes psicométricos, verificación de antecedentes, estudio socioeconómico y evaluación médica. Todo sin costo para ti.' },
  { num: '5', title: 'Contratación y Capacitación', time: '2-3 días', text: 'Firma de contrato, alta al IMSS, inducción corporativa, capacitación en protocolos de seguridad y entrega de uniformes.' },
];

const faqs = [
  { q: '¿Necesito tener experiencia previa en seguridad privada?', a: '<strong>No es indispensable</strong>. Contratamos tanto a personas con experiencia como a quienes inician su carrera. Nosotros te capacitamos completamente sin costo, te certificamos ante la SSC. Lo más importante es tu actitud, responsabilidad y compromiso.' },
  { q: '¿Qué prestaciones y beneficios ofrecen?', a: 'Prestaciones superiores de ley: alta al IMSS desde el primer día, aguinaldo superior al mínimo legal, vacaciones y prima vacacional, días festivos pagados, uniformes profesionales sin costo, equipo de trabajo completo, capacitación y certificación SSC pagada, seguro de vida, oportunidades de crecimiento.' },
  { q: '¿Cuánto tiempo tarda el proceso de contratación?', a: 'Entre 1 a 2 semanas desde que aplicas hasta tu incorporación. En casos urgentes, contratación inmediata.' },
  { q: '¿Qué requisitos debo cumplir?', a: 'Ser mayor de 18 años, educación mínima secundaria terminada, disponibilidad de horario, no contar con antecedentes penales, presentación formal, actitud de servicio, responsabilidad y puntualidad. Certificación SSC la tramitamos nosotros sin costo.' },
  { q: '¿Qué horarios de trabajo tienen disponibles?', a: 'Turnos de 12 horas (diurno 07:00-19:00 o nocturno 19:00-07:00), esquema 24x24, turnos mixtos y fines de semana.' },
  { q: '¿Hay oportunidades de crecimiento y ascenso?', a: 'Sí. Guardia intramuros → guardia especializado → supervisor de área → coordinador de operaciones → jefe de zona. Evaluamos desempeño trimestralmente.' },
];
---
<BaseLayout title={title} description={description}>
  <section class="hero-two-col">
    <div class="hero-two-col__container">
      <div class="hero-two-col__left">
        <div class="hero-two-col__badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
          <span>Empresa #1 en Seguridad Privada</span>
        </div>
        <h1 class="hero-two-col__title">Únete al Equipo #1 en Seguridad Privada de México</h1>
        <p class="hero-two-col__subtitle">Estabilidad Laboral Real, Prestaciones Superiores de Ley, Capacitación Pagada y Crecimiento Profesional</p>
        <p class="hero-two-col__description"><strong>IMSS desde día 1, aguinaldo completo garantizado, pagos puntuales cada quincena y certificación SSC pagada 100% por nosotros</strong>. Sin experiencia? No es problema — nosotros te capacitamos y certificamos sin costo.</p>
        <div class="hero-two-col__cta">
          <a href="#aplicar" class="btn btn-primary">Aplicar Ahora</a>
          <a href="https://wa.me/525530255580?text=Hola,%20me%20interesa%20trabajar%20con%20ustedes" class="btn btn-whatsapp" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
      <div class="hero-two-col__right">
        <div class="hero-two-col__card">
          <h2 class="hero-two-col__card-title">Empleos estables con prestaciones reales</h2>
          <p class="hero-two-col__card-text">Uniformes tácticos de calidad, radios Motorola profesionales, lámpara, bastón — todo incluido. Turnos diurnos, nocturnos, esquema 24x24 que te permite pasar tiempo con tu familia. Asignaciones en empresas corporativas premium en Polanco, Santa Fe, Bosques.</p>
        </div>
        <div class="hero-two-col__card">
          <h2 class="hero-two-col__card-title">Crecimiento profesional comprobable</h2>
          <p class="hero-two-col__card-text">Empezaste como guardia intramuros, demostraste compromiso, ascendiste a supervisor en 2-3 años con mejor sueldo. Clientes de primer nivel que reconocen tu trabajo. Esta es tu oportunidad de trabajar con dignidad, estabilidad y futuro real.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="page-section page-section--alt">
    <div class="container">
      <h2 class="section-title">Por Qué Guardias con 5+ Años Eligieron Quedarse con Nosotros</h2>
      <p class="section-subtitle">No somos otra empresa que promete y no cumple. Realmente invertimos en nuestro equipo</p>
      <div class="content-grid">
        {benefits.map(b => (
          <div class="content-card">
            <h3>{b.title}</h3>
            <p>{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="page-section">
    <div class="container">
      <h2 class="section-title">Proceso de Reclutamiento y Selección</h2>
      <p class="section-subtitle">Un proceso transparente, rápido y profesional en solo 5 pasos</p>
      <div style="max-width:800px;margin:0 auto;display:flex;flex-direction:column;gap:20px">
        {pasos.map(p => (
          <div style="display:flex;gap:16px;align-items:flex-start;background:var(--gray-100);border-radius:12px;padding:24px">
            <div style="background:var(--blue-900);color:var(--white);width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0">{p.num}</div>
            <div>
              <h3 style="margin-bottom:4px">{p.title} <span style="font-weight:400;font-size:.85rem;color:var(--gray-500)">({p.time})</span></h3>
              <p>{p.text}</p>
            </div>
          </div>
        ))}
      </div>
      <p style="text-align:center;margin-top:16px;font-size:.9rem;color:var(--gray-500)">Tiempo total: 1 a 2 semanas desde tu aplicación hasta tu incorporación. En casos urgentes podemos acelerar el proceso.</p>
    </div>
  </section>

  <!-- Application Form -->
  <section class="cotizacion-section" id="aplicar">
    <div class="container">
      <div class="cotizacion-header">
        <h2>Aplica Ahora</h2>
        <p>Completa el formulario y nos pondremos en contacto contigo en menos de 48 horas</p>
      </div>
      <div class="cotizacion-form-wrapper">
        <form action="https://formsubmit.co/josecruz@originsecurity.mx" method="POST">
          <input type="hidden" name="_subject" value="Nueva aplicación de empleo - seguridad-privada.com.mx">
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_next" value="https://seguridad-privada.com.mx/bolsa-de-trabajo">
          <div class="cotizacion-form-row">
            <div class="cotizacion-form-col">
              <div class="cotizacion-field">
                <label for="nombre">Nombre Completo *</label>
                <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre completo">
              </div>
              <div class="cotizacion-field">
                <label for="edad">Edad *</label>
                <input type="number" id="edad" name="edad" required min="18" max="65" placeholder="Ej: 28">
              </div>
              <div class="cotizacion-field">
                <label for="telefono">Teléfono Celular *</label>
                <input type="tel" id="telefono" name="telefono" required placeholder="55 1234 5678">
              </div>
              <div class="cotizacion-field">
                <label for="email">Correo Electrónico *</label>
                <input type="email" id="email" name="email" required placeholder="correo@ejemplo.com">
              </div>
              <div class="cotizacion-field">
                <label for="colonia">Colonia / Alcaldía *</label>
                <input type="text" id="colonia" name="colonia" required placeholder="Ej: Col Industrial, Gustavo A. Madero">
              </div>
            </div>
            <div class="cotizacion-form-col">
              <div class="cotizacion-field">
                <label for="experiencia">Experiencia en Seguridad *</label>
                <select id="experiencia" name="experiencia" required>
                  <option value="">Selecciona</option>
                  <option value="sin-experiencia">No tengo experiencia</option>
                  <option value="menos-1">Menos de 1 año</option>
                  <option value="1-3">1 - 3 años</option>
                  <option value="3-5">3 - 5 años</option>
                  <option value="mas-5">Más de 5 años</option>
                </select>
              </div>
              <div class="cotizacion-field">
                <label for="certificacion">¿Certificación SSC?</label>
                <select id="certificacion" name="certificacion">
                  <option value="">Selecciona</option>
                  <option value="vigente">Sí, vigente</option>
                  <option value="vencida">Sí, pero vencida</option>
                  <option value="no">No tengo</option>
                </select>
              </div>
              <div class="cotizacion-field">
                <label for="puesto">Puesto de Interés *</label>
                <select id="puesto" name="puesto" required>
                  <option value="">Selecciona</option>
                  <option value="guardia-intramuros">Guardia Intramuros</option>
                  <option value="guardia-condominios">Guardia para Condominios</option>
                  <option value="guardia-nocturno">Guardia Nocturno</option>
                  <option value="supervisor">Supervisor</option>
                  <option value="cualquier">Cualquier puesto disponible</option>
                </select>
              </div>
              <div class="cotizacion-field">
                <label for="disponibilidad">Disponibilidad para Iniciar *</label>
                <select id="disponibilidad" name="disponibilidad" required>
                  <option value="">Selecciona</option>
                  <option value="inmediata">Inmediata</option>
                  <option value="1-semana">1 semana</option>
                  <option value="2-semanas">2 semanas</option>
                  <option value="1-mes">1 mes</option>
                </select>
              </div>
              <div class="cotizacion-field">
                <label for="mensaje">¿Por qué te gustaría trabajar con nosotros? *</label>
                <textarea id="mensaje" name="mensaje" required placeholder="Cuéntanos sobre ti y por qué te interesa este empleo..."></textarea>
              </div>
            </div>
          </div>
          <div class="cotizacion-footer">
            <div class="cotizacion-terms">
              <input type="checkbox" name="terminos" required>
              <span>Declaro que la información es verídica y acepto el <a href="/aviso-de-privacidad">Aviso de Privacidad</a></span>
            </div>
            <button type="submit" class="cotizacion-submit">Enviar Solicitud de Empleo</button>
            <p class="cotizacion-note">Te contactaremos en menos de 48 horas hábiles</p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2 class="section-title">Preguntas Frecuentes sobre Empleo</h2>
      <div class="faq-container">
        {faqs.map(faq => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              <span class="faq-question-text">{faq.q}</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer"><p set:html={faq.a} /></div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
