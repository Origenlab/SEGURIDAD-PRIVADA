---
import Base from '../../layouts/Base.astro';
import HeroPagina from '../../components/HeroPagina.astro';
import NavCTA from '../../components/NavCTA.astro';
import '../../styles/pages/emergencias.css';
import '../../styles/pages/emergencias-detalle.css';

const siteUrl = 'https://seguridad-privada.com.mx';

// ── Líneas SSC ─────────────────────────────────────────────────────────────
const lineasSSC = [
  { zona:'SSC CDMX — Atención Ciudadana',    tel:'55 5208-9898', tipo:'Línea ciudadana central 24h',       alcaldia:'Toda CDMX',        disponible:'24h' },
  { zona:'SSC CDMX — Subsecretaría Operac.', tel:'55 5242-5100', tipo:'Subsecretaría de Operación Policial',alcaldia:'Toda CDMX',        disponible:'24h' },
  { zona:'Miguel Hidalgo',                   tel:'55 5208-9898', tipo:'Línea ciudadana SSC zonal',          alcaldia:'Miguel Hidalgo',   disponible:'24h' },
  { zona:'Benito Juárez — Base Plata',       tel:'55 5604-4926', tipo:'Base Plata — emergencias locales',   alcaldia:'Benito Juárez',    disponible:'24h' },
  { zona:'Cuauhtémoc',                       tel:'55 5208-9898', tipo:'Línea ciudadana SSC',                alcaldia:'Cuauhtémoc',       disponible:'24h' },
  { zona:'Coyoacán',                         tel:'55 5208-9898', tipo:'Línea ciudadana SSC',                alcaldia:'Coyoacán',         disponible:'24h' },
  { zona:'Álvaro Obregón',                   tel:'55 5208-9898', tipo:'Línea ciudadana SSC',                alcaldia:'Álvaro Obregón',   disponible:'24h' },
  { zona:'Gustavo A. Madero',                tel:'55 5208-9898', tipo:'Línea ciudadana SSC',                alcaldia:'Gustavo A. Madero',disponible:'24h' },
  { zona:'Iztapalapa',                       tel:'55 5208-9898', tipo:'Línea ciudadana SSC',                alcaldia:'Iztapalapa',       disponible:'24h' },
  { zona:'Xochimilco',                       tel:'55 5208-9898', tipo:'Línea ciudadana SSC',                alcaldia:'Xochimilco',       disponible:'24h' },
  { zona:'Naucalpan — EdoMex',               tel:'55 3605-1440', tipo:'Comisaría Gral. Seg. Pública',       alcaldia:'Naucalpan',        disponible:'24h' },
  { zona:'Tlalnepantla — EdoMex',            tel:'55 5366-3922', tipo:'Dir. Municipal de Seguridad',        alcaldia:'Tlalnepantla',     disponible:'24h' },
  { zona:'Atizapán — EdoMex',                tel:'55 5366-7193', tipo:'C4 — Centro de Control y Comando',   alcaldia:'Atizapán',         disponible:'24h' },
];

// ── Cuándo usar cada número ────────────────────────────────────────────────
const escenarios = [
  { num:'9-1-1', color:'#111', bg:'rgba(10,15,30,0.06)', cuando:'Emergencia activa — ahora mismo', ejemplos:['Robo en proceso', 'Agresión o violencia', 'Persona herida', 'Cualquier riesgo inmediato'], velocidad:'Más rápido', nota:'Despacha la patrulla más cercana disponible. Úsalo como primera opción en toda emergencia.' },
  { num:'060',   color:'#1d4ed8', bg:'rgba(29,78,216,0.06)', cuando:'Reportar sospechoso o situación irregular', ejemplos:['Persona sospechosa en la zona', 'Vehículo abandonado', 'Ruidos de pelea sin ver agresión', 'Actividad inusual en la calle'], velocidad:'Respuesta moderada', nota:'Radio patrulla SSC CDMX. Para reportes donde no hay riesgo inmediato de vida.' },
  { num:'55 5208-9898', color:'#1d4ed8', bg:'rgba(29,78,216,0.04)', cuando:'Seguimiento de casos y denuncias no urgentes', ejemplos:['Seguimiento de robo ya reportado', 'Solicitar patrullaje adicional', 'Información sobre detenidos', 'Reportes no urgentes'], velocidad:'Atención administrativa', nota:'Línea ciudadana SSC. No es para emergencias activas — el 9-1-1 siempre es más rápido.' },
  { num:'089',   color:'#4b5563', bg:'rgba(75,85,99,0.06)', cuando:'Denuncias anónimas de delitos', ejemplos:['Conoces a alguien que cometió un delito', 'Tráfico de drogas en la zona', 'Información sobre robo pasado', 'Sin querer identificarte'], velocidad:'Registro — no despacha patrulla', nota:'Denuncia anónima SSC CDMX. No genera respuesta inmediata — es para información de inteligencia.' },
];

const faqs = [
  {
    q: '¿Cuál es el número de la policía en CDMX?',
    a: 'Para emergencias activas: 9-1-1 (gratuito, 24h, despacha la patrulla más cercana). Para reportes no urgentes: 55 5208-9898 (SSC Atención Ciudadana). Para radio patrulla directa: 060. Para denuncia anónima: 089.',
  },
  {
    q: '¿Cuánto tarda en llegar una patrulla en CDMX?',
    a: 'El tiempo promedio de respuesta de la SSC CDMX varía entre 8 y 20 minutos dependiendo de la alcaldía, el turno y la disponibilidad de patrullas. Alcaldías con mayor densidad policial como Benito Juárez y Miguel Hidalgo tienden a tener tiempos menores. Marca 9-1-1 — es el canal más rápido para despacho.',
  },
  {
    q: '¿La policía puede entrar a mi condominio sin autorización?',
    a: 'Ante una emergencia activa (robo en proceso, agresión, llamada al 9-1-1), la policía puede y debe ingresar sin esperar autorización del administrador. El guardia del condominio debe abrir inmediatamente al identificarse la unidad policial en respuesta a una emergencia. Obstaculizar el ingreso puede tener consecuencias legales.',
  },
  {
    q: '¿Qué hace la SSC que la seguridad privada no puede hacer?',
    a: 'La SSC puede detener personas, hacer arrestos, usar fuerza proporcional según la ley y actuar en espacio público. La seguridad privada de ORIGINS opera exclusivamente en el espacio privado del condominio: lobby, estacionamiento, pasillos y áreas comunes. No compiten — se complementan: la SSC cubre la calle, ORIGINS cubre el interior.',
  },
  {
    q: '¿Debo llamar al 9-1-1 o a la línea directa de la alcaldía?',
    a: 'Siempre marca 9-1-1 primero en una emergencia. El sistema del 9-1-1 identifica tu ubicación y despacha la unidad más cercana disponible — puede ser más rápido que la línea de la alcaldía. Las líneas directas de la SSC son más útiles para seguimiento de reportes previos y situaciones no urgentes.',
  },
  {
    q: '¿Cómo reporto un robo ocurrido (no en proceso)?',
    a: 'Si el robo ya ocurrió y no hay riesgo inmediato, tienes dos opciones: llamar al 55 5208-9898 (SSC Atención Ciudadana) para un reporte inicial, o acudir directamente a la Fiscalía (FGJ CDMX) para levantar la denuncia formal. También puedes iniciar la denuncia en línea en denuncia.fgjcdmx.gob.mx. El número 089 es para denuncias anónimas de delitos conocidos.',
  },
];

const otrasCategoriasEmg = [
  { label:'Cruz Roja Mexicana', href:'/emergencias/cruz-roja', color:'#dc2626', badge:'065 · Delegación CDMX' },
  { label:'Bomberos CDMX', href:'/emergencias/bomberos', color:'#ea580c', badge:'068 · 14 estaciones' },
  { label:'Protección Civil', href:'/emergencias/proteccion-civil', color:'#d97706', badge:'9 alcaldías CDMX' },
  { label:'Ministerio Público', href:'/emergencias/ministerio-publico', color:'#4b5563', badge:'089 · FGJ CDMX' },
  { label:'Números Universales', href:'/emergencias/numeros-emergencia', color:'#059669', badge:'9-1-1 · 065 · 068 · 089' },
];

const zonasLinks = [
  { label:'Miguel Hidalgo (Polanco)', href:'/zonas/miguel-hidalgo' },
  { label:'Benito Juárez (Del Valle)', href:'/zonas/benito-juarez' },
  { label:'Cuauhtémoc (Condesa)', href:'/zonas/cuauhtemoc' },
  { label:'Coyoacán', href:'/zonas/coyoacan' },
  { label:'Álvaro Obregón', href:'/zonas/alvaro-obregon' },
  { label:'Naucalpan', href:'/zonas/naucalpan' },
  { label:'Tlalnepantla', href:'/zonas/tlalnepantla' },
  { label:'Atizapán', href:'/zonas/atizapan' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${siteUrl}/emergencias/policia`,
      "name": "Policía SSC CDMX — Números Directos y Cuándo Llamar · ORIGINS",
      "description": "Líneas directas de la SSC CDMX por alcaldía y municipio. 9-1-1, 060, 089 y cuándo usar cada número. Verificado de fuentes oficiales.",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
          { "@type": "ListItem", "position": 2, "name": "Directorio de Emergencias", "item": `${siteUrl}/emergencias` },
          { "@type": "ListItem", "position": 3, "name": "Policía SSC CDMX", "item": `${siteUrl}/emergencias/policia` },
        ]
      }
    },
    {
      "@type": "GovernmentOffice",
      "name": "Secretaría de Seguridad Ciudadana CDMX",
      "url": "https://ssc.cdmx.gob.mx",
      "telephone": "+5215552089898",
      "areaServed": "Ciudad de México",
      "openingHours": "Mo-Su 00:00-23:59",
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<Base
  title="Policía SSC CDMX — Números Directos y Cuándo Llamar · ORIGINS"
  description="Líneas directas SSC CDMX por alcaldía y municipios EdoMex. Cuándo usar 9-1-1, 060 o línea ciudadana. Guía de reportes de delitos. Verificado abr. 2026."
  canonical={`${siteUrl}/emergencias/policia`}
  schema={schema}
>

  <div class="emg-strip">
    <div class="emg-strip__inner">
      <span class="emg-strip__badge">Emergencia</span>
      <a href="tel:911" class="emg-strip__link">9-1-1</a>
      <span class="emg-strip__label">· Gratuito · 24h · Policía, bomberos y ambulancias</span>
    </div>
  </div>

  <HeroPagina
    badge="Directorio de Emergencias · Policía"
    titulo="Policía SSC CDMX — Números Directos y Cuándo Usar Cada Uno"
    descripcion="Líneas directas de la Secretaría de Seguridad Ciudadana CDMX por alcaldía y municipios del Estado de México. Guía de qué número marcar según el tipo de emergencia."
    breadcrumb={[
      { label:'Directorio de Emergencias', href:'/emergencias' },
      { label:'Policía SSC', href:'/emergencias/policia' },
    ]}
    ctaPrimario={{ texto:'Emergencia: 9-1-1', href:'tel:911' }}
    ctaWhatsapp={false}
    seoParrafo1={`La <strong>Secretaría de Seguridad Ciudadana (SSC) de CDMX</strong> opera 73 sectores de patrullaje y una línea central de atención ciudadana disponible las 24 horas. Para emergencias activas, el <strong>9-1-1</strong> despacha la patrulla más cercana — sin importar la alcaldía. Para reportes no urgentes, denuncias y seguimiento de casos: <strong>55 5208-9898</strong>.`}
    seoParrafo2={`Las unidades municipales de Seguridad Pública de Naucalpan, Tlalnepantla y Atizapán operan con sus propias líneas directas, distintas a la SSC CDMX. En todos los municipios del Estado de México, el <strong>9-1-1</strong> también funciona y despacha la unidad correspondiente. Fuente: <a href="https://ssc.cdmx.gob.mx" target="_blank" rel="noopener">ssc.cdmx.gob.mx</a>. Verificado abril 2026.`}
  />

  <div class="emgd-urgency-bar">
    <div class="container">
      <div class="emgd-urgency-bar__inner">
        <a href="tel:911" class="emgd-urgency-bar__num emgd-urgency-bar__num--911" style="background:rgba(29,78,216,0.15)">
          <span class="emgd-urgency-bar__eyebrow">Emergencia activa · Patrulla más cercana</span>
          <span class="emgd-urgency-bar__digit" style="color:#93c5fd">9-1-1</span>
          <span class="emgd-urgency-bar__sub">Gratuito · 24h · Todo México</span>
        </a>
        <a href="tel:060" class="emgd-urgency-bar__num">
          <span class="emgd-urgency-bar__eyebrow">Radio Patrulla SSC · CDMX</span>
          <span class="emgd-urgency-bar__digit" style="color:#93c5fd">060</span>
          <span class="emgd-urgency-bar__sub">Patrullas SSC · Reportes directos</span>
        </a>
        <a href="tel:089" class="emgd-urgency-bar__num">
          <span class="emgd-urgency-bar__eyebrow">Denuncia anónima · SSC CDMX</span>
          <span class="emgd-urgency-bar__digit" style="color:rgba(255,255,255,0.6)">089</span>
          <span class="emgd-urgency-bar__sub">Sin identificarse · Gratuito</span>
        </a>
      </div>
    </div>
  </div>

  <div class="emg-layout">
    <div class="container">
      <div class="emg-layout__grid">

        <main class="emg-layout__main">

          <!-- ══ CUÁNDO USAR CADA NÚMERO ══════════════════════════════════ -->
          <section class="emg-section emgd-section--first" id="numeros" aria-labelledby="numeros-title">
            <div class="emg-section__header emg-section__header--policia">
              <div class="emg-section__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.82 15a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.93 4.11h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 11.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h2 id="numeros-title" class="emg-section__title">¿A Cuál Número Llamo? Guía por Escenario</h2>
                <p class="emg-section__sub">No todos los números de policía hacen lo mismo — esta guía te ahorra tiempo en una emergencia</p>
              </div>
            </div>

            <div class="emgd-escenarios-grid">
              {escenarios.map(e => (
                <div class="emgd-escenario-card" style={`--e-color:${e.color};--e-bg:${e.bg}`}>
                  <div class="emgd-escenario-card__num-wrap">
                    <a href={`tel:${e.num.replace(/[\s-]/g,'')}`} class="emgd-escenario-card__num">{e.num}</a>
                    <span class="emgd-escenario-card__velocidad">{e.velocidad}</span>
                  </div>
                  <div class="emgd-escenario-card__body">
                    <h3 class="emgd-escenario-card__cuando">{e.cuando}</h3>
                    <ul class="emgd-escenario-card__ejemplos">
                      {e.ejemplos.map(ej => <li>{ej}</li>)}
                    </ul>
                    <p class="emgd-escenario-card__nota">{e.nota}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>

          <!-- ══ LÍNEAS DIRECTAS SSC ══════════════════════════════════════ -->
          <section class="emg-section emg-section--alt" id="lineas" aria-labelledby="lineas-title">
            <div class="emg-section__header emg-section__header--policia">
              <div class="emg-section__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h2 id="lineas-title" class="emg-section__title">Líneas Directas SSC CDMX y Municipios</h2>
                <p class="emg-section__sub">{lineasSSC.length} líneas verificadas · <a href="https://ssc.cdmx.gob.mx" target="_blank" rel="noopener">ssc.cdmx.gob.mx</a> · Abr. 2026</p>
              </div>
              <a href="tel:911" class="emg-section__cta">Emergencia: 9-1-1</a>
            </div>
            <div class="emg-pol-grid">
              {lineasSSC.map(l => (
                <div class="emg-pol-row">
                  <div class="emg-pol-row__zona">{l.zona}</div>
                  <div class="emg-pol-row__tipo">{l.tipo}</div>
                  <div class="emg-pol-row__actions">
                    <a href={`tel:${l.tel.replace(/[\s-]/g,'')}`} class="emg-pol-row__tel">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.82 15a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.93 4.11h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 11.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                      {l.tel}
                    </a>
                    <span class="emg-pol-row__badge">{l.disponible}</span>
                  </div>
                </div>
              ))}
            </div>
            <div class="emg-section__note" style="margin-top:1.5rem">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span>La SSC divide CDMX en 73 sectores de patrullaje. Los sectores no tienen dirección física pública — el despacho se hace a través del C5 (Centro de Comando, Control). Para emergencias, el 9-1-1 siempre es más eficiente que llamar a la línea de la alcaldía.</span>
            </div>
          </section>

          <!-- ══ EL GAP: LO QUE LA SSC NO CUBRE ════════════════════════ -->
          <section class="emg-section" id="gap-cobertura" aria-labelledby="gap-title">
            <div class="emg-section__header emg-section__header--policia">
              <div class="emg-section__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
              </div>
              <div>
                <h2 id="gap-title" class="emg-section__title">Lo que la SSC Hace — y lo que No Puede Hacer</h2>
                <p class="emg-section__sub">Entender el límite de cobertura pública es clave para proteger tu condominio</p>
              </div>
            </div>
            <div class="emgd-compare-policia">
              <div class="emgd-compare-policia__col emgd-compare-policia__col--ssc">
                <div class="emgd-compare-policia__col-header">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  <span>SSC CDMX — Espacio Público</span>
                </div>
                <ul class="emgd-compare-policia__list emgd-compare-policia__list--yes">
                  <li>Patrullaje en vialidades y calles</li>
                  <li>Respuesta a llamadas de emergencia (9-1-1)</li>
                  <li>Detención de personas en flagrancia</li>
                  <li>Control de multitudes y eventos públicos</li>
                  <li>Atención de accidentes viales</li>
                  <li>Inspección de vehículos en vía pública</li>
                </ul>
              </div>
              <div class="emgd-compare-policia__col emgd-compare-policia__col--gap">
                <div class="emgd-compare-policia__col-header">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                  <span>Espacio Privado — Sin cobertura constante SSC</span>
                </div>
                <ul class="emgd-compare-policia__list emgd-compare-policia__list--no">
                  <li>Lobby y accesos del condominio</li>
                  <li>Estacionamiento privado</li>
                  <li>Pasillos, escaleras y azoteas</li>
                  <li>Vigilancia 24/7 de áreas comunes</li>
                  <li>Control de acceso de visitantes y proveedores</li>
                  <li>Monitoreo de cámaras internas</li>
                  <li>Respuesta en segundos (no minutos)</li>
                </ul>
              </div>
            </div>
            <div class="emgd-tip-box" style="margin-top:1.5rem;background:rgba(29,78,216,0.04);border-color:rgba(29,78,216,0.15);border-left-color:#1d4ed8">
              <div class="emgd-tip-box__icon" style="color:#1d4ed8">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <div>
                <strong>El tiempo de respuesta promedio de una patrulla SSC es de 8 a 20 minutos.</strong> En ese intervalo, la única persona responsable de la seguridad en el espacio privado de tu condominio es el guardia. Sin guardia, no hay respuesta hasta que llega la patrulla.
              </div>
            </div>
          </section>

          <!-- ══ PASOS PARA REPORTAR ══════════════════════════════════════ -->
          <section class="emg-section emg-section--alt" id="como-reportar" aria-labelledby="reportar-title">
            <div class="emg-section__header emg-section__header--policia">
              <div class="emg-section__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.82 15a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.93 4.11h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 11.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h2 id="reportar-title" class="emg-section__title">Cómo Reportar un Delito o Pedir Apoyo Policial</h2>
                <p class="emg-section__sub">Qué decir y cómo decirlo para conseguir una respuesta más rápida</p>
              </div>
            </div>
            <div class="emgd-steps">
              <div class="emgd-step">
                <div class="emgd-step__num">01</div>
                <div class="emgd-step__content">
                  <h3 class="emgd-step__title"><a href="tel:911" style="color:#1d4ed8">Marca 9-1-1</a> si hay riesgo inmediato</h3>
                  <p class="emgd-step__desc">No importa la alcaldía ni el municipio — el 9-1-1 despacha la unidad más cercana disponible. Es el canal más rápido en toda CDMX y Estado de México. Gratuito, sin saldo, desde cualquier celular o teléfono fijo.</p>
                </div>
              </div>
              <div class="emgd-step">
                <div class="emgd-step__num">02</div>
                <div class="emgd-step__content">
                  <h3 class="emgd-step__title">Di el tipo de emergencia en las primeras 5 palabras</h3>
                  <p class="emgd-step__desc">"Robo en proceso, Insurgentes 1234." "Agresión con arma, Col. Del Valle." El operador lo primero que necesita es el tipo de incidente para priorizar el despacho. No empieces con contexto innecesario.</p>
                </div>
              </div>
              <div class="emgd-step">
                <div class="emgd-step__num">03</div>
                <div class="emgd-step__content">
                  <h3 class="emgd-step__title">Dirección exacta: calle, número y colonia</h3>
                  <p class="emgd-step__desc">Si no sabes la dirección exacta: "Enfrente del Oxxo de Insurgentes con Viaducto" o "Estacionamiento del edificio Tres Torres, Polanco." Una referencia reconocible puede ser más útil que un número de calle.</p>
                </div>
              </div>
              <div class="emgd-step">
                <div class="emgd-step__num">04</div>
                <div class="emgd-step__content">
                  <h3 class="emgd-step__title">Describe al sospechoso o al vehículo si los hay</h3>
                  <p class="emgd-step__desc">Ropa (color + tipo), complexión, estatura aproximada, dirección de huida. Vehículo: color, marca, placas (aunque sean parciales). Esta información es lo que permite identificar al sospechoso cuando llegue la patrulla.</p>
                </div>
              </div>
              <div class="emgd-step">
                <div class="emgd-step__num">05</div>
                <div class="emgd-step__content">
                  <h3 class="emgd-step__title">No cuelgues hasta que el operador te lo indique</h3>
                  <p class="emgd-step__desc">El operador del 9-1-1 puede darte instrucciones mientras la patrulla está en camino, actualizar la prioridad del despacho si la situación cambia, y coordinar entre múltiples unidades. Mantén la línea activa.</p>
