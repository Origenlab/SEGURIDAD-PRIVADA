---
import Base from '../../layouts/Base.astro';
import HeroPagina from '../../components/HeroPagina.astro';
import NavCTA from '../../components/NavCTA.astro';
import '../../styles/pages/emergencias.css';

// SVG reutilizables — evitar repetición en el template
const svgPhone = `<svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.82 15a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.93 4.11h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 11.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`;
const svgPin   = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.35 11.76a1 1 0 0 0 1.3 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>`;
const svgArrow = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`;
import '../../styles/pages/emergencias-detalle.css';

const siteUrl = 'https://seguridad-privada.com.mx';

// ── Datos Bomberos ─────────────────────────────────────────────────────────
const alcaldias = [
  {
    nombre: 'Miguel Hidalgo',
    estaciones: [
      { nombre:'Estación Tacuba', comandante:'Cte. Antonio Pimentel', direccion:'Golfo Gabes No. 29, Esq. Golfo San Jorge', colonia:'Tacuba', cp:'11410', tels:['55 5527-7004','55 5527-9633'], maps:'https://goo.gl/maps/MeL778RxiSAxo6xR7' },
      { nombre:'Estación Tacubaya', comandante:'Cte. Artemio Venegas Mancera', direccion:'José María Vigil No. 56, Esq. Carlos B. Zetina', colonia:'Tacubaya', cp:'11870', tels:['55 5515-5994','55 5515-0437'], maps:'https://goo.gl/maps/N4fYi1SPqn4oggMH6' },
    ],
  },
  {
    nombre: 'Benito Juárez',
    estaciones: [
      { nombre:'Estación Portales', comandante:'Cte. Enrique Padilla Lupercio', direccion:'Eje Central Lázaro Cárdenas, Esq. Santa Cruz', colonia:'Portales', cp:'03300', tels:['55 5672-8955','55 5672-9124','55 5672-9212'], maps:'https://goo.gl/maps/jtvCJbADqxLjSzkC6' },
    ],
  },
  {
    nombre: 'Cuauhtémoc',
    estaciones: [
      { nombre:'Estación San Rafael', comandante:'Cte. Eulalio Mujica Pérez', direccion:'Av. Insurgentes Norte No. 95', colonia:'San Rafael', cp:'06470', tels:['55 5705-3369','55 5705-4230'], maps:'https://goo.gl/maps/txx7SP7MmLv7PPes6' },
    ],
  },
  {
    nombre: 'Coyoacán',
    estaciones: [
      { nombre:'Estación CTM Culhuacán', comandante:'Cte. Miguel Félix Bravo', direccion:'Av. Canal Nacional No. 1130, Esq. Calzada de la Virgen', colonia:'CTM Culhuacán', cp:'04920', tels:['55 5656-1044','55 5656-1047','55 5589-8500'], maps:'https://goo.gl/maps/SpjhSP8QxJaUgw2x9' },
    ],
  },
  {
    nombre: 'Álvaro Obregón',
    estaciones: [
      { nombre:'Estación San Pedro de los Pinos', comandante:'Cte. Isidoro Solache', direccion:'Av. Escuadrón 201, Esq. Antiguo Camino a La Venta', colonia:'San Pedro de los Pinos', cp:'01150', tels:['55 5527-1248','55 5527-1461','55 5527-1516'], maps:'https://goo.gl/maps/tnCecf29j51N29xZ7' },
      { nombre:'Subestación Olivar de los Padres', comandante:null, direccion:'Av. Toluca, Esq. San Pablo', colonia:'Olivar de los Padres', cp:'01780', tels:['55 5705-4233','55 5893-1072'], maps:'https://goo.gl/maps/9gYCbzkdfzKfSZzM7' },
    ],
  },
  {
    nombre: 'Gustavo A. Madero',
    estaciones: [
      { nombre:'Estación Guadalupe Tepeyac', comandante:'Cte. José Saavedra del Razo', direccion:'Av. Henry Ford, Esq. Martha', colonia:'Guadalupe Tepeyac', cp:'07840', tels:['55 5517-0330','55 5759-5785'], maps:'https://goo.gl/maps/eBSUNMXiJs9yPfVQ8' },
      { nombre:'Subestación Villa Madero', comandante:null, direccion:'Calle 5 de Mayo No. 59', colonia:'Villa Madero', cp:'07200', tels:['55 5667-8004','55 5871-7988'], maps:'https://goo.gl/maps/Gvqtzsv7MgyscMsJ6' },
    ],
  },
  {
    nombre: 'Iztapalapa',
    estaciones: [
      { nombre:'Estación Constitución de 1917', comandante:'Cte. Jesús Blanquel Corona', direccion:'Calzada Ermita Iztapalapa No. 2121', colonia:'Constitución de 1917', cp:'09260', tels:['55 5612-1080','55 5612-1140','55 5894-4312'], maps:'https://goo.gl/maps/bSwpbhH5yRVn8hMF8' },
      { nombre:'Estación Chinampac de Juárez', comandante:'Cte. Felipe Zepeda Díaz', direccion:'Prolongación Marcelino Buendía', colonia:'Chinampac de Juárez', cp:'09208', tels:['55 5744-5345','55 5744-5354'], maps:'https://goo.gl/maps/qBumYsjUxYwzUahj8' },
    ],
  },
  {
    nombre: 'Xochimilco',
    estaciones: [
      { nombre:'Estación Xochimilco', comandante:'Cte. Ignacio Ponce de León', direccion:'Prol. 16 de Septiembre, Esq. Capulines', colonia:'Infonavit Nativitas', cp:'16090', tels:['55 5555-8420','55 5555-8987'], maps:'https://goo.gl/maps/QcDXexge63RuCh2V9' },
    ],
  },
  {
    nombre: 'Estado de México',
    nota: 'Los municipios del EdoMex cuentan con unidades propias de Protección Civil y Bomberos. Para emergencias inmediatas siempre marca 9-1-1.',
    estaciones: [
      { nombre:'Bomberos / Protección Civil Naucalpan', comandante:null, direccion:'Av. Benito Juárez 39, Edif. de Seguridad', colonia:'El Mirador', cp:'53050', tels:['55 5371-8300'], maps:null },
      { nombre:'Protección Civil Tlalnepantla', comandante:null, direccion:'Av. Sor Juana Inés de la Cruz s/n', colonia:'Centro', cp:'54000', tels:['55 5390-6548','55 5683-1154'], maps:null },
    ],
  },
];

const totalEstaciones = alcaldias.reduce((acc, a) => acc + a.estaciones.length, 0);

const faqs = [
  {
    q: '¿Cómo llamo a los Bomberos de CDMX?',
    a: 'Marca 068 o 9-1-1 desde cualquier teléfono — ambos son gratuitos, sin saldo, 24 horas. El 068 conecta directo con Bomberos CDMX. El 9-1-1 despacha la unidad más cercana disponible y puede activar simultáneamente a Bomberos y Cruz Roja.',
  },
  {
    q: '¿Cuántas estaciones de Bomberos hay en CDMX?',
    a: 'El Heroico Cuerpo de Bomberos opera 14 estaciones físicas en CDMX, distribuidas en alcaldías como Miguel Hidalgo (2 estaciones), Álvaro Obregón (2), Gustavo A. Madero (2) e Iztapalapa (2). Cada estación tiene comandante responsable, dirección exacta y teléfonos directos.',
  },
  {
    q: '¿Cuánto tarda en llegar Bomberos?',
    a: 'El tiempo depende de la distancia a la estación más cercana, el tráfico y la disponibilidad de unidades. En CDMX el tiempo de respuesta promedio es de 6 a 12 minutos para incendios estructurales. Mientras esperas, desaloja el área, cierra puertas para contener el fuego y espera en la calle para guiar a la unidad.',
  },
  {
    q: '¿Los Bomberos cobran por el servicio?',
    a: 'No. El servicio del Heroico Cuerpo de Bomberos de la Ciudad de México es completamente gratuito. Es una institución pública financiada por el gobierno de la CDMX. No se condiciona la atención al pago en ningún caso.',
  },
  {
    q: '¿Qué debo hacer mientras espero a los Bomberos en un incendio?',
    a: 'Desaloja el edificio inmediatamente. Activa la alarma de incendio. Cierra las puertas al salir (sin llave) para ralentizar la propagación del fuego. No uses elevadores. Reúnete en el punto de encuentro del condominio. Pon a alguien en la entrada principal para guiar a la unidad. Nunca regreses al interior.',
  },
  {
    q: '¿Los Bomberos atienden rescates y no solo incendios?',
    a: 'Sí. El Heroico Cuerpo de Bomberos también atiende rescates en altura, accidentes vehiculares con atrapados, derrumbes, fugas de gas, inundaciones y materiales peligrosos. El 068 o el 9-1-1 son los números correctos para cualquier emergencia que requiera sus capacidades técnicas.',
  },
  {
    q: '¿Qué pasa si hay un incendio en mi condominio y el portón está cerrado?',
    a: 'El guardia o encargado tiene la obligación de abrir el acceso inmediatamente ante cualquier emergencia. Retrasar el acceso a Bomberos en un incendio puede ser sancionado legalmente. El condominio debe tener un protocolo de emergencia que incluya el acceso inmediato sin obstáculos para servicios de emergencia.',
  },
];

const otrasCategoriasEmg = [
  { label:'Cruz Roja Mexicana', href:'/emergencias/cruz-roja', color:'#dc2626', badge:'065 · Delegación CDMX' },
  { label:'Policía SSC', href:'/emergencias/policia', color:'#1d4ed8', badge:'9-1-1 · Líneas directas' },
  { label:'Protección Civil', href:'/emergencias/proteccion-civil', color:'#d97706', badge:'9 alcaldías CDMX' },
  { label:'Ministerio Público', href:'/emergencias/ministerio-publico', color:'#4b5563', badge:'089 · FGJ CDMX' },
  { label:'Números Universales', href:'/emergencias/numeros-emergencia', color:'#059669', badge:'9-1-1 · 065 · 068 · 089' },
];

const zonasLinks = [
  { label:'Miguel Hidalgo (Polanco)', href:'/zonas/miguel-hidalgo' },
  { label:'Benito Juárez (Del Valle)', href:'/zonas/benito-juarez' },
  { label:'Cuauhtémoc (Condesa)', href:'/zonas/cuauhtemoc' },
  { label:'Coyoacán', href:'/zonas/coyoacan' },
  { label:'Álvaro Obregón', href:'/zonas/alvaro-obregon' },
  { label:'Gustavo A. Madero', href:'/zonas/gustavo-a-madero' },
  { label:'Iztapalapa', href:'/zonas/iztapalapa' },
  { label:'Xochimilco', href:'/zonas/xochimilco' },
  { label:'Naucalpan', href:'/zonas/naucalpan' },
  { label:'Tlalnepantla', href:'/zonas/tlalnepantla' },
];

const allEstaciones = alcaldias.flatMap(a => a.estaciones);

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${siteUrl}/emergencias/bomberos`,
      "name": "Bomberos CDMX — Estaciones, Dirección y Teléfonos · ORIGINS",
      "description": `Directorio de las ${totalEstaciones} estaciones del Heroico Cuerpo de Bomberos CDMX con dirección, comandante y teléfonos directos. Verificado de fuentes oficiales.`,
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
          { "@type": "ListItem", "position": 2, "name": "Directorio de Emergencias", "item": `${siteUrl}/emergencias` },
          { "@type": "ListItem", "position": 3, "name": "Bomberos CDMX", "item": `${siteUrl}/emergencias/bomberos` },
        ]
      }
    },
    ...allEstaciones.map(e => ({
      "@type": "FireStation",
      "name": e.nombre,
      "telephone": e.tels[0].replace(/\s/g,''),
      "address": {
        "@type": "PostalAddress",
        "streetAddress": e.direccion,
        "addressLocality": e.colonia,
        "postalCode": e.cp,
        "addressCountry": "MX"
      }
    })),
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<Base
  title={`Bomberos CDMX — ${totalEstaciones} Estaciones, Dirección y Teléfonos · ORIGINS`}
  description={`Directorio de ${totalEstaciones} estaciones Heroico Cuerpo de Bomberos CDMX: dirección, comandante y teléfonos directos por alcaldía. Fuente oficial. Verificado abr. 2026.`}
  canonical={`${siteUrl}/emergencias/bomberos`}
  schema={schema}
>

  <div class="emg-strip">
    <div class="emg-strip__inner">
      <span class="emg-strip__badge">Emergencia</span>
      <a href="tel:911" class="emg-strip__link">9-1-1</a>
      <span class="emg-strip__label">· Gratuito · 24h · Policía, bomberos y ambulancias</span>
    </div>
  </div>

  <HeroPagina
    badge="Directorio de Emergencias · Bomberos"
    titulo={`Heroico Cuerpo de Bomberos CDMX — ${totalEstaciones} Estaciones Verificadas`}
    descripcion="Dirección exacta, comandante responsable y teléfonos directos de cada estación de Bomberos en CDMX y Estado de México. Para emergencias inmediatas: 068 o 9-1-1."
    breadcrumb={[
      { label:'Directorio de Emergencias', href:'/emergencias' },
      { label:'Bomberos CDMX', href:'/emergencias/bomberos' },
    ]}
    ctaPrimario={{ texto:'Llamar: 068', href:'tel:068' }}
    ctaWhatsapp={false}
    seoParrafo1={`El <strong>Heroico Cuerpo de Bomberos de la Ciudad de México</strong> opera <strong>${totalEstaciones} estaciones físicas</strong> distribuidas en alcaldías como Miguel Hidalgo, Benito Juárez, Cuauhtémoc, Coyoacán, Álvaro Obregón, Gustavo A. Madero, Iztapalapa y Xochimilco. Cada estación tiene comandante responsable, dirección exacta y teléfonos directos.`}
    seoParrafo2={`Para reportar un incendio o solicitar rescate marca <strong>068</strong> — es gratuito desde cualquier teléfono, 24 horas. También puedes marcar <strong>9-1-1</strong> para despachar la unidad más cercana. Fuente: <a href="https://bomberos.cdmx.gob.mx/estaciones" target="_blank" rel="noopener">bomberos.cdmx.gob.mx</a>. Verificado abril 2026.`}
  />

  <!-- ── URGENCY BAR ─────────────────────────────────────────────────────── -->
  <div class="emgd-urgency-bar">
    <div class="container">
      <div class="emgd-urgency-bar__inner">
        <a href="tel:068" class="emgd-urgency-bar__num emgd-urgency-bar__num--bomberos">
          <span class="emgd-urgency-bar__eyebrow">Bomberos CDMX · Gratuito · Todo México</span>
          <span class="emgd-urgency-bar__digit">068</span>
          <span class="emgd-urgency-bar__sub">Heroico Cuerpo de Bomberos · 24 horas</span>
        </a>
        <a href="tel:911" class="emgd-urgency-bar__num emgd-urgency-bar__num--911">
          <span class="emgd-urgency-bar__eyebrow">Emergencia inmediata · Todo México</span>
          <span class="emgd-urgency-bar__digit">9-1-1</span>
          <span class="emgd-urgency-bar__sub">Policía · Bomberos · Ambulancias</span>
        </a>
        <div class="emgd-urgency-bar__num emgd-urgency-bar__num--info">
          <span class="emgd-urgency-bar__eyebrow">Estaciones verificadas en esta página</span>
          <span class="emgd-urgency-bar__digit">{totalEstaciones}</span>
          <span class="emgd-urgency-bar__sub">CDMX y Estado de México · Abr. 2026</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ BODY CON SIDEBAR ═══════════════════════════════════════════════ -->
  <div class="emg-layout">
    <div class="container">
      <div class="emg-layout__grid">

        <main class="emg-layout__main">

          <!-- ══ ESTACIONES POR ALCALDÍA ══════════════════════════════════ -->
          <section class="emg-section emgd-section--first" id="estaciones" aria-labelledby="estaciones-title">
            <div class="emg-section__header emg-section__header--bomberos">
              <div class="emg-section__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
              </div>
              <div>
                <h2 id="estaciones-title" class="emg-section__title">Estaciones del Heroico Cuerpo de Bomberos CDMX</h2>
                <p class="emg-section__sub">{totalEstaciones} estaciones verificadas · <a href="https://bomberos.cdmx.gob.mx/estaciones" target="_blank" rel="noopener">bomberos.cdmx.gob.mx</a> · Abr. 2026</p>
              </div>
              <a href="tel:068" class="emg-section__cta emg-section__cta--orange">Llamar: 068</a>
            </div>

            {alcaldias.map(alcaldia => (
              <div class="emgd-alcaldia-group">
                <div class="emgd-alcaldia-group__header">
                  <div class="emgd-alcaldia-group__dot"></div>
                  <h3 class="emgd-alcaldia-group__name">{alcaldia.nombre}</h3>
                  <span class="emgd-alcaldia-group__count">{alcaldia.estaciones.length} estación{alcaldia.estaciones.length > 1 ? 'es' : ''}</span>
                </div>
                {alcaldia.nota && (
                  <p class="emgd-alcaldia-group__nota">{alcaldia.nota}</p>
                )}
                <div class="emgd-estaciones-grid">
                  {alcaldia.estaciones.map(e => (
                    <article class="emgd-estacion-card">
                      <div class="emgd-estacion-card__header">
                        <div class="emgd-estacion-card__header-content">
                          <span class="emgd-estacion-card__tipo">{e.comandante ? 'Estación' : 'Subestación'}</span>
                          <h4 class="emgd-estacion-card__nombre">{e.nombre}</h4>
                        </div>
                        {e.comandante && (
                          <div class="emgd-estacion-card__comandante">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                            {e.comandante}
                          </div>
                        )}
                      </div>
                      <div class="emgd-estacion-card__body">
                        {e.maps ? (
                          <a href={e.maps} target="_blank" rel="noopener" class="emgd-sede-card__dir emgd-sede-card__dir--link" style="--sede-color:#ea580c">
                            <div class="emgd-sede-card__dir-icon emgd-sede-card__dir-icon--bomberos">
                              <svg width="14" height="14" aria-hidden="true"><use href="#icon-pin"/></svg>
                            </div>
                            <div class="emgd-sede-card__dir-text">
                              <span class="emgd-sede-card__calle">{e.direccion}</span>
                              <span class="emgd-sede-card__colonia">Col. {e.colonia} · C.P. {e.cp}</span>
                              <span class="emgd-sede-card__maps-cta" style="color:#ea580c">Ver en Google Maps →</span>
                            </div>
                          </a>
                        ) : (
                          <div class="emgd-sede-card__dir">
                            <div class="emgd-sede-card__dir-icon emgd-sede-card__dir-icon--bomberos">
                              <svg width="14" height="14" aria-hidden="true"><use href="#icon-pin"/></svg>
                            </div>
                            <div class="emgd-sede-card__dir-text">
                              <span class="emgd-sede-card__calle">{e.direccion}</span>
                              <span class="emgd-sede-card__colonia">Col. {e.colonia} · C.P. {e.cp}</span>
                            </div>
                          </div>
                        )}
                        <div class="emgd-estacion-card__tels">
                          {e.tels.map((t, i) => (
                            <a href={`tel:${t.replace(/\s/g,'')}`} class={`emgd-estacion-card__tel${i===0?' emgd-estacion-card__tel--primary':''}`}>
                              <svg width="11" height="11" aria-hidden="true"><use href="#icon-phone"/></svg>
                              {t}
                            </a>
                          ))}
                        </div>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            ))}
          </section>

          <!-- ══ CÓMO REPORTAR ════════════════════════════════════════════ -->
          <section class="emg-section emg-section--alt" id="como-llamar" aria-labelledby="llamar-title">
            <div class="emg-section__header emg-section__header--bomberos">
              <div class="emg-section__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.82 15a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.93 4.11h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 11.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h2 id="llamar-title" class="emg-section__title">Cómo Reportar un Incendio o Pedir Rescate</h2>
                <p class="emg-section__sub">Pasos exactos para llamar al 068 y qué hacer mientras llegan los Bomberos</p>
              </div>
            </div>
            <div class="emgd-steps">
              <div class="emgd-step" style="--step-color:#ea580c">
                <div class="emgd-step__num">01</div>
                <div class="emgd-step__content">
                  <h3 class="emgd-step__title"><a href="tel:068" style="color:#ea580c">Marca 068</a> o <a href="tel:911" style="color:#ea580c">9-1-1</a> de inmediato</h3>
                  <p class="emgd-step__desc">No esperes para ver si el fuego crece. El 068 conecta directo a Bomberos CDMX. El 9-1-1 puede despachar múltiples unidades a la vez: bomberos, ambulancias y policía. Ambos son gratuitos, sin saldo, desde cualquier celular.</p>
                </div>
              </div>
              <div class="emgd-step" style="--step-color:#ea580c">
                <div class="emgd-step__num">02</div>
                <div class="emgd-step__content">
                  <h3 class="emgd-step__title">Desaloja el área antes de llamar o mientras llamas</h3>
                  <p class="emgd-step__desc">Tu seguridad primero. Activa la alarma de incendio, da la voz de alerta a los vecinos y sal del edificio. Puedes llamar al 068 desde la calle. No regreses a buscar objetos personales.</p>
                </div>
              </div>
              <div class="emgd-step" style="--step-color:#ea580c">
                <div class="emgd-step__num">03</div>
                <div class="emgd-step__content">
