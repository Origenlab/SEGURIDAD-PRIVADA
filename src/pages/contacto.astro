---
import Base from '../layouts/Base.astro';
import HeroPagina from '../components/HeroPagina.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PageCTA from '../components/PageCTA.astro';
import '../styles/pages/contacto.css';

const siteUrl = 'https://seguridad-privada.com.mx';
---

<Base
  title="Contacto | ORIGINS Private Security"
  description="Contacta a ORIGINS Private Security para cotizar seguridad privada para condominios en CDMX. Respondemos en menos de 2 horas por WhatsApp, teléfono o formulario."
  canonical={`${siteUrl}/contacto`}
>

  <HeroPagina
    badge="Atención Inmediata"
    titulo="Contacta a ORIGINS Private Security"
    descripcion="Solicita tu cotización o diagnóstico gratuito. Respondemos en menos de 2 horas por WhatsApp, teléfono o formulario."
    breadcrumb={[{ label: 'Contacto', href: '/contacto' }]}
    ctaWhatsapp={true}
    ctaPrimario={{ texto: 'Solicitar Cotización', href: '#formulario' }}
    seoParrafo1='¿Necesitas <a href="/servicios/guardias-intramuros">guardias intramuros</a> para tu condominio? ¿Quieres mejorar el <a href="/servicios/control-de-accesos">control de accesos</a> en tu fraccionamiento? Nuestro equipo de atención está disponible <strong>24 horas al día, los 7 días de la semana</strong>. La primera consulta y el diagnóstico de seguridad son completamente gratuitos.'
    seoParrafo2='Atendemos a administradores de condominio, comités de vigilancia y desarrolladoras en toda la <a href="/zonas">Zona Metropolitana</a>. Con <strong>Permiso SSC 0102-15</strong> y más de 15 años de operación, entregamos una propuesta formal en menos de 24 horas con costos transparentes, sin letra pequeña.'
  />

  <!-- Canales de contacto -->
  <section class="contacto-canales">
    <div class="container">
      <SectionHeader
        badge="Canales Directos"
        titulo="Elige cómo comunicarte"
        subtitulo="Estamos disponibles 24/7 por WhatsApp y teléfono. El formulario tiene respuesta en menos de 24 horas."
        align="center"
      />

      <div class="contacto-canales__grid">

        <!-- WhatsApp -->
        <div class="contacto-canal-card contacto-canal-card--wa">
          <div class="contacto-canal-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <h3 class="contacto-canal-card__titulo">WhatsApp</h3>
          <p class="contacto-canal-card__dato">55 3025 5580 · Disponible 24/7</p>
          <a
            href="https://wa.me/525530255580?text=Hola%2C%20me%20interesa%20cotizar%20seguridad%20para%20mi%20condominio"
            class="contacto-canal-card__cta"
            target="_blank"
            rel="noopener"
          >
            Enviar mensaje
          </a>
        </div>

        <!-- Teléfono -->
        <div class="contacto-canal-card">
          <div class="contacto-canal-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3 class="contacto-canal-card__titulo">Teléfono</h3>
          <p class="contacto-canal-card__dato">55 3025 5580 · Lunes–Domingo, 24h</p>
          <a href="tel:+525530255580" class="contacto-canal-card__cta contacto-canal-card__cta--secondary">
            Llamar ahora
          </a>
        </div>

        <!-- Email -->
        <div class="contacto-canal-card">
          <div class="contacto-canal-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2,4 12,13 22,4"/></svg>
          </div>
          <h3 class="contacto-canal-card__titulo">Correo Electrónico</h3>
          <p class="contacto-canal-card__dato">contacto@seguridad-privada.com.mx</p>
          <a href="mailto:contacto@seguridad-privada.com.mx" class="contacto-canal-card__cta contacto-canal-card__cta--secondary">
            Enviar correo
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Formulario + Info -->
  <section class="contacto-form-section">
    <div class="container">
      <div class="contacto-main-grid">

        <!-- Formulario -->
        <div class="contacto-form-card">
          <div class="contacto-form-card__header">
            <span class="contacto-form-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Cotización Gratuita
            </span>
            <h2>Solicita tu diagnóstico de seguridad</h2>
            <p>Respuesta personalizada en menos de 24 horas. Sin compromiso.</p>
          </div>

          <form id="contactForm" class="faq-cotizacion__form" action="https://formsubmit.co/josecruz@originsecurity.mx" method="POST" novalidate>
            <input type="text" name="_honey" style="display:none" aria-hidden="true">
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_next" value="https://seguridad-privada.com.mx/gracias.html">

            <div class="faq-form__field">
              <label for="nombre">Nombre completo <span aria-hidden="true">*</span></label>
              <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre completo" autocomplete="name">
            </div>

            <div class="faq-form__row">
              <div class="faq-form__field">
                <label for="telefono">Teléfono <span aria-hidden="true">*</span></label>
                <input type="tel" id="telefono" name="telefono" required placeholder="55 1234 5678" autocomplete="tel">
              </div>
              <div class="faq-form__field">
                <label for="email">Correo electrónico <span aria-hidden="true">*</span></label>
                <input type="email" id="email" name="email" required placeholder="correo@empresa.com" autocomplete="email">
              </div>
            </div>

            <div class="faq-form__field">
              <label for="empresa">Nombre del condominio / residencial <span aria-hidden="true">*</span></label>
              <input type="text" id="empresa" name="empresa" required placeholder="Ej: Torre Polanco 200, Residencial Interlomas">
            </div>

            <div class="faq-form__row">
              <div class="faq-form__field">
                <label for="ubicacion">Zona <span aria-hidden="true">*</span></label>
                <select id="ubicacion" name="ubicacion" required>
                  <option value="">Selecciona</option>
                  <optgroup label="CDMX">
                    <option value="cdmx-miguel-hidalgo">Miguel Hidalgo</option>
                    <option value="cdmx-cuauhtemoc">Cuauhtémoc</option>
                    <option value="cdmx-benito-juarez">Benito Juárez</option>
                    <option value="cdmx-alvaro-obregon">Álvaro Obregón</option>
                    <option value="cdmx-coyoacan">Coyoacán</option>
                    <option value="cdmx-tlalpan">Tlalpan</option>
                    <option value="cdmx-otras">Otra alcaldía CDMX</option>
                  </optgroup>
                  <optgroup label="Estado de México">
                    <option value="edomex-naucalpan">Naucalpan / Interlomas</option>
                    <option value="edomex-tlalnepantla">Tlalnepantla</option>
                    <option value="edomex-atizapan">Atizapán</option>
                    <option value="edomex-otros">Otro municipio EdoMex</option>
                  </optgroup>
                </select>
              </div>
              <div class="faq-form__field">
                <label for="tipoServicio">Servicio <span aria-hidden="true">*</span></label>
                <select id="tipoServicio" name="tipoServicio" required>
                  <option value="">Selecciona</option>
                  <option value="seguridad-condominios">Seguridad Condominios</option>
                  <option value="guardias-intramuros">Guardias Intramuros</option>
                  <option value="seguridad-residenciales">Residenciales / Fraccionamientos</option>
                  <option value="control-accesos">Control de Accesos</option>
                  <option value="patrullaje">Patrullaje</option>
                  <option value="vigilancia-cctv">Vigilancia CCTV</option>
                  <option value="consultoria">Consultoría de Seguridad</option>
                </select>
              </div>
            </div>

            <div class="faq-form__field">
              <label for="mensaje">Cuéntanos sobre tu condominio <span class="faq-form__optional">(opcional)</span></label>
              <textarea id="mensaje" name="mensaje" rows="3" placeholder="Número de accesos, torres o casas, residentes aproximados..."></textarea>
            </div>

            <div class="faq-form__terms">
              <input type="checkbox" id="terminos" name="terminos" required>
              <label for="terminos">Acepto la <a href="/aviso-de-privacidad">política de privacidad</a> y recibir información comercial</label>
            </div>

            <button type="submit" class="faq-form__submit">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Solicitar Cotización por WhatsApp
            </button>

            <p class="faq-form__note">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              Diagnóstico gratuito · Respuesta en 24h · Permiso SSC 0102-15
            </p>
          </form>
        </div>

        <!-- Información de contacto -->
        <div class="contacto-info">
          <h2 class="contacto-info__titulo">Información de Contacto</h2>

          <div class="contacto-info__item">
            <div class="contacto-info__item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.35 11.76a1 1 0 0 0 1.3 0C13 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
            </div>
            <div class="contacto-info__item-content">
              <h4>Dirección</h4>
              <p>Basiliso Romo Anguiano No 22 int 3<br>Col. Industrial, CDMX 07800</p>
            </div>
          </div>

          <div class="contacto-info__item">
            <div class="contacto-info__item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="contacto-info__item-content">
              <h4>Teléfono</h4>
              <a href="tel:+525530255580">55 3025 5580</a>
              <p>Disponible 24/7, todos los días</p>
            </div>
          </div>

          <div class="contacto-info__item">
            <div class="contacto-info__item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2,4 12,13 22,4"/></svg>
            </div>
            <div class="contacto-info__item-content">
              <h4>Correo Electrónico</h4>
              <a href="mailto:contacto@seguridad-privada.com.mx">contacto@seguridad-privada.com.mx</a>
            </div>
          </div>

          <div class="contacto-info__item">
            <div class="contacto-info__item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <div class="contacto-info__item-content">
              <h4>Permiso de Operación</h4>
              <p>SSC 0102-15 — Secretaría de Seguridad Ciudadana de la Ciudad de México</p>
            </div>
          </div>

          <div class="contacto-info__item">
            <div class="contacto-info__item-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="contacto-info__item-content">
              <h4>Horario de Atención</h4>
              <p>Operación 24 horas / 7 días<br>Guardias disponibles en todo momento</p>
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>

  <PageCTA
    titulo="¿Prefieres contacto directo?"
    descripcion="Nuestro equipo responde en minutos por WhatsApp. Sin bots, sin esperas."
    ctaWhatsapp={true}
    ctaPrimario={{ texto: 'Ver Servicios', href: '/servicios' }}
  />

</Base>
