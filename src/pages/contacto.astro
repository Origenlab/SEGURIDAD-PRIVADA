---
import Base from '../layouts/Base.astro';

const siteUrl = 'https://seguridad-privada.com.mx';
---

<Base
  title="Contacto | ORIGINS Private Security"
  description="Contacta a ORIGINS Private Security para cotizar seguridad privada para condominios, residenciales y guardias intramuros en CDMX."
  canonical={`${siteUrl}/contacto`}
>
  <section class="contact-page">
    <div class="container">
      <span class="contact-page__badge">Atención inmediata</span>
      <h1>Contacto</h1>
      <p class="contact-page__intro">
        Solicita una cotización para seguridad privada en condominios y residenciales. Atendemos
        CDMX y Zona Metropolitana.
      </p>

      <div class="contact-page__grid">
        <article class="contact-card">
          <h2>Canales directos</h2>
          <ul class="contact-list">
            <li><strong>Teléfono:</strong> <a href="tel:+525530255580">55 3025 5580</a></li>
            <li><strong>WhatsApp:</strong> <a href="https://wa.me/525530255580" target="_blank" rel="noopener">Enviar mensaje</a></li>
            <li><strong>Email:</strong> <a href="mailto:contacto@seguridad-privada.com.mx">contacto@seguridad-privada.com.mx</a></li>
            <li><strong>Horario:</strong> Lun a Dom, 24 horas</li>
          </ul>
        </article>

        <article class="contact-card">
          <h2>Oficina</h2>
          <p>
            ORIGINS PRIVATE SECURITY S.A. DE C.V.<br />
            Basiliso Romo Anguiano No 22 int 3<br />
            Col. Industrial, CDMX<br />
            C.P. 07800
          </p>
        </article>
      </div>

      <div class="contact-actions">
        <a href="/#cotizacion" class="btn btn-primary">Ir al formulario</a>
        <a href="/servicios" class="btn btn-secondary">Ver servicios</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-page {
    padding: 4rem 0;
  }

  .contact-page__badge {
    display: inline-block;
    margin-bottom: 1rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: var(--color-accent);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .contact-page h1 {
    margin-bottom: 1rem;
  }

  .contact-page__intro {
    max-width: 720px;
    margin-bottom: 2rem;
    color: var(--color-text-light);
  }

  .contact-page__grid {
    display: grid;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .contact-card {
    padding: 1.5rem;
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-md);
  }

  .contact-card h2 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .contact-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
