const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${siteUrl}/emergencias`,
      "name": "Directorio de Emergencias — Policía, Bomberos y Cruz Roja por Alcaldía",
      "description": "Números de emergencia verificados para policía, bomberos, Cruz Roja y protección civil en CDMX y Estado de México.",
      "url": `${siteUrl}/emergencias`,
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
          { "@type": "ListItem", "position": 2, "name": "Directorio de Emergencias", "item": `${siteUrl}/emergencias` }
        ]
      }
    },
    {
      "@type": "EmergencyService",
      "name": "Emergencias Nacionales — 9-1-1",
      "telephone": "911",
      "description": "Número de emergencias nacional de México. Gratuito, 24 horas, 365 días.",
      "areaServed": { "@type": "Country", "name": "México" },
      "availableChannel": { "@type": "ServiceChannel", "serviceUrl": "tel:911" }
    }
