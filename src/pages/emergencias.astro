---

<Base
  title="Directorio de Emergencias CDMX | Bomberos, Policía y Ministerio Público · ORIGINS"
  description="Directorio de estaciones de Bomberos, Policía, Cruz Roja, Protección Civil y Ministerio Público en CDMX. Dirección exacta, colonia y teléfono verificado por zona."
  canonical={`${siteUrl}/emergencias`}
  schema={schema}
>

  <!-- ── 911 STRIP ──────────────────────────────────────────────────────── -->
  <div class="emg-strip">
    <div class="emg-strip__inner">
      <span class="emg-strip__badge">Emergencia</span>
      <a href="tel:911" class="emg-strip__link">9-1-1</a>
      <span class="emg-strip__label">· Gratuito · 24h · Policía, bomberos y ambulancias</span>
    </div>
  </div>

  <!-- ── HERO ───────────────────────────────────────────────────────────── -->
  <HeroPagina
    badge="Directorio de Emergencias"
    titulo="Estaciones de Bomberos, Policía, Cruz Roja y Más"
    descripcion="Nombre, dirección exacta, colonia y teléfono de cada institución de emergencias en las 11 zonas donde opera ORIGINS — CDMX y Estado de México."
    breadcrumb={[{ label:'Inicio', href:'/' }, { label:'Directorio de Emergencias', href:'/emergencias' }]}
    ctaPrimario={{ texto:'Cotizar Seguridad Privada', href:'/contacto' }}
    ctaWhatsapp={true}
    seoParrafo1={`Directorio verificado de <strong>estaciones físicas</strong> del Heroico Cuerpo de Bomberos, Cruz Roja, Protección Civil por alcaldía, Ministerio Público y Policía SSC — para saber exactamente <strong>a dónde ir en persona</strong> o a quién llamar directamente.`}
    seoParrafo2={`Datos de fuentes oficiales: <a href="https://bomberos.cdmx.gob.mx" target="_blank" rel="noopener">bomberos.cdmx.gob.mx</a>, <a href="https://proteccioncivil.cdmx.gob.mx" target="_blank" rel="noopener">proteccioncivil.cdmx.gob.mx</a> y <a href="https://fgjcdmx.gob.mx" target="_blank" rel="noopener">fgjcdmx.gob.mx</a>. Verificado abril 2026. Para emergencias inmediatas marca siempre <strong>9-1-1</strong>.`}
  />

  <!-- ── STATS ──────────────────────────────────────────────────────────── -->
  <div class="emg-stats">
    <div class="container">
      <div class="emg-stats__grid">
        <div class="emg-stats__item"><div class="emg-stats__num">{bomberos.length}</div><div class="emg-stats__label">Estaciones bomberos</div></div>
        <div class="emg-stats__item"><div class="emg-stats__num">6</div><div class="emg-stats__label">Categorías de servicio</div></div>
        <div class="emg-stats__item"><div class="emg-stats__num" style="color:#dc2626">9-1-1</div><div class="emg-stats__label">Emergencia inmediata</div></div>
        <div class="emg-stats__item"><div class="emg-stats__num">Abr'26</div><div class="emg-stats__label">Última verificación</div></div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BODY CON SIDEBAR
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="emg-layout">
    <div class="container">
      <div class="emg-layout__grid">

        <!-- ── MAIN ──────────────────────────────────────────────────────── -->
        <main class="emg-layout__main">

          <!-- ── ÍNDICE DE CATEGORÍAS ─────────────────────────────────── -->
          <section class="emg-index" aria-labelledby="index-title">
            <div class="emg-index__header">
              <span class="prose-section-badge">Categorías del directorio</span>
              <h2 id="index-title" class="emg-index__title">¿Qué tipo de servicio necesitas?</h2>
              <p class="emg-index__sub">Selecciona la categoría para ir directamente al directorio correspondiente.</p>
            </div>
            <div class="emg-index__grid">
              {categorias.map(cat => (
                <a href={cat.ancla} class="emg-cat-card" style={`--cat-color:${cat.color};--cat-bg:${cat.colorBg}`}>

                  {/* Header de color — equivalente a la imagen del ServiceCard */}
                  <div class="emg-cat-card__header">
                    <div class="emg-cat-card__header-inner">
                      <span class="emg-cat-card__badge">{cat.badge}</span>
                      <h3 class="emg-cat-card__title">{cat.titulo}</h3>
                    </div>
                    <div class="emg-cat-card__header-accent" aria-hidden="true"></div>
                  </div>

                  {/* Body */}
                  <div class="emg-cat-card__body">
                    <p class="emg-cat-card__subtitulo">{cat.subtitulo}</p>
                    <p class="emg-cat-card__desc">{cat.descripcion}</p>
                    <ul class="emg-cat-card__features">
                      {cat.features.map(f => <li>{f}</li>)}
                    </ul>
                  </div>

                  {/* CTA barra inferior — igual que ServiceCard */}
                  <span class="emg-cat-card__cta">
                    {cat.cta}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </span>

                </a>
              ))}
            </div>
          </section>

          <!-- ══ SECCIÓN 1: BOMBEROS ══════════════════════════════════════ -->
          <section class="emg-section" id="bomberos" aria-labelledby="bomberos-title">
            <div class="emg-section__header emg-section__header--bomberos">
              <div class="emg-section__icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg></div>
              <div>
                <h2 id="bomberos-title" class="emg-section__title">Heroico Cuerpo de Bomberos CDMX</h2>
                <p class="emg-section__sub">Estaciones físicas verificadas · <a href="https://bomberos.cdmx.gob.mx/estaciones" target="_blank" rel="noopener">bomberos.cdmx.gob.mx</a> · Verificado abr. 2026</p>
              </div>
              <a href="tel:068" class="emg-section__cta emg-section__cta--orange">Llamar: 068</a>
            </div>
            <div class="emg-dir__grid">
              {bomberos.map(b => (
                <article class="emg-scard emg-scard--bomberos">
                  <div class="emg-scard__zone-tag">{b.zona}</div>
                  <div class="emg-scard__body">
                    <h3 class="emg-scard__nombre">{b.nombre}</h3>
