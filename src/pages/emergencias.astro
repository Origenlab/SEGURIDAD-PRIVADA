---

<Base
  title="Directorio de Emergencias CDMX | Bomberos, Policía y Ministerio Público · ORIGINS"
  description="Directorio de estaciones de Bomberos, Policía, Cruz Roja, Protección Civil y Ministerio Público en CDMX. Dirección exacta, colonia y teléfono verificado por zona."
  canonical={`${siteUrl}/emergencias`}
  schema={schema}
>

  <!-- ── 911 STICKY ─────────────────────────────────────────────────────── -->
  <div class="emg-strip">
    <div class="emg-strip__inner">
      <span class="emg-strip__badge">Emergencia ahora</span>
      <a href="tel:911" class="emg-strip__link">9-1-1</a>
      <span class="emg-strip__label">· Gratuito · 24h · Policía, bomberos y ambulancias</span>
    </div>
  </div>

  <!-- ── HERO ──────────────────────────────────────────────────────────── -->
  <HeroPagina
    badge="Directorio de Emergencias"
    titulo="Estaciones de Bomberos, Policía, Cruz Roja y Más"
    descripcion="Nombre, dirección exacta, colonia y teléfono de cada institución de emergencias en las zonas donde ORIGINS opera — CDMX y Estado de México."
    breadcrumb={[{ label:'Inicio', href:'/' }, { label:'Directorio de Emergencias', href:'/emergencias' }]}
    ctaPrimario={{ texto:'Cotizar Seguridad Privada', href:'/contacto' }}
    ctaWhatsapp={true}
    seoParrafo1={`Directorio verificado de <strong>estaciones físicas</strong> del Heroico Cuerpo de Bomberos, Cruz Roja, Protección Civil por alcaldía, Ministerio Público (Fiscalía CDMX) y Policía SSC — para que sepas exactamente <strong>a dónde ir en persona</strong> o a quién llamar directamente según el tipo de emergencia.`}
    seoParrafo2={`Datos obtenidos de fuentes oficiales: <a href="https://bomberos.cdmx.gob.mx" target="_blank" rel="noopener">bomberos.cdmx.gob.mx</a>, <a href="https://proteccioncivil.cdmx.gob.mx" target="_blank" rel="noopener">proteccioncivil.cdmx.gob.mx</a> y <a href="https://fgjcdmx.gob.mx" target="_blank" rel="noopener">fgjcdmx.gob.mx</a>. Verificado abril 2026. Para emergencias inmediatas, marca siempre <strong>9-1-1</strong> primero.`}
  />

  <!-- ── STATS ─────────────────────────────────────────────────────────── -->
  <div class="emg-stats">
    <div class="container">
      <div class="emg-stats__grid">
        <div class="emg-stats__item">
          <div class="emg-stats__num">{bomberos.length}</div>
          <div class="emg-stats__label">Estaciones bomberos</div>
        </div>
        <div class="emg-stats__item">
          <div class="emg-stats__num">6</div>
          <div class="emg-stats__label">Categorías de servicio</div>
        </div>
        <div class="emg-stats__item">
          <div class="emg-stats__label" style="font-size:0.7rem;margin-bottom:0.1rem;text-transform:uppercase;letter-spacing:0.05em">Emergencia</div>
          <div class="emg-stats__num" style="color:#dc2626">9-1-1</div>
        </div>
        <div class="emg-stats__item">
          <div class="emg-stats__num">Abr'26</div>
          <div class="emg-stats__label">Última verificación</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── ÍNDICE DE CATEGORÍAS ───────────────────────────────────────────── -->
  <section class="emg-index" aria-labelledby="index-title">
    <div class="container">
      <div class="emg-index__header">
        <span class="prose-section-badge">Categorías del directorio</span>
        <h2 id="index-title" class="emg-index__title">¿Qué tipo de ayuda necesitas?</h2>
        <p class="emg-index__sub">Selecciona la categoría para ir directamente al directorio correspondiente.</p>
      </div>

      <div class="emg-index__grid">
        {categorias.map(cat => (
          <a href={cat.ancla} class="emg-cat-card" style={`--cat-color:${cat.color};--cat-bg:${cat.bg}`}>
            <div class="emg-cat-card__icon" aria-hidden="true">
              {cat.icono === 'fire' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>}
              {cat.icono === 'shield' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {cat.icono === 'alert' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>}
              {cat.icono === 'cross' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 12h6M12 9v6"/></svg>}
              {cat.icono === 'gavel' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 14l-4-4 6-6-2-2-6 6-4-4-2 2 10 10z"/><path d="M3 21h18"/></svg>}
              {cat.icono === 'phone' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.82 15a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.93 4.11h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 11.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>}
            </div>
            <div class="emg-cat-card__body">
              <strong class="emg-cat-card__nombre">{cat.nombre}</strong>
              <span class="emg-cat-card__sub">{cat.subtitulo}</span>
              <p class="emg-cat-card__desc">{cat.descripcion}</p>
            </div>
            <div class="emg-cat-card__footer">
              <span class="emg-cat-card__total">{cat.total}</span>
              <span class="emg-cat-card__arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- SECCIÓN 1: BOMBEROS                                                   -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <section class="emg-section" id="bomberos" aria-labelledby="bomberos-title">
    <div class="container">
      <div class="emg-section__header emg-section__header--bomberos">
        <div class="emg-section__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
