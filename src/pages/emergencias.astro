    ...bomberos.map(b => ({
      "@type": "FireStation",
      "name": b.nombre,
      "address": { "@type": "PostalAddress", "streetAddress": b.direccion, "addressLocality": b.colonia, "addressRegion": b.zona, "postalCode": b.cp, "addressCountry": "MX" },
