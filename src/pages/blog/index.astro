---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const featuredPosts = sortedPosts.filter(post => post.data.featured);
const regularPosts = sortedPosts.filter(post => !post.data.featured);

const siteUrl = 'https://seguridad-privada.com.mx';

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog de Seguridad Privada | ORIGINS Security",
  "description": "Guías, consejos y artículos sobre seguridad privada para condominios, residenciales y empresas en CDMX.",
  "url": `${siteUrl}/blog`,
  "publisher": {
    "@id": `${siteUrl}/#organization`
  }
};
---

<Base
  title="Blog de Seguridad Privada | Guías y Consejos | ORIGINS"
  description="Artículos, guías y consejos sobre seguridad privada para condominios, residenciales y empresas. Aprende a proteger tu propiedad con expertos."
  canonical={`${siteUrl}/blog`}
  schema={schema}
>
  <!-- Hero -->
  <section class="blog-hero">
    <div class="container">
      <h1>Blog de Seguridad Privada</h1>
      <p>Guías, consejos y artículos de expertos para proteger tu condominio, residencial o empresa</p>
    </div>
  </section>

  <!-- Featured Posts -->
  {featuredPosts.length > 0 && (
    <section class="blog-featured">
      <div class="container">
        <h2>Artículos Destacados</h2>
        <div class="featured-grid">
          {featuredPosts.slice(0, 3).map((post) => (
            <a href={`/blog/${post.id}`} class="featured-card">
              {post.data.heroImage && (
                <div class="featured-card__image">
                  <img src={post.data.heroImage.src} alt={post.data.heroImage.alt} loading="eager" />
                </div>
              )}
              <div class="featured-card__content">
                <span class="featured-card__category">{post.data.cluster.replace(/-/g, ' ')}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="featured-card__meta">
                  <span>{post.data.readingTime || 5} min de lectura</span>
                  <span>{new Date(post.data.publishDate).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- All Posts -->
  <section class="blog-list">
    <div class="container">
      <h2>Todos los Artículos</h2>
      <div class="posts-grid">
        {sortedPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card">
            {post.data.heroImage && (
              <div class="post-card__image">
                <img src={post.data.heroImage.src} alt={post.data.heroImage.alt} loading="lazy" />
              </div>
            )}
            <div class="post-card__content">
              <span class="post-card__category">{post.data.cluster.replace(/-/g, ' ')}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="post-card__read-more">Leer artículo →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="blog-cta">
    <div class="container">
      <h2>¿Necesitas Seguridad Profesional?</h2>
      <p>Solicita una evaluación gratuita para tu condominio o residencial</p>
      <a href="/contacto" class="btn btn-primary">Solicitar Cotización</a>
    </div>
  </section>
</Base>

<style>
  .blog-hero {
    padding: 3rem 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, #1a1a1a 100%);
    color: var(--color-white);
    text-align: center;
  }

  .blog-hero h1 {
    color: var(--color-white);
    margin-bottom: 0.75rem;
  }

  .blog-hero p {
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  .blog-featured,
  .blog-list {
    padding: 3rem 0;
  }

  .blog-featured {
    background: var(--color-accent);
  }

  .blog-featured h2,
  .blog-list h2 {
    margin-bottom: 2rem;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .featured-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    text-decoration: none;
    box-shadow: var(--shadow-md);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    opacity: 1;
  }

  .featured-card__image {
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .featured-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-card__content {
    padding: 1.5rem;
  }

  .featured-card__category {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: var(--color-accent);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }

  .featured-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }

  .featured-card p {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .featured-card__meta {
    display: flex;
    gap: 1rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: var(--border-radius);
    overflow: hidden;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s ease;
  }

  .post-card:hover {
    box-shadow: var(--shadow-md);
    opacity: 1;
  }

  .post-card__image {
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .post-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-card__content {
    padding: 1.25rem;
  }

  .post-card__category {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    background: var(--color-accent);
    color: var(--color-primary);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }

  .post-card h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    color: var(--color-primary);
  }

  .post-card p {
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__read-more {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .blog-cta {
    padding: 4rem 0;
    background: var(--color-primary);
    color: var(--color-white);
    text-align: center;
  }

  .blog-cta h2 {
    color: var(--color-white);
    margin-bottom: 0.75rem;
  }

  .blog-cta p {
    opacity: 0.9;
    margin-bottom: 2rem;
  }

  .blog-cta .btn-primary {
    background: var(--color-white);
    color: var(--color-primary);
  }

  @media (min-width: 640px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .blog-hero {
      padding: 4rem 0;
    }

    .blog-featured,
    .blog-list {
      padding: 4rem 0;
    }

    .featured-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
