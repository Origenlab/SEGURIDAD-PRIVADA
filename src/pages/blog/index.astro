---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import HeroPagina from '../../components/HeroPagina.astro';
import NavCTA from '../../components/NavCTA.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import '../../styles/pages/blog.css';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const siteUrl = 'https://seguridad-privada.com.mx';

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog de Seguridad Privada | ORIGINS Private Security",
  "description": "Guías, consejos y artículos especializados para administradores de condominios, comités de vigilancia y comunidades residenciales en CDMX.",
  "url": `${siteUrl}/blog`,
  "publisher": {
    "@id": `${siteUrl}/#organization`
  }
};
---

<Base
  title="Blog de Seguridad Privada | ORIGINS"
  description="Guías, consejos y artículos especializados para administradores de condominios, comités de vigilancia y comunidades residenciales en CDMX."
  canonical={`${siteUrl}/blog`}
  schema={schema}
>

  <HeroPagina
    badge="Blog y Recursos"
    titulo="Blog de Seguridad Privada para Condominios"
    descripcion="Guías, consejos y artículos especializados para administradores de condominios, comités de vigilancia y comunidades residenciales en CDMX."
    breadcrumb={[{ label: 'Blog', href: '/blog' }]}
    seoParrafo1='Nuestro blog es un recurso gratuito para administradores de condominio, comités de vigilancia y desarrolladoras. Aquí encontrarás guías prácticas sobre <a href="/servicios/control-de-accesos">control de accesos</a>, protocolos de <a href="/servicios/guardias-intramuros">guardias intramuros</a>, normativa SSC y mejores prácticas para comunidades residenciales en CDMX.'
    seoParrafo2='Todo el contenido es producido por el equipo de <strong>ORIGINS Private Security</strong> con base en nuestra experiencia real de más de 15 años en el sector. Si tienes una duda específica sobre seguridad para tu <a href="/servicios/seguridad-condominios">condominio</a>, escríbenos — podemos convertirla en el próximo artículo.'
  />

  <NavCTA
    ariaLabel="Explora nuestros servicios de seguridad"
    cards={[
      { label: 'Servicios de Seguridad', sublabel: 'Guardias, accesos y monitoreo', href: '/servicios', icon: 'shield' },
      { label: 'Zonas de Cobertura', sublabel: 'CDMX y Zona Metropolitana', href: '/zonas', icon: 'map' },
      { label: 'Quiénes Somos', sublabel: '+15 años protegiendo condominios', href: '/nosotros', icon: 'people' },
      { label: 'Cotización Gratuita', sublabel: 'Diagnóstico en menos de 24 horas', href: 'https://wa.me/525530255580?text=Hola%2C%20me%20interesa%20cotizar%20seguridad%20para%20mi%20condominio', whatsapp: true, accent: true, external: true },
    ]}
  />

  <section class="blog-index" aria-labelledby="blog-index-title">
    <div class="container">
      <SectionHeader
        badge="Artículos"
        titulo="Guías y Recursos para tu Condominio"
        subtitulo="Contenido especializado de nuestro equipo para ayudarte a tomar mejores decisiones de seguridad."
        align="center"
      />

      {sortedPosts.length > 0 ? (
        <div class="blog-index__grid">
          {sortedPosts.map(post => (
            <BlogPostCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              category={post.data.cluster}
              publishDate={post.data.publishDate}
              readingTime={post.data.readingTime}
              heroImage={post.data.heroImage}
            />
          ))}
        </div>
      ) : (
        <p style="text-align:center; color: rgba(10,15,30,0.55); padding: 3rem 0;">
          Próximamente publicaremos guías y artículos sobre seguridad para condominios.
        </p>
      )}
    </div>
  </section>

  <NavCTA
    footer={true}
    ariaLabel="Explora nuestros servicios de seguridad"
    cards={[
      { label: 'Servicios de Seguridad', sublabel: 'Guardias, accesos y monitoreo',      href: '/servicios',  icon: 'shield'  },
      { label: 'Zonas de Cobertura',     sublabel: 'CDMX y Zona Metropolitana',          href: '/zonas',      icon: 'map'     },
      { label: 'Quiénes Somos',          sublabel: 'Permiso SSC 0102-15 · Desde 2008',  href: '/nosotros',   icon: 'people'  },
      { label: 'Cotización Gratuita',    sublabel: 'Diagnóstico en menos de 24 horas',   href: 'https://wa.me/525530255580?text=Hola%2C%20me%20interesa%20cotizar%20seguridad%20para%20mi%20condominio', whatsapp: true, accent: true, external: true },
    ]}
  />

</Base>
