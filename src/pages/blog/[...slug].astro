---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const siteUrl = 'https://seguridad-privada.com.mx';

// Build Schema.org structured data
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": post.data.schemaType || "BlogPosting",
      "@id": `${siteUrl}/blog/${post.id}#article`,
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.publishDate.toISOString(),
      "dateModified": (post.data.updatedDate || post.data.publishDate).toISOString(),
      "author": {
        "@type": "Person",
        "name": post.data.author.name,
        "jobTitle": post.data.author.role
      },
      "publisher": {
        "@id": `${siteUrl}/#organization`
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": `${siteUrl}/blog/${post.id}`
      },
      "image": post.data.heroImage ? `${siteUrl}${post.data.heroImage.src}` : undefined,
      "keywords": post.data.keywords.join(', ')
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Blog",
          "item": `${siteUrl}/blog`
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": post.data.title,
          "item": `${siteUrl}/blog/${post.id}`
        }
      ]
    }
  ]
};

// Add FAQPage schema if FAQs exist
if (post.data.faqs && post.data.faqs.length > 0) {
  schema["@graph"].push({
    "@type": "FAQPage",
    "mainEntity": post.data.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  });
}

// Get related posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter(p => p.id !== post.id && p.data.cluster === post.data.cluster)
  .slice(0, 3);
---

<Base
  title={post.data.title}
  description={post.data.description}
  canonical={`${siteUrl}/blog/${post.id}`}
  schema={schema}
>
  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumbs__list">
        <li><a href="/">Inicio</a></li>
        <li><a href="/blog">Blog</a></li>
        <li aria-current="page">{post.data.title.length > 50 ? post.data.title.slice(0, 50) + '...' : post.data.title}</li>
      </ol>
    </div>
  </nav>

  <!-- Article Header -->
  <header class="article-header">
    <div class="container">
      <span class="article-header__category">{post.data.cluster.replace(/-/g, ' ')}</span>
      <h1>{post.data.title}</h1>
      <p class="article-header__description">{post.data.description}</p>

      <div class="article-header__meta">
        <div class="article-header__author">
          <span class="author-name">{post.data.author.name}</span>
          {post.data.author.role && <span class="author-role">{post.data.author.role}</span>}
        </div>
        <div class="article-header__info">
          <span>{new Date(post.data.publishDate).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          <span>•</span>
          <span>{post.data.readingTime || 5} min de lectura</span>
        </div>
      </div>
    </div>
  </header>

  <!-- Hero Image -->
  {post.data.heroImage && (
    <div class="article-hero">
      <div class="container">
        <img src={post.data.heroImage.src} alt={post.data.heroImage.alt} loading="eager" />
      </div>
    </div>
  )}

  <!-- Article Content -->
  <article class="article-content">
    <div class="container">
      <div class="article-grid">
        <div class="article-main prose">
          <Content />
        </div>

        <!-- Sidebar -->
        <aside class="article-sidebar">
          <!-- CTA Card -->
          <div class="sidebar-card sidebar-card--cta">
            <h3>¿Necesitas Seguridad Profesional?</h3>
            <p>Solicita una evaluación gratuita para tu propiedad.</p>
            <a href="/contacto" class="btn btn-primary btn-block">Solicitar Cotización</a>
          </div>

          <!-- Related Pillar -->
          {post.data.relatedPillar && (
            <div class="sidebar-card">
              <h4>Servicio Relacionado</h4>
              <a href={`/servicios/${post.data.relatedPillar}`} class="pillar-link">
                {post.data.relatedPillar.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          )}

          <!-- Tags -->
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="sidebar-card">
              <h4>Temas</h4>
              <div class="tags-list">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          )}
        </aside>
      </div>
    </div>
  </article>

  <!-- FAQs Section -->
  {post.data.faqs && post.data.faqs.length > 0 && (
    <section class="article-faqs">
      <div class="container">
        <h2>Preguntas Frecuentes</h2>
        <div class="faq-container">
          {post.data.faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-question">
                <span class="faq-question-text">{faq.question}</span>
                <span class="faq-icon" aria-hidden="true"></span>
              </summary>
              <div class="faq-answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="related-posts">
      <div class="container">
        <h2>Artículos Relacionados</h2>
        <div class="related-grid">
          {relatedPosts.map((related) => (
            <a href={`/blog/${related.id}`} class="related-card">
              {related.data.heroImage && (
                <div class="related-card__image">
                  <img src={related.data.heroImage.src} alt={related.data.heroImage.alt} loading="lazy" />
                </div>
              )}
              <div class="related-card__content">
                <h3>{related.data.title}</h3>
                <span>Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="article-cta">
    <div class="container">
      <h2>Protege tu Propiedad con Expertos</h2>
      <p>Más de 15 años de experiencia en seguridad privada para condominios y residenciales.</p>
      <div class="cta-buttons">
        <a href="/contacto" class="btn btn-primary">Solicitar Cotización</a>
        <a href="https://wa.me/525530255580" class="btn btn-whatsapp">WhatsApp Directo</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Breadcrumbs */
  .breadcrumbs {
    padding: 1rem 0;
    background: var(--color-accent);
    font-size: 0.875rem;
  }

  .breadcrumbs__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .breadcrumbs__list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumbs__list li:not(:last-child)::after {
    content: '/';
    color: var(--color-text-muted);
  }

  .breadcrumbs__list a {
    color: var(--color-text-light);
  }

  .breadcrumbs__list li[aria-current="page"] {
    color: var(--color-primary);
    font-weight: 500;
  }

  /* Article Header */
  .article-header {
    padding: 2rem 0;
    text-align: center;
  }

  .article-header__category {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-accent);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    border-radius: 50px;
    margin-bottom: 1rem;
  }

  .article-header h1 {
    font-size: 1.75rem;
    max-width: 800px;
    margin: 0 auto 1rem;
  }

  .article-header__description {
    font-size: 1.125rem;
    color: var(--color-text-light);
    max-width: 700px;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
  }

  .article-header__meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }

  .article-header__author {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .author-name {
    font-weight: 600;
    color: var(--color-primary);
  }

  .author-role {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .article-header__info {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* Hero Image */
  .article-hero {
    padding-bottom: 2rem;
  }

  .article-hero img {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    display: block;
    border-radius: var(--border-radius-lg);
  }

  /* Article Content */
  .article-content {
    padding: 2rem 0 3rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .article-main.prose {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .article-main.prose h2 {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .article-main.prose h3 {
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .article-main.prose h4 {
    font-size: 1.125rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .article-main.prose p {
    margin-bottom: 1.5rem;
  }

  .article-main.prose ul,
  .article-main.prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .article-main.prose li {
    margin-bottom: 0.5rem;
  }

  .article-main.prose strong {
    color: var(--color-primary);
  }

  .article-main.prose blockquote {
    border-left: 4px solid var(--color-primary);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--color-text-light);
  }

  .article-main.prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
  }

  .article-main.prose th,
  .article-main.prose td {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .article-main.prose th {
    background: var(--color-accent);
    font-weight: 600;
  }

  /* Sidebar */
  .article-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-card {
    background: var(--color-accent);
    padding: 1.5rem;
    border-radius: var(--border-radius);
  }

  .sidebar-card--cta {
    background: var(--color-primary);
    color: var(--color-white);
  }

  .sidebar-card--cta h3 {
    color: var(--color-white);
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
  }

  .sidebar-card--cta p {
    opacity: 0.9;
    margin-bottom: 1rem;
    font-size: 0.9375rem;
  }

  .sidebar-card--cta .btn-primary {
    background: var(--color-white);
    color: var(--color-primary);
  }

  .sidebar-card h4 {
    font-size: 0.9375rem;
    margin-bottom: 1rem;
  }

  .pillar-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    background: var(--color-white);
    border-radius: var(--border-radius);
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    text-transform: capitalize;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: var(--color-white);
    border-radius: 50px;
    font-size: 0.8125rem;
    color: var(--color-text);
  }

  .btn-block {
    display: block;
    width: 100%;
    text-align: center;
  }

  /* FAQs */
  .article-faqs {
    padding: 3rem 0;
    background: var(--color-accent);
  }

  .article-faqs h2 {
    text-align: center;
    margin-bottom: 2rem;
  }

  .article-faqs .faq-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-white);
  }

  .faq-item:first-child {
    border-radius: var(--border-radius) var(--border-radius) 0 0;
  }

  .faq-item:last-child {
    border-radius: 0 0 var(--border-radius) var(--border-radius);
    border-bottom: none;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem;
    cursor: pointer;
    list-style: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question-text {
    font-weight: 600;
    color: var(--color-primary);
    padding-right: 1rem;
  }

  .faq-icon {
    width: 24px;
    height: 24px;
    position: relative;
    flex-shrink: 0;
  }

  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background: var(--color-primary);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.3s ease;
  }

  .faq-icon::before {
    width: 12px;
    height: 2px;
  }

  .faq-icon::after {
    width: 2px;
    height: 12px;
  }

  .faq-item[open] .faq-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .faq-answer {
    padding: 0 1.25rem 1.25rem;
  }

  .faq-answer p {
    color: var(--color-text-light);
    line-height: 1.7;
    margin: 0;
  }

  /* Related Posts */
  .related-posts {
    padding: 3rem 0;
  }

  .related-posts h2 {
    margin-bottom: 2rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: var(--border-radius);
    overflow: hidden;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
  }

  .related-card:hover {
    opacity: 1;
    box-shadow: var(--shadow-md);
  }

  .related-card__image {
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .related-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .related-card__content {
    padding: 1rem;
  }

  .related-card h3 {
    font-size: 0.9375rem;
    margin-bottom: 0.5rem;
    color: var(--color-primary);
  }

  .related-card span {
    font-size: 0.8125rem;
    color: var(--color-text-light);
  }

  /* CTA */
  .article-cta {
    padding: 4rem 0;
    background: var(--color-primary);
    color: var(--color-white);
    text-align: center;
  }

  .article-cta h2 {
    color: var(--color-white);
    margin-bottom: 0.75rem;
  }

  .article-cta p {
    opacity: 0.9;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  .article-cta .btn-primary {
    background: var(--color-white);
    color: var(--color-primary);
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .cta-buttons {
      flex-direction: row;
    }
  }

  @media (min-width: 768px) {
    .article-header {
      padding: 3rem 0;
    }

    .article-header h1 {
      font-size: 2.25rem;
    }

    .article-header__meta {
      flex-direction: row;
      gap: 2rem;
    }

    .article-header__author {
      flex-direction: row;
      gap: 0.5rem;
      align-items: center;
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: 1fr 300px;
      gap: 3rem;
    }

    .article-sidebar {
      position: sticky;
      top: 2rem;
      align-self: start;
    }
  }
</style>
