---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import HeroPagina from '../../components/HeroPagina.astro';
import PageCTA from '../../components/PageCTA.astro';
import '../../styles/pages/blog.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const siteUrl = 'https://seguridad-privada.com.mx';

// Schema BlogPosting
const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.publishDate.toISOString(),
  "dateModified": post.data.updatedDate?.toISOString() || post.data.publishDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "ORIGINS Private Security",
    "url": siteUrl
  },
  "publisher": {
    "@id": `${siteUrl}/#organization`
  },
  "url": `${siteUrl}/blog/${post.id}`,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/blog/${post.id}`
  },
  ...(post.data.heroImage ? { "image": `${siteUrl}${post.data.heroImage.src}` } : {})
};
---

<Base
  title={post.data.title}
  description={post.data.description}
  canonical={`${siteUrl}/blog/${post.id}`}
  ogType="article"
  schema={schema}
>

  <HeroPagina
    badge={post.data.cluster.replace(/-/g, ' ')}
    titulo={post.data.title}
    descripcion={post.data.description}
    breadcrumb={[
      { label: 'Blog', href: '/blog' },
      { label: post.data.title.substring(0, 40) + (post.data.title.length > 40 ? '...' : ''), href: `/blog/${post.id}` }
    ]}
  />

  <div class="blog-post-wrapper">
    <div class="container">
      <div class="blog-post-grid">

        <!-- Contenido principal -->
        <article class="blog-post__main">
          {post.data.heroImage && (
            <div class="blog-post__hero-img">
              <img
                src={post.data.heroImage.src}
                alt={post.data.heroImage.alt}
                loading="eager"
                width="1200"
                height="675"
              />
            </div>
          )}

          <div class="blog-post__meta">
            <span class="blog-post__category">{post.data.cluster.replace(/-/g, ' ')}</span>
            <time datetime={post.data.publishDate.toISOString()}>
              {post.data.publishDate.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {post.data.readingTime && (
              <span>{post.data.readingTime} min de lectura</span>
            )}
          </div>

          <div class="blog-post__content prose">
            <Content />
          </div>
        </article>

        <!-- Sidebar -->
        <aside class="blog-post__sidebar">
          <div class="blog-sidebar-card blog-sidebar-card--cta">
            <h3>¿Necesitas seguridad para tu condominio?</h3>
            <p>Diagnóstico gratuito en 24 horas.</p>
            <a
              href="https://wa.me/525530255580?text=Hola%2C%20me%20interesa%20cotizar%20seguridad%20para%20mi%20condominio"
              target="_blank"
              rel="noopener"
              class="blog-sidebar-cta"
            >
              WhatsApp Directo
            </a>
            <a href="tel:+525530255580" class="blog-sidebar-tel">55 3025 5580</a>
          </div>

          <div class="blog-sidebar-card">
            <h4>Servicios relacionados</h4>
            <ul>
              <li><a href="/servicios/guardias-intramuros">Guardias Intramuros</a></li>
              <li><a href="/servicios/seguridad-condominios">Seguridad Condominios</a></li>
              <li><a href="/servicios/control-de-accesos">Control de Accesos</a></li>
              <li><a href="/servicios/vigilancia-remota-cctv">Vigilancia CCTV</a></li>
            </ul>
          </div>
        </aside>

      </div>
    </div>
  </div>

  <PageCTA
    titulo="¿Tienes preguntas sobre seguridad?"
    descripcion="Nuestro equipo especializado en condominios responde en menos de 2 horas."
    ctaPrimario={{ texto: 'Solicitar Cotización', href: '/contacto' }}
    ctaWhatsapp={true}
  />

</Base>
