---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeroPagina from '../components/HeroPagina.astro';
import NavCTA from '../components/NavCTA.astro';
import '../styles/pages/legal.css';

const servicios = await getCollection('servicios', ({ data }) => !data.draft);
const posts = await getCollection('blog', ({ data }) => !data.draft);
const siteUrl = 'https://seguridad-privada.com.mx';
---

<Base
  title="Mapa del Sitio · ORIGINS Seguridad Privada CDMX 2025"
  description="Todas las páginas de ORIGINS Private Security: servicios de seguridad, zonas de cobertura CDMX, directorio de emergencias y blog para condominios."
  canonical={`${siteUrl}/mapa-del-sitio`}
>

  <HeroPagina
    badge="Navegación"
    titulo="Mapa del Sitio"
    descripcion="Todas las páginas y secciones de ORIGINS Private Security, empresa de seguridad privada para condominios en CDMX."
    breadcrumb={[{ label: 'Mapa del Sitio', href: '/mapa-del-sitio' }]}
  />

  <section class="sitemap-page">
    <div class="container sitemap-page__container">

      <section>
        <h2>Páginas principales</h2>
        <ul>
          <li><a href="/">Inicio</a></li>
          <li><a href="/servicios">Servicios</a></li>
          <li><a href="/nosotros">Nosotros</a></li>
          <li><a href="/zonas">Zonas de Cobertura</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contacto">Contacto</a></li>
          <li><a href="/bolsa-de-trabajo">Bolsa de Trabajo</a></li>
          <li><a href="/aviso-de-privacidad">Aviso de Privacidad</a></li>
        </ul>
      </section>

      <section>
        <h2>Servicios</h2>
        <ul>
          {servicios.map((servicio) => (
            <li><a href={`/servicios/${servicio.id}`}>{servicio.data.title.split('|')[0].trim()}</a></li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Blog</h2>
        <ul>
          {posts.map((post) => (
            <li><a href={`/blog/${post.id}`}>{post.data.title}</a></li>
          ))}
        </ul>
      </section>

    </div>
  </section>

  <NavCTA
    footer={true}
    ariaLabel="Explora ORIGINS Private Security"
    cards={[
      { label: 'Nuestros Servicios', sublabel: 'Guardias, accesos y monitoreo',         href: '/servicios', icon: 'shield'  },
      { label: 'Zonas de Cobertura', sublabel: 'CDMX y Zona Metropolitana',             href: '/zonas',     icon: 'map'     },
      { label: 'Quiénes Somos',     sublabel: 'Permiso SSC 0102-15 · Desde 2008',      href: '/nosotros',  icon: 'people'  },
      { label: 'Cotización Gratuita', sublabel: 'Diagnóstico en menos de 24 horas',     href: 'https://wa.me/525530255580?text=Hola%2C%20me%20interesa%20cotizar%20seguridad%20para%20mi%20condominio', whatsapp: true, accent: true, external: true },
    ]}
  />
</Base>
