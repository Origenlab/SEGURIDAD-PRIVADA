---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeroPagina from '../components/HeroPagina.astro';
import '../styles/pages/legal.css';

const servicios = await getCollection('servicios', ({ data }) => !data.draft);
const posts = await getCollection('blog', ({ data }) => !data.draft);
const siteUrl = 'https://seguridad-privada.com.mx';
---

<Base
  title="Mapa del Sitio | ORIGINS Private Security"
  description="Listado de todas las páginas y secciones del sitio de ORIGINS Private Security — Seguridad Privada para Condominios en CDMX."
  canonical={`${siteUrl}/mapa-del-sitio`}
>

  <HeroPagina
    badge="Navegación"
    titulo="Mapa del Sitio"
    descripcion="Todas las páginas y secciones de ORIGINS Private Security, empresa de seguridad privada para condominios en CDMX."
    breadcrumb={[{ label: 'Mapa del Sitio', href: '/mapa-del-sitio' }]}
  />

  <section class="sitemap-page">
    <div class="container sitemap-page__container">

      <section>
        <h2>Páginas principales</h2>
        <ul>
          <li><a href="/">Inicio</a></li>
          <li><a href="/servicios">Servicios</a></li>
          <li><a href="/nosotros">Nosotros</a></li>
          <li><a href="/zonas">Zonas de Cobertura</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contacto">Contacto</a></li>
          <li><a href="/bolsa-de-trabajo">Bolsa de Trabajo</a></li>
          <li><a href="/aviso-de-privacidad">Aviso de Privacidad</a></li>
        </ul>
      </section>

      <section>
        <h2>Servicios</h2>
        <ul>
          {servicios.map((servicio) => (
            <li><a href={`/servicios/${servicio.id}`}>{servicio.data.title.split('|')[0].trim()}</a></li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Blog</h2>
        <ul>
          {posts.map((post) => (
            <li><a href={`/blog/${post.id}`}>{post.data.title}</a></li>
          ))}
        </ul>
      </section>

    </div>
  </section>

</Base>
